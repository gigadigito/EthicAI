    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.CRIPTOVERSUS_API_BASE_URL }}/api/social/hot-matches",
        "options": {
          "timeout": 30000
        }
      },
      "id": "http-hot-matches",
      "name": "HTTP Request - Hot Matches",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -860,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ Array.isArray($json) ? $json.length > 0 : ($input.all().length > 0 && Object.keys($json).length > 0) }}",
              "operation": "true"
            }
          ]
        }
      },
      "id": "if-has-hot-match",
      "name": "IF - Existe Jogo Quente",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        -620,
        300
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const raw = $input.all().map(item => item.json);\nconst matches = raw.flatMap(item => Array.isArray(item) ? item : [item]).filter(item => item && typeof item === 'object' && item.matchId);\nif (!matches.length) {\n  return [];\n}\nmatches.sort((a, b) => (b.hotScore ?? 0) - (a.hotScore ?? 0));\nreturn [{ json: matches[0] }];"
      },
      "id": "code-pick-first",
      "name": "Code - Escolher Primeiro Jogo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -380,
        220
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.CRIPTOVERSUS_API_BASE_URL }}/api/social/matches/{{ $json.matchId }}/share-card",
        "options": {
          "timeout": 30000
        }
      },
      "id": "http-share-card",
      "name": "HTTP Request - Share Card",
