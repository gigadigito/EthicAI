    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/responses",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { model: 'gpt-4.1-mini', input: [ { role: 'system', content: 'Você é o narrador oficial do CriptoVersus. Crie um post curto para o X sobre uma partida cripto em andamento. Regras: - Máximo 240 caracteres. - Tom empolgado de arena esportiva. - Não prometa lucro. - Não diga que é recomendação financeira. - Cite o placar. - Cite o evento mais recente, se existir. - Inclua a URL da partida. - Use no máximo 3 hashtags.' }, { role: 'user', content: 'Dados:\\n' + JSON.stringify($json) } ] } }}",
        "options": {
          "timeout": 45000
        }
      },
      "id": "openai-generate-narration",
      "name": "OpenAI - Gerar Narração",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        380,
        300
      ]
    },
    {
      "parameters": {
        "mode": "combine",
        "combineBy": "combineByPosition"
      },
      "id": "merge-ai-with-share-card",
      "name": "Merge - IA + Share Card",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [
        640,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const data = $json;\nconst textFromOutput = data.output_text\n  ?? data.output?.map(block => (block.content ?? []).map(content => content.text ?? '').join(' ')).join(' ')\n  ?? data.content?.map(content => content.text ?? '').join(' ')\n  ?? '';\nconst fallbackText = data.suggestedText || `${data.homeSymbol} vs ${data.awaySymbol}: ${data.score} ${data.publicUrl}`;\nconst finalPostText = (textFromOutput || fallbackText).trim();\nreturn [{ json: { ...data, finalPostText } }];"
      },
      "id": "code-prepare-final-post",
      "name": "Code - Preparar Texto Final",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        900,
        300
      ]
    },
