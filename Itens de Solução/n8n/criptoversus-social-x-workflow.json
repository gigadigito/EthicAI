    {
      "parameters": {
        "jsCode": "const data = $json;\nconst tweetId = data.id ?? data.data?.id ?? data.tweetId ?? data.tweet_id ?? null;\nconst postUrl = tweetId ? `https://x.com/i/web/status/${tweetId}` : null;\nreturn [{\n  json: {\n    matchId: data.matchId,\n    platform: 'X',\n    postText: data.finalPostText,\n    postUrl,\n    externalPostId: tweetId,\n    hotScore: data.hotScore,\n    reason: data.reason\n  }\n}];"
      },
