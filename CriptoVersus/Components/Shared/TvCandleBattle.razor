    private string RootClass => IsBroadcastCompact
        ? "tv-candle-battle tv-candle-battle--broadcast-compact"
        : "tv-candle-battle";

    private string WorkspaceClass => ShowTacticalPanel
        ? "tv-candle-battle__workspace"
        : "tv-candle-battle__workspace tv-candle-battle__workspace--no-sidebar";

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrWhiteSpace(InstanceId))
            _resolvedInstanceId = InstanceId.Trim();
    }

    private IReadOnlyList<TvPriceChartPoint> OrderedLeftPoints => NormalizePoints(LeftPoints);
    private IReadOnlyList<TvPriceChartPoint> OrderedRightPoints => NormalizePoints(RightPoints);
    private IReadOnlyList<ChartCandleVisual> LeftChartCandles => BuildChartCandles(OrderedLeftPoints, BattleSide.Left, IsBroadcastCompact);
    private IReadOnlyList<ChartCandleVisual> RightChartCandles => BuildChartCandles(OrderedRightPoints, BattleSide.Right, IsBroadcastCompact);
    private IReadOnlyList<BattleCandle> BattleCandles => BuildBattleCandles();
    private BattleSummary Battle => BuildBattleSummary(BattleCandles);

    private string WaitingHistoryText => T("labels.waitingCandleHistory");
    private string PanelTitle => T("labels.tacticalPanel");
    private string LeaderTitle => T("labels.leadership");
    private string CandlesAnalyzedTitle => T("labels.candlesAnalyzed");
    private string StreakTitle => T("labels.currentStreak");
    private string LastCandleTitle => T("labels.lastCandle");
    private string PerformanceTitle => T("labels.lastVariation");

    private string TimelineStyle
    {
        get
        {
            var count = Math.Max(BattleCandles.Count, 1);
            var minWidth = IsBroadcastCompact ? "0" : "10px";
            return $"grid-template-columns: repeat({count}, minmax({minWidth}, 1fr));";
        }
    }

    private RenderFragment RenderCandleCard(bool isLeft, bool compact) => @<section class="@GetCardClass(isLeft, compact)">
    <div class="tv-candle-battle-card__head">
        <div class="tv-candle-battle-card__head-copy">
            <span class="@GetKickerClass(isLeft)">@GetAssetVariationLabel(isLeft)</span>
            <strong>@GetAssetTitle(isLeft)</strong>
        </div>
        <em id="@($"{_resolvedInstanceId}-{(isLeft ? "left" : "right")}-live")"
            class="@GetChangeClass(isLeft ? LeftChangePercent : RightChangePercent)">
            @FormatChangePercent(isLeft ? LeftChangePercent : RightChangePercent)
        </em>
    </div>

    <div class="tv-candle-battle-card__legend">
        <span class="is-left">@LeftHeroLabel @T("labels.won")</span>
        <span class="is-right">@RightHeroLabel @T("labels.won")</span>
        <span class="is-tie">@T("labels.tie")</span>
    </div>

    <div class="tv-candle-battle-card__body">
        <div class="tv-candle-battle-card__chart-area">
            <div id="@($"{_resolvedInstanceId}-chart-split-{(isLeft ? "left" : "right")}")"
                 class="tv-telemetry-chart-shell tv-telemetry-chart-shell--battle"
                 aria-label="@GetChartAriaLabel(isLeft)">
                @if (!GetChartCandles(isLeft).Any())
                                {
                <div class="tv-candle-battle__empty">@WaitingHistoryText</div>
                                }
                                else
                                {
                <svg class="tv-candle-battle__svg" viewBox="0 0 1000 320" preserveAspectRatio="none" role="img" aria-label="@T("labels.chartForAsset", GetTickerLabel(isLeft))">
                    <line class="tv-candle-battle__grid-line" x1="0" y1="80" x2="1000" y2="80" />
                    <line class="tv-candle-battle__grid-line" x1="0" y1="160" x2="1000" y2="160" />
                    <line class="tv-candle-battle__grid-line" x1="0" y1="240" x2="1000" y2="240" />
                    @foreach (var candle in GetChartCandles(isLeft))
                                        {
                    <line class="@candle.WickClass" x1="@N(candle.X)" y1="@N(candle.HighY)" x2="@N(candle.X)" y2="@N(candle.LowY)" />
                    <rect class="@candle.BodyClass" x="@N(candle.BodyX)" y="@N(candle.BodyY)" width="@N(candle.BodyWidth)" height="@N(candle.BodyHeight)" rx="3" />
                                        }
                </svg>
                                }
            </div>

            <div class="tv-candle-battle-card__timeline">
                <span>@T("labels.winnerPerCandle")</span>
                <div id="@($"{_resolvedInstanceId}-timeline-{(isLeft ? "left" : "right")}")"
                     class="tv-candle-battle-card__timeline-track"
                     style="@TimelineStyle">
                    @foreach (var candle in BattleCandles)
                    {
                        <i class="tv-candle-battle-card__timeline-marker @candle.MarkerClass" title="@candle.Title"></i>
                    }
                </div>
            </div>
        </div>
    </div>
</section>;

private string ResolveAriaLabel()
    => !string.IsNullOrWhiteSpace(AriaLabel)
        ? AriaLabel!
        : T("labels.candleBattleA11y", LeftTickerLabel, RightTickerLabel);

private string GetCardClass(bool isLeft, bool compact)
    => $"tv-candle-battle-card tv-candle-battle-card--{(isLeft ? "left" : "right")}{(compact ? " tv-candle-battle-card--compact" : string.Empty)}";

private string GetKickerClass(bool isLeft)
    => $"tv-candle-battle-card__kicker tv-candle-battle-card__kicker--{(isLeft ? "left" : "right")}";

private string GetAssetVariationLabel(bool isLeft)
    => isLeft ? T("labels.assetVariationA") : T("labels.assetVariationB");

private string GetAssetTitle(bool isLeft)
    => GetTickerLabel(isLeft);

private string GetTickerLabel(bool isLeft)
    => isLeft ? LeftTickerLabel : RightTickerLabel;

private string GetChartAriaLabel(bool isLeft)
    => T("labels.chartForAsset", GetTickerLabel(isLeft));

private IReadOnlyList<ChartCandleVisual> GetChartCandles(bool isLeft)
    => isLeft ? LeftChartCandles : RightChartCandles;

private static IReadOnlyList<TvPriceChartPoint> NormalizePoints(IReadOnlyList<TvPriceChartPoint>? points)
    => points is null
        ? Array.Empty<TvPriceChartPoint>()
        : points
            .Where(x => x.Value != 0m || x.Time > 0)
            .OrderBy(x => x.Time)
            .ToList();

private IReadOnlyList<ChartCandleVisual> BuildChartCandles(IReadOnlyList<TvPriceChartPoint> points, BattleSide visualSide, bool compact)
{
    if (points.Count < 2)
        return Array.Empty<ChartCandleVisual>();

    var values = points
        .Where(point => point.Value > 0m)
        .Select(point => point.Value)
        .ToArray();

    if (values.Length < 2)
        return Array.Empty<ChartCandleVisual>();

    var minValue = values.Min();
    var maxValue = values.Max();
    var range = maxValue - minValue;

    if (range <= 0m)
    {
        var safeValue = Math.Abs(maxValue);
        var padding = safeValue <= 0m ? 1m : safeValue * 0.0025m;
        minValue -= padding;
        maxValue += padding;
    }
    else
    {
        var padding = range * 0.18m;
        minValue -= padding;
        maxValue += padding;
    }

    var candleCount = points.Count - 1;
    var slotWidth = 1000d / Math.Max(candleCount, 1);

    var bodyWidth = compact
        ? Math.Clamp(slotWidth * 0.46d, 5d, 14d)
        : Math.Clamp(slotWidth * 0.58d, 7d, 20d);

    var result = new List<ChartCandleVisual>(candleCount);
    var sideClass = visualSide == BattleSide.Left ? "left" : "right";

    const double chartTop = 18d;
    const double chartBottom = 302d;
    const double minBodyHeight = 9d;
    const double minWickPad = 8d;

    for (var i = 1; i < points.Count; i++)
    {
        var previous = points[i - 1].Value;
        var current = points[i].Value;

        if (previous <= 0m || current <= 0m)
            continue;

        var openY = MapCandleY(previous, minValue, maxValue, chartTop, chartBottom);
        var closeY = MapCandleY(current, minValue, maxValue, chartTop, chartBottom);
        var isUp = current >= previous;

        var bodyTop = Math.Min(openY, closeY);
        var bodyBottom = Math.Max(openY, closeY);
        var bodyHeight = Math.Max(minBodyHeight, bodyBottom - bodyTop);

        if (bodyHeight > bodyBottom - bodyTop)
        {
            var center = (openY + closeY) / 2d;
            bodyTop = center - (bodyHeight / 2d);
            bodyBottom = center + (bodyHeight / 2d);
        }

        var previousDelta = i > 1
            ? Math.Abs(ComputePercentChange(points[i - 2].Value, previous))
            : Math.Abs(ComputePercentChange(previous, current));

        var currentDelta = Math.Abs(ComputePercentChange(previous, current));
        var nextDelta = i + 1 < points.Count
            ? Math.Abs(ComputePercentChange(current, points[i + 1].Value))
            : currentDelta;

        var localVolatility = (double)Math.Min(5m, previousDelta + currentDelta + nextDelta);
        var rhythm = Math.Abs(Math.Sin((i + 1) * 1.618d + (visualSide == BattleSide.Left ? 0.25d : 0.85d)));
        var wickPad = minWickPad + (localVolatility * 7.5d) + (rhythm * 16d);

        var highY = Math.Max(chartTop, bodyTop - wickPad);
        var lowY = Math.Min(chartBottom, bodyBottom + (wickPad * (0.72d + rhythm * 0.42d)));

        var x = ((i - 1) + .5d) * slotWidth;

        result.Add(new ChartCandleVisual
        {
            X = x,
            HighY = highY,
            LowY = lowY,
            BodyX = x - (bodyWidth / 2d),
            BodyY = Math.Clamp(bodyTop, chartTop, chartBottom - bodyHeight),
            BodyWidth = bodyWidth,
            BodyHeight = Math.Clamp(bodyHeight, minBodyHeight, chartBottom - chartTop),
            WickClass = $"tv-candle-battle__wick tv-candle-battle__wick--{sideClass} {(isUp ? "is-up" : "is-down")}",
            BodyClass = $"tv-candle-battle__body tv-candle-battle__body--{sideClass} {(isUp ? "is-up" : "is-down")}"
        });
    }

    return result;
}

private static double MapCandleY(decimal value, decimal min, decimal max, double top, double bottom)
{
    var range = max - min;
    if (range <= 0m)
        return (top + bottom) / 2d;

    var ratio = (double)((value - min) / range);
    ratio = Math.Clamp(ratio, 0d, 1d);
    return bottom - (ratio * (bottom - top));
}

private IReadOnlyList<BattleCandle> BuildBattleCandles()
{
    var left = OrderedLeftPoints;
    var right = OrderedRightPoints;
    var count = Math.Min(left.Count, right.Count);

    if (count < 2)
        return Array.Empty<BattleCandle>();

    var result = new List<BattleCandle>(count - 1);

    for (var i = 1; i < count; i++)
    {
        var leftDelta = ComputePercentChange(left[i - 1].Value, left[i].Value);
        var rightDelta = ComputePercentChange(right[i - 1].Value, right[i].Value);
        var diff = leftDelta - rightDelta;
        var side = Math.Abs(diff) <= 0.00000001m
            ? BattleSide.Tie
            : diff > 0m
                ? BattleSide.Left
                : BattleSide.Right;

        var title = side switch
        {
            BattleSide.Left => $"{LeftHeroLabel} {T("labels.won")} • {FormatDeltaPercent(leftDelta)} vs {FormatDeltaPercent(rightDelta)}",
            BattleSide.Right => $"{RightHeroLabel} {T("labels.won")} • {FormatDeltaPercent(rightDelta)} vs {FormatDeltaPercent(leftDelta)}",
            _ => $"{T("labels.tie")} • {FormatDeltaPercent(leftDelta)} vs {FormatDeltaPercent(rightDelta)}"
        };

        result.Add(new BattleCandle
        {
            Index = i,
            Side = side,
            LeftDeltaPercent = leftDelta,
            RightDeltaPercent = rightDelta,
            MarkerClass = side switch
            {
                BattleSide.Left => "is-left",
                BattleSide.Right => "is-right",
                _ => "is-tie"
            },
            Title = title
        });
    }

    return result;
}

private BattleSummary BuildBattleSummary(IReadOnlyList<BattleCandle> candles)
{
    if (candles.Count == 0)
    {
        return new BattleSummary
        {
            LeaderLabel = T("labels.momentumNeutral"),
            ShortLeaderLabel = T("labels.tie"),
            MomentumStatusLabel = T("labels.tiePressure"),
            LastRunLabel = "-",
            LastRunClass = "is-tie",
            LeaderClass = "is-tie",
            LeftMomentumPercent = 50d,
            RightMomentumPercent = 50d
        };
    }

    var leftWins = candles.Count(x => x.Side == BattleSide.Left);
    var rightWins = candles.Count(x => x.Side == BattleSide.Right);
    var ties = candles.Count(x => x.Side == BattleSide.Tie);
    var scoreLeft = leftWins + (ties * .5d);
    var scoreRight = rightWins + (ties * .5d);
    var scoreTotal = Math.Max(1d, scoreLeft + scoreRight);
    var leftMomentum = Math.Round((scoreLeft / scoreTotal) * 100d);
    var rightMomentum = 100d - leftMomentum;
    var last = candles[^1];
    var lastRunSide = last.Side;
    var lastRunLength = 0;

    for (var i = candles.Count - 1; i >= 0; i--)
    {
        if (candles[i].Side != lastRunSide)
            break;

        lastRunLength++;
    }

    var leaderLabel = leftWins == rightWins
        ? T("labels.momentumNeutral")
        : leftWins > rightWins
            ? T("labels.controlsCandlesBy", LeftHeroLabel)
            : T("labels.controlsCandlesBy", RightHeroLabel);

    var shortLeaderLabel = leftWins == rightWins
        ? T("labels.tie")
        : leftWins > rightWins
            ? LeftHeroLabel
            : RightHeroLabel;

    var leaderClass = leftWins == rightWins
        ? "is-tie"
        : leftWins > rightWins
            ? "is-left"
            : "is-right";

    var momentumStatus = leftWins == rightWins
        ? T("labels.tiePressure")
        : leftWins > rightWins
            ? T("labels.pressureAdvantageBy", LeftHeroLabel)
            : T("labels.pressureAdvantageBy", RightHeroLabel);

    return new BattleSummary
    {
        HasData = true,
        LeftWins = leftWins,
        RightWins = rightWins,
        Ties = ties,
        TotalComparableCandles = candles.Count,
        LeftMomentumPercent = leftMomentum,
        RightMomentumPercent = rightMomentum,
        LeaderLabel = leaderLabel,
        ShortLeaderLabel = shortLeaderLabel,
        LeaderClass = leaderClass,
        MomentumStatusLabel = momentumStatus,
        LastRunLength = lastRunLength,
        LastRunClass = lastRunSide switch
        {
            BattleSide.Left => "is-left",
            BattleSide.Right => "is-right",
            _ => "is-tie"
        },
        LastRunLabel = lastRunSide switch
        {
            BattleSide.Left => LeftHeroLabel,
            BattleSide.Right => RightHeroLabel,
            _ => T("labels.tie")
        },
        LastLeftDeltaPercent = last.LeftDeltaPercent,
        LastRightDeltaPercent = last.RightDeltaPercent
    };
}

private static decimal ComputePercentChange(decimal previous, decimal current)
{
    if (previous == 0m)
        return current == 0m ? 0m : (current - previous) * 100m;

    return ((current - previous) / Math.Abs(previous)) * 100m;
}

private static double MapY(decimal value, decimal min, decimal max)
{
    var range = max - min;
    if (range == 0m)
        return 160d;

    var ratio = (double)((value - min) / range);
    ratio = Math.Clamp(ratio, 0d, 1d);
    return (1d - ratio) * 300d + 10d;
}

private static string FormatChangePercent(decimal? value)
    => value.HasValue
        ? value.Value > 0m
            ? $"+{value.Value:0.00}%"
            : $"{value.Value:0.00}%"
        : "--";

private static string FormatDeltaPercent(decimal value)
    => value > 0m
        ? $"+{value:0.00}%"
        : $"{value:0.00}%";

private static string GetChangeClass(decimal? value)
    => value switch
    {
        > 0m => "tv-change tv-change--positive",
        < 0m => "tv-change tv-change--negative",
        0m => "tv-change tv-change--neutral",
        _ => "tv-change tv-change--missing"
    };

private string T(string key, params object?[] args)
    => L.T($"tv.{key}", string.IsNullOrWhiteSpace(Culture) ? CultureInfo.CurrentUICulture.Name : Culture, args);

private static string N(double value)
    => value.ToString("0.##", CultureInfo.InvariantCulture);

private enum BattleSide
{
    Left,
    Right,
    Tie
}

private sealed class ChartCandleVisual
{
    public double X { get; init; }
    public double HighY { get; init; }
    public double LowY { get; init; }
    public double BodyX { get; init; }
    public double BodyY { get; init; }
    public double BodyWidth { get; init; }
    public double BodyHeight { get; init; }
    public string WickClass { get; init; } = string.Empty;
    public string BodyClass { get; init; } = string.Empty;
}

private sealed class BattleCandle
{
    public int Index { get; init; }
    public BattleSide Side { get; init; }
    public decimal LeftDeltaPercent { get; init; }
    public decimal RightDeltaPercent { get; init; }
    public string MarkerClass { get; init; } = string.Empty;
    public string Title { get; init; } = string.Empty;
}

private sealed class BattleSummary
{
    public bool HasData { get; init; }
    public int LeftWins { get; init; }
    public int RightWins { get; init; }
    public int Ties { get; init; }
    public int TotalComparableCandles { get; init; }
    public double LeftMomentumPercent { get; init; } = 50d;
    public double RightMomentumPercent { get; init; } = 50d;
    public string LeftMomentumPercentString => $"{LeftMomentumPercent:0}%";
    public string RightMomentumPercentString => $"{RightMomentumPercent:0}%";
    public string LeaderLabel { get; init; } = string.Empty;
    public string ShortLeaderLabel { get; init; } = string.Empty;
    public string LeaderClass { get; init; } = string.Empty;
    public string MomentumStatusLabel { get; init; } = string.Empty;
    public int LastRunLength { get; init; }
    public string LastRunClass { get; init; } = string.Empty;
    public string LastRunLabel { get; init; } = string.Empty;
    public decimal LastLeftDeltaPercent { get; init; }
    public decimal LastRightDeltaPercent { get; init; }
}
