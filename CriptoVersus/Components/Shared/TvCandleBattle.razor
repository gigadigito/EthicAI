<section id="tv-candle-battle-root"
         class="tv-candle-battle"
         aria-label="@ResolveAriaLabel()">

    <section class="tv-candle-battle__scoreboard">
        <div class="tv-candle-battle__score-side tv-candle-battle__score-side--left">
            <img src="@LeftLogoUrl" alt="" />
            <div class="tv-candle-battle__score-copy">
                <strong>@LeftTickerLabel</strong>
                <span>Candles vencidos</span>
            </div>
            <b id="tv-candle-battle-score-left">0</b>
        </div>

        <div class="tv-candle-battle__score-center">
            <span>Candle Battle</span>
            <strong>×</strong>
            <small id="tv-candle-battle-score-leader">Momentum neutro</small>
        </div>

        <div class="tv-candle-battle__score-side tv-candle-battle__score-side--right">
            <b id="tv-candle-battle-score-right">0</b>
            <div class="tv-candle-battle__score-copy tv-candle-battle__score-copy--right">
                <strong>@RightTickerLabel</strong>
                <span>Candles vencidos</span>
            </div>
            <img src="@RightLogoUrl" alt="" />
        </div>

        <aside class="tv-candle-battle__score-momentum-card">
            <span>Momentum atual</span>

            <div class="tv-candle-battle__score-momentum-track" aria-hidden="true">
                <i id="tv-candle-battle-score-momentum-left-fill"
                   class="tv-candle-battle__score-momentum-fill tv-candle-battle__score-momentum-fill--left"
                   style="width:50%;"></i>

                <i id="tv-candle-battle-score-momentum-right-fill"
                   class="tv-candle-battle__score-momentum-fill tv-candle-battle__score-momentum-fill--right"
                   style="width:50%;"></i>
            </div>

            <div class="tv-candle-battle__score-momentum-meta">
                <strong id="tv-candle-battle-score-momentum-left">50%</strong>
                <strong id="tv-candle-battle-score-momentum-right">50%</strong>
            </div>

            <small id="tv-candle-battle-score-momentum-status">Disputa equilibrada</small>
        </aside>
    </section>

    <div class="tv-candle-battle__workspace">
        <div class="tv-candle-battle__cards">
            <TvArenaBattleDetailCard SmallLabel="VARIAÇÃO DO ATIVO A"
                                     Title="MOEDA A - USDT"
                                     ChangePercent="@LeftChangePercent"
                                     ChartId="tv-telemetry-chart-split-left"
                                     TimelineId="tv-candle-battle-timeline-left"
                                     ChartAriaLabel="chart split ativo A"
                                     IsAssetA="true" />

            <TvArenaBattleDetailCard SmallLabel="VARIAÇÃO DO ATIVO B"
                                     Title="MOEDA B - USDT"
                                     ChangePercent="@RightChangePercent"
                                     ChartId="tv-telemetry-chart-split-right"
                                     TimelineId="tv-candle-battle-timeline-right"
                                     ChartAriaLabel="chart split ativo B"
                                     IsAssetA="false" />
        </div>
    </div>
</section>

<style>
    .tv-candle-battle {
        height: 100%;
        min-height: 0;
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
        gap: 12px;
    }

    .tv-candle-battle__scoreboard {
        border-radius: 22px;
        padding: 14px 16px;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr) minmax(200px, 0.8fr);
        gap: 14px;
        align-items: center;
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.06);
        background: linear-gradient(180deg, rgba(11, 19, 34, 0.96), rgba(7, 12, 24, 0.94)),
            radial-gradient(circle at top left, rgba(42, 201, 255, 0.08), transparent 30%),
            radial-gradient(circle at top right, rgba(255, 128, 0, 0.10), transparent 28%);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04), 0 18px 42px rgba(0, 0, 0, 0.22);
    }

        .tv-candle-battle__scoreboard::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, rgba(42, 201, 255, 0.06), transparent 34%, transparent 66%, rgba(255, 128, 0, 0.08));
            pointer-events: none;
        }

    .tv-candle-battle__score-side,
    .tv-candle-battle__score-center,
    .tv-candle-battle__score-momentum-card {
        position: relative;
        z-index: 1;
    }

    .tv-candle-battle__score-side {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        gap: 12px;
        align-items: center;
    }

        .tv-candle-battle__score-side img {
            width: 42px;
            height: 42px;
            object-fit: contain;
            filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.18));
        }

    .tv-candle-battle__score-copy {
        display: grid;
        gap: 3px;
        min-width: 0;
    }

    .tv-candle-battle__score-copy--right {
        text-align: right;
    }

    .tv-candle-battle__score-copy strong {
        font-size: .98rem;
        letter-spacing: .04em;
        color: #f5fbff;
    }

    .tv-candle-battle__score-copy span,
    .tv-candle-battle__score-center span,
    .tv-candle-battle__score-center small,
    .tv-candle-battle__score-momentum-card span,
    .tv-candle-battle__score-momentum-card small {
        text-transform: uppercase;
    }

    .tv-candle-battle__score-copy span {
        color: rgba(201, 221, 243, 0.68);
        font-size: .68rem;
        font-weight: 800;
        letter-spacing: .12em;
    }

    .tv-candle-battle__score-side b {
        font-size: clamp(2.6rem, 5vw, 4.1rem);
        line-height: 1;
        letter-spacing: -.06em;
    }

    .tv-candle-battle__score-side--left b {
        color: rgba(42, 201, 255, 0.92);
        text-shadow: 0 0 14px rgba(0, 255, 214, 0.22);
    }

    .tv-candle-battle__score-side--right b {
        color: rgba(255, 166, 0, 0.96);
        text-shadow: 0 0 14px rgba(255, 128, 0, 0.22);
    }

    .tv-candle-battle__score-center {
        display: grid;
        justify-items: center;
        gap: 4px;
        padding-inline: 12px;
    }

        .tv-candle-battle__score-center span {
            color: #f5fbff;
            font-weight: 900;
            letter-spacing: .12em;
        }

        .tv-candle-battle__score-center strong {
            font-size: 2rem;
            color: rgba(240, 245, 252, 0.9);
        }

        .tv-candle-battle__score-center small,
        .tv-candle-battle__score-momentum-card small {
            color: rgba(201, 221, 243, 0.74);
            font-weight: 800;
            letter-spacing: .1em;
        }

    .tv-candle-battle__score-momentum-card {
        display: grid;
        gap: 8px;
        padding: 12px 14px;
        border-radius: 18px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        background: rgba(255, 255, 255, 0.03);
    }

        .tv-candle-battle__score-momentum-card span {
            color: rgba(224, 235, 247, 0.84);
            font-size: .72rem;
            font-weight: 900;
            letter-spacing: .14em;
        }

    .tv-candle-battle__score-momentum-track {
        position: relative;
        width: 100%;
        height: 10px;
        border-radius: 999px;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.06);
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.04);
    }

    .tv-candle-battle__score-momentum-fill {
        position: absolute;
        top: 0;
        bottom: 0;
        transition: width .3s ease;
    }

    .tv-candle-battle__score-momentum-fill--left {
        left: 0;
        background: linear-gradient(90deg, rgba(42, 201, 255, 0.92), rgba(0, 255, 214, 0.88));
    }

    .tv-candle-battle__score-momentum-fill--right {
        right: 0;
        background: linear-gradient(90deg, rgba(255, 166, 0, 0.96), rgba(255, 128, 0, 0.84));
    }

    .tv-candle-battle__score-momentum-meta {
        width: 100%;
        display: flex;
        justify-content: space-between;
        gap: 10px;
        font-size: .8rem;
        font-weight: 900;
    }

    .tv-candle-battle__workspace {
        min-height: 0;
        display: grid;
        grid-template-columns: minmax(0, 1fr);
    }

    .tv-candle-battle__cards {
        min-width: 0;
        min-height: 0;
        display: grid;
        grid-template-rows: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    @@media (max-width: 980px) {
        .tv-candle-battle__scoreboard {
            grid-template-columns: 1fr;
        }

        .tv-candle-battle__score-center {
            padding-inline: 0;
        }
    }
</style>

@code {
    [Parameter, EditorRequired]
    public string LeftTickerLabel { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string RightTickerLabel { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string LeftHeroLabel { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string RightHeroLabel { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string LeftLogoUrl { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string RightLogoUrl { get; set; } = string.Empty;

    [Parameter]
    public decimal? LeftChangePercent { get; set; }

    [Parameter]
    public decimal? RightChangePercent { get; set; }

    [Parameter]
    public string? AriaLabel { get; set; }

    private string ResolveAriaLabel()
        => !string.IsNullOrWhiteSpace(AriaLabel)
            ? AriaLabel!
            : $"{LeftTickerLabel} vs {RightTickerLabel} candle battle arena";
}
