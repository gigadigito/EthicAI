@using System.Globalization
@using DTOs
@inject LocalizationService L

<section id="@_resolvedInstanceId"
         data-tv-candle-battle-instance="@_resolvedInstanceId"
         class="@RootClass"
         aria-label="@ResolveAriaLabel()">

    @if (IsBroadcastCompact)
    {
        <div class="tv-candle-battle__compact">
            <header class="tv-candle-battle__compact-scorebar">
                <div class="tv-candle-battle__compact-team tv-candle-battle__compact-team--left">
                    <img src="@LeftLogoUrl" alt="" />
                    <div>
                        <strong>@LeftTickerLabel</strong>
                        <span>@T("labels.candlesWon")</span>
                    </div>
                    <b id="@($"{_resolvedInstanceId}-score-left")">@Battle.LeftWins</b>
                </div>

                <div class="tv-candle-battle__compact-center">
                    <span>@T("labels.candleBattle")</span>
                    <strong id="@($"{_resolvedInstanceId}-score-leader")">@Battle.LeaderLabel</strong>
                    <div class="tv-candle-battle__compact-momentum" aria-hidden="true">
                        <i class="tv-candle-battle__compact-momentum-fill tv-candle-battle__compact-momentum-fill--left"
                           style="width:@Battle.LeftMomentumPercentString;"></i>
                        <i class="tv-candle-battle__compact-momentum-fill tv-candle-battle__compact-momentum-fill--right"
                           style="width:@Battle.RightMomentumPercentString;"></i>
                    </div>
                </div>

                <div class="tv-candle-battle__compact-team tv-candle-battle__compact-team--right">
                    <b id="@($"{_resolvedInstanceId}-score-right")">@Battle.RightWins</b>
                    <div>
                        <strong>@RightTickerLabel</strong>
                        <span>@T("labels.candlesWon")</span>
                    </div>
                    <img src="@RightLogoUrl" alt="" />
                </div>
            </header>

            @RenderCandleCard(true, compact: true)
            @RenderCandleCard(false, compact: true)
        </div>
    }
    else
    {
        <section class="tv-candle-battle__scoreboard">
            <div class="tv-candle-battle__score-side tv-candle-battle__score-side--left">
                <img src="@LeftLogoUrl" alt="" />
                <div class="tv-candle-battle__score-copy">
                    <strong>@LeftTickerLabel</strong>
                    <span>@T("labels.candlesWon")</span>
                </div>
                <b id="@($"{_resolvedInstanceId}-score-left")">@Battle.LeftWins</b>
            </div>

            <div class="tv-candle-battle__score-center">
                <span>@T("labels.candleBattle")</span>
                <strong>⚔</strong>
                <small id="@($"{_resolvedInstanceId}-score-leader")">@Battle.LeaderLabel</small>
            </div>

            <div class="tv-candle-battle__score-side tv-candle-battle__score-side--right">
                <b id="@($"{_resolvedInstanceId}-score-right")">@Battle.RightWins</b>
                <div class="tv-candle-battle__score-copy tv-candle-battle__score-copy--right">
                    <strong>@RightTickerLabel</strong>
                    <span>@T("labels.candlesWon")</span>
                </div>
                <img src="@RightLogoUrl" alt="" />
            </div>

            <aside class="tv-candle-battle__score-momentum-card">
                <span>@T("labels.momentumCurrent")</span>

                <div class="tv-candle-battle__score-momentum-track" aria-hidden="true">
                    <i id="@($"{_resolvedInstanceId}-score-momentum-left-fill")"
                       class="tv-candle-battle__score-momentum-fill tv-candle-battle__score-momentum-fill--left"
                       style="width:@Battle.LeftMomentumPercentString;"></i>

                    <i id="@($"{_resolvedInstanceId}-score-momentum-right-fill")"
                       class="tv-candle-battle__score-momentum-fill tv-candle-battle__score-momentum-fill--right"
                       style="width:@Battle.RightMomentumPercentString;"></i>
                </div>

                <div class="tv-candle-battle__score-momentum-meta">
                    <strong id="@($"{_resolvedInstanceId}-score-momentum-left")">@Battle.LeftMomentumPercentString</strong>
                    <strong id="@($"{_resolvedInstanceId}-score-momentum-right")">@Battle.RightMomentumPercentString</strong>
                </div>

                <small id="@($"{_resolvedInstanceId}-score-momentum-status")">@Battle.MomentumStatusLabel</small>
            </aside>
        </section>

        <div class="tv-candle-battle__workspace">
            <div class="tv-candle-battle__cards">
                @RenderCandleCard(true, compact: false)
                @RenderCandleCard(false, compact: false)
            </div>

            <aside id="@($"{_resolvedInstanceId}-stats-panel")"
                   class="tv-candle-battle__sidebar"
                   aria-label="Painel tático do Candle Battle">
                <div class="tv-candle-battle__sidebar-top">
                    <div class="tv-candle-battle__sidebar-kicker">
                        <span>@PanelTitle</span>
                        <strong class="@Battle.LeaderClass">@Battle.ShortLeaderLabel</strong>
                    </div>

                    <div class="tv-candle-battle__sidebar-leader">
                        <span>@LeaderTitle</span>
                        <strong>@Battle.LeaderLabel</strong>
                    </div>

                    <div class="tv-candle-battle__sidebar-momentum" aria-hidden="true">
                        <i class="tv-candle-battle__sidebar-momentum-fill tv-candle-battle__sidebar-momentum-fill--left"
                           style="width:@Battle.LeftMomentumPercentString;"></i>
                        <i class="tv-candle-battle__sidebar-momentum-fill tv-candle-battle__sidebar-momentum-fill--right"
                           style="width:@Battle.RightMomentumPercentString;"></i>
                    </div>
                </div>

                <div class="tv-candle-battle__sidebar-section">
                    <div class="tv-candle-battle__sidebar-section-head">
                        <span>@CandlesAnalyzedTitle</span>
                        <strong>@Battle.TotalComparableCandles</strong>
                    </div>

                    <div class="tv-candle-battle__sidebar-grid">
                        <div class="tv-candle-battle__sidebar-row">
                            <span>@LeftHeroLabel</span>
                            <strong class="is-left">@Battle.LeftWins</strong>
                        </div>
                        <div class="tv-candle-battle__sidebar-row">
                            <span>@RightHeroLabel</span>
                            <strong class="is-right">@Battle.RightWins</strong>
                        </div>
                        <div class="tv-candle-battle__sidebar-row">
                            <span>@T("labels.tie")</span>
                            <strong>@Battle.Ties</strong>
                        </div>
                    </div>
                </div>

                <div class="tv-candle-battle__sidebar-section">
                    <div class="tv-candle-battle__sidebar-section-head">
                        <span>@StreakTitle</span>
                        <strong>@Battle.LastRunLength</strong>
                    </div>

                    <div class="tv-candle-battle__sidebar-streak">
                        <i class="tv-candle-battle__sidebar-streak-icon @Battle.LastRunClass"></i>
                        <div>
                            <small>@LastCandleTitle</small>
                            <strong class="@Battle.LastRunClass">@Battle.LastRunLabel</strong>
                        </div>
                    </div>
                </div>

                <div class="tv-candle-battle__sidebar-section">
                    <div class="tv-candle-battle__sidebar-section-head">
                        <span>@PerformanceTitle</span>
                        <strong>@Battle.MomentumStatusLabel</strong>
                    </div>

                    <div class="tv-candle-battle__sidebar-performance">
                        <div class="tv-candle-battle__sidebar-row">
                            <span>@LeftHeroLabel</span>
                            <strong class="is-left">@FormatDeltaPercent(Battle.LastLeftDeltaPercent)</strong>
                        </div>
                        <div class="tv-candle-battle__sidebar-row">
                            <span>@RightHeroLabel</span>
                            <strong class="is-right">@FormatDeltaPercent(Battle.LastRightDeltaPercent)</strong>
                        </div>
                    </div>
                </div>

                @if (!Battle.HasData)
                {
                    <div class="tv-candle-battle__sidebar-muted">@WaitingHistoryText</div>
                }
            </aside>
        </div>
    }
</section>

<style>
    .tv-candle-battle {
        --team-left-color: #ff9100;
        --team-left-color-soft: rgba(255, 145, 0, .72);
        --team-left-color-glow: rgba(255, 145, 0, .22);
        --team-left-color-faint: rgba(255, 145, 0, .08);
        --team-right-color: #18d8d2;
        --team-right-color-soft: rgba(24, 216, 210, .72);
        --team-right-color-glow: rgba(24, 216, 210, .22);
        --team-right-color-faint: rgba(24, 216, 210, .08);
        container-type: inline-size;
        container-name: candle-battle;
        width: 100%;
        height: auto;
        min-width: 0;
        min-height: 0;
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
        gap: 12px;
    }

        .tv-candle-battle,
        .tv-candle-battle * {
            box-sizing: border-box;
        }

    .tv-candle-battle__scoreboard,
    .tv-candle-battle-card,
    .tv-candle-battle__sidebar,
    .tv-candle-battle__compact-scorebar {
        min-width: 0;
        border: 1px solid rgba(255,255,255,0.06);
        background: linear-gradient(180deg, rgba(11, 19, 34, 0.96), rgba(7, 12, 24, 0.94)), radial-gradient(circle at top left, rgba(42, 201, 255, 0.08), transparent 30%), radial-gradient(circle at top right, rgba(255, 128, 0, 0.10), transparent 28%);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.04), 0 18px 42px rgba(0,0,0,0.22);
    }

    .tv-candle-battle__scoreboard {
        position: relative;
        overflow: hidden;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr) minmax(190px, .8fr);
        gap: 14px;
        align-items: center;
        padding: 14px 16px;
        border-radius: 22px;
    }

        .tv-candle-battle__scoreboard::before {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            background: linear-gradient(90deg, rgba(42, 201, 255, 0.06), transparent 34%, transparent 66%, rgba(255, 128, 0, 0.08));
        }

    .tv-candle-battle__score-side,
    .tv-candle-battle__score-center,
    .tv-candle-battle__score-momentum-card {
        position: relative;
        z-index: 1;
        min-width: 0;
    }

    .tv-candle-battle__score-side {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        gap: 12px;
        align-items: center;
    }

        .tv-candle-battle__score-side img {
            width: 42px;
            height: 42px;
            object-fit: contain;
            filter: drop-shadow(0 0 10px rgba(255,255,255,.18));
        }

    .tv-candle-battle__score-copy {
        min-width: 0;
        display: grid;
        gap: 3px;
    }

    .tv-candle-battle__score-copy--right {
        text-align: right;
    }

    .tv-candle-battle__score-copy strong,
    .tv-candle-battle-card__head strong {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .tv-candle-battle__score-copy strong {
        color: #f5fbff;
        font-size: .98rem;
        letter-spacing: .04em;
    }

    .tv-candle-battle__score-copy span,
    .tv-candle-battle__score-center span,
    .tv-candle-battle__score-center small,
    .tv-candle-battle__score-momentum-card span,
    .tv-candle-battle__score-momentum-card small,
    .tv-candle-battle-card__legend span,
    .tv-candle-battle-card__timeline span {
        text-transform: uppercase;
    }

    .tv-candle-battle__score-copy span {
        color: rgba(201,221,243,.68);
        font-size: .68rem;
        font-weight: 800;
        letter-spacing: .12em;
    }

    .tv-candle-battle__score-side b {
        font-size: clamp(2rem, 4cqi, 4.1rem);
        line-height: 1;
        letter-spacing: -.06em;
    }

    .tv-candle-battle__score-side--left b,
    .tv-candle-battle__compact-team--left b {
        color: var(--team-left-color);
        text-shadow: 0 0 14px var(--team-left-color-glow);
    }

    .tv-candle-battle__score-side--right b,
    .tv-candle-battle__compact-team--right b {
        color: var(--team-right-color);
        text-shadow: 0 0 14px var(--team-right-color-glow);
    }

    .tv-candle-battle__score-center {
        display: grid;
        justify-items: center;
        gap: 4px;
        padding-inline: 10px;
        text-align: center;
    }

        .tv-candle-battle__score-center span {
            color: #f5fbff;
            font-weight: 900;
            letter-spacing: .12em;
        }

        .tv-candle-battle__score-center strong {
            color: rgba(240,245,252,.9);
            font-size: 2rem;
        }

        .tv-candle-battle__score-center small,
        .tv-candle-battle__score-momentum-card small {
            color: rgba(201,221,243,.74);
            font-weight: 800;
            letter-spacing: .1em;
        }

    .tv-candle-battle__score-momentum-card {
        display: grid;
        gap: 8px;
        padding: 12px 14px;
        border: 1px solid rgba(255,255,255,.05);
        border-radius: 18px;
        background: rgba(255,255,255,.03);
    }

        .tv-candle-battle__score-momentum-card span {
            color: rgba(224,235,247,.84);
            font-size: .72rem;
            font-weight: 900;
            letter-spacing: .14em;
        }

    .tv-candle-battle__score-momentum-track,
    .tv-candle-battle__sidebar-momentum,
    .tv-candle-battle__compact-momentum {
        position: relative;
        width: 100%;
        height: 10px;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(255,255,255,.06);
        box-shadow: inset 0 0 0 1px rgba(255,255,255,.04);
    }

    .tv-candle-battle__compact-momentum {
        width: min(100%, 320px);
        height: 8px;
    }

    .tv-candle-battle__score-momentum-fill,
    .tv-candle-battle__sidebar-momentum-fill,
    .tv-candle-battle__compact-momentum-fill {
        position: absolute;
        inset-block: 0;
        transition: width .3s ease;
    }

    .tv-candle-battle__score-momentum-fill--left,
    .tv-candle-battle__sidebar-momentum-fill--left,
    .tv-candle-battle__compact-momentum-fill--left {
        left: 0;
        background: linear-gradient(90deg, var(--team-left-color), var(--team-left-color-soft));
    }

    .tv-candle-battle__score-momentum-fill--right,
    .tv-candle-battle__sidebar-momentum-fill--right,
    .tv-candle-battle__compact-momentum-fill--right {
        right: 0;
        background: linear-gradient(90deg, var(--team-right-color), var(--team-right-color-soft));
    }

    .tv-candle-battle__score-momentum-meta {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        width: 100%;
        font-size: .8rem;
        font-weight: 900;
    }

    .tv-candle-battle__workspace {
        min-width: 0;
        min-height: 0;
        display: grid;
        grid-template-columns: minmax(0, 1fr) clamp(250px, 24cqi, 320px);
        gap: 12px;
        align-items: stretch;
    }

    .tv-candle-battle__cards {
        min-width: 0;
        min-height: 0;
        display: grid;
        grid-template-rows: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .tv-candle-battle-card {
        min-height: 0;
        display: grid;
        grid-template-rows: auto auto minmax(0, 1fr);
        gap: 10px;
        padding: 14px;
        border-radius: 22px;
        overflow: hidden;
    }

    .tv-candle-battle-card__head {
        min-width: 0;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 12px;
        align-items: center;
    }

    .tv-candle-battle-card__head-copy {
        min-width: 0;
        display: grid;
        gap: 5px;
    }

    .tv-candle-battle-card__kicker {
        font-size: .68rem;
        font-weight: 900;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .tv-candle-battle-card__kicker--left {
        color: var(--team-left-color);
    }

    .tv-candle-battle-card__kicker--right {
        color: var(--team-right-color);
    }

    .tv-candle-battle-card__head strong {
        font-size: 1.12rem;
        letter-spacing: .05em;
    }

    .tv-candle-battle-card__head em {
        flex: 0 0 auto;
        padding: 6px 12px;
        border: 1px solid rgba(255,255,255,.10);
        border-radius: 999px;
        background: rgba(255,255,255,.04);
        font-style: normal;
        font-weight: 900;
        white-space: nowrap;
    }

    .tv-candle-battle-card--left .tv-candle-battle-card__head em {
        border-color: var(--team-left-color-glow);
        background: var(--team-left-color-faint);
    }

    .tv-candle-battle-card--right .tv-candle-battle-card__head em {
        border-color: var(--team-right-color-glow);
        background: var(--team-right-color-faint);
    }

    .tv-change--positive {
        color: var(--team-right-color);
    }

    .tv-change--negative {
        color: #ff9f9f;
    }

    .tv-change--neutral,
    .tv-change--missing {
        color: rgba(219,231,245,.78);
    }

    .tv-candle-battle-card__legend {
        min-width: 0;
        display: flex;
        flex-wrap: wrap;
        gap: 8px 14px;
        color: rgba(219,231,245,.78);
        font-size: .7rem;
        font-weight: 800;
        letter-spacing: .08em;
    }

        .tv-candle-battle-card__legend .is-left::before,
        .tv-candle-battle-card__legend .is-right::before,
        .tv-candle-battle-card__legend .is-tie::before {
            content: "";
            display: inline-block;
            width: 8px;
            height: 8px;
            margin-right: 7px;
            border-radius: 50%;
            vertical-align: middle;
        }

        .tv-candle-battle-card__legend .is-left::before {
            background: linear-gradient(90deg, var(--team-left-color), var(--team-left-color-soft));
        }

        .tv-candle-battle-card__legend .is-right::before {
            background: linear-gradient(90deg, var(--team-right-color), var(--team-right-color-soft));
        }

        .tv-candle-battle-card__legend .is-tie::before {
            background: rgba(154,167,184,.65);
        }

    .tv-candle-battle-card__body,
    .tv-candle-battle-card__chart-area {
        min-width: 0;
        min-height: 0;
        display: grid;
    }

    .tv-candle-battle-card__chart-area {
        grid-template-rows: minmax(180px, clamp(180px, 24cqi, 240px)) auto;
        gap: 10px;
    }

    .tv-telemetry-chart-shell--battle {
        position: relative;
        width: 100%;
        height: 100%;
        min-width: 0;
        min-height: 180px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,.05);
        border-radius: 18px;
        background: linear-gradient(180deg, rgba(7,14,27,.92), rgba(5,10,19,.98));
    }

    .tv-candle-battle__svg {
        display: block;
        width: 100%;
        height: 100%;
        min-height: 180px;
    }

    .tv-candle-battle__grid-line {
        stroke: rgba(255,255,255,.055);
        stroke-width: 1;
        vector-effect: non-scaling-stroke;
    }

    .tv-candle-battle__wick {
        stroke-width: 2.4;
        stroke-linecap: round;
        vector-effect: non-scaling-stroke;
    }

    .tv-candle-battle__wick--left,
    .tv-candle-battle__body--left {
        stroke: var(--team-left-color);
        fill: var(--team-left-color-soft);
        filter: drop-shadow(0 0 7px var(--team-left-color-glow));
    }

    .tv-candle-battle__wick--right,
    .tv-candle-battle__body--right {
        stroke: var(--team-right-color);
        fill: var(--team-right-color-soft);
        filter: drop-shadow(0 0 7px var(--team-right-color-glow));
    }

    .tv-candle-battle__empty {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        padding: 18px;
        color: rgba(201,221,243,.62);
        font-size: .82rem;
        font-weight: 800;
        letter-spacing: .08em;
        text-align: center;
        text-transform: uppercase;
    }

    .tv-candle-battle-card__timeline {
        min-width: 0;
        display: grid;
        gap: 8px;
        padding-top: 2px;
    }

        .tv-candle-battle-card__timeline span {
            color: rgba(127,246,223,.86);
            font-size: .68rem;
            font-weight: 900;
            letter-spacing: .14em;
        }

    .tv-candle-battle-card__timeline-track {
        --battle-candle-gap: 8px;
        display: grid;
        align-items: center;
        gap: var(--battle-candle-gap);
        width: 100%;
        min-width: 0;
        max-width: 100%;
        overflow-x: auto;
        overflow-y: hidden;
        padding: 4px 2px 2px;
        scrollbar-width: thin;
    }

        .tv-candle-battle-card__timeline-track::-webkit-scrollbar {
            height: 6px;
        }

        .tv-candle-battle-card__timeline-track::-webkit-scrollbar-thumb {
            border-radius: 999px;
            background: rgba(255,255,255,.16);
        }

    .tv-candle-battle-card__timeline-marker {
        width: 100%;
        min-width: 10px;
        height: 8px;
        border: 0;
        border-radius: 2px;
        background: transparent;
        opacity: .95;
        box-shadow: none;
    }

        .tv-candle-battle-card__timeline-marker.is-left {
            background: linear-gradient(90deg, var(--team-left-color), var(--team-left-color-soft));
        }

        .tv-candle-battle-card__timeline-marker.is-right {
            background: linear-gradient(90deg, var(--team-right-color), var(--team-right-color-soft));
        }

        .tv-candle-battle-card__timeline-marker.is-tie {
            height: 3px;
            border-radius: 999px;
            background: rgba(154,167,184,.48);
            opacity: .75;
        }

        .tv-candle-battle-card__timeline-marker:hover {
            opacity: 1;
            filter: brightness(1.12);
        }

    .tv-candle-battle__sidebar {
        min-height: 0;
        display: grid;
        align-content: start;
        gap: 12px;
        padding: 16px;
        border-radius: 22px;
        overflow: auto;
    }

    .tv-candle-battle__sidebar-top {
        display: grid;
        gap: 10px;
        padding-bottom: 10px;
        border-bottom: 1px solid rgba(255,255,255,.06);
    }

    .tv-candle-battle__sidebar-kicker,
    .tv-candle-battle__sidebar-leader,
    .tv-candle-battle__sidebar-section-head,
    .tv-candle-battle__sidebar-row {
