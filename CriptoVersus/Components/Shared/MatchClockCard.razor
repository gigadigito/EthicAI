<div class="@BuildCardClass()">
    @if (ShowWinnerCelebration && ShowResultStage && HasWinner)
    {
        <span class="winner-firework winner-firework--card winner-firework--card-a"></span>
        <span class="winner-firework winner-firework--card winner-firework--card-b"></span>
    }

    @if (ShowResultStage)
    {
        <div class="final-result-card__scene @(HasWinner ? "final-result-card__scene--winner" : "final-result-card__scene--draw")"></div>
        <div class="final-result-card__floor"></div>

        <div class="final-result-card__content">
            <div class="final-result-card__icon" aria-hidden="true">
                @if (HasWinner)
                {
                    <span class="final-result-card__trophy">🏆</span>
                }
                else
                {
                    <span class="final-result-card__handshake">🤝</span>
                }
            </div>

            <div class="final-result-card__eyebrow @(HasWinner ? "final-result-card__eyebrow--winner" : "final-result-card__eyebrow--draw")">
                @FinalResultText
            </div>

            <div class="final-result-card__label">
                @(HasWinner? WinnerLabelText : NoLeaderLabelText)
            </div>

            <div class="final-result-card__winner-line @(HasWinner ? "final-result-card__winner-line--winner" : "final-result-card__winner-line--draw")">
                @if (HasWinner && !string.IsNullOrWhiteSpace(WinnerLogoUrl))
                {
                    <span class="final-result-card__winner-coin">
                        <img src="@WinnerLogoUrl"
                             alt=""
                             loading="lazy"
                             onerror="this.parentElement?.classList.add('d-none');" />
                    </span>
                }

                <span class="final-result-card__winner @(HasWinner ? "final-result-card__winner--winner" : "final-result-card__winner--draw")">
                    @WinnerName
                </span>
            </div>

            <div class="final-result-card__summary">
                @GetResultSummaryText()
            </div>

            <div class="final-result-card__score">
                <span class="final-result-card__score-value final-result-card__score-value--left">@ScoreA</span>
                <strong>x</strong>
                <span class="final-result-card__score-value final-result-card__score-value--right">@ScoreB</span>
            </div>

            <div class="final-result-card__caption">
                @FinalScoreText
            </div>

            <div class="mt-2">
                <span class="badge rounded-pill match-live__pill final-result-card__status">
                    <span class="final-result-card__status-dot" aria-hidden="true"></span>
                    @StatusText
                </span>
            </div>
        </div>
    }
    else
    {
        <div class="clock-live-card__content">
            <div class="clock-title">@MatchClockText</div>

            <div class="clock-time">@ClockText</div>

            <div class="clock-remaining">
                @RemainingText <span class="fw-semibold">@RemainingValue</span>
            </div>

            <div class="mt-2">
                @if (ShowLiveBadge)
                {
                    <span class="badge rounded-pill bg-danger match-live__pill">
                        <span class="match-live__dot"></span>
                        @LiveText
                    </span>
                }
                else
                {
                    <span class="badge rounded-pill text-bg-dark border border-secondary-subtle match-live__pill">
                        @StatusText
                    </span>
                }
            </div>
        </div>
    }
</div>

