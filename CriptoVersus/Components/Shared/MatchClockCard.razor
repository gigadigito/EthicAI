    @@media (max-width: 991.98px) {
        .clock-card {
            min-height: 0;
            height: auto;
        }
    }

    @@media (max-width: 420px) {
        .final-result-card__winner-line {
            gap: .45rem;
        }

        .final-result-card__winner-coin {
            width: 32px;
            height: 32px;
        }

        .final-result-card__winner--winner,
        .final-result-card__winner--draw {
            font-size: clamp(1.65rem, 9vw, 2.15rem);
        }

        .final-result-card__score-value {
            font-size: clamp(1.2rem, 6vw, 1.55rem);
        }

        .final-result-card__eyebrow {
            font-size: .58rem;
            letter-spacing: .18em;
        }

        .social-share-clock-card {
            min-width: 0;
        }
    }
</style>

@code {
    [Parameter] public bool ShowWinnerCelebration { get; set; }
    [Parameter] public bool ShowResultStage { get; set; }
    [Parameter] public bool ShowLiveBadge { get; set; }
    [Parameter] public bool HasWinner { get; set; }

    [Parameter] public int ScoreA { get; set; }
    [Parameter] public int ScoreB { get; set; }

    [Parameter] public string ClockText { get; set; } = "00:00.000";
    [Parameter] public string RemainingValue { get; set; } = "(90:00.000)";
    [Parameter] public string WinnerName { get; set; } = "-";
    [Parameter] public string? WinnerLogoUrl { get; set; }
    [Parameter] public string StatusText { get; set; } = "-";

    [Parameter] public string FinalResultText { get; set; } = "Final Result";
    [Parameter] public string WinnerLabelText { get; set; } = "Winner";
    [Parameter] public string NoLeaderLabelText { get; set; } = "No leader";
    [Parameter] public string FinalScoreText { get; set; } = "Final score";
    [Parameter] public string MatchClockText { get; set; } = "Match Clock";
    [Parameter] public string RemainingText { get; set; } = "Remaining";
    [Parameter] public string LiveText { get; set; } = "LIVE";
    [Parameter] public string WinnerSummaryText { get; set; } = "won the match";
    [Parameter] public string DrawSummaryText { get; set; } = "No leader defined";

    [Parameter] public string? Class { get; set; }

    private string BuildCardClass()
    {
        var classes = "card clock-card social-share-clock-card p-3 text-center d-flex flex-column justify-content-center";

        if (ShowResultStage)
            classes += HasWinner ? " clock-card--winner" : " clock-card--draw";

        if (!string.IsNullOrWhiteSpace(Class))
            classes += $" {Class}";

        return classes;
    }

    private string GetResultSummaryText()
        => HasWinner ? WinnerSummaryText : DrawSummaryText;
}