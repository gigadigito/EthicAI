    @@keyframes fireworkPop {
        0% {
            opacity: 0;
            transform: scale(.16);
        }

        14% {
            opacity: 1;
            transform: scale(.44);
        }

        32% {
            opacity: .98;
            transform: scale(1);
        }

        58% {
            opacity: .44;
            transform: scale(1.18);
        }

        100% {
            opacity: 0;
            transform: scale(1.34);
