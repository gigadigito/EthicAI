@using System.Globalization
@using System.Diagnostics
@using DTOs
@implements IAsyncDisposable
@inject LocalizationService L
@inject IJSRuntime JS
@inject ILogger<TvMatchPriceBattleChart> Logger

<section class="tv-price-battle"
         aria-label="@ResolveAriaLabel()"
         style="@BuildCssVariables()">
    <div class="tv-price-battle__panel">
        <header class="tv-price-battle__header">
            <div class="tv-price-battle__header-copy">
                <span class="tv-price-battle__eyebrow">@HeaderEyebrow()</span>
                <h3>@HeaderTitle()</h3>
                <p>@HeaderSubtitle()</p>
            </div>

            <div class="tv-price-battle__header-meta">
                <span class="tv-price-battle__badge">@HeaderBadge()</span>
                <strong>@BuildMatchHeadline()</strong>
                <small>@HeaderMetaSubtitle()</small>
            </div>
        </header>

        <div class="tv-price-battle__body">
            <article class="tv-price-battle__side tv-price-battle__side--left">
                <div class="tv-price-battle__identity">
                    <div class="tv-price-battle__logo-ring">
                        @if (!string.IsNullOrWhiteSpace(LeftLogoUrl))
                        {
                            <img src="@LeftLogoUrl"
                                 alt="@string.Format(CultureInfo.CurrentCulture, T("logoAlt"), DisplaySymbol(LeftSymbol))" />
                        }
                        else
                        {
                            <span>@CompactSymbol(LeftSymbol)</span>
                        }
                    </div>

                    <div class="tv-price-battle__copy">
                        <span class="tv-price-battle__team-label">TIME A</span>
                        <strong>@DisplaySymbol(LeftSymbol)</strong>
                        <span>@DisplayText(LeftDisplayName)</span>
                    </div>
                </div>

                <div class="tv-price-battle__metrics">
                    <div class="tv-price-battle__metric">
                        <span>@T("currentPrice")</span>
                        <strong class="@GetValueClass(LeftCurrentPrice)">@FormatPrice(LeftCurrentPrice)</strong>
                    </div>

                    <div class="tv-price-battle__change @GetChangeClass(LeftChangePercent)">
                        <span>@T("change")</span>
                        <strong>@FormatChangePercent(LeftChangePercent)</strong>
                    </div>
                </div>

                <div class="tv-price-battle__chart-shell">
                    <div id="@_leftChartId"
                         class="tv-price-battle__chart"
                         aria-label="@T("chartAria")"></div>

                    @if (LeftPoints.Count == 0)
                    {
                        <div class="tv-price-battle__empty">
                            <strong>@GetEmptyTitle(LeftHasPriceHistory)</strong>
                            <small>@T("subtitle")</small>
                        </div>
                    }
                </div>
            </article>

            <section class="tv-price-battle__center">
                <div class="tv-price-battle__vs-ring">
                    <span class="tv-price-battle__vs-label">VS</span>
                    <strong>@Competitiveness</strong>
                </div>
                <small>@T("centerHint")</small>
            </section>

            <article class="tv-price-battle__side tv-price-battle__side--right">
                <div class="tv-price-battle__identity tv-price-battle__identity--right">
                    <div class="tv-price-battle__copy tv-price-battle__copy--right">
                        <span class="tv-price-battle__team-label">TIME B</span>
                        <strong>@DisplaySymbol(RightSymbol)</strong>
                        <span>@DisplayText(RightDisplayName)</span>
                    </div>

                    <div class="tv-price-battle__logo-ring">
                        @if (!string.IsNullOrWhiteSpace(RightLogoUrl))
                        {
                            <img src="@RightLogoUrl"
                                 alt="@string.Format(CultureInfo.CurrentCulture, T("logoAlt"), DisplaySymbol(RightSymbol))" />
                        }
                        else
                        {
                            <span>@CompactSymbol(RightSymbol)</span>
                        }
                    </div>
                </div>

                <div class="tv-price-battle__metrics tv-price-battle__metrics--right">
                    <div class="tv-price-battle__metric">
                        <span>@T("currentPrice")</span>
                        <strong class="@GetValueClass(RightCurrentPrice)">@FormatPrice(RightCurrentPrice)</strong>
                    </div>

                    <div class="tv-price-battle__change @GetChangeClass(RightChangePercent)">
                        <span>@T("change")</span>
                        <strong>@FormatChangePercent(RightChangePercent)</strong>
                    </div>
                </div>

                <div class="tv-price-battle__chart-shell">
                    <div id="@_rightChartId"
                         class="tv-price-battle__chart"
                         aria-label="@T("chartAria")"></div>

                    @if (RightPoints.Count == 0)
                    {
                        <div class="tv-price-battle__empty">
                            <strong>@GetEmptyTitle(RightHasPriceHistory)</strong>
                            <small>@T("subtitle")</small>
                        </div>
                    }
                </div>
            </article>
        </div>
    </div>
</section>

@code {
    private readonly string _leftChartId = $"tv-price-battle-left-{Guid.NewGuid():N}";
    private readonly string _rightChartId = $"tv-price-battle-right-{Guid.NewGuid():N}";
    private IJSObjectReference? _module;
    private bool _pendingSync = true;
    private string _lastSyncSignature = string.Empty;
    private bool _disposed;

    [Parameter] public string Culture { get; set; } = AppCultureService.DefaultRouteCulture;
    [Parameter] public string LeftSymbol { get; set; } = string.Empty;
    [Parameter] public string LeftDisplayName { get; set; } = string.Empty;
    [Parameter] public string LeftLogoUrl { get; set; } = string.Empty;
    [Parameter] public decimal? LeftCurrentPrice { get; set; }
    [Parameter] public decimal? LeftChangePercent { get; set; }
    [Parameter] public string LeftColor { get; set; } = "#ff9100";
    [Parameter] public IReadOnlyList<TvPriceChartPoint> LeftPoints { get; set; } = Array.Empty<TvPriceChartPoint>();
    [Parameter] public bool LeftHasPriceHistory { get; set; }
    [Parameter] public string RightSymbol { get; set; } = string.Empty;
    [Parameter] public string RightDisplayName { get; set; } = string.Empty;
    [Parameter] public string RightLogoUrl { get; set; } = string.Empty;
    [Parameter] public decimal? RightCurrentPrice { get; set; }
    [Parameter] public decimal? RightChangePercent { get; set; }
    [Parameter] public string RightColor { get; set; } = "#18d8d2";
    [Parameter] public IReadOnlyList<TvPriceChartPoint> RightPoints { get; set; } = Array.Empty<TvPriceChartPoint>();
    [Parameter] public bool RightHasPriceHistory { get; set; }
    [Parameter] public int Competitiveness { get; set; }

    protected override void OnParametersSet()
    {
        _pendingSync = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_disposed)
            return;

        if (firstRender && _module is null)
        {
            try
            {
                var importSw = Stopwatch.StartNew();
                _module = await JS.InvokeAsync<IJSObjectReference>("import", "/js/tvMatchPriceBattleChart.mjs?v=20260610-2");
                Logger.LogInformation("[TV_MATCH_LOAD] TvMatchPriceBattleChart JS import elapsedMs={ElapsedMs}", importSw.ElapsedMilliseconds);
                _pendingSync = true;
            }
            catch (JSDisconnectedException)
            {
                return;
            }
            catch (ObjectDisposedException)
            {
                return;
            }
        }

        if (_module is null || !_pendingSync)
            return;

        var signature = BuildSyncSignature();
        if (string.Equals(signature, _lastSyncSignature, StringComparison.Ordinal))
        {
            _pendingSync = false;
            return;
        }

        try
        {
            var syncSw = Stopwatch.StartNew();
            await _module.InvokeVoidAsync("updateMatchPriceBattleChart", new
            {
                left = new
                {
                    chartId = _leftChartId,
                    points = LeftPoints.Select(point => new { time = point.Time, value = (double)point.Value }).ToArray(),
                    color = LeftColor,
                    side = "left",
                    label = DisplaySymbol(LeftSymbol)
                },
                right = new
                {
                    chartId = _rightChartId,
                    points = RightPoints.Select(point => new { time = point.Time, value = (double)point.Value }).ToArray(),
                    color = RightColor,
                    side = "right",
                    label = DisplaySymbol(RightSymbol)
                }
            });

            Logger.LogInformation("[TV_MATCH_LOAD] TvMatchPriceBattleChart update leftPoints={LeftPoints} rightPoints={RightPoints} elapsedMs={ElapsedMs}", LeftPoints.Count, RightPoints.Count, syncSw.ElapsedMilliseconds);
            _lastSyncSignature = signature;
        }
        catch (JSDisconnectedException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
        finally
        {
            _pendingSync = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;

        if (_module is null)
            return;

        try
        {
            await _module.InvokeVoidAsync("disposeMatchPriceBattleChart", _leftChartId);
            await _module.InvokeVoidAsync("disposeMatchPriceBattleChart", _rightChartId);
        }
        catch (JSDisconnectedException)
        {
        }
        catch (ObjectDisposedException)
        {
        }

        try
        {
            await _module.DisposeAsync();
        }
        catch
        {
        }
    }

    private string BuildSyncSignature()
    {
        var leftTail = LeftPoints.Count == 0
            ? "0"
            : $"{LeftPoints.Count}:{LeftPoints[LeftPoints.Count - 1].Time}:{LeftPoints[LeftPoints.Count - 1].Value:0.##########}";
        var rightTail = RightPoints.Count == 0
            ? "0"
            : $"{RightPoints.Count}:{RightPoints[RightPoints.Count - 1].Time}:{RightPoints[RightPoints.Count - 1].Value:0.##########}";

        return string.Join("|",
            Culture,
            DisplaySymbol(LeftSymbol),
            DisplayText(LeftDisplayName),
            LeftCurrentPrice?.ToString("0.##########", CultureInfo.InvariantCulture) ?? string.Empty,
            LeftChangePercent?.ToString("0.##########", CultureInfo.InvariantCulture) ?? string.Empty,
            leftTail,
            LeftHasPriceHistory ? "1" : "0",
            DisplaySymbol(RightSymbol),
            DisplayText(RightDisplayName),
            RightCurrentPrice?.ToString("0.##########", CultureInfo.InvariantCulture) ?? string.Empty,
            RightChangePercent?.ToString("0.##########", CultureInfo.InvariantCulture) ?? string.Empty,
            rightTail,
            RightHasPriceHistory ? "1" : "0",
            Competitiveness.ToString(CultureInfo.InvariantCulture),
            LeftColor,
            RightColor);
    }

    private string BuildCssVariables()
        => FormattableString.Invariant($"--price-battle-left:{LeftColor}; --price-battle-right:{RightColor};");

    private string ResolveAriaLabel()
        => string.Format(
            CultureInfo.CurrentCulture,
            T("ariaLabel"),
            DisplaySymbol(LeftSymbol),
            DisplaySymbol(RightSymbol),
            Competitiveness);

    private string T(string key, params object?[] args)
        => L.T($"tv.priceBattle.{key}", Culture, args);

    private string HeaderEyebrow()
        => IsPortuguese() ? "ATIVIDADE AO VIVO" : "LIVE ACTIVITY";

    private string HeaderTitle()
        => IsPortuguese() ? "Movimentação da partida" : "Match movement";

    private string HeaderSubtitle()
        => IsPortuguese()
            ? "Eventos, pressão, momentum e mudanças táticas acontecendo em tempo real."
            : "Events, pressure, momentum and tactical swings happening live.";

    private string HeaderBadge()
        => IsPortuguese() ? "PARTIDA REAL" : "REAL MATCH";

    private string HeaderMetaSubtitle()
        => IsPortuguese()
            ? "Snapshot de mercado dos dois lados da partida."
            : "Market snapshot for both match sides.";

    private string BuildMatchHeadline()
        => $"{CompactSymbol(LeftSymbol)}VS {CompactSymbol(RightSymbol)}";

    private static string DisplaySymbol(string? value)
        => string.IsNullOrWhiteSpace(value) ? "--" : value.Trim().ToUpperInvariant();

    private static string DisplayText(string? value)
        => string.IsNullOrWhiteSpace(value) ? "--" : value.Trim();

    private static string CompactSymbol(string? value)
    {
        var symbol = BaseSymbol(value);
        return symbol.Length <= 4 ? symbol : symbol[..4];
    }

    private static string BaseSymbol(string? value)
    {
        var symbol = DisplaySymbol(value);
        var suffixes = new[] { "USDT", "USDC", "FDUSD", "BUSD", "TUSD", "USDP", "USD" };

        foreach (var suffix in suffixes)
        {
            if (symbol.EndsWith(suffix, StringComparison.OrdinalIgnoreCase) && symbol.Length > suffix.Length)
                return symbol[..^suffix.Length];
        }

        return symbol;
    }

    private static string FormatPrice(decimal? value)
        => value.HasValue
            ? $"${value.Value.ToString("0.########", CultureInfo.InvariantCulture)}"
            : "--";

    private static string FormatChangePercent(decimal? value)
        => value.HasValue
            ? value.Value > 0m
                ? $"+{value.Value:0.00}%"
                : $"{value.Value:0.00}%"
            : "--";

    private static string GetChangeClass(decimal? value)
        => value switch
        {
            > 0m => "tv-price-battle__change--positive",
            < 0m => "tv-price-battle__change--negative",
            0m => "tv-price-battle__change--neutral",
            _ => "tv-price-battle__change--missing"
        };

    private static string GetValueClass(decimal? value)
        => value.HasValue ? string.Empty : "tv-price-battle__metric-value--missing";

    private string GetEmptyTitle(bool hasPriceHistory)
        => hasPriceHistory
            ? T("waitingHistory")
            : T("noData");

    private bool IsPortuguese()
        => Culture.StartsWith("pt", StringComparison.OrdinalIgnoreCase);
}
