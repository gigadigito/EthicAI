@using System.Globalization
@using System.Diagnostics
@using DTOs
@implements IAsyncDisposable
@inject LocalizationService L
@inject IJSRuntime JS
@inject ILogger<TvMatchPriceBattleChart> Logger

<section class="tv-price-battle"
         aria-label="@ResolveAriaLabel()"
         style="@BuildCssVariables()">

    <header class="tv-price-battle__header">
        <div class="tv-price-battle__header-copy">
            <span class="tv-price-battle__eyebrow">@HeaderEyebrow()</span>
            <h3>@HeaderTitle()</h3>
            <p>@HeaderSubtitle()</p>
        </div>

        <div class="tv-price-battle__match-meta">
            <span class="tv-price-battle__match-badge">
                <i aria-hidden="true"></i>
                @HeaderBadge()
            </span>
            <strong>@BuildMatchHeadline()</strong>
            <small>@MatchIdValue()</small>
        </div>
    </header>

    <div class="tv-price-battle__arena">
        <article class="tv-price-battle__team tv-price-battle__team--left">
            <header class="tv-price-battle__team-header">
                <div class="tv-price-battle__logo-shell">
                    @if (!string.IsNullOrWhiteSpace(LeftLogoUrl))
                    {
                        <img src="@LeftLogoUrl" alt="@string.Format(CultureInfo.CurrentCulture, T("logoAlt"), DisplaySymbol(LeftSymbol))" />
                    }
                    else
                    {
                        <span>@CompactSymbol(LeftSymbol)</span>
                    }
                </div>
                <div class="tv-price-battle__identity">
                    <span class="tv-price-battle__team-label">@TeamALabel()</span>
                    <strong>@DisplaySymbol(LeftSymbol)</strong>
                    <small>@DisplayText(LeftDisplayName)</small>
                </div>
            </header>

            <div class="tv-price-battle__market-row">
                <div class="tv-price-battle__market-value">
                    <span>@T("currentPrice")</span>
                    <strong class="@GetPriceClass(LeftCurrentPrice)">@FormatPrice(LeftCurrentPrice)</strong>
                </div>
                <div class="tv-price-battle__market-change @GetChangeClass(LeftChangePercent)">
                    <span>@VariationLabel()</span>
                    <strong>@FormatChangePercent(LeftChangePercent)</strong>
                </div>
            </div>

            <div class="tv-price-battle__chart-shell">
                <div id="@LeftChartId" class="tv-price-battle__chart" aria-label="@T("chartAria")"></div>
                @if (LeftPoints.Count == 0)
                {
                    <div class="tv-price-battle__empty">
                        <strong>@GetEmptyTitle(LeftHasPriceHistory)</strong>
                        <small>@WaitingPriceDescription()</small>
                    </div>
                }
            </div>
        </article>

        <section class="tv-price-battle__center" aria-label="@CompetitivenessLabel()">
            <span class="tv-price-battle__versus">VS</span>
            <span class="tv-price-battle__competitiveness-label">@CompetitivenessLabel()</span>
            <div class="tv-price-battle__score-ring">
                <div class="tv-price-battle__score-ring-inner">
                    <strong>@Competitiveness</strong>
                </div>
            </div>
            <small>@CenterDescription()</small>
        </section>

        <article class="tv-price-battle__team tv-price-battle__team--right">
            <header class="tv-price-battle__team-header tv-price-battle__team-header--right">
                <div class="tv-price-battle__identity tv-price-battle__identity--right">
                    <span class="tv-price-battle__team-label">@TeamBLabel()</span>
                    <strong>@DisplaySymbol(RightSymbol)</strong>
                    <small>@DisplayText(RightDisplayName)</small>
                </div>
                <div class="tv-price-battle__logo-shell">
                    @if (!string.IsNullOrWhiteSpace(RightLogoUrl))
                    {
                        <img src="@RightLogoUrl" alt="@string.Format(CultureInfo.CurrentCulture, T("logoAlt"), DisplaySymbol(RightSymbol))" />
                    }
                    else
                    {
                        <span>@CompactSymbol(RightSymbol)</span>
                    }
                </div>
            </header>

            <div class="tv-price-battle__market-row tv-price-battle__market-row--right">
                <div class="tv-price-battle__market-value">
                    <span>@T("currentPrice")</span>
                    <strong class="@GetPriceClass(RightCurrentPrice)">@FormatPrice(RightCurrentPrice)</strong>
                </div>
                <div class="tv-price-battle__market-change @GetChangeClass(RightChangePercent)">
                    <span>@VariationLabel()</span>
                    <strong>@FormatChangePercent(RightChangePercent)</strong>
                </div>
            </div>

            <div class="tv-price-battle__chart-shell">
                <div id="@RightChartId" class="tv-price-battle__chart" aria-label="@T("chartAria")"></div>
                @if (RightPoints.Count == 0)
                {
                    <div class="tv-price-battle__empty">
                        <strong>@GetEmptyTitle(RightHasPriceHistory)</strong>
                        <small>@WaitingPriceDescription()</small>
                    </div>
                }
            </div>
        </article>
    </div>

    <section class="tv-price-battle__insights">
        <article class="tv-price-battle__insight tv-price-battle__insight--left">
            <div>
                <span>@MomentumTitle()</span>
                <strong>@MomentumValue()</strong>
                <small>@MomentumDescription()</small>
            </div>
            <i class="tv-price-battle__insight-icon">↗</i>
        </article>

        <article class="tv-price-battle__insight tv-price-battle__insight--left">
            <div>
                <span>@PressureTitle()</span>
                <strong>@DisplaySymbol(LeftSymbol)</strong>
                <small>@PressureDescription()</small>
            </div>
            <i class="tv-price-battle__insight-icon">◔</i>
        </article>

        <article class="tv-price-battle__insight tv-price-battle__insight--right">
            <div>
                <span>@ReasonTitle()</span>
                <strong>@ReasonValue()</strong>
                <small>@ReasonDescription()</small>
            </div>
            <i class="tv-price-battle__insight-icon">◉</i>
        </article>

        <article class="tv-price-battle__insight tv-price-battle__insight--right">
            <div>
                <span>@PoolTitle()</span>
                <strong>@PoolStatusValue()</strong>
                <small>@PoolValue</small>
            </div>
            <i class="tv-price-battle__insight-icon">◌</i>
        </article>
    </section>

    <section class="tv-price-battle__variations">
        <article class="tv-price-battle__variation tv-price-battle__variation--left">
            <div class="tv-price-battle__variation-head">
                <div>
                    <span>@AssetVariationTitle(true)</span>
                    <small>@DisplaySymbol(LeftSymbol)</small>
                </div>
                <strong>@FormatChangePercent(LeftChangePercent)</strong>
            </div>
            <div class="tv-price-battle__variation-track">
                <i style="@BuildVariationStyle(LeftChangePercent, "--price-battle-left")"></i>
            </div>
        </article>

        <article class="tv-price-battle__variation tv-price-battle__variation--right">
            <div class="tv-price-battle__variation-head">
                <div>
                    <span>@AssetVariationTitle(false)</span>
                    <small>@DisplaySymbol(RightSymbol)</small>
                </div>
                <strong>@FormatChangePercent(RightChangePercent)</strong>
            </div>
            <div class="tv-price-battle__variation-track">
                <i style="@BuildVariationStyle(RightChangePercent, "--price-battle-right")"></i>
            </div>
        </article>
    </section>

    <section class="tv-price-battle__footer-grid">
        <footer class="tv-price-battle__broadcast-status">
            <div class="tv-price-battle__broadcast-heading">
                <span>@SignalStatusLabel()</span>
                <strong>@DisplayText(BroadcastFocusLabel)</strong>
            </div>

            <div class="tv-price-battle__broadcast-metric">
                <div class="tv-price-battle__broadcast-metric-head">
                    <span>@RotationLabel()</span>
                    <strong>@DisplayText(BroadcastRotationRemaining)</strong>
                </div>
                <div class="tv-price-battle__broadcast-track">
                    <i class="tv-price-battle__broadcast-fill tv-price-battle__broadcast-fill--rotation" style="@BuildRotationStyle()"></i>
                </div>
            </div>

            <div class="tv-price-battle__broadcast-metric">
                <div class="tv-price-battle__broadcast-metric-head">
                    <span>@CameraFocusLabel()</span>
                    <strong>@FormatProgress(BroadcastFocusProgress)</strong>
                </div>
                <div class="tv-price-battle__broadcast-track">
                    <i class="tv-price-battle__broadcast-fill tv-price-battle__broadcast-fill--focus" style="@BuildFocusStyle()"></i>
                </div>
            </div>
        </footer>

        <article class="tv-price-battle__events">
            <span class="tv-price-battle__events-title">@LatestEventsTitle()</span>
            <div class="tv-price-battle__event-row">
                <time>@LatestEventTimeValue()</time>
                <div>
                    <strong>@LatestEventSymbolValue()</strong>
                    <small>@LatestEventDescriptionValue()</small>
                </div>
                <em>@LatestEventScoreValue()</em>
            </div>
        </article>
    </section>
</section>

@code {
    private IJSObjectReference? _module;
    private bool _pendingSync = true;
    private string _lastSyncSignature = string.Empty;
    private bool _disposed;

    [Parameter] public string Culture { get; set; } = AppCultureService.DefaultRouteCulture;
    [Parameter] public string LeftSymbol { get; set; } = string.Empty;
    [Parameter] public string LeftDisplayName { get; set; } = string.Empty;
    [Parameter] public string LeftLogoUrl { get; set; } = string.Empty;
    [Parameter] public string LeftChartId { get; set; } = $"tv-price-battle-left-{Guid.NewGuid():N}";
    [Parameter] public decimal? LeftCurrentPrice { get; set; }
    [Parameter] public decimal? LeftChangePercent { get; set; }
    [Parameter] public string LeftColor { get; set; } = "#ff9100";
    [Parameter] public IReadOnlyList<TvPriceChartPoint> LeftPoints { get; set; } = Array.Empty<TvPriceChartPoint>();
    [Parameter] public bool LeftHasPriceHistory { get; set; }

    [Parameter] public string RightSymbol { get; set; } = string.Empty;
    [Parameter] public string RightDisplayName { get; set; } = string.Empty;
    [Parameter] public string RightLogoUrl { get; set; } = string.Empty;
    [Parameter] public string RightChartId { get; set; } = $"tv-price-battle-right-{Guid.NewGuid():N}";
    [Parameter] public decimal? RightCurrentPrice { get; set; }
    [Parameter] public decimal? RightChangePercent { get; set; }
    [Parameter] public string RightColor { get; set; } = "#18d8d2";
    [Parameter] public IReadOnlyList<TvPriceChartPoint> RightPoints { get; set; } = Array.Empty<TvPriceChartPoint>();
    [Parameter] public bool RightHasPriceHistory { get; set; }

    [Parameter] public int Competitiveness { get; set; }
    [Parameter] public string BroadcastFocusLabel { get; set; } = string.Empty;
    [Parameter] public string BroadcastRotationRemaining { get; set; } = "00:00";
    [Parameter] public double BroadcastRotationProgress { get; set; }
    [Parameter] public double BroadcastFocusProgress { get; set; }
    [Parameter] public string BroadcastFocusColor { get; set; } = "#18d8d2";
    [Parameter] public bool IsSignalStable { get; set; } = true;

    [Parameter] public string MatchIdLabel { get; set; } = string.Empty;
    [Parameter] public string LatestEventTime { get; set; } = string.Empty;
    [Parameter] public string LatestEventSymbol { get; set; } = string.Empty;
    [Parameter] public string LatestEventDescription { get; set; } = string.Empty;
    [Parameter] public string LatestEventScore { get; set; } = string.Empty;
    [Parameter] public string PoolStatus { get; set; } = string.Empty;
    [Parameter] public string PoolValue { get; set; } = "0";

    protected override void OnParametersSet() => _pendingSync = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_disposed)
            return;

        if (firstRender && _module is null)
        {
            try
            {
                var sw = Stopwatch.StartNew();
                _module = await JS.InvokeAsync<IJSObjectReference>(
                    "import",
                    "/js/tvMatchPriceBattleChart.mjs?v=20260612-reference-layout-1");

                Logger.LogInformation(
                    "[TV_MATCH_LOAD] TvMatchPriceBattleChart JS import elapsedMs={ElapsedMs}",
                    sw.ElapsedMilliseconds);

                _pendingSync = true;
            }
            catch (JSDisconnectedException)
            {
                return;
            }
            catch (ObjectDisposedException)
            {
                return;
            }
        }

        if (_module is null || !_pendingSync)
            return;

        var signature = BuildSyncSignature();
        if (string.Equals(signature, _lastSyncSignature, StringComparison.Ordinal))
        {
            _pendingSync = false;
            return;
        }

        try
        {
            await _module.InvokeVoidAsync(
                "updateMatchPriceBattleChart",
                new
                {
                    left = new
                    {
                        chartId = LeftChartId,
                        points = LeftPoints.Select(point => new
                        {
                            time = point.Time,
                            value = (double)point.Value
                        }).ToArray(),
                        color = LeftColor,
                        side = "left",
                        label = DisplaySymbol(LeftSymbol)
                    },
                    right = new
                    {
                        chartId = RightChartId,
                        points = RightPoints.Select(point => new
                        {
                            time = point.Time,
                            value = (double)point.Value
                        }).ToArray(),
                        color = RightColor,
                        side = "right",
                        label = DisplaySymbol(RightSymbol)
                    }
                });

            _lastSyncSignature = signature;
        }
        catch (JSDisconnectedException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
        catch (JSException ex)
        {
            Logger.LogWarning(ex, "[TV_PRICE_BATTLE] Failed to update price charts.");
        }
        finally
        {
            _pendingSync = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_module is null)
            return;

        try
        {
            await _module.InvokeVoidAsync("disposeMatchPriceBattleChart", LeftChartId);
            await _module.InvokeVoidAsync("disposeMatchPriceBattleChart", RightChartId);
        }
        catch (JSDisconnectedException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
        catch (JSException)
        {
        }

        try
        {
            await _module.DisposeAsync();
        }
        catch
        {
        }
    }

    private string BuildSyncSignature()
    {
        static string Tail(IReadOnlyList<TvPriceChartPoint> points)
            => points.Count == 0
                ? "0"
                : string.Create(
                    CultureInfo.InvariantCulture,
                    $"{points.Count}:{points[^1].Time}:{points[^1].Value:0.##########}");

        return string.Join(
            "|",
            Culture,
            DisplaySymbol(LeftSymbol),
            LeftCurrentPrice?.ToString("0.##################", CultureInfo.InvariantCulture) ?? string.Empty,
            LeftChangePercent?.ToString("0.##########", CultureInfo.InvariantCulture) ?? string.Empty,
            Tail(LeftPoints),
            LeftHasPriceHistory ? "1" : "0",
            DisplaySymbol(RightSymbol),
            RightCurrentPrice?.ToString("0.##################", CultureInfo.InvariantCulture) ?? string.Empty,
            RightChangePercent?.ToString("0.##########", CultureInfo.InvariantCulture) ?? string.Empty,
            Tail(RightPoints),
            RightHasPriceHistory ? "1" : "0",
            Competitiveness.ToString(CultureInfo.InvariantCulture),
            BroadcastFocusLabel,
            BroadcastRotationRemaining,
            BroadcastRotationProgress.ToString("0.####", CultureInfo.InvariantCulture),
            BroadcastFocusProgress.ToString("0.####", CultureInfo.InvariantCulture),
            BroadcastFocusColor,
            IsSignalStable ? "1" : "0",
            LeftColor,
            RightColor);
    }

    private string BuildCssVariables()
    {
        // Padrao visual fixo dos lados no card publico:
        // Time/Moeda A = amarelo; Time/Moeda B = azul.
        // Nao usar a cor dinamica da moeda aqui, para manter consistencia
        // com os demais blocos da arena.
        const string left = "#ffd76e";
        const string right = "#53c8ff";

        return FormattableString.Invariant(
            $"--price-battle-left:{left}; --price-battle-right:{right}; --price-battle-accent:{right};");
    }

    private string ResolveAriaLabel()
        => string.Format(
            CultureInfo.CurrentCulture,
            T("ariaLabel"),
            DisplaySymbol(LeftSymbol),
            DisplaySymbol(RightSymbol),
            Competitiveness);

    private string T(string key, params object?[] args)
        => L.T($"tv.priceBattle.{key}", Culture, args);

    private bool IsPortuguese()
        => Culture.StartsWith("pt", StringComparison.OrdinalIgnoreCase);

    private string HeaderEyebrow() => IsPortuguese() ? "ATIVIDADE AO VIVO" : "LIVE ACTIVITY";
    private string HeaderTitle() => IsPortuguese() ? "Movimentação da partida" : "Match movement";
    private string HeaderSubtitle() => IsPortuguese()
        ? "Eventos, pressão, momentum e mudanças táticas acontecendo em tempo real."
        : "Events, pressure, momentum and tactical swings happening live.";
    private string HeaderBadge() => IsPortuguese() ? "PARTIDA REAL" : "REAL MATCH";
    private string TeamALabel() => IsPortuguese() ? "TIME A" : "TEAM A";
    private string TeamBLabel() => IsPortuguese() ? "TIME B" : "TEAM B";
    private string VariationLabel() => IsPortuguese() ? "VARIAÇÃO 24H" : "24H CHANGE";
    private string CompetitivenessLabel() => IsPortuguese() ? "COMPETITIVIDADE" : "COMPETITIVENESS";
    private string CenterDescription() => IsPortuguese() ? "Batalha ao vivo por um ponto" : "Live battle for one point";
    private string WaitingPriceDescription() => IsPortuguese()
        ? "O histórico será exibido assim que novos snapshots forem registrados."
        : "History will appear as soon as new snapshots are recorded.";
    private string BuildMatchHeadline() => $"{CompactSymbol(LeftSymbol)} VS {CompactSymbol(RightSymbol)}";
    private string MatchIdValue() => string.IsNullOrWhiteSpace(MatchIdLabel)
        ? (IsPortuguese() ? "Partida" : "Match")
        : MatchIdLabel.Trim();

    private string SignalStatusLabel() => IsSignalStable
        ? (IsPortuguese() ? "SINAL ESTÁVEL" : "STABLE SIGNAL")
        : (IsPortuguese() ? "SINAL DEGRADADO" : "DEGRADED SIGNAL");
    private string RotationLabel() => IsPortuguese() ? "ROTAÇÃO DA TRANSMISSÃO" : "BROADCAST ROTATION";
    private string CameraFocusLabel() => IsPortuguese() ? "FOCO DA CÂMERA" : "CAMERA FOCUS";

    private string MomentumTitle() => "MOMENTUM";
    private string MomentumValue() => $"{DisplaySymbol(LeftSymbol)} momentum rising";
    private string MomentumDescription() => IsPortuguese() ? "Virada detectada" : "Reversal detected";
    private string PressureTitle() => IsPortuguese() ? "PRESSÃO" : "PRESSURE";
    private string PressureDescription() => IsPortuguese() ? "Fluxo ao vivo ativo" : "Live flow active";
    private string ReasonTitle() => IsPortuguese() ? "MOTIVO" : "REASON";
    private string ReasonValue() => IsPortuguese() ? "Dinâmica viva de recompensas" : "Live reward dynamics";
    private string ReasonDescription() => IsPortuguese()
        ? "Jogo com muitos gols, placar apertado, gol recente."
        : "High-scoring match, tight score, recent goal.";
    private string PoolTitle() => IsPortuguese() ? "STATUS DO POOL" : "POOL STATUS";
    private string PoolStatusValue() => string.IsNullOrWhiteSpace(PoolStatus)
        ? (IsPortuguese() ? "Fluxo ao vivo ativo" : "Live flow active")
        : PoolStatus.Trim();
    private string AssetVariationTitle(bool left) => IsPortuguese()
        ? $"VARIAÇÃO DO ATIVO {(left ? "A" : "B")}"
        : $"ASSET {(left ? "A" : "B")} CHANGE";
    private string LatestEventsTitle() => IsPortuguese() ? "ÚLTIMOS EVENTOS" : "LATEST EVENTS";
    private string LatestEventTimeValue() => string.IsNullOrWhiteSpace(LatestEventTime) ? "--:--" : LatestEventTime.Trim();
    private string LatestEventSymbolValue() => string.IsNullOrWhiteSpace(LatestEventSymbol)
        ? DisplaySymbol(RightSymbol)
        : DisplaySymbol(LatestEventSymbol);
    private string LatestEventDescriptionValue() => string.IsNullOrWhiteSpace(LatestEventDescription)
        ? (IsPortuguese()
            ? $"{LatestEventSymbolValue()} marcou 1 ponto por cruzar a linha de valorização percentual para cima."
            : $"{LatestEventSymbolValue()} scored 1 point by crossing the percentage appreciation line upward.")
        : LatestEventDescription.Trim();
    private string LatestEventScoreValue() => string.IsNullOrWhiteSpace(LatestEventScore) ? "—" : LatestEventScore.Trim();

    private static string DisplaySymbol(string? value)
        => string.IsNullOrWhiteSpace(value) ? "--" : value.Trim().ToUpperInvariant();
    private static string DisplayText(string? value)
        => string.IsNullOrWhiteSpace(value) ? "--" : value.Trim();
    private static string CompactSymbol(string? value)
    {
        var symbol = BaseSymbol(value);
        return symbol.Length <= 6 ? symbol : symbol[..6];
    }
    private static string BaseSymbol(string? value)
    {
        var symbol = DisplaySymbol(value);
        string[] suffixes = ["USDT", "USDC", "FDUSD", "BUSD", "TUSD", "USDP", "USD"];
        foreach (var suffix in suffixes)
        {
            if (symbol.EndsWith(suffix, StringComparison.OrdinalIgnoreCase) && symbol.Length > suffix.Length)
                return symbol[..^suffix.Length];
        }
        return symbol;
    }
    private static string FormatPrice(decimal? value)
    {
        if (!value.HasValue || value.Value <= 0m)
            return "--";
        var absolute = Math.Abs(value.Value);
        var format = absolute switch
        {
            >= 1000m => "N2",
            >= 100m => "0.00",
            >= 10m => "0.000",
            >= 1m => "0.0000",
            >= 0.1m => "0.00000",
            >= 0.01m => "0.000000",
            >= 0.001m => "0.0000000",
            _ => "0.################"
        };
        return $"${value.Value.ToString(format, CultureInfo.InvariantCulture)}";
    }
    private static string FormatChangePercent(decimal? value)
        => !value.HasValue
            ? "--"
            : value.Value > 0m
                ? $"+{value.Value.ToString("0.00", CultureInfo.InvariantCulture)}%"
                : $"{value.Value.ToString("0.00", CultureInfo.InvariantCulture)}%";
    private static string GetChangeClass(decimal? value) => value switch
    {
        > 0m => "tv-price-battle__market-change--positive",
        < 0m => "tv-price-battle__market-change--negative",
        0m => "tv-price-battle__market-change--neutral",
        _ => "tv-price-battle__market-change--missing"
    };
    private static string GetPriceClass(decimal? value)
        => value.HasValue && value.Value > 0m ? string.Empty : "tv-price-battle__price--missing";
    private string GetEmptyTitle(bool hasPriceHistory)
        => hasPriceHistory ? T("waitingHistory") : T("noData");
    private static string FormatProgress(double value)
        => $"{Math.Clamp(value, 0d, 1d) * 100d:0}%";
    private string BuildRotationStyle()
        => FormattableString.Invariant($"width:{Math.Clamp(BroadcastRotationProgress, 0d, 1d) * 100d:0.##}%;");
    private string BuildFocusStyle()
    {
        var color = string.IsNullOrWhiteSpace(BroadcastFocusColor) ? "#18d8d2" : BroadcastFocusColor.Trim();
        return FormattableString.Invariant($"width:{Math.Clamp(BroadcastFocusProgress, 0d, 1d) * 100d:0.##}%; --broadcast-focus-color:{color};");
    }
    private static double NormalizeVariation(decimal? value)
        => !value.HasValue ? 0d : Math.Clamp(Math.Abs((double)value.Value) / 20d, 0d, 1d);
    private string BuildVariationStyle(decimal? value, string colorVariable)
        => FormattableString.Invariant($"width:{NormalizeVariation(value) * 100d:0.##}%; --variation-color:var({colorVariable});");
}

<style>
    .tv-price-battle {
        --price-battle-left: #ffd76e;
        --price-battle-right: #53c8ff;
        --price-battle-accent: #53c8ff;
        --price-battle-accent: var(--price-battle-right);
        --price-battle-panel: rgba(3, 10, 21, 0.94);
        --price-battle-panel-strong: rgba(2, 8, 17, 0.98);
        --price-battle-border: rgba(72, 118, 156, .22);
        position: relative;
        display: grid;
        grid-template-rows: auto auto auto auto;
        gap: 8px;
        width: 100%;
        height: auto;
        max-height: 720px;
        min-width: 0;
        min-height: 0;
        padding: 12px;
        box-sizing: border-box;
        overflow: hidden;
        color: #f5f7fb;
        border: 1px solid var(--price-battle-border);
        border-radius: 22px;
        background: radial-gradient(circle at 12% 10%, color-mix(in srgb, var(--price-battle-left) 8%, transparent), transparent 28%), radial-gradient(circle at 88% 10%, color-mix(in srgb, var(--price-battle-right) 8%, transparent), transparent 30%), linear-gradient(180deg, #030914 0%, #020812 100%);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.025), 0 24px 60px rgba(0,0,0,.30);
        isolation: isolate;
        container-type: inline-size;
        container-name: price-battle;
    }

        .tv-price-battle::before {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            opacity: .10;
            background-image: linear-gradient(rgba(255,255,255,.022) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.016) 1px, transparent 1px);
            background-size: 42px 42px;
            mask-image: linear-gradient(180deg, #000, transparent 94%);
