@using System.Globalization
@using System.Diagnostics
@using DTOs
@implements IAsyncDisposable
@inject LocalizationService L
@inject IJSRuntime JS
@inject ILogger<TvMatchPriceBattleChart> Logger

<section class="tv-price-battle @(_chartReady ? "is-chart-ready" : "is-chart-pending")"
         aria-label="@ResolveAriaLabel()"
         style="@BuildCssVariables()">

    <header class="tv-price-battle__scoreboard">
        <article class="tv-price-battle__score-team tv-price-battle__score-team--left">
            <div class="tv-price-battle__score-logo">
                @if (!string.IsNullOrWhiteSpace(LeftLogoUrl))
                {
                    <img src="@LeftLogoUrl" alt="@string.Format(CultureInfo.CurrentCulture, T("logoAlt"), DisplaySymbol(LeftSymbol))" />
                }
                else
                {
                    <span>@CompactSymbol(LeftSymbol)</span>
                }
            </div>

            <div class="tv-price-battle__score-copy">
                <span>@TeamALabel()</span>
                <strong>@DisplaySymbol(LeftSymbol)</strong>
                <small>@PricePointsLabel()</small>
            </div>

            <b id="@($"{CombinedChartId}-score-left")">@LeftPricePointCount</b>
        </article>

        <div class="tv-price-battle__score-center" aria-label="@BuildMatchHeadline()">
            <span>@PriceBattleTitle()</span>
            <strong>@TotalPricePointCount @PointsShortLabel()</strong>
            <small>@LiveLabel()</small>
        </div>

        <article class="tv-price-battle__score-team tv-price-battle__score-team--right">
            <b id="@($"{CombinedChartId}-score-right")">@RightPricePointCount</b>

            <div class="tv-price-battle__score-copy tv-price-battle__score-copy--right">
                <span>@TeamBLabel()</span>
                <strong>@DisplaySymbol(RightSymbol)</strong>
                <small>@PricePointsLabel()</small>
            </div>

            <div class="tv-price-battle__score-logo">
                @if (!string.IsNullOrWhiteSpace(RightLogoUrl))
                {
                    <img src="@RightLogoUrl" alt="@string.Format(CultureInfo.CurrentCulture, T("logoAlt"), DisplaySymbol(RightSymbol))" />
                }
                else
                {
                    <span>@CompactSymbol(RightSymbol)</span>
                }
            </div>
        </article>
    </header>

    <div class="tv-price-battle__chart-shell">
        <div id="@CombinedChartId"
             class="tv-price-battle__chart"
             aria-label="@ChartAriaLabel()"></div>

        @if (_chartReady && CrossGuides.Count > 0)
        {
            <div class="tv-price-battle__cross-guides" aria-hidden="true">
                @foreach (var guide in CrossGuides)
                {
                    <span class="tv-price-battle__cross-guide @(guide.IsLeft ? "tv-price-battle__cross-guide--left" : "tv-price-battle__cross-guide--right")"
                          style="@BuildCrossGuideStyle(guide)"></span>
                }
            </div>
        }

        @if (!HasEnoughChartData())
        {
            <div class="tv-price-battle__empty">
                <strong>@EmptyChartTitle()</strong>
                <small>@WaitingPriceDescription()</small>
            </div>
        }
        else if (!_chartReady)
        {
            <div class="tv-price-battle__empty tv-price-battle__empty--loading">
                <strong>@LoadingChartTitle()</strong>
                <small>@LoadingChartDescription()</small>
            </div>
        }
    </div>

    <footer class="tv-price-battle__bottom-bar">
        <div class="tv-price-battle__legend">
            <span class="tv-price-battle__legend-item tv-price-battle__legend-item--left">
                <i aria-hidden="true"></i>
                @DisplaySymbol(LeftSymbol)
            </span>
            <span class="tv-price-battle__legend-item tv-price-battle__legend-item--right">
                <i aria-hidden="true"></i>
                @DisplaySymbol(RightSymbol)
            </span>
        </div>

        <div class="tv-price-battle__cross-events" aria-label="@CrossEventsLabel()">
            @if (CrossEvents.Count == 0)
            {
                <span class="tv-price-battle__no-cross">@NoCrossEventsText()</span>
            }
            else
            {
                @foreach (var crossEvent in CrossEvents)
                {
                    <span class="tv-price-battle__cross-pill @(crossEvent.IsLeft ? "tv-price-battle__cross-pill--left" : "tv-price-battle__cross-pill--right")">
                        <span class="tv-price-battle__mini-logo">
                            @if (!string.IsNullOrWhiteSpace(crossEvent.LogoUrl))
                            {
                                <img src="@crossEvent.LogoUrl" alt="@crossEvent.Symbol" />
                            }
                            else
                            {
                                <strong>@CompactSymbol(crossEvent.Symbol)</strong>
                            }
                        </span>
                        <i aria-hidden="true">↑</i>
                        <small>@FormatCrossTime(crossEvent.Time)</small>
                    </span>
                }
            }
        </div>
    </footer>
</section>

@code {
    private IJSObjectReference? _module;
    private bool _pendingSync = true;
    private bool _chartReady;
    private string _lastSyncSignature = string.Empty;
    private bool _disposed;
    private IReadOnlyList<CrossEventViewModel> CrossEvents { get; set; } = Array.Empty<CrossEventViewModel>();
    private IReadOnlyList<CrossGuideViewModel> CrossGuides { get; set; } = Array.Empty<CrossGuideViewModel>();

    private PriceBattleScoreSummary PriceScore => BuildPriceScore();
    private int LeftPricePointCount => PriceScore.LeftPoints;
    private int RightPricePointCount => PriceScore.RightPoints;
    private int TotalPricePointCount => LeftPricePointCount + RightPricePointCount;

    [Parameter] public string Culture { get; set; } = AppCultureService.DefaultRouteCulture;

    [Parameter] public string LeftSymbol { get; set; } = string.Empty;
    [Parameter] public string LeftDisplayName { get; set; } = string.Empty;
    [Parameter] public string LeftLogoUrl { get; set; } = string.Empty;
    [Parameter] public string LeftChartId { get; set; } = $"tv-price-battle-left-{Guid.NewGuid():N}";
    [Parameter] public decimal? LeftCurrentPrice { get; set; }
    [Parameter] public decimal? LeftChangePercent { get; set; }
    [Parameter] public string LeftColor { get; set; } = "#ffd76e";
    [Parameter] public IReadOnlyList<TvPriceChartPoint> LeftPoints { get; set; } = Array.Empty<TvPriceChartPoint>();
    [Parameter] public bool LeftHasPriceHistory { get; set; }

    [Parameter] public string RightSymbol { get; set; } = string.Empty;
    [Parameter] public string RightDisplayName { get; set; } = string.Empty;
    [Parameter] public string RightLogoUrl { get; set; } = string.Empty;
    [Parameter] public string RightChartId { get; set; } = $"tv-price-battle-right-{Guid.NewGuid():N}";
    [Parameter] public decimal? RightCurrentPrice { get; set; }
    [Parameter] public decimal? RightChangePercent { get; set; }
    [Parameter] public string RightColor { get; set; } = "#53c8ff";
    [Parameter] public IReadOnlyList<TvPriceChartPoint> RightPoints { get; set; } = Array.Empty<TvPriceChartPoint>();
    [Parameter] public bool RightHasPriceHistory { get; set; }

    [Parameter] public string CombinedChartId { get; set; } = $"tv-price-battle-combined-{Guid.NewGuid():N}";

    [Parameter] public int Competitiveness { get; set; }
    [Parameter] public string BroadcastFocusLabel { get; set; } = string.Empty;
    [Parameter] public string BroadcastRotationRemaining { get; set; } = "00:00";
    [Parameter] public double BroadcastRotationProgress { get; set; }
    [Parameter] public double BroadcastFocusProgress { get; set; }
    [Parameter] public string BroadcastFocusColor { get; set; } = "#53c8ff";
    [Parameter] public bool IsSignalStable { get; set; } = true;

    [Parameter] public string MatchIdLabel { get; set; } = string.Empty;
    [Parameter] public string LatestEventTime { get; set; } = string.Empty;
    [Parameter] public string LatestEventSymbol { get; set; } = string.Empty;
    [Parameter] public string LatestEventDescription { get; set; } = string.Empty;
    [Parameter] public string LatestEventScore { get; set; } = string.Empty;
    [Parameter] public string PoolStatus { get; set; } = string.Empty;
    [Parameter] public string PoolValue { get; set; } = "0";

    protected override void OnParametersSet()
    {
        CrossEvents = BuildCrossEvents();
        CrossGuides = BuildCrossGuides();
        _pendingSync = true;

        if (!HasEnoughChartData())
            _chartReady = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_disposed)
            return;

        if (firstRender && _module is null)
        {
            try
            {
                var sw = Stopwatch.StartNew();
                _module = await JS.InvokeAsync<IJSObjectReference>(
                    "import",
                    "/js/tvMatchPriceBattleChart.mjs?v=20260625-price-host-flow-1");

                Logger.LogInformation(
                    "[TV_MATCH_LOAD] TvMatchPriceBattleChart JS import elapsedMs={ElapsedMs}",
                    sw.ElapsedMilliseconds);

                _pendingSync = true;
            }
            catch (JSDisconnectedException)
            {
                return;
            }
            catch (ObjectDisposedException)
            {
                return;
            }
        }

        if (_module is null || !_pendingSync)
            return;

        var signature = BuildSyncSignature();
        if (string.Equals(signature, _lastSyncSignature, StringComparison.Ordinal))
        {
            _pendingSync = false;
            return;
        }

        try
        {
            await _module.InvokeVoidAsync(
                "updateMatchPriceBattleChart",
                new
                {
                    chartId = CombinedChartId,
                    left = new
                    {
                        points = LeftPoints.Select(point => new
                        {
                            time = point.Time,
                            value = (double)point.Value
                        }).ToArray(),
                        color = "#ff9100",
                        side = "left",
                        label = DisplaySymbol(LeftSymbol),
                        compactLabel = CompactSymbol(LeftSymbol),
                        logoUrl = LeftLogoUrl
                    },
                    right = new
                    {
                        points = RightPoints.Select(point => new
                        {
                            time = point.Time,
                            value = (double)point.Value
                        }).ToArray(),
                        color = "#18d8d2",
                        side = "right",
                        label = DisplaySymbol(RightSymbol),
                        compactLabel = CompactSymbol(RightSymbol),
                        logoUrl = RightLogoUrl
                    },
                    options = new
                    {
                        culture = Culture,
                        showCrossovers = false,
                        normalize = true,
                        backgroundColor = "#030a13",
                        textColor = "rgba(232,239,249,.82)",
                        gridColor = "rgba(112,146,172,.12)"
                    }
                });

            _lastSyncSignature = signature;

            var shouldShowChart = HasEnoughChartData();
            if (_chartReady != shouldShowChart)
            {
                _chartReady = shouldShowChart;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (JSDisconnectedException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
        catch (JSException ex)
        {
            if (_chartReady)
            {
                _chartReady = false;
                await InvokeAsync(StateHasChanged);
            }

            Logger.LogWarning(ex, "[TV_PRICE_BATTLE] Failed to update combined price battle chart.");
        }
        finally
        {
            _pendingSync = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_module is null)
            return;

        try
        {
            await _module.InvokeVoidAsync("disposeMatchPriceBattleChart", CombinedChartId);
        }
        catch (JSDisconnectedException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
        catch (JSException)
        {
        }

        try
        {
            await _module.DisposeAsync();
        }
        catch
        {
        }
    }

    private string BuildSyncSignature()
    {
        static string Tail(IReadOnlyList<TvPriceChartPoint> points)
            => points.Count == 0
                ? "0"
                : string.Create(
                    CultureInfo.InvariantCulture,
                    $"{points.Count}:{points[^1].Time}:{points[^1].Value:0.##########}");

        return string.Join(
            "|",
            Culture,
            CombinedChartId,
            DisplaySymbol(LeftSymbol),
            LeftCurrentPrice?.ToString("0.##################", CultureInfo.InvariantCulture) ?? string.Empty,
            LeftChangePercent?.ToString("0.##########", CultureInfo.InvariantCulture) ?? string.Empty,
            Tail(LeftPoints),
            LeftHasPriceHistory ? "1" : "0",
            DisplaySymbol(RightSymbol),
            RightCurrentPrice?.ToString("0.##################", CultureInfo.InvariantCulture) ?? string.Empty,
            RightChangePercent?.ToString("0.##########", CultureInfo.InvariantCulture) ?? string.Empty,
            Tail(RightPoints),
            RightHasPriceHistory ? "1" : "0",
            LeftLogoUrl,
            RightLogoUrl);
    }

    private string BuildCssVariables()
    {
        const string left = "#ff9100";
        const string right = "#18d8d2";

        return FormattableString.Invariant(
            $"--price-battle-left:{left}; --price-battle-right:{right}; --price-battle-accent:{right};");
    }

    private IReadOnlyList<CrossGuideViewModel> BuildCrossGuides()
    {
        var left = NormalizePoints(LeftPoints);
        var right = NormalizePoints(RightPoints);
        var count = Math.Min(left.Count, right.Count);

        if (count < 2)
            return Array.Empty<CrossGuideViewModel>();

        var minTime = Math.Min(
            left.Min(point => point.Time),
            right.Min(point => point.Time));

        var maxTime = Math.Max(
            left.Max(point => point.Time),
            right.Max(point => point.Time));

        if (maxTime <= minTime)
            return Array.Empty<CrossGuideViewModel>();

        var allValues = left
            .Take(count)
            .Select(point => point.Value)
            .Concat(right.Take(count).Select(point => point.Value))
            .ToArray();

        var minValue = allValues.Min();
        var maxValue = allValues.Max();

        if (Math.Abs(maxValue - minValue) <= 0.0000001d)
        {
            minValue -= 0.01d;
            maxValue += 0.01d;
        }

        var guides = new List<CrossGuideViewModel>();

        for (var index = 1; index < count; index++)
        {
            var leftPrev = left[index - 1];
            var leftCurr = left[index];
            var rightPrev = right[index - 1];
            var rightCurr = right[index];

            var previousDelta = leftPrev.Value - rightPrev.Value;
            var currentDelta = leftCurr.Value - rightCurr.Value;

            var crossedToLeft = previousDelta <= 0d && currentDelta > 0d;
            var crossedToRight = previousDelta >= 0d && currentDelta < 0d;

            if (!crossedToLeft && !crossedToRight)
                continue;

            var interpolation = ResolveCrossInterpolation(previousDelta, currentDelta);
            var crossoverTime = InterpolateLong(leftPrev.Time, leftCurr.Time, interpolation);
            var leftValue = InterpolateDouble(leftPrev.Value, leftCurr.Value, interpolation);
            var rightValue = InterpolateDouble(rightPrev.Value, rightCurr.Value, interpolation);
            var crossoverValue = (leftValue + rightValue) / 2d;

            guides.Add(new CrossGuideViewModel(
                crossedToLeft,
                crossoverTime,
                NormalizeGuidePercent(crossoverTime, minTime, maxTime),
                NormalizeGuideYPercent(crossoverValue, minValue, maxValue)));
        }

        return guides.ToArray();
    }

    private static double ResolveCrossInterpolation(double previousDelta, double currentDelta)
    {
        var denominator = Math.Abs(previousDelta) + Math.Abs(currentDelta);
        if (denominator <= 0.0000001d)
            return 0.5d;

        return Math.Clamp(Math.Abs(previousDelta) / denominator, 0d, 1d);
    }

    private static long InterpolateLong(long from, long to, double ratio)
        => from + (long)Math.Round((to - from) * ratio, MidpointRounding.AwayFromZero);

    private static double InterpolateDouble(double from, double to, double ratio)
        => from + ((to - from) * ratio);

    private static double NormalizeGuidePercent(long time, long minTime, long maxTime)
    {
        if (maxTime <= minTime)
            return 0d;

        var percent = ((double)(time - minTime) / (double)(maxTime - minTime)) * 100d;
        return Math.Clamp(percent, 0d, 100d);
    }

    private static double NormalizeGuideYPercent(double value, double minValue, double maxValue)
    {
        if (maxValue <= minValue)
            return 50d;

        var percent = ((maxValue - value) / (maxValue - minValue)) * 100d;
        return Math.Clamp(percent, 0d, 100d);
    }

    private static string BuildCrossGuideStyle(CrossGuideViewModel guide)
        => FormattableString.Invariant($"left:{guide.Percent:0.###}%; --cross-guide-y:{guide.YPercent:0.###}%;");

    private PriceBattleScoreSummary BuildPriceScore()
    {
        var left = NormalizePoints(LeftPoints);
        var right = NormalizePoints(RightPoints);
        var count = Math.Min(left.Count, right.Count);

        if (count < 2)
            return new PriceBattleScoreSummary(0, 0);

        var leftPoints = 0;
        var rightPoints = 0;

        for (var index = 1; index < count; index++)
        {
            var previousDelta = left[index - 1].Value - right[index - 1].Value;
            var currentDelta = left[index].Value - right[index].Value;

            if (previousDelta <= 0d && currentDelta > 0d)
                leftPoints++;
            else if (previousDelta >= 0d && currentDelta < 0d)
                rightPoints++;
        }

        return new PriceBattleScoreSummary(leftPoints, rightPoints);
    }

    private IReadOnlyList<CrossEventViewModel> BuildCrossEvents()
    {
        var left = NormalizePoints(LeftPoints);
        var right = NormalizePoints(RightPoints);
        var count = Math.Min(left.Count, right.Count);

        if (count < 2)
            return Array.Empty<CrossEventViewModel>();

        var events = new List<CrossEventViewModel>();

        for (var index = 1; index < count; index++)
        {
            var previousDelta = left[index - 1].Value - right[index - 1].Value;
            var currentDelta = left[index].Value - right[index].Value;

            if (previousDelta <= 0d && currentDelta > 0d)
            {
                events.Add(new CrossEventViewModel(
                    true,
                    DisplaySymbol(LeftSymbol),
                    LeftLogoUrl,
                    left[index].Time));
            }
            else if (previousDelta >= 0d && currentDelta < 0d)
            {
                events.Add(new CrossEventViewModel(
                    false,
                    DisplaySymbol(RightSymbol),
                    RightLogoUrl,
                    right[index].Time));
            }
        }

        return events
            .TakeLast(6)
            .Reverse()
            .ToArray();
    }

    private static IReadOnlyList<NormalizedPoint> NormalizePoints(IReadOnlyList<TvPriceChartPoint> points)
    {
        if (points.Count == 0)
            return Array.Empty<NormalizedPoint>();

        var baseValueDecimal = points
            .Where(point => point.Value > 0m)
            .Select(point => point.Value)
            .FirstOrDefault();

        if (baseValueDecimal <= 0m)
            return Array.Empty<NormalizedPoint>();

        var baseValue = (double)baseValueDecimal;

        return points
            .Where(point => point.Value > 0m)
            .Select(point => new NormalizedPoint(point.Time, (double)point.Value / baseValue))
            .ToArray();
    }

    private bool HasEnoughChartData()
        => LeftPoints.Count > 1 && RightPoints.Count > 1;

    private string ResolveAriaLabel()
        => string.Format(
            CultureInfo.CurrentCulture,
            T("ariaLabel"),
            DisplaySymbol(LeftSymbol),
            DisplaySymbol(RightSymbol),
            Competitiveness);

    private string ChartAriaLabel()
        => IsPortuguese()
            ? $"Gráfico comparativo de {DisplaySymbol(LeftSymbol)} e {DisplaySymbol(RightSymbol)} com cruzamentos para cima."
            : $"Comparison chart for {DisplaySymbol(LeftSymbol)} and {DisplaySymbol(RightSymbol)} with upward crossovers.";

    private string T(string key, params object?[] args)
        => L.T($"tv.priceBattle.{key}", Culture, args);

    private bool IsPortuguese()
        => Culture.StartsWith("pt", StringComparison.OrdinalIgnoreCase);

    private string TeamALabel() => IsPortuguese() ? "MOEDA A" : "ASSET A";
    private string TeamBLabel() => IsPortuguese() ? "MOEDA B" : "ASSET B";
    private string CrossEventsLabel() => IsPortuguese() ? "Cruzamentos para cima" : "Upward crossovers";
    private string NoCrossEventsText() => IsPortuguese() ? "Sem cruzamento ainda" : "No crossover yet";
    private string PriceBattleTitle() => IsPortuguese() ? "BATALHA DE PREÇO" : "PRICE BATTLE";
    private string PricePointsLabel() => IsPortuguese() ? "PONTOS DE PREÇO" : "PRICE POINTS";
    private string PointsShortLabel() => IsPortuguese() ? "PTS" : "PTS";
    private string LiveLabel() => IsPortuguese() ? "AO VIVO" : "LIVE";
    private string EmptyChartTitle() => IsPortuguese() ? "Aguardando histórico das duas moedas" : "Waiting for both assets history";
    private string LoadingChartTitle() => IsPortuguese() ? "Carregando gráfico de preço" : "Loading price chart";
    private string LoadingChartDescription() => IsPortuguese()
        ? "Preparando as linhas antes de exibir a arena."
        : "Preparing the lines before showing the arena.";

    private string WaitingPriceDescription() => IsPortuguese()
        ? "O gráfico aparece quando as duas linhas tiverem snapshots suficientes."
        : "The chart appears when both lines have enough snapshots.";

    private string BuildMatchHeadline() => $"{CompactSymbol(LeftSymbol)} × {CompactSymbol(RightSymbol)}";

    private string MatchIdValue() => string.IsNullOrWhiteSpace(MatchIdLabel)
        ? (IsPortuguese() ? "ao vivo" : "live")
        : MatchIdLabel.Trim();

    private static string DisplaySymbol(string? value)
        => string.IsNullOrWhiteSpace(value) ? "--" : value.Trim().ToUpperInvariant();

    private static string CompactSymbol(string? value)
    {
        var symbol = BaseSymbol(value);
        return symbol.Length <= 6 ? symbol : symbol[..6];
    }

    private static string BaseSymbol(string? value)
    {
        var symbol = DisplaySymbol(value);
        var suffixes = new[] { "USDT", "USDC", "FDUSD", "BUSD", "TUSD", "USDP", "USD" };

        foreach (var suffix in suffixes)
        {
            if (symbol.EndsWith(suffix, StringComparison.OrdinalIgnoreCase) && symbol.Length > suffix.Length)
                return symbol[..^suffix.Length];
        }

        return symbol;
    }

    private static string FormatPrice(decimal? value)
    {
        if (!value.HasValue || value.Value <= 0m)
            return "--";

        var absolute = Math.Abs(value.Value);
        var format = "0.################";

        if (absolute >= 1000m)
            format = "N2";
        else if (absolute >= 100m)
            format = "0.00";
        else if (absolute >= 10m)
            format = "0.000";
        else if (absolute >= 1m)
            format = "0.0000";
        else if (absolute >= 0.1m)
            format = "0.00000";
        else if (absolute >= 0.01m)
            format = "0.000000";
        else if (absolute >= 0.001m)
            format = "0.0000000";

        return $"${value.Value.ToString(format, CultureInfo.InvariantCulture)}";
    }

    private static string FormatChangePercent(decimal? value)
        => !value.HasValue
            ? "--"
            : value.Value > 0m
                ? $"+{value.Value.ToString("0.00", CultureInfo.InvariantCulture)}%"
                : $"{value.Value.ToString("0.00", CultureInfo.InvariantCulture)}%";

    private string FormatCrossTime(long value)
    {
        if (value <= 0)
            return IsPortuguese() ? "agora" : "now";

        try
        {
            var dateTime = value > 9_999_999_999L
                ? DateTimeOffset.FromUnixTimeMilliseconds(value)
                : DateTimeOffset.FromUnixTimeSeconds(value);

            return dateTime.ToLocalTime().ToString("HH:mm", CultureInfo.CurrentCulture);
        }
        catch (ArgumentOutOfRangeException)
        {
            return value.ToString(CultureInfo.InvariantCulture);
        }
    }

    private sealed record NormalizedPoint(long Time, double Value);
    private sealed record PriceBattleScoreSummary(int LeftPoints, int RightPoints);
    private sealed record CrossEventViewModel(bool IsLeft, string Symbol, string LogoUrl, long Time);
    private sealed record CrossGuideViewModel(bool IsLeft, long Time, double Percent, double YPercent);
}

<style>
    .tv-price-battle {
        --price-battle-left: #ffd76e;
        --price-battle-right: #53c8ff;
        --price-battle-accent: var(--price-battle-right);
        --price-battle-panel: rgba(3, 10, 21, 0.94);
        --price-battle-panel-strong: rgba(2, 8, 17, 0.98);
        --price-battle-border: rgba(72, 118, 156, .24);
        position: relative;
        display: grid;
        grid-template-rows: auto minmax(0, 1fr) auto;
        gap: 10px;
        width: 100%;
        min-width: 0;
        height: 100%;
        min-height: 400px;
        padding: 14px;
        box-sizing: border-box;
        overflow: hidden;
        color: #f5f7fb;
        border: 1px solid var(--price-battle-border);
        border-radius: 22px;
        background: radial-gradient(circle at 18% 8%, color-mix(in srgb, var(--price-battle-left) 10%, transparent), transparent 30%), radial-gradient(circle at 84% 10%, color-mix(in srgb, var(--price-battle-right) 10%, transparent), transparent 32%), linear-gradient(180deg, #030914 0%, #020812 100%);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.025), 0 24px 60px rgba(0,0,0,.30);
        isolation: isolate;
        container-type: inline-size;
        container-name: price-battle;
    }

        .tv-price-battle::before {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            opacity: .11;
            background-image: linear-gradient(rgba(255,255,255,.022) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.016) 1px, transparent 1px);
            background-size: 44px 44px;
            mask-image: linear-gradient(180deg, #000, transparent 94%);
        }

    .tv-price-battle__compact-header,
    .tv-price-battle__chart-shell,
    .tv-price-battle__bottom-bar {
        position: relative;
        z-index: 1;
        min-width: 0;
