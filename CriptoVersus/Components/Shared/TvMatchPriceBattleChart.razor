@using System.Globalization
@using System.Diagnostics
@using DTOs
@implements IAsyncDisposable
@inject LocalizationService L
@inject IJSRuntime JS
@inject ILogger<TvMatchPriceBattleChart> Logger

<section class="tv-price-battle"
         aria-label="@ResolveAriaLabel()"
         style="@BuildCssVariables()">

    <header class="tv-price-battle__header">
        <div class="tv-price-battle__header-copy">
            <span class="tv-price-battle__eyebrow">
                @HeaderEyebrow()
            </span>

            <h3>@HeaderTitle()</h3>

            <p>@HeaderSubtitle()</p>
        </div>

        <div class="tv-price-battle__match-meta">
            <span class="tv-price-battle__match-badge">
                <i aria-hidden="true"></i>
                @HeaderBadge()
            </span>

            <strong>@BuildMatchHeadline()</strong>

            <small>@HeaderMetaSubtitle()</small>
        </div>
    </header>

    <div class="tv-price-battle__arena">

        <article class="tv-price-battle__team tv-price-battle__team--left">

            <header class="tv-price-battle__team-header">
                <div class="tv-price-battle__logo-shell">
                    @if (!string.IsNullOrWhiteSpace(LeftLogoUrl))
                    {
                        <img src="@LeftLogoUrl"
                             alt="@string.Format(
                                                              CultureInfo.CurrentCulture,
                                                              T("logoAlt"),
                                                              DisplaySymbol(LeftSymbol))" />
                                        }
                    else
                    {
                        <span>@CompactSymbol(LeftSymbol)</span>
                    }
                </div>

                <div class="tv-price-battle__identity">
                    <span class="tv-price-battle__team-label">
                        @TeamALabel()
                    </span>

                    <strong>@DisplaySymbol(LeftSymbol)</strong>

                    <small>@DisplayText(LeftDisplayName)</small>
                </div>
            </header>

            <div class="tv-price-battle__market-row">
                <div class="tv-price-battle__market-value">
                    <span>@T("currentPrice")</span>

                    <strong class="@GetPriceClass(LeftCurrentPrice)">
                        @FormatPrice(LeftCurrentPrice)
                    </strong>
                </div>

                <div class="tv-price-battle__market-change @GetChangeClass(LeftChangePercent)">
                    <span>@VariationLabel()</span>

                    <strong>
                        @FormatChangePercent(LeftChangePercent)
                    </strong>
                </div>
            </div>

            <div class="tv-price-battle__chart-shell">
                <div id="@_leftChartId"
                     class="tv-price-battle__chart"
                     aria-label="@T("chartAria")">
                </div>

                @if (LeftPoints.Count == 0)
                {
                    <div class="tv-price-battle__empty">
                        <strong>@GetEmptyTitle(LeftHasPriceHistory)</strong>
                        <small>@WaitingPriceDescription()</small>
                    </div>
                }
            </div>
        </article>

        <section class="tv-price-battle__center"
                 aria-label="@CompetitivenessLabel()">

            <span class="tv-price-battle__versus">VS</span>

            <div class="tv-price-battle__score-ring">
                <div class="tv-price-battle__score-ring-inner">
                    <strong>@Competitiveness</strong>
                </div>
            </div>

            <span class="tv-price-battle__competitiveness-label">
                @CompetitivenessLabel()
            </span>

            <small>@CenterDescription()</small>
        </section>

        <article class="tv-price-battle__team tv-price-battle__team--right">

            <header class="tv-price-battle__team-header tv-price-battle__team-header--right">
                <div class="tv-price-battle__identity tv-price-battle__identity--right">
                    <span class="tv-price-battle__team-label">
                        @TeamBLabel()
                    </span>

                    <strong>@DisplaySymbol(RightSymbol)</strong>

                    <small>@DisplayText(RightDisplayName)</small>
                </div>

                <div class="tv-price-battle__logo-shell">
                    @if (!string.IsNullOrWhiteSpace(RightLogoUrl))
                    {
                        <img src="@RightLogoUrl"
                             alt="@string.Format(
                                                              CultureInfo.CurrentCulture,
                                                              T("logoAlt"),
                                                              DisplaySymbol(RightSymbol))" />
                                        }
                    else
                    {
                        <span>@CompactSymbol(RightSymbol)</span>
                    }
                </div>
            </header>

            <div class="tv-price-battle__market-row tv-price-battle__market-row--right">
                <div class="tv-price-battle__market-value">
                    <span>@T("currentPrice")</span>

                    <strong class="@GetPriceClass(RightCurrentPrice)">
                        @FormatPrice(RightCurrentPrice)
                    </strong>
                </div>

                <div class="tv-price-battle__market-change @GetChangeClass(RightChangePercent)">
                    <span>@VariationLabel()</span>

                    <strong>
                        @FormatChangePercent(RightChangePercent)
                    </strong>
                </div>
            </div>

            <div class="tv-price-battle__chart-shell">
                <div id="@_rightChartId"
                     class="tv-price-battle__chart"
                     aria-label="@T("chartAria")">
                </div>

                @if (RightPoints.Count == 0)
                {
                    <div class="tv-price-battle__empty">
                        <strong>@GetEmptyTitle(RightHasPriceHistory)</strong>
                        <small>@WaitingPriceDescription()</small>
                    </div>
                }
            </div>
        </article>
    </div>
    <footer class="tv-price-battle__broadcast-status">
        <div class="tv-price-battle__broadcast-heading">
            <div>
                <span>@SignalStatusLabel()</span>
                <strong>@DisplayText(BroadcastFocusLabel)</strong>
            </div>

            <small>@BroadcastStatusDescription()</small>
        </div>

        <div class="tv-price-battle__broadcast-grid">
            <div class="tv-price-battle__broadcast-metric">
                <div class="tv-price-battle__broadcast-metric-head">
                    <span>@RotationLabel()</span>
                    <strong>@DisplayText(BroadcastRotationRemaining)</strong>
                </div>

                <div class="tv-price-battle__broadcast-track"
                     aria-label="@RotationLabel()">
                    <i class="tv-price-battle__broadcast-fill tv-price-battle__broadcast-fill--rotation"
                       style="@BuildRotationStyle()"></i>
                </div>
            </div>

            <div class="tv-price-battle__broadcast-metric">
                <div class="tv-price-battle__broadcast-metric-head">
                    <span>@CameraFocusLabel()</span>
                    <strong>@FormatProgress(BroadcastFocusProgress)</strong>
                </div>

                <div class="tv-price-battle__broadcast-track"
                     aria-label="@CameraFocusLabel()">
                    <i class="tv-price-battle__broadcast-fill tv-price-battle__broadcast-fill--focus"
                       style="@BuildFocusStyle()"></i>
                </div>
            </div>
        </div>
    </footer>
</section>

@code {
    private readonly string _leftChartId =
        $"tv-price-battle-left-{Guid.NewGuid():N}";

    private readonly string _rightChartId =
        $"tv-price-battle-right-{Guid.NewGuid():N}";

    private IJSObjectReference? _module;
    private bool _pendingSync = true;
    private string _lastSyncSignature = string.Empty;
    private bool _disposed;
    [Parameter]
    public string BroadcastFocusLabel { get; set; } = string.Empty;

    [Parameter]
    public string BroadcastRotationRemaining { get; set; } = "00:00";

    [Parameter]
    public double BroadcastRotationProgress { get; set; }

    [Parameter]
    public double BroadcastFocusProgress { get; set; }

    [Parameter]
    public string BroadcastFocusColor { get; set; } = "#18d8d2";

    [Parameter]
    public bool IsSignalStable { get; set; } = true;
    [Parameter]
    public string Culture { get; set; } =
        AppCultureService.DefaultRouteCulture;

    [Parameter]
    public string LeftSymbol { get; set; } = string.Empty;

    [Parameter]
    public string LeftDisplayName { get; set; } = string.Empty;

    [Parameter]
    public string LeftLogoUrl { get; set; } = string.Empty;

    [Parameter]
    public decimal? LeftCurrentPrice { get; set; }

    [Parameter]
    public decimal? LeftChangePercent { get; set; }

    [Parameter]
    public string LeftColor { get; set; } = "#ff9100";

    [Parameter]
    public IReadOnlyList<TvPriceChartPoint> LeftPoints { get; set; } =
        Array.Empty<TvPriceChartPoint>();

    [Parameter]
    public bool LeftHasPriceHistory { get; set; }

    [Parameter]
    public string RightSymbol { get; set; } = string.Empty;

    [Parameter]
    public string RightDisplayName { get; set; } = string.Empty;

    [Parameter]
    public string RightLogoUrl { get; set; } = string.Empty;

    [Parameter]
    public decimal? RightCurrentPrice { get; set; }

    [Parameter]
    public decimal? RightChangePercent { get; set; }

    [Parameter]
    public string RightColor { get; set; } = "#18d8d2";

    [Parameter]
    public IReadOnlyList<TvPriceChartPoint> RightPoints { get; set; } =
        Array.Empty<TvPriceChartPoint>();

    [Parameter]
    public bool RightHasPriceHistory { get; set; }

    [Parameter]
    public int Competitiveness { get; set; }

    protected override void OnParametersSet()
    {
        _pendingSync = true;
    }
    private string SignalStatusLabel()
    => IsSignalStable
        ? IsPortuguese()
            ? "SINAL ESTÁVEL"
            : "STABLE SIGNAL"
        : IsPortuguese()
            ? "SINAL DEGRADADO"
            : "DEGRADED SIGNAL";

    private string BroadcastStatusDescription()
        => IsPortuguese()
            ? "Direção automática da transmissão em tempo real."
            : "Automatic live broadcast direction.";

    private string RotationLabel()
        => IsPortuguese()
            ? "ROTAÇÃO DA TRANSMISSÃO"
            : "BROADCAST ROTATION";

    private string CameraFocusLabel()
        => IsPortuguese()
            ? "FOCO DA CÂMERA"
            : "CAMERA FOCUS";

    private static string FormatProgress(double value)
    {
        var normalized = Math.Clamp(value, 0d, 1d);

        return $"{normalized * 100d:0}%";
    }

    private string BuildRotationStyle()
    {
        var progress = Math.Clamp(
            BroadcastRotationProgress,
            0d,
            1d);

        return $"width:{progress * 100d:0.##}%;";
    }

    private string BuildFocusStyle()
    {
        var progress = Math.Clamp(
            BroadcastFocusProgress,
            0d,
            1d);

        var color = string.IsNullOrWhiteSpace(BroadcastFocusColor)
            ? "#18d8d2"
            : BroadcastFocusColor.Trim();

        return $"width:{progress * 100d:0.##}%; --broadcast-focus-color:{color};";
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_disposed)
            return;

        if (firstRender && _module is null)
        {
            try
            {
                var importSw = Stopwatch.StartNew();

                _module = await JS.InvokeAsync<IJSObjectReference>(
                    "import",
                    "/js/tvMatchPriceBattleChart.mjs?v=20260611-visual-3");

                Logger.LogInformation(
                    "[TV_MATCH_LOAD] TvMatchPriceBattleChart JS import elapsedMs={ElapsedMs}",
                    importSw.ElapsedMilliseconds);

                _pendingSync = true;
            }
            catch (JSDisconnectedException)
            {
                return;
            }
            catch (ObjectDisposedException)
            {
                return;
            }
        }

        if (_module is null || !_pendingSync)
            return;

        var signature = BuildSyncSignature();

        if (string.Equals(
                signature,
                _lastSyncSignature,
                StringComparison.Ordinal))
        {
            _pendingSync = false;
            return;
        }

        try
        {
            var syncSw = Stopwatch.StartNew();

            await _module.InvokeVoidAsync(
                "updateMatchPriceBattleChart",
                new
                {
                    left = new
                    {
                        chartId = _leftChartId,
                        points = LeftPoints
                            .Select(point => new
                            {
                                time = point.Time,
                                value = (double)point.Value
                            })
                            .ToArray(),
                        color = LeftColor,
                        side = "left",
                        label = DisplaySymbol(LeftSymbol)
                    },
                    right = new
                    {
                        chartId = _rightChartId,
                        points = RightPoints
                            .Select(point => new
                            {
                                time = point.Time,
                                value = (double)point.Value
                            })
                            .ToArray(),
                        color = RightColor,
                        side = "right",
                        label = DisplaySymbol(RightSymbol)
                    }
                });

            Logger.LogInformation(
                "[TV_MATCH_LOAD] TvMatchPriceBattleChart update leftPoints={LeftPoints} rightPoints={RightPoints} elapsedMs={ElapsedMs}",
                LeftPoints.Count,
                RightPoints.Count,
                syncSw.ElapsedMilliseconds);

            _lastSyncSignature = signature;
        }
        catch (JSDisconnectedException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
        catch (JSException ex)
        {
            Logger.LogWarning(
                ex,
                "[TV_PRICE_BATTLE] Failed to update price charts.");
        }
        finally
        {
            _pendingSync = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;

        if (_module is null)
            return;

        try
        {
            await _module.InvokeVoidAsync(
                "disposeMatchPriceBattleChart",
                _leftChartId);

            await _module.InvokeVoidAsync(
                "disposeMatchPriceBattleChart",
                _rightChartId);
        }
        catch (JSDisconnectedException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
        catch (JSException)
        {
        }

        try
        {
            await _module.DisposeAsync();
        }
        catch
        {
        }
    }

    private string BuildSyncSignature()
    {
        var leftTail = LeftPoints.Count == 0
            ? "0"
            : string.Create(
                CultureInfo.InvariantCulture,
                $"{LeftPoints.Count}:{LeftPoints[^1].Time}:{LeftPoints[^1].Value:0.##########}");

        var rightTail = RightPoints.Count == 0
            ? "0"
            : string.Create(
                CultureInfo.InvariantCulture,
                $"{RightPoints.Count}:{RightPoints[^1].Time}:{RightPoints[^1].Value:0.##########}");

        return string.Join(
     "|",
     Culture,
     DisplaySymbol(LeftSymbol),
     DisplayText(LeftDisplayName),
     LeftCurrentPrice?.ToString(
         "0.##################",
         CultureInfo.InvariantCulture) ?? string.Empty,
     LeftChangePercent?.ToString(
         "0.##########",
         CultureInfo.InvariantCulture) ?? string.Empty,
     leftTail,
     LeftHasPriceHistory ? "1" : "0",
     DisplaySymbol(RightSymbol),
     DisplayText(RightDisplayName),
     RightCurrentPrice?.ToString(
         "0.##################",
         CultureInfo.InvariantCulture) ?? string.Empty,
     RightChangePercent?.ToString(
         "0.##########",
         CultureInfo.InvariantCulture) ?? string.Empty,
     rightTail,
     RightHasPriceHistory ? "1" : "0",
     Competitiveness.ToString(
         CultureInfo.InvariantCulture),
     DisplayText(BroadcastFocusLabel),
     DisplayText(BroadcastRotationRemaining),
     BroadcastRotationProgress.ToString(
         "0.####",
         CultureInfo.InvariantCulture),
     BroadcastFocusProgress.ToString(
         "0.####",
         CultureInfo.InvariantCulture),
     BroadcastFocusColor,
     IsSignalStable ? "1" : "0",
     LeftColor,
     RightColor);
    }

    private string BuildCssVariables()
    {
        var safeLeft = string.IsNullOrWhiteSpace(LeftColor)
            ? "#ff9100"
            : LeftColor.Trim();

        var safeRight = string.IsNullOrWhiteSpace(RightColor)
            ? "#18d8d2"
            : RightColor.Trim();

        return FormattableString.Invariant(
            $"--price-battle-left:{safeLeft}; --price-battle-right:{safeRight};");
    }

    private string ResolveAriaLabel()
    {
        return string.Format(
            CultureInfo.CurrentCulture,
            T("ariaLabel"),
            DisplaySymbol(LeftSymbol),
            DisplaySymbol(RightSymbol),
            Competitiveness);
    }

    private string T(string key, params object?[] args)
        => L.T($"tv.priceBattle.{key}", Culture, args);

    private string HeaderEyebrow()
        => IsPortuguese()
            ? "ATIVIDADE AO VIVO"
            : "LIVE ACTIVITY";

    private string HeaderTitle()
        => IsPortuguese()
            ? "Movimentação da partida"
            : "Match movement";

    private string HeaderSubtitle()
        => IsPortuguese()
            ? "Eventos, pressão, momentum e mudanças táticas acontecendo em tempo real."
            : "Events, pressure, momentum and tactical swings happening live.";

    private string HeaderBadge()
        => IsPortuguese()
            ? "PARTIDA REAL"
            : "REAL MATCH";

    private string HeaderMetaSubtitle()
        => IsPortuguese()
            ? "Snapshot de mercado dos dois lados da partida."
            : "Market snapshot for both sides of the match.";

    private string TeamALabel()
        => IsPortuguese() ? "TIME A" : "TEAM A";

    private string TeamBLabel()
        => IsPortuguese() ? "TIME B" : "TEAM B";

    private string VariationLabel()
        => IsPortuguese() ? "VARIAÇÃO 24H" : "24H CHANGE";

    private string CompetitivenessLabel()
        => IsPortuguese()
            ? "COMPETITIVIDADE"
            : "COMPETITIVENESS";

    private string CenterDescription()
        => IsPortuguese()
            ? "Batalha ao vivo por um ponto"
            : "Live battle for one point";

    private string WaitingPriceDescription()
        => IsPortuguese()
            ? "O histórico será exibido assim que novos snapshots forem registrados."
            : "History will appear as soon as new snapshots are recorded.";

    private string BuildMatchHeadline()
        => $"{CompactSymbol(LeftSymbol)} VS {CompactSymbol(RightSymbol)}";

    private static string DisplaySymbol(string? value)
        => string.IsNullOrWhiteSpace(value)
            ? "--"
            : value.Trim().ToUpperInvariant();

    private static string DisplayText(string? value)
        => string.IsNullOrWhiteSpace(value)
            ? "--"
            : value.Trim();

    private static string CompactSymbol(string? value)
    {
        var symbol = BaseSymbol(value);

        return symbol.Length <= 6
            ? symbol
            : symbol[..6];
    }

    private static string BaseSymbol(string? value)
    {
        var symbol = DisplaySymbol(value);

        string[] suffixes =
        [
            "USDT",
            "USDC",
            "FDUSD",
            "BUSD",
            "TUSD",
            "USDP",
            "USD"
        ];

        foreach (var suffix in suffixes)
        {
            if (symbol.EndsWith(
                    suffix,
                    StringComparison.OrdinalIgnoreCase)
                && symbol.Length > suffix.Length)
            {
                return symbol[..^suffix.Length];
            }
        }

        return symbol;
    }

    private static string FormatPrice(decimal? value)
    {
        if (!value.HasValue || value.Value <= 0m)
            return "--";

        var absolute = Math.Abs(value.Value);

        var format = absolute switch
        {
            >= 1000m => "N2",
            >= 100m => "0.00",
            >= 10m => "0.000",
            >= 1m => "0.0000",
            >= 0.1m => "0.00000",
            >= 0.01m => "0.000000",
            >= 0.001m => "0.0000000",
            _ => "0.################"
        };

        return $"${value.Value.ToString(format, CultureInfo.InvariantCulture)}";
    }

    private static string FormatChangePercent(decimal? value)
    {
        if (!value.HasValue)
            return "--";

        return value.Value > 0m
            ? $"+{value.Value.ToString("0.00", CultureInfo.InvariantCulture)}%"
            : $"{value.Value.ToString("0.00", CultureInfo.InvariantCulture)}%";
    }

    private static string GetChangeClass(decimal? value)
        => value switch
        {
            > 0m => "tv-price-battle__market-change--positive",
            < 0m => "tv-price-battle__market-change--negative",
            0m => "tv-price-battle__market-change--neutral",
            _ => "tv-price-battle__market-change--missing"
        };

    private static string GetPriceClass(decimal? value)
        => value.HasValue && value.Value > 0m
            ? string.Empty
            : "tv-price-battle__price--missing";

    private string GetEmptyTitle(bool hasPriceHistory)
        => hasPriceHistory
            ? T("waitingHistory")
            : T("noData");

    private bool IsPortuguese()
        => Culture.StartsWith(
            "pt",
            StringComparison.OrdinalIgnoreCase);
}

<style>
    .tv-price-battle {
        --price-battle-left: #ff9100;
        --price-battle-right: #18d8d2;
        position: relative;
        display: flex;
        width: 100%;
        height: 100%;
        min-width: 0;
        min-height: 1060px;
        overflow: hidden;
        flex-direction: column;
        color: #f6f8ff;
        border: 1px solid rgba(116, 182, 216, 0.16);
        border-radius: 22px;
        background: radial-gradient( circle at 8% 10%, color-mix(in srgb, var(--price-battle-left) 13%, transparent), transparent 34% ), radial-gradient( circle at 94% 10%, color-mix(in srgb, var(--price-battle-right) 12%, transparent), transparent 36% ), linear-gradient( 135deg, rgba(14, 29, 40, 0.98), rgba(7, 14, 25, 0.99) 48%, rgba(5, 14, 23, 0.99) );
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.025);
        isolation: isolate;
    }

        .tv-price-battle::before {
            content: "";
            position: absolute;
            inset: 0;
            z-index: -2;
            pointer-events: none;
            background: linear-gradient( 104deg, rgba(35, 103, 126, 0.12) 0%, rgba(35, 103, 126, 0.05) 33%, rgba(77, 30, 72, 0.12) 33.2%, rgba(77, 30, 72, 0.05) 45%, transparent 45.2% );
        }

        .tv-price-battle::after {
            content: "";
            position: absolute;
            inset: 0;
            z-index: -1;
            pointer-events: none;
            opacity: 0.18;
            background-image: linear-gradient( rgba(255, 255, 255, 0.025) 1px, transparent 1px ), linear-gradient( 90deg, rgba(255, 255, 255, 0.018) 1px, transparent 1px );
            background-size: 38px 38px;
            mask-image: linear-gradient( to bottom, black, transparent 86% );
        }

    .tv-price-battle__header {
        position: relative;
        z-index: 2;
        display: flex;
        flex: 0 0 auto;
        align-items: flex-start;
        justify-content: space-between;
        gap: 24px;
        padding: 24px 28px 18px;
    }

    .tv-price-battle__header-copy {
        min-width: 0;
        max-width: 760px;
    }

    .tv-price-battle__eyebrow {
        display: block;
        margin-bottom: 6px;
        color: #55f4dc;
        font-size: 0.72rem;
        font-weight: 900;
        line-height: 1;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    .tv-price-battle__header-copy h3 {
        margin: 0;
        max-width: 100%;
        color: #f7f8fc;
        font-size: clamp(1.9rem, 3vw, 2.8rem);
        font-weight: 900;
        line-height: 0.98;
        letter-spacing: -0.045em;
        text-wrap: balance;
    }

    .tv-price-battle__header-copy p {
        margin: 8px 0 0;
        color: rgba(218, 228, 241, 0.74);
        font-size: 0.88rem;
        font-weight: 500;
        line-height: 1.4;
    }

    .tv-price-battle__match-meta {
        display: flex;
        min-width: 200px;
        max-width: 320px;
        flex: 0 0 auto;
        align-items: flex-end;
        flex-direction: column;
        text-align: right;
    }

    .tv-price-battle__match-badge {
        display: inline-flex;
        min-height: 28px;
        padding: 0 13px;
        align-items: center;
        gap: 8px;
        color: #e8f7f6;
        border: 1px solid rgba(108, 205, 199, 0.18);
        border-radius: 999px;
        background: rgba(22, 55, 61, 0.55);
        font-size: 0.68rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

        .tv-price-battle__match-badge i {
            width: 7px;
            height: 7px;
            flex: 0 0 auto;
            border-radius: 50%;
            background: var(--price-battle-right);
            box-shadow: 0 0 8px color-mix( in srgb, var(--price-battle-right) 78%, transparent );
        }

    .tv-price-battle__match-meta > strong {
        display: block;
        margin-top: 9px;
        color: #f8f9fc;
        font-size: clamp(1.05rem, 1.8vw, 1.45rem);
        font-weight: 900;
        line-height: 1.1;
        letter-spacing: -0.025em;
    }

    .tv-price-battle__match-meta > small {
        display: block;
        max-width: 290px;
        margin-top: 5px;
        color: rgba(210, 220, 233, 0.55);
        font-size: 0.68rem;
        font-weight: 600;
        line-height: 1.35;
    }

    .tv-price-battle__arena {
        position: relative;
        z-index: 2;
        display: grid;
        width: 100%;
        min-width: 0;
        min-height: 0;
        flex: 1 1 auto;
