@using System.Globalization
@using CriptoVersus.Web.Services
@inject LocalizationService L

<section class="tv-arena-pressure-gauge @StateClass @(IsCompact ? "is-compact" : string.Empty)"
         aria-label="@AriaLabel"
         title="@AriaLabel">
    <div class="tv-arena-pressure-gauge__panel">
        <header class="tv-arena-pressure-gauge__header">
            <div>
                <h3>@Tg("title")</h3>
                <p>@Tg("subtitle")</p>
            </div>
        </header>

        <div class="tv-arena-pressure-gauge__layout">
            <section class="tv-arena-pressure-gauge__side tv-arena-pressure-gauge__side--left"
                     title="@string.Format(CultureInfo.CurrentCulture, Tg("pressureTooltip"), DisplaySymbol(LeftSymbol), DisplayText(LeftDisplayName), LeftPressureDisplay)">
                <div class="tv-arena-pressure-gauge__identity">
                    <div class="tv-arena-pressure-gauge__logo-ring">
                        @if (!string.IsNullOrWhiteSpace(LeftLogoUrl))
                        {
                            <img src="@LeftLogoUrl" alt="@string.Format(CultureInfo.CurrentCulture, Tg("logoAlt"), DisplaySymbol(LeftSymbol))" />
                        }
                        else
                        {
                            <span>@CompactSymbol(LeftSymbol)</span>
                        }
                    </div>
                    <div class="tv-arena-pressure-gauge__copy">
                        <strong>@DisplaySymbol(LeftSymbol)</strong>
                        <span>@DisplayText(LeftDisplayName)</span>
                    </div>
                </div>
                <div class="tv-arena-pressure-gauge__metric">
                    <strong>@LeftPressureDisplay%</strong>
                    <span>@Tg("pressureLabel")</span>
                </div>
            </section>

            <section class="tv-arena-pressure-gauge__center">
                <div class="tv-arena-pressure-gauge__gauge-shell">
                    <svg class="tv-arena-pressure-gauge__svg"
                         viewBox="0 0 420 250"
                         role="img"
                         aria-label="@AriaLabel">
                        <defs>
                            <linearGradient id="@($"{_gradientId}-left")" x1="0%" y1="0%" x2="100%" y2="0%">
                                <stop offset="0%" stop-color="#ff6b00" />
                                <stop offset="100%" stop-color="#ffbf3c" />
                            </linearGradient>
                            <linearGradient id="@($"{_gradientId}-right")" x1="0%" y1="0%" x2="100%" y2="0%">
                                <stop offset="0%" stop-color="#24e1ef" />
                                <stop offset="100%" stop-color="#73fff0" />
                            </linearGradient>
                            <filter id="@($"{_gradientId}-glow-left")" x="-40%" y="-40%" width="180%" height="180%">
                                <feDropShadow dx="0" dy="0" stdDeviation="4" flood-color="#ff8b1f" flood-opacity="0.85" />
                            </filter>
                            <filter id="@($"{_gradientId}-glow-right")" x="-40%" y="-40%" width="180%" height="180%">
                                <feDropShadow dx="0" dy="0" stdDeviation="4" flood-color="#31f6ff" flood-opacity="0.85" />
                            </filter>
                        </defs>

                        <path d="@ArcPath" class="tv-arena-pressure-gauge__track" pathLength="100" />
                        @foreach (var tick in MajorTicks)
                        {
                            <line x1="@SvgNumber(tick.LineX1)" y1="@SvgNumber(tick.LineY1)" x2="@SvgNumber(tick.LineX2)" y2="@SvgNumber(tick.LineY2)"
                                  class="tv-arena-pressure-gauge__tick-line @(tick.IsCenter ? "is-center" : string.Empty)" />
                        }
                        @foreach (var tick in MinorTicks)
                        {
                            <line x1="@SvgNumber(tick.LineX1)" y1="@SvgNumber(tick.LineY1)" x2="@SvgNumber(tick.LineX2)" y2="@SvgNumber(tick.LineY2)"
                                  class="tv-arena-pressure-gauge__tick-line tv-arena-pressure-gauge__tick-line--minor" />
                        }

                        <path d="@ArcPath" class="tv-arena-pressure-gauge__fill tv-arena-pressure-gauge__fill--left"
                              pathLength="100" style="@LeftArcStyle">
                            <title>@($"{LeftSymbol}: {LeftPressureDisplay}%")</title>
                        </path>
                        <path d="@ArcPath" class="tv-arena-pressure-gauge__fill tv-arena-pressure-gauge__fill--right"
                              pathLength="100" transform="translate(420 0) scale(-1 1)" style="@RightArcStyle">
                            <title>@($"{RightSymbol}: {RightPressureDisplay}%")</title>
                        </path>

                        <line x1="@SvgNumber(SplitMarker.X)" y1="@SvgNumber(SplitMarker.Y1)" x2="@SvgNumber(SplitMarker.X)" y2="@SvgNumber(SplitMarker.Y2)"
                              class="tv-arena-pressure-gauge__split-marker" />
                    </svg>

                    <div class="tv-arena-pressure-gauge__tick-overlay" aria-hidden="true">
                        @foreach (var tick in MajorTicks)
                        {
                            <span class="tv-arena-pressure-gauge__tick-badge @(tick.IsCenter ? "is-center" : string.Empty)"
                                  style="@BuildTickBadgeStyle(tick)">@tick.Label</span>
                        }
                    </div>

                    <div class="tv-arena-pressure-gauge__duel" aria-hidden="true">
                        <span class="tv-arena-pressure-gauge__arrow tv-arena-pressure-gauge__arrow--left"></span>
                        <span class="tv-arena-pressure-gauge__ball" style="@BallSpinStyle">
                            <img src="/img/bola_da_copa.png" alt="" class="tv-arena-pressure-gauge__ball-image" />
                        </span>
                        <span class="tv-arena-pressure-gauge__arrow tv-arena-pressure-gauge__arrow--right"></span>
                    </div>

                    <div class="tv-arena-pressure-gauge__center-copy">
                        <span>@Tg("currentPressureLabel")</span>
                        <strong>@CurrentPressureDisplay%</strong>
                        <em>@DisplayStatusLabel</em>
                    </div>
                </div>
            </section>

            <section class="tv-arena-pressure-gauge__side tv-arena-pressure-gauge__side--right"
                     title="@string.Format(CultureInfo.CurrentCulture, Tg("pressureTooltip"), DisplaySymbol(RightSymbol), DisplayText(RightDisplayName), RightPressureDisplay)">
                <div class="tv-arena-pressure-gauge__identity">
                    <div class="tv-arena-pressure-gauge__copy">
                        <strong>@DisplaySymbol(RightSymbol)</strong>
                        <span>@DisplayText(RightDisplayName)</span>
                    </div>
                    <div class="tv-arena-pressure-gauge__logo-ring">
                        @if (!string.IsNullOrWhiteSpace(RightLogoUrl))
                        {
                            <img src="@RightLogoUrl" alt="@string.Format(CultureInfo.CurrentCulture, Tg("logoAlt"), DisplaySymbol(RightSymbol))" />
                        }
                        else
                        {
                            <span>@CompactSymbol(RightSymbol)</span>
                        }
                    </div>
                </div>
                <div class="tv-arena-pressure-gauge__metric">
                    <strong>@RightPressureDisplay%</strong>
                    <span>@Tg("pressureLabel")</span>
                </div>
            </section>
        </div>

        <footer class="tv-arena-pressure-gauge__footer">
            <section class="tv-arena-pressure-gauge__momentum tv-arena-pressure-gauge__momentum--left">
                <span>@Tg("momentumLabel")</span>
                <strong>@DisplaySymbol(LeftSymbol)</strong>
                <div class="tv-arena-pressure-gauge__bars" aria-hidden="true">
                    @foreach (var bar in LeftBars)
                    {
                        <i style="@bar.Style"></i>
                    }
                </div>
                <small>@DisplayText(LeftMomentumLabel)</small>
            </section>

            <section class="tv-arena-pressure-gauge__footer-status">
                <strong>@FooterPrimaryStatus</strong>
                <div class="tv-arena-pressure-gauge__footer-arrows" aria-hidden="true">
                    <span class="tv-arena-pressure-gauge__arrow tv-arena-pressure-gauge__arrow--left"></span>
                    <span class="tv-arena-pressure-gauge__ball tv-arena-pressure-gauge__ball--small">
                        <img src="/img/bola_da_copa.png" alt="" class="tv-arena-pressure-gauge__ball-image" />
                    </span>
                    <span class="tv-arena-pressure-gauge__arrow tv-arena-pressure-gauge__arrow--right"></span>
                </div>
                <small>@FooterSecondaryStatus</small>
            </section>

            <section class="tv-arena-pressure-gauge__momentum tv-arena-pressure-gauge__momentum--right">
                <span>@Tg("momentumLabel")</span>
                <strong>@DisplaySymbol(RightSymbol)</strong>
                <div class="tv-arena-pressure-gauge__bars" aria-hidden="true">
                    @foreach (var bar in RightBars)
                    {
                        <i style="@bar.Style"></i>
                    }
                </div>
                <small>@DisplayText(RightMomentumLabel)</small>
            </section>
        </footer>

        <div class="tv-arena-pressure-gauge__description">
            <span class="tv-arena-pressure-gauge__description-icon">i</span>
            <p>@DisplayDescription</p>
        </div>
    </div>
</section>

@code {
    private readonly string _gradientId = $"tv-pressure-{Guid.NewGuid():N}";

    [Parameter] public string LeftSymbol { get; set; } = string.Empty;
    [Parameter] public string LeftDisplayName { get; set; } = string.Empty;
    [Parameter] public string LeftLogoUrl { get; set; } = string.Empty;
    [Parameter] public double? LeftPressurePercent { get; set; }
    [Parameter] public string LeftMomentumLabel { get; set; } = string.Empty;
    [Parameter] public string RightSymbol { get; set; } = string.Empty;
    [Parameter] public string RightDisplayName { get; set; } = string.Empty;
    [Parameter] public string RightLogoUrl { get; set; } = string.Empty;
    [Parameter] public double? RightPressurePercent { get; set; }
    [Parameter] public string RightMomentumLabel { get; set; } = string.Empty;
    [Parameter] public double? CurrentPressurePercent { get; set; }
    [Parameter] public string StatusLabel { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public bool IsCompact { get; set; }
    [Parameter] public string Culture { get; set; } = AppCultureService.DefaultRouteCulture;

    private const double ArcRadius = 165d;
    private const double ArcCenterX = 210d;
    private const double ArcCenterY = 190d;
    private const string ArcPath = "M45 190 A165 165 0 0 1 375 190";

    private int LeftPressureDisplay => _pressure.Left;
    private int RightPressureDisplay => _pressure.Right;
    private int PressureDelta => LeftPressureDisplay - RightPressureDisplay;
    private int CurrentPressureDisplay => Math.Clamp((int)Math.Round(CurrentPressurePercent ?? Math.Max(LeftPressureDisplay, RightPressureDisplay), MidpointRounding.AwayFromZero), 0, 100);
    private string DisplayStatusLabel => string.IsNullOrWhiteSpace(StatusLabel) ? DefaultStatusLabel : StatusLabel.Trim().ToUpperInvariant();
    private string DisplayDescription => string.IsNullOrWhiteSpace(Description)
        ? Tg("description")
        : Description.Trim();
    private string StateClass => string.Join(" ", BuildStateClasses());
    private string AriaLabel
        => string.Format(CultureInfo.CurrentCulture, Tg("ariaLabel"), DisplaySymbol(LeftSymbol), LeftPressureDisplay, DisplaySymbol(RightSymbol), RightPressureDisplay, DisplayStatusLabel);
    private string BallSpinStyle => BuildBallSpinStyle();
    private string LeftArcStyle => FormattableString.Invariant($"stroke-dasharray:{LeftPressureDisplay} 100;");
    private string RightArcStyle => FormattableString.Invariant($"stroke-dasharray:{RightPressureDisplay} 100;");
    private (int Left, int Right) _pressure => NormalizePressures(LeftPressurePercent, RightPressurePercent);
    private string DefaultStatusLabel
        => LeftPressureDisplay switch
        {
            >= 70 => string.Format(CultureInfo.CurrentCulture, Tg("statusCritical"), DisplaySymbol(LeftSymbol)),
            >= 60 => string.Format(CultureInfo.CurrentCulture, Tg("statusControlsArena"), DisplaySymbol(LeftSymbol)),
            _ when RightPressureDisplay >= 70 => string.Format(CultureInfo.CurrentCulture, Tg("statusCritical"), DisplaySymbol(RightSymbol)),
            _ when RightPressureDisplay >= 60 => string.Format(CultureInfo.CurrentCulture, Tg("statusControlsArena"), DisplaySymbol(RightSymbol)),
            _ when Math.Abs(LeftPressureDisplay - RightPressureDisplay) <= 10 => Tg("statusBalanced"),
            _ => Tg("statusTransition")
        };
    private string FooterPrimaryStatus
        => Math.Abs(LeftPressureDisplay - RightPressureDisplay) <= 10
            ? Tg("footerInDispute")
            : LeftPressureDisplay > RightPressureDisplay
                ? string.Format(CultureInfo.CurrentCulture, Tg("footerPressuring"), DisplaySymbol(LeftSymbol))
                : string.Format(CultureInfo.CurrentCulture, Tg("footerPressuring"), DisplaySymbol(RightSymbol));
    private string FooterSecondaryStatus
        => Math.Abs(LeftPressureDisplay - RightPressureDisplay) <= 10
            ? Tg("footerNeutralPossession")
            : LeftPressureDisplay > RightPressureDisplay
                ? Tg("footerLeftDominant")
                : Tg("footerRightDominant");
    private SplitMarkerDto SplitMarker => BuildSplitMarker(LeftPressureDisplay);
    private IReadOnlyList<TickMark> MajorTicks => BuildMajorTicks();
    private IReadOnlyList<TickMark> MinorTicks => BuildMinorTicks();
    private IReadOnlyList<BarStyle> LeftBars => BuildBars(LeftPressureDisplay, true);
    private IReadOnlyList<BarStyle> RightBars => BuildBars(RightPressureDisplay, false);

    private IEnumerable<string> BuildStateClasses()
    {
        if (LeftPressureDisplay >= 70 || RightPressureDisplay >= 70)
            yield return "critical-pressure";

        if (LeftPressureDisplay >= 60)
            yield return "left-dominant";
        else if (RightPressureDisplay >= 60)
            yield return "right-dominant";
        else if (CurrentPressureDisplay is >= 45 and <= 55)
            yield return "balanced";
        else
            yield return "balanced";
    }

    private static (int Left, int Right) NormalizePressures(double? leftRaw, double? rightRaw)
    {
        var left = leftRaw ?? double.NaN;
        var right = rightRaw ?? double.NaN;

        if (double.IsNaN(left) && double.IsNaN(right))
            return (50, 50);

        if (double.IsNaN(left))
            left = 100d - right;

        if (double.IsNaN(right))
            right = 100d - left;

        left = Math.Clamp(left, 0d, 100d);
        right = Math.Clamp(right, 0d, 100d);
        var total = left + right;
        if (total <= 0.001d)
            return (50, 50);

        var normalizedLeft = (int)Math.Round((left / total) * 100d, MidpointRounding.AwayFromZero);
        normalizedLeft = Math.Clamp(normalizedLeft, 0, 100);
        return (normalizedLeft, 100 - normalizedLeft);
    }

    private static string DisplaySymbol(string? value)
        => string.IsNullOrWhiteSpace(value) ? "--" : value.Trim().ToUpperInvariant();

    private static string DisplayText(string? value)
        => string.IsNullOrWhiteSpace(value) ? "--" : value.Trim();

    private static string SvgNumber(double value)
        => value.ToString(CultureInfo.InvariantCulture);

    private static string CompactSymbol(string? value)
    {
        var normalized = DisplaySymbol(value);
        return normalized.Length <= 4 ? normalized : normalized[..4];
    }

    private string Tg(string key, params object?[] args)
        => L.T($"tv.pressureGauge.{key}", Culture, args);

    private static SplitMarkerDto BuildSplitMarker(int leftPercent)
    {
        var point = PointOnArc(leftPercent);
        return new SplitMarkerDto(point.X, point.Y - 16d, point.Y + 16d);
    }

    private static IReadOnlyList<TickMark> BuildMajorTicks()
        => new[] { 0, 25, 50, 75, 100 }.Select(value => BuildTick(value, true)).ToList();

    private static IReadOnlyList<TickMark> BuildMinorTicks()
        => Enumerable.Range(1, 19).Select(index => index * 5).Where(value => value % 25 != 0).Select(value => BuildTick(value, false)).ToList();

    private static TickMark BuildTick(int value, bool major)
    {
        var outer = PointOnArc(value, 0d);
        var inner = PointOnArc(value, major ? 12d : 7d);
        var label = PointOnArc(value, -28d);
        return new TickMark(value, $"{value}%", outer.X, outer.Y, inner.X, inner.Y, label.X, label.Y, value == 50);
    }

    private static string BuildTickBadgeStyle(TickMark tick)
        => FormattableString.Invariant($"left:{(tick.LabelX / 420d) * 100d:0.##}%; top:{(tick.LabelY / 250d) * 100d:0.##}%;");

    private string BuildBallSpinStyle()
    {
        var magnitude = Math.Abs(PressureDelta);
        var direction = PressureDelta >= 0 ? 1 : -1;
        var duration = magnitude switch
        {
            >= 30 => 1.45d,
            >= 20 => 1.9d,
            >= 10 => 2.35d,
            >= 5 => 2.85d,
            _ => 3.4d
        };

        var lean = Math.Clamp(magnitude * 0.2d, 0d, 7d) * direction;
        return FormattableString.Invariant($"--ball-spin-duration:{duration:0.##}s; --ball-spin-direction:{direction}; --ball-lean:{lean:0.##}px;");
    }

    private static ArcPoint PointOnArc(int value, double radialOffset = 0d)
    {
        var radius = ArcRadius + radialOffset;
        var angle = Math.PI - ((Math.Clamp(value, 0, 100) / 100d) * Math.PI);
        var x = ArcCenterX + (radius * Math.Cos(angle));
        var y = ArcCenterY - (radius * Math.Sin(angle));
        return new ArcPoint(x, y);
    }

    private static IReadOnlyList<BarStyle> BuildBars(int pressure, bool left)
    {
        var emphasis = pressure / 100d;
        var bars = new List<BarStyle>(20);
        for (var i = 0; i < 20; i++)
        {
            var wave = 0.42d + (Math.Sin((i + 1) * 0.62d + (left ? 0.4d : 1.1d)) * 0.18d);
            var peak = Math.Exp(-Math.Pow(i - (left ? 8.5d : 11.5d), 2d) / 22d) * (0.42d + (emphasis * 0.45d));
            var height = Math.Clamp((wave + peak) * 100d, 18d, 100d);
            bars.Add(new BarStyle(FormattableString.Invariant($"height:{height:0.##}%;")));
        }

        return bars;
    }

    private sealed record ArcPoint(double X, double Y);
    private sealed record TickMark(int Value, string Label, double LineX1, double LineY1, double LineX2, double LineY2, double LabelX, double LabelY, bool IsCenter);
    private sealed record SplitMarkerDto(double X, double Y1, double Y2);
    private sealed record BarStyle(string Style);
}

<style>
    .tv-arena-pressure-gauge {
        --pressure-left: #ff8a1f;
        --pressure-right: #2ee8f2;
        --pressure-track: rgba(206, 232, 255, 0.16);
        --pressure-glass: linear-gradient(180deg, rgba(8, 17, 33, 0.94), rgba(5, 10, 24, 0.92));
        --pressure-border: rgba(98, 145, 191, 0.22);
        position: relative;
        min-width: 0;
        min-height: 900px;
    }

    .tv-arena-pressure-gauge__panel {
        min-width: 0;
        display: grid;
        grid-template-rows: auto minmax(0, 1fr) auto auto;
        gap: clamp(0.9rem, 1.6vw, 1.3rem);
        padding: clamp(1rem, 1.8vw, 1.5rem);
        border-radius: 28px;
        border: 1px solid var(--pressure-border);
        background:
            radial-gradient(circle at 50% 0%, rgba(46, 232, 242, 0.08), transparent 38%),
            radial-gradient(circle at 10% 50%, rgba(255, 138, 31, 0.08), transparent 36%),
            var(--pressure-glass);
        box-shadow:
            inset 0 0 0 1px rgba(255,255,255,0.025),
            0 24px 54px rgba(0, 0, 0, 0.28),
            0 0 38px rgba(13, 33, 56, 0.24);
        overflow: hidden;
        position: relative;
        height: 100%;
    }

    .tv-arena-pressure-gauge__panel::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        pointer-events: none;
        background:
            linear-gradient(90deg, rgba(255, 138, 31, 0.06), transparent 28%, transparent 72%, rgba(46, 232, 242, 0.06)),
            linear-gradient(180deg, rgba(255,255,255,0.04), transparent 14%);
    }

    .tv-arena-pressure-gauge__header,
    .tv-arena-pressure-gauge__layout,
    .tv-arena-pressure-gauge__footer,
    .tv-arena-pressure-gauge__description {
        position: relative;
        z-index: 1;
        min-width: 0;
    }

    .tv-arena-pressure-gauge__header {
        text-align: center;
    }

    .tv-arena-pressure-gauge__header h3 {
        margin: 0;
        color: #72f7ff;
        font-size: clamp(1.1rem, 2vw, 1.9rem);
        font-weight: 900;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        text-shadow: 0 0 18px rgba(70, 245, 255, 0.34);
    }

    .tv-arena-pressure-gauge__header p {
        margin: 0.28rem 0 0;
        color: rgba(214, 231, 255, 0.68);
        font-size: clamp(0.7rem, 0.85vw, 0.92rem);
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    .tv-arena-pressure-gauge__layout {
        display: grid;
        grid-template-columns: minmax(150px, 0.85fr) minmax(0, 2fr) minmax(150px, 0.85fr);
        gap: clamp(0.85rem, 1.5vw, 1.4rem);
        align-items: center;
        min-height: 0;
    }

    .tv-arena-pressure-gauge__side {
        min-width: 0;
        display: grid;
        gap: 0.9rem;
        align-content: center;
    }

    .tv-arena-pressure-gauge__side--left {
        justify-items: start;
        text-align: left;
    }

    .tv-arena-pressure-gauge__side--right {
        justify-items: end;
        text-align: right;
    }

    .tv-arena-pressure-gauge__identity {
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 0.9rem;
    }

    .tv-arena-pressure-gauge__side--right .tv-arena-pressure-gauge__identity {
        flex-direction: row-reverse;
    }

    .tv-arena-pressure-gauge__logo-ring {
        width: clamp(82px, 7vw, 112px);
        aspect-ratio: 1;
        border-radius: 50%;
        padding: 0.85rem;
        display: grid;
        place-items: center;
        background: radial-gradient(circle at 50% 35%, rgba(255,255,255,0.08), rgba(16, 24, 41, 0.86));
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.03);
    }

    .tv-arena-pressure-gauge__side--left .tv-arena-pressure-gauge__logo-ring {
        box-shadow: 0 0 24px rgba(255, 138, 31, 0.26), inset 0 0 0 1px rgba(255,255,255,0.03);
    }

    .tv-arena-pressure-gauge__side--right .tv-arena-pressure-gauge__logo-ring {
        box-shadow: 0 0 24px rgba(46, 232, 242, 0.24), inset 0 0 0 1px rgba(255,255,255,0.03);
    }

    .tv-arena-pressure-gauge__logo-ring img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        filter: drop-shadow(0 0 16px rgba(255,255,255,0.18));
    }

    .tv-arena-pressure-gauge__logo-ring span {
        font-size: clamp(1rem, 1.8vw, 1.4rem);
        font-weight: 900;
        letter-spacing: 0.08em;
        color: #f6fbff;
    }

    .tv-arena-pressure-gauge__copy {
        min-width: 0;
        display: grid;
        gap: 0.22rem;
    }

    .tv-arena-pressure-gauge__copy strong,
    .tv-arena-pressure-gauge__copy span,
    .tv-arena-pressure-gauge__metric span,
    .tv-arena-pressure-gauge__momentum span,
    .tv-arena-pressure-gauge__momentum small,
    .tv-arena-pressure-gauge__footer-status small,
    .tv-arena-pressure-gauge__center-copy span,
    .tv-arena-pressure-gauge__center-copy em {
        text-transform: uppercase;
    }

    .tv-arena-pressure-gauge__copy strong {
        color: #f7fbff;
        font-size: clamp(1.1rem, 2vw, 2rem);
        font-weight: 900;
        letter-spacing: 0.08em;
        line-height: 1;
    }

    .tv-arena-pressure-gauge__side--left .tv-arena-pressure-gauge__copy strong,
    .tv-arena-pressure-gauge__side--left .tv-arena-pressure-gauge__metric strong,
    .tv-arena-pressure-gauge__side--left .tv-arena-pressure-gauge__momentum strong {
        color: #ff9e2a;
        text-shadow: 0 0 18px rgba(255, 138, 31, 0.2);
    }

    .tv-arena-pressure-gauge__side--right .tv-arena-pressure-gauge__copy strong,
    .tv-arena-pressure-gauge__side--right .tv-arena-pressure-gauge__metric strong,
    .tv-arena-pressure-gauge__side--right .tv-arena-pressure-gauge__momentum strong {
        color: #46f4ff;
        text-shadow: 0 0 18px rgba(46, 232, 242, 0.2);
    }

    .tv-arena-pressure-gauge__copy span {
        color: rgba(210, 226, 245, 0.72);
        font-size: clamp(0.74rem, 0.9vw, 1rem);
        font-weight: 700;
        letter-spacing: 0.14em;
        overflow-wrap: anywhere;
    }

    .tv-arena-pressure-gauge__metric {
        display: grid;
        gap: 0.25rem;
    }

    .tv-arena-pressure-gauge__metric strong {
        font-size: clamp(2rem, 4vw, 3.5rem);
        line-height: 1;
        font-weight: 900;
        letter-spacing: -0.05em;
    }

    .tv-arena-pressure-gauge__metric span {
        color: rgba(217, 232, 246, 0.62);
        font-size: clamp(0.78rem, 0.9vw, 1rem);
        font-weight: 800;
        letter-spacing: 0.14em;
    }

