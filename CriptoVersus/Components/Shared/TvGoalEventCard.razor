@using CriptoVersus.Web.Services

<article class="tv-event-card @(Model.IsHero ? "tv-event-card--hero" : "tv-event-card--compact") @(Model.IsHighPriority ? "tv-event-card--high-priority" : string.Empty)"
         data-tv-event-card
         data-enter-from="@Model.EnterFrom"
         data-priority="@Model.PriorityLevel"
         style="@BuildCssVars()">
    <div class="tv-event-card__scanlines" aria-hidden="true"></div>
    <div class="tv-event-card__edge-glow" aria-hidden="true"></div>

    <div class="tv-event-card__event-icon-shell" aria-hidden="true">
        <div class="tv-event-card__event-icon-art">
            <img class="tv-event-card__event-icon-image" src="@GetEventIconSrc()" alt=""
                 onerror="this.style.display='none';this.nextElementSibling.style.opacity='1';" />
            <span class="tv-event-card__event-icon-fallback">@Model.IconFallback</span>
        </div>
    </div>

    <div class="tv-event-card__team-coin-shell">
        <div class="tv-event-card__team-coin">
            @if (!string.IsNullOrWhiteSpace(Model.TeamLogoUrl))
            {
                <img src="@Model.TeamLogoUrl" alt="" />
            }
            else
            {
                <span>@Model.TeamSymbol</span>
            }
        </div>
    </div>

    <div class="tv-event-card__content">
        <div class="tv-event-card__identity">
            <span class="tv-event-card__team-symbol">@Model.TeamSymbol</span>
        </div>

        <div class="tv-event-card__copy">
            <h3>@Model.EventTitle</h3>
            <p>@Model.EventSubtitle</p>
        </div>
    </div>

    <div class="tv-event-card__meta">
        <strong class="tv-event-card__timer">@Model.TimerLabel</strong>
        <em class="tv-event-card__reward">@Model.RewardLabel</em>
    </div>

    @if (Model.IsHighPriority)
    {
        <div class="tv-event-card__particles" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
        </div>
    }
</article>

@code {
    [Parameter, EditorRequired] public TvGoalEventCardModel Model { get; set; } = default!;

    private string BuildCssVars()
        => $"--event-accent-start:{Model.AccentStart};--event-accent-end:{Model.AccentEnd};--event-glow:{Model.GlowColor};";

    private string GetEventIconSrc()
    {
        return Model.EventTypeId switch
        {
            "graph-crossover" => "/img/events/graph-crossover-64.png",

            "momentum-surge" => BuildGenericIcon(
                "<path d='M18 42 L34 22 L34 32 L46 20 L50 24 L38 36 L48 36 L28 50 Z' fill='white'/>"),

            "dominance-streak" => BuildGenericIcon(
                "<path d='M14 44 L18 18 L30 30 L40 16 L50 30 L54 20 L50 44 Z' fill='white'/><rect x='16' y='44' width='34' height='4' rx='2' fill='white'/>"),

            "volatility-impact" => BuildGenericIcon(
                "<path d='M34 10 L20 34 H30 L26 54 L44 28 H34 Z' fill='white'/>"),

            "defensive-hold" => BuildGenericIcon(
                "<path d='M32 12 L50 18 V30 C50 42 42 50 32 54 C22 50 14 42 14 30 V18 Z' fill='white'/><path d='M24 32 L30 38 L41 24' fill='none' stroke='#08111d' stroke-width='4' stroke-linecap='round' stroke-linejoin='round'/>"),

            "comeback-event" => BuildGenericIcon(
                "<path d='M22 20 L14 28 L22 36' fill='none' stroke='white' stroke-width='5' stroke-linecap='round' stroke-linejoin='round'/><path d='M16 28 H38 C46 28 50 34 50 40 C50 46 46 50 40 50 H22' fill='none' stroke='white' stroke-width='5' stroke-linecap='round' stroke-linejoin='round'/>"),

            "sentiment-goal" => BuildGenericIcon(
                "<path d='M10 34 H20 L26 24 L32 40 L38 18 L44 34 H54' fill='none' stroke='white' stroke-width='4' stroke-linecap='round' stroke-linejoin='round'/><circle cx='48' cy='18' r='5' fill='white' opacity='0.85'/>"),

            "breakout-event" => BuildGenericIcon(
                "<path d='M16 42 L28 30 L36 30 L48 18' fill='none' stroke='white' stroke-width='5' stroke-linecap='round' stroke-linejoin='round'/><path d='M38 18 H50 V30' fill='none' stroke='white' stroke-width='5' stroke-linecap='round' stroke-linejoin='round'/>"),

            "candle-battle-dominance" => BuildGenericIcon(
                "<path d='M20 44 H44' fill='none' stroke='white' stroke-width='4' stroke-linecap='round'/><path d='M22 40 C24 28 30 22 32 18 C34 22 40 28 42 40' fill='none' stroke='white' stroke-width='4' stroke-linecap='round' stroke-linejoin='round'/><path d='M34 14 L46 26 L38 26 L38 40 L30 40 L30 26 L22 26 Z' fill='white'/>"),


            "candle-battle-lead-change" => BuildGenericIcon(
                "<path d='M20 44 H44' fill='none' stroke='white' stroke-width='4' stroke-linecap='round'/><path d='M22 40 C24 28 30 22 32 18 C34 22 40 28 42 40' fill='none' stroke='white' stroke-width='4' stroke-linecap='round' stroke-linejoin='round'/><path d='M34 14 L46 26 L38 26 L38 40 L30 40 L30 26 L22 26 Z' fill='white'/>"),

            _ => BuildGenericIcon(
                $"<text x='32' y='39' text-anchor='middle' fill='white' font-size='18' font-family='Arial' font-weight='700'>{Model.IconFallback}</text>")
        };
    }

    private string BuildGraphCrossoverIcon()
    {
        var svg = string.Concat(
            "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'>",
            "<defs>",
            $"<linearGradient id='g1' x1='0' y1='0' x2='1' y2='1'><stop offset='0%' stop-color='{Model.AccentStart}'/><stop offset='100%' stop-color='#6b31ff'/></linearGradient>",
            $"<linearGradient id='g2' x1='0' y1='1' x2='1' y2='0'><stop offset='0%' stop-color='#7cff4a'/><stop offset='100%' stop-color='{Model.AccentEnd}'/></linearGradient>",
            "</defs>",
            "<rect width='64' height='64' rx='16' fill='#08111d'/>",
            "<path d='M10 48 L24 34 L32 32 L54 12' fill='none' stroke='url(#g2)' stroke-width='5' stroke-linecap='round' stroke-linejoin='round'/>",
            "<path d='M10 12 L24 26 L32 32 L54 52' fill='none' stroke='url(#g1)' stroke-width='5' stroke-linecap='round' stroke-linejoin='round'/>",
            "<circle cx='32' cy='32' r='10' fill='#f8fbff' stroke='#0b1220' stroke-width='2'/>",
            "<polygon points='32,25 37,28 35,34 29,34 27,28' fill='#101828'/>",
            "<path d='M32 42 L29 34 M32 42 L35 34 M22 30 L27 28 M42 30 L37 28 M24 39 L29 34 M40 39 L35 34' stroke='#101828' stroke-width='2' stroke-linecap='round'/>",
            "</svg>");

        return SvgToDataUri(svg);
    }

    private string BuildGenericIcon(string inner)
    {
        var svg = string.Concat(
            "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'>",
            "<defs>",
            $"<linearGradient id='g' x1='0' y1='0' x2='1' y2='1'><stop offset='0%' stop-color='{Model.AccentStart}'/><stop offset='100%' stop-color='{Model.AccentEnd}'/></linearGradient>",
            "</defs>",
            "<rect width='64' height='64' rx='16' fill='#08111d'/>",
            "<rect x='6' y='6' width='52' height='52' rx='14' fill='url(#g)' opacity='0.22'/>",
            inner,
            "</svg>");

        return SvgToDataUri(svg);
    }

    private static string SvgToDataUri(string svg)
        => $"data:image/svg+xml;utf8,{Uri.EscapeDataString(svg)}";
}
<style>
    .tv-event-card {
        min-height: 0;
        height: auto;
        max-height: 130px;
        display: grid;
        grid-template-columns: auto auto minmax(0, 1fr) auto;
        align-items: center;
        gap: 0.75rem;
        padding: 0.65rem 0.9rem;
        overflow: hidden;
    }

    .tv-event-card--hero,
    .tv-event-card--compact {
        min-height: 0;
        height: auto;
        max-height: 130px;
    }

    .tv-event-card__event-icon-shell {
        width: 58px;
        height: 58px;
        min-width: 58px;
    }

    .tv-event-card__event-icon-art {
        width: 58px;
        height: 58px;
    }

    .tv-event-card__event-icon-image,
    .tv-event-card__event-icon-fallback {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .tv-event-card__team-coin-shell {
        width: 42px;
        min-width: 42px;
        align-self: center;
    }

    .tv-event-card__team-coin {
        width: 42px;
        height: 42px;
    }

    .tv-event-card__content {
        min-width: 0;
        align-self: center;
    }

    .tv-event-card__identity {
        margin-bottom: 0.15rem;
    }

    .tv-event-card__copy {
        min-width: 0;
    }

        .tv-event-card__copy h3 {
            margin: 0;
            font-size: clamp(1rem, 1.15vw, 1.35rem);
            line-height: 1.05;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .tv-event-card__copy p {
            margin: 0.25rem 0 0;
            font-size: clamp(0.72rem, 0.8vw, 0.95rem);
            line-height: 1.25;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

    .tv-event-card__meta {
        align-self: stretch;
        min-width: 86px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-end;
        gap: 0.35rem;
    }

    .tv-event-card__timer {
        font-size: 0.95rem;
        line-height: 1;
        padding: 0.45rem 0.65rem;
    }

    .tv-event-card__reward {
        font-size: clamp(1.4rem, 2.2vw, 2rem);
        line-height: 1;
    }

    .tv-event-card__particles,
    .tv-event-card__scanlines,
    .tv-event-card__edge-glow {
        pointer-events: none;
    }

    @@media (max-width: 720px) {
        .tv-event-card {
            max-height: none;
            grid-template-columns: auto minmax(0, 1fr) auto;
            padding: 0.7rem;
        }

        .tv-event-card__team-coin-shell {
            display: none;
        }

        .tv-event-card__copy h3 {
            white-space: normal;
        }
    }
</style>