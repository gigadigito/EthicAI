@using CriptoVersus.Web.Components.Pages.Internet
@inherits LayoutComponentBase

<div class="app-shell">
    <aside class="app-sidebar">
        <NavMenu />
    </aside>

    <main class="app-main">
        <header class="app-topbar">
            <div>
                <span class="topbar-eyebrow">CriptoVersus Arena</span>
                <h1>Mercado de partidas</h1>
            </div>

            <button class="wallet-button" @onclick="AbrirLoginAsync">
                Login com Solana
            </button>
        </header>

        <article class="app-content">
            @Body
        </article>
    </main>
</div>

<SolanaLoginModal @ref="loginModal" />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">x</a>
</div>

@code {
    private SolanaLoginModal? loginModal;

    private async Task AbrirLoginAsync()
    {
        if (loginModal is not null)
        {
            await loginModal.OpenAsync();
        }
    }
}
