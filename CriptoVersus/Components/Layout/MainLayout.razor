@using CriptoVersus.Web.Components.Pages.Internet
@using CriptoVersus.Web.Services
@inherits LayoutComponentBase
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject WalletSessionState WalletState
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject AppCultureService AppCulture
@inject LocalizationService L
@inject RouteLocalizationService RouteLocalization
@inject PublishedVersionService PublishedVersion
@implements IAsyncDisposable

@if (!ShouldHideInitialLoader)
{
    <InitialBrandLoader IsVisible="_showInitialLoader"
                        Hidden="HandleLoaderHiddenAsync" />
}

@if (IsTvRoute)
{
    <main class="tv-layout-shell">
        @Body
    </main>
}
else
{
<div class="app-shell">
    <input type="hidden"
           id="cv-published-version"
           value="@PublishedVersion.VersionTag"
           data-version-tag="@PublishedVersion.VersionTag"
           data-environment="@PublishedVersion.EnvironmentName"
           data-version="@PublishedVersion.VersionValue"
           data-published-at-utc="@PublishedVersion.PublishedAtUtc" />

    <aside class="app-sidebar">
        <NavMenu />
    </aside>

    <main class="app-main">
        <header class="app-topbar">
            <div>
                <span class="topbar-eyebrow">@L.T("layout.topbar.eyebrow", CurrentCulture)</span>
                <h1>@L.T("layout.topbar.title", CurrentCulture)</h1>
            </div>

            <div class="topbar-tools">
                <div class="language-switcher" role="group" aria-label="@L.T("layout.topbar.language", CurrentCulture)">
                    <button type="button"
                            class="language-switcher__btn @(CurrentCulture == "en" ? "language-switcher__btn--active" : string.Empty)"
                            @onclick='() => ChangeLanguageAsync("en")'>
                        @L.T("layout.topbar.english", CurrentCulture)
                    </button>
                    <button type="button"
                            class="language-switcher__btn @(CurrentCulture == "pt" ? "language-switcher__btn--active" : string.Empty)"
                            @onclick='() => ChangeLanguageAsync("pt")'>
                        @L.T("layout.topbar.portuguese", CurrentCulture)
                    </button>
                </div>

                @if (ShowWalletUi)
                {
                    @if (IsLoggedIn)
                    {
                        <button class="wallet-identity" title="@walletPublicKey" @onclick="AbrirLoginAsync">
                            <img class="wallet-avatar" src="@GetWalletAvatarUrl(walletPublicKey!)" alt="" />
                            <span class="wallet-address">@ShortWallet(walletPublicKey!)</span>
                        </button>
                    }
                    else
                    {
                        <button class="wallet-button" @onclick="AbrirLoginAsync">
                            <span class="wallet-button-label">Connect Wallet</span>
                        </button>
                    }
                }
            </div>
        </header>

        <article class="app-content">
            @Body
        </article>

        @if (IsPublicSeoRoute)
        {
            <footer class="app-footer app-footer--public">
                <p>@L.T("layout.footer.semanticDescription", CurrentCulture)</p>
            </footer>
        }
    </main>
</div>
}

@if (ShowWalletUi)
{
    <SolanaWalletModal @ref="loginModal"
                       OnLoginSucceeded="HandleLoginSucceededAsync"
                       OnSessionChanged="HandleSessionChangedAsync" />
}

@if (_showPostLoginPrompt)
{
    <div class="post-login-overlay" @onclick="StayOnCurrentPage">
        <div class="post-login-dialog" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="post-login-title">
            <span class="post-login-dialog__eyebrow">@PostLoginText("eyebrow")</span>
            <h2 id="post-login-title">@PostLoginText("title")</h2>
            <p>@PostLoginText("body")</p>

            <div class="post-login-dialog__actions">
                <button type="button" class="post-login-dialog__btn post-login-dialog__btn--secondary" @onclick="StayOnCurrentPage">
                    @PostLoginText("stay")
                </button>
                <button type="button" class="post-login-dialog__btn post-login-dialog__btn--primary" @onclick="GoToWalletPage">
                    @PostLoginText("goToWallet")
                </button>
            </div>
        </div>
    </div>
}

@if (_interactiveChromeReady && !IsPublicSeoRoute)
{
    <div id="blazor-error-ui" data-nosnippet>
        An unhandled error has occurred.
        <a href="" class="reload">Reload</a>
        <a class="dismiss">x</a>
    </div>
}

<div id="html5-toast" class="toast-message" style="display:none;" aria-live="polite" aria-atomic="true">
    <span id="html5-toast-text"></span>
</div>

<style>
    .tv-layout-shell {
        min-height: 100vh;
        overflow: hidden;
        background:
            radial-gradient(circle at top left, rgba(83, 200, 255, 0.12), transparent 24%),
            radial-gradient(circle at top right, rgba(76, 243, 141, 0.14), transparent 22%),
            linear-gradient(180deg, #02060f, #050914 52%, #040812);
    }

    .wallet-button-label {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
    }

    .topbar-tools {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .language-switcher {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .language-switcher__btn {
        border: 0;
        background: transparent;
        color: rgba(255,255,255,.72);
        border-radius: 999px;
        padding: .45rem .8rem;
        font-size: .78rem;
        font-weight: 800;
        letter-spacing: .04em;
    }

    .language-switcher__btn--active {
        color: #fff;
        background: rgba(255,255,255,.1);
    }

    .post-login-overlay {
        position: fixed;
        inset: 0;
        z-index: 1200;
        display: grid;
        place-items: center;
        padding: 1rem;
        background: rgba(2, 6, 16, 0.68);
        backdrop-filter: blur(10px);
    }

    .post-login-dialog {
        width: min(100%, 480px);
        padding: 1.4rem;
        border-radius: 24px;
        border: 1px solid rgba(127, 246, 223, 0.18);
        background:
            radial-gradient(circle at top left, rgba(76, 243, 141, 0.12), transparent 28%),
            radial-gradient(circle at top right, rgba(96, 165, 250, 0.1), transparent 26%),
            linear-gradient(180deg, rgba(10, 13, 21, 0.98), rgba(7, 9, 15, 0.99));
        box-shadow: 0 24px 80px rgba(0,0,0,.42);
        color: #eef5ff;
    }

    .post-login-dialog__eyebrow {
        display: block;
        color: #7ff6df;
        font-size: .78rem;
        font-weight: 900;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .post-login-dialog h2 {
        margin: .55rem 0 .45rem;
        font-size: clamp(1.25rem, 2vw, 1.6rem);
        line-height: 1.1;
    }

    .post-login-dialog p {
        margin: 0;
        color: #b9c7da;
        line-height: 1.6;
    }

    .post-login-dialog__actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: .75rem;
        margin-top: 1.15rem;
    }

    .post-login-dialog__btn {
        min-height: 2.9rem;
        padding: .72rem 1rem;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,.12);
        font-weight: 800;
        letter-spacing: .03em;
    }

    .post-login-dialog__btn--secondary {
        color: #eef5ff;
        background: rgba(255,255,255,.04);
    }

    .post-login-dialog__btn--primary {
        color: #03150f;
        background: linear-gradient(90deg, #4cf38d, #7ff6df);
        border-color: rgba(127, 246, 223, 0.35);
    }

    .app-footer--public {
        margin: 0 1.4rem 1.4rem;
        padding: 1rem 1.15rem;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,.08);
        background: rgba(255,255,255,.03);
        color: #b8c7d8;
    }

    .app-footer--public p {
        margin: 0;
        line-height: 1.65;
        font-size: .95rem;
    }

    @@media (max-width: 480px) {
        .post-login-dialog {
            padding: 1.15rem;
            border-radius: 20px;
        }

        .post-login-dialog__actions {
            flex-direction: column-reverse;
        }

        .post-login-dialog__btn {
            width: 100%;
        }

        .app-footer--public {
            margin: 0 1rem 1rem;
        }
    }
</style>

@code {
    private SolanaWalletModal? loginModal;
    private string? authToken;
    private string? walletPublicKey;
    private bool _showInitialLoader = true;
    private readonly DateTime _loaderStartedUtc = DateTime.UtcNow;
    private IJSObjectReference? _walletActionsModule;
    private IJSObjectReference? _cultureModule;
    private IJSObjectReference? _appVersionModule;
    private DotNetObjectReference<MainLayout>? _walletObserverRef;
    private string CurrentCulture => AppCulture.GetCurrentRouteCulture(Nav);
    private bool _interactiveChromeReady;
    private bool _showPostLoginPrompt;
    private bool IsPublicSeoRoute => IsPublicRoute(Nav.Uri);
    private bool IsPublicHomeRoute => IsHomeRoute(Nav.Uri);
    private bool IsTvRoute => IsTvModeRoute(Nav.Uri);
    private bool ShouldHideInitialLoader => IsTvRoute || (IsPublicSeoRoute && !IsPublicHomeRoute);
    private bool ShowWalletUi => _interactiveChromeReady && !IsTvRoute;

    private bool IsLoggedIn
        => !string.IsNullOrWhiteSpace(authToken)
            && !string.IsNullOrWhiteSpace(walletPublicKey);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _interactiveChromeReady = true;

        try
        {
            await LoadLoginSessionAsync();
            await SyncWalletObserverAsync();
            await WarnPublishedVersionAsync();
            StateHasChanged();
        }
        catch (Exception ex) when (InteropSafety.IsDeferredInteropException(ex))
        {
            // SessionStorage depende de JS interop e pode falhar durante o prerender.
            return;
        }

        await HideInitialLoaderWhenReadyAsync();
    }

    private async Task AbrirLoginAsync()
    {
        if (loginModal is not null)
        {
            await loginModal.OpenAsync();
        }
    }

    private async Task ChangeLanguageAsync(string targetCulture)
    {
        _cultureModule ??= await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "./js/culturePreference.js");

        await _cultureModule.InvokeVoidAsync("setPreferredCulture", targetCulture);
        var targetPath = RouteLocalization.BuildLocalizedPathForCurrentPage(targetCulture, Nav.ToBaseRelativePath(Nav.Uri));
        Nav.NavigateTo(targetPath, forceLoad: true);
    }

    private async Task WarnPublishedVersionAsync()
    {
        _appVersionModule ??= await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "./js/appVersion.js");

        await _appVersionModule.InvokeVoidAsync(
            "warnPublishedVersion",
            PublishedVersion.VersionTag);
    }

    private async Task LoadLoginSessionAsync()
    {
        authToken = await SessionStorage.GetItemAsync<string>("authToken");
        walletPublicKey = await SessionStorage.GetItemAsync<string>("walletPublicKey");
        WalletState.SetSession(authToken, walletPublicKey);
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleLoginSucceededAsync()
    {
        await LoadLoginSessionAsync();
        await SyncWalletObserverAsync();
        _showPostLoginPrompt = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleSessionChangedAsync()
    {
        await LoadLoginSessionAsync();
        await SyncWalletObserverAsync();
    }

    private Task StayOnCurrentPage()
    {
        _showPostLoginPrompt = false;
        return InvokeAsync(StateHasChanged);
    }



    private void GoToWalletPage()
    {
        _showPostLoginPrompt = false;
        var culture = AppCulture.GetCurrentRouteCulture(Nav);
        Nav.NavigateTo(RouteLocalization.BuildWalletPath(culture));
    }
    private async Task SyncWalletObserverAsync()
    {
        _walletActionsModule ??= await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "./js/solanaWalletActions.js?v=20260506");

        if (string.IsNullOrWhiteSpace(authToken) || string.IsNullOrWhiteSpace(walletPublicKey))
        {
            await _walletActionsModule.InvokeVoidAsync("unregisterWalletObserver");
            return;
        }

        _walletObserverRef ??= DotNetObjectReference.Create(this);

        await _walletActionsModule.InvokeAsync<bool>(
            "registerWalletObserver",
            _walletObserverRef,
            new
            {
                expectedWallet = walletPublicKey,
                cluster = "session"
            });
    }

    [JSInvokable]
    public async Task HandleWalletProviderSessionChanged(WalletProviderStateChange state)
    {
        if (string.IsNullOrWhiteSpace(authToken) || string.IsNullOrWhiteSpace(walletPublicKey))
            return;

        if (string.Equals(state.status, "connected", StringComparison.OrdinalIgnoreCase))
            return;

        await SessionStorage.RemoveItemAsync("authToken");
        await SessionStorage.RemoveItemAsync("userId");
        await SessionStorage.RemoveItemAsync("walletPublicKey");

        authToken = null;
        walletPublicKey = null;
        _showPostLoginPrompt = false;
        WalletState.SetSession(null, null);

        if (_walletActionsModule is not null)
        {
            await _walletActionsModule.InvokeVoidAsync("unregisterWalletObserver");
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task HideInitialLoaderWhenReadyAsync()
    {
        if (!_showInitialLoader)
            return;

        var elapsed = DateTime.UtcNow - _loaderStartedUtc;
        var remaining = TimeSpan.FromMilliseconds(2400) - elapsed;
        if (remaining > TimeSpan.Zero)
            await Task.Delay(remaining);

        _showInitialLoader = false;
        await InvokeAsync(StateHasChanged);
    }

    private Task HandleLoaderHiddenAsync()
        => Task.CompletedTask;

    private string PostLoginText(string key)
    {
        var isEnglish = string.Equals(CurrentCulture, "en", StringComparison.OrdinalIgnoreCase);

        return key switch
        {
            "eyebrow" => isEnglish ? "Wallet connected" : "Carteira conectada",
            "title" => isEnglish ? "Do you want to open your wallet now?" : "Deseja ir para sua carteira agora?",
            "body" => isEnglish
                ? "Your wallet was connected successfully. You can open My Wallet now or stay on the current page."
                : "Sua carteira foi conectada com sucesso. Voce pode abrir a pagina Minha Carteira agora ou continuar na pagina atual.",
            "stay" => isEnglish ? "Stay on this page" : "Ficar nesta pagina",
            "goToWallet" => isEnglish ? "Go to My Wallet" : "Ir para Minha Carteira",
            _ => key
        };
    }

    private static string GetWalletAvatarUrl(string wallet)
        => $"https://api.dicebear.com/9.x/identicon/svg?seed={Uri.EscapeDataString(wallet)}";

    private static string ShortWallet(string wallet)
    {
        const int start = 8;
        const int end = 6;

        if (wallet.Length <= start + end + 3)
            return wallet;

        return $"{wallet[..start]}...{wallet[^end..]}";
    }

    private static bool IsPublicRoute(string absoluteUri)
    {
        if (!Uri.TryCreate(absoluteUri, UriKind.Absolute, out var uri))
            return true;

        var path = uri.AbsolutePath.TrimEnd('/').ToLowerInvariant();

        if (string.IsNullOrWhiteSpace(path))
            return true;

        return path switch
        {
            "" or "/" or "/en" or "/pt" or "/en/roadmap" or "/pt/roadmap" or "/en/how-it-works" or "/pt/como-funciona" => true,
            _ => path.StartsWith("/en/match/", StringComparison.Ordinal)
                 || path.StartsWith("/pt/partida/", StringComparison.Ordinal)
        };
    }

    private static bool IsHomeRoute(string absoluteUri)
    {
        if (!Uri.TryCreate(absoluteUri, UriKind.Absolute, out var uri))
            return true;

        var path = uri.AbsolutePath.TrimEnd('/').ToLowerInvariant();

        return string.IsNullOrWhiteSpace(path)
            || path is "" or "/" or "/en" or "/pt";
    }

    private static bool IsTvModeRoute(string absoluteUri)
    {
        if (!Uri.TryCreate(absoluteUri, UriKind.Absolute, out var uri))
            return false;

        var path = uri.AbsolutePath.TrimEnd('/').ToLowerInvariant();
        return path == "/tv" || path.StartsWith("/tv/match/", StringComparison.Ordinal);
    }

    public async ValueTask DisposeAsync()
    {
        if (_walletActionsModule is not null)
        {
            try
            {
                await _walletActionsModule.InvokeVoidAsync("unregisterWalletObserver");
            }
            catch
            {
                // Ignora falhas de teardown do observer JS.
            }

            await _walletActionsModule.DisposeAsync();
        }

        if (_appVersionModule is not null)
            await _appVersionModule.DisposeAsync();

        if (_cultureModule is not null)
        {
            await _cultureModule.DisposeAsync();
        }

        _walletObserverRef?.Dispose();
    }

    public sealed class WalletProviderStateChange
    {
        public string? status { get; set; }
        public string? reason { get; set; }
        public string? connectedWallet { get; set; }
        public string? expectedWallet { get; set; }
        public string? cluster { get; set; }
    }
}
