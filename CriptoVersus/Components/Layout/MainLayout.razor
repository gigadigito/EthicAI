@using CriptoVersus.Web.Components.Pages.Internet
@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>

            <button class="btn btn-sm btn-primary" @onclick="AbrirLoginAsync">
                Login com Solana
            </button>

            <p>@debugTexto</p>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<SolanaLoginModal @ref="loginModal" />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private SolanaLoginModal? loginModal;

    @code {
        private string debugTexto = "não clicou";

        private async Task AbrirLoginAsync()
        {
            debugTexto = "clicou";
            StateHasChanged();

            if (loginModal is not null)
            {
                await loginModal.OpenAsync();
            }

          
        }
    }
}