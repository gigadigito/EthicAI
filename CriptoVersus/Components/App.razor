<!DOCTYPE html>
@inject IHttpContextAccessor HttpContextAccessor
@using CriptoVersus.Web.Services
@inject AppCultureService AppCulture
@inject LocalizationService L
<html lang="@AppCulture.ToHtmlLang(AppCulture.DetectPreferredRouteCulture(HttpContextAccessor.HttpContext))">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="CriptoVersus.Web.styles.css" />
    <link rel="apple-touch-icon" sizes="180x180" href="apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="favicon-16x16.png" />
    <link rel="icon" type="image/png" href="favicon.png" />
    <link rel="manifest" href="site.webmanifest" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <meta name="theme-color" content="#3f3c58" />
    <meta charset="utf-8" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-4B737GWQYX"></script>
    <script>
        (function () {
            try {
                var key = 'cv_culture';
                var culture = localStorage.getItem(key);
                if (culture) {
                    document.cookie = key + '=' + encodeURIComponent(culture) + '; path=/; max-age=31536000; SameSite=Lax';
                }
            } catch (e) { }
        })();

        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-4B737GWQYX');
    </script>
@*     <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="/js/dashboardHubWs.js"></script> *@
    <HeadOutlet />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <div id="components-reconnect-modal" class="components-reconnect-hide" data-nosnippet data-reconnect-culture="@ReconnectCulture">
        <div class="cv-reconnect-overlay" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="cv-reconnect-backdrop"></div>
            <div class="cv-reconnect-card">
                <div class="cv-reconnect-card__glow cv-reconnect-card__glow--green"></div>
                <div class="cv-reconnect-card__glow cv-reconnect-card__glow--violet"></div>
                <div class="cv-reconnect-card__eyebrow" data-reconnect-key="eyebrow">@L.T("reconnect.eyebrow", ReconnectCulture)</div>
                <div class="cv-reconnect-card__spinner" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
                <h2 class="cv-reconnect-card__title" data-reconnect-key="title">@L.T("reconnect.title", ReconnectCulture)</h2>
                <p class="cv-reconnect-card__body" data-reconnect-key="connectionLost">@L.T("reconnect.connectionLost", ReconnectCulture)</p>
                <div class="cv-reconnect-card__attempts">
                    <span data-reconnect-key="attempt">@L.T("reconnect.attempt", ReconnectCulture)</span>
                    <strong class="components-reconnect-current-attempt">1</strong>
                    <span data-reconnect-key="of">@L.T("reconnect.of", ReconnectCulture)</span>
                    <strong class="components-reconnect-max-retries">?</strong>
                </div>
                <div class="cv-reconnect-card__status">
                    <span class="cv-reconnect-status cv-reconnect-status--retrying" data-reconnect-key="retrying">@L.T("reconnect.retrying", ReconnectCulture)</span>
                    <span class="cv-reconnect-status cv-reconnect-status--failed" data-reconnect-key="failed">@L.T("reconnect.failed", ReconnectCulture)</span>
                    <span class="cv-reconnect-status cv-reconnect-status--rejected" data-reconnect-key="rejected">@L.T("reconnect.rejected", ReconnectCulture)</span>
                    <span class="cv-reconnect-status cv-reconnect-status--paused" data-reconnect-key="paused">@L.T("reconnect.paused", ReconnectCulture)</span>
                </div>
                <button type="button"
                        class="cv-reconnect-card__button"
                        onclick="window.location.reload()">
                    @L.T("reconnect.reload", ReconnectCulture)
                </button>
            </div>
        </div>
    </div>
    <script src="/js/solanaweb3.js?v=20260506"></script>
    <script src="/js/solanaWalletInterop.js?v=20260511"></script>
    <script src="/js/userTime.js"></script>
    <script src="/js/toast.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/echarts@5.6.0/dist/echarts.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
    <script src="/js/tvNarrationAnimations.js?v=20260514"></script>
    <script src="/js/tvReplayEngine.js?v=20260521-1"></script>
    <script src="/js/criptoversus-stats-charts.js"></script>
    <script src="/js/tokenomicsCharts.js"></script>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>
    <script src="/js/communityMatchModal.js?v=20260717" defer></script>
    <script src="_framework/blazor.web.js"></script>
    <script src="/js/blazor-reconnect.js"></script>

   
    <script type="module" src="/js/dist/interop/blazor.js"></script>


</body>

@code {
    private string ReconnectCulture => AppCulture.DetectPreferredRouteCulture(HttpContextAccessor.HttpContext);
}

</html>


