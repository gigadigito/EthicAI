    private void ApplyDateFilters()
    {
        _filters.CreatedAfterUtc = ParseDate(_createdAfterText, false);
        _filters.CreatedBeforeUtc = ParseDate(_createdBeforeText, true);
    }

    private string BuildQueryString()
    {
        var query = new List<string>();
        AddQuery(query, "eventType", _filters.EventType);
        AddQuery(query, "language", _filters.Language);
        AddQuery(query, "teamSymbol", _filters.TeamSymbol);
        AddQuery(query, "normalizedSymbol", _filters.NormalizedSymbol);
        AddQuery(query, "teamName", _filters.TeamName);
        AddQuery(query, "status", _filters.Status);
        AddQuery(query, "containsText", _filters.ContainsText);
        if (_filters.CreatedAfterUtc.HasValue)
        {
            AddQuery(query, "createdAfterUtc", _filters.CreatedAfterUtc.Value.ToString("O"));
        }
        if (_filters.CreatedBeforeUtc.HasValue)
        {
            AddQuery(query, "createdBeforeUtc", _filters.CreatedBeforeUtc.Value.ToString("O"));
        }
        if (_filters.SuspectsOnly == true)
        {
            AddQuery(query, "suspectsOnly", "true");
        }
        AddQuery(query, "sortBy", _filters.SortBy);
        AddQuery(query, "sortDirection", _filters.SortDirection);
        AddQuery(query, "page", _filters.Page.ToString());
        AddQuery(query, "pageSize", _filters.PageSize.ToString());
        return query.Count == 0 ? string.Empty : $"?{string.Join("&", query)}";
    }

    private void ChangeSort(string sortBy)
    {
        if (string.Equals(_filters.SortBy, sortBy, StringComparison.OrdinalIgnoreCase))
        {
            _filters.SortDirection = string.Equals(_filters.SortDirection, "asc", StringComparison.OrdinalIgnoreCase) ? "desc" : "asc";
        }
        else
        {
            _filters.SortBy = sortBy;
            _filters.SortDirection = "desc";
        }

        _filters.Page = 1;
        _ = LoadAllAsync();
    }

    private bool IsSortedBy(string sortBy) => string.Equals(_filters.SortBy, sortBy, StringComparison.OrdinalIgnoreCase);

    private string SortIndicator(string sortBy)
    {
        if (!IsSortedBy(sortBy))
        {
            return " ";
        }

        return string.Equals(_filters.SortDirection, "asc", StringComparison.OrdinalIgnoreCase) ? "↑" : "↓";
    }

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((_assets.TotalCount <= 0 ? 1 : _assets.TotalCount) / (double)Math.Max(1, _filters.PageSize)));

    private async Task GoToPageAsync(int page)
    {
        var targetPage = Math.Clamp(page, 1, TotalPages);
        if (targetPage == _filters.Page)
        {
            return;
        }

        _filters.Page = targetPage;
        await LoadAllAsync();
    }

    private async Task ChangePageSizeAsync(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var parsed))
        {
            return;
        }

        _filters.PageSize = Math.Clamp(parsed, 10, 200);
        _filters.Page = 1;
        await LoadAllAsync();
    }

