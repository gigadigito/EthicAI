    private static void AddQuery(List<string> query, string key, string? value)
    {
        if (!string.IsNullOrWhiteSpace(value))
        {
            query.Add($"{Uri.EscapeDataString(key)}={Uri.EscapeDataString(value)}");
        }
    }

    private static DateTime? ParseDate(string? raw, bool endOfDay)
    {
        if (!DateTime.TryParse(raw, out var parsed))
        {
            return null;
        }

        return endOfDay ? parsed.Date.AddDays(1).AddTicks(-1) : parsed.Date;
    }

    private static bool IsConfiguredWallet(string? wallet, string? configuredWallet) =>
        !string.IsNullOrWhiteSpace(wallet) && !string.IsNullOrWhiteSpace(configuredWallet) && string.Equals(wallet, configuredWallet, StringComparison.Ordinal);

