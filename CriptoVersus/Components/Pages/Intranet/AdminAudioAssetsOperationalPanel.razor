                OverrideTextPrompt = asset.TextPrompt
            });
            _feedback = result is null ? $"Regeneracao do asset {asset.Id} enviada sem retorno." : $"Regeneracao enviada. JobId={result.JobId}.";
        }
        catch (Exception ex)
        {
            _error = $"Falha ao regenerar asset {asset.Id}: {ex.Message}";
        }
    }

