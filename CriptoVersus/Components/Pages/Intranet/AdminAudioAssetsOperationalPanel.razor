    private async Task PreviewNarrativeAsync()
    {
        _testPreview = await Api.PostAudioResolveTestAsync(BuildResolvePreviewRequest());
        if (!string.IsNullOrWhiteSpace(_testPreview?.Request?.TextPrompt) && string.IsNullOrWhiteSpace(_testLab.OverrideTextPrompt))
        {
            _testLab.OverrideTextPrompt = _testPreview.Request.TextPrompt;
        }
    }

    private async Task GenerateTestAudioAsync()
    {
        _generatingTestAudio = true;

        try
        {
            if (string.IsNullOrWhiteSpace(_testLab.OverrideTextPrompt))
            {
                await PreviewNarrativeAsync();
            }

            var request = CloneTestRequest(_testLab);
            var response = await Api.GenerateTestAudioAsync(request);
            _lastGenerateRequest = CloneTestRequest(request);
            _currentTestJobId = response?.JobId;
            _currentTestStatus = "pending";

            if (_currentTestJobId.HasValue)
            {
                await PollTestStatusAsync(_currentTestJobId.Value);
            }
        }
        catch (Exception ex)
        {
            _error = $"Falha ao gerar audio de teste: {ex.Message}";
        }
        finally
        {
            _generatingTestAudio = false;
        }
    }

    private async Task RegenerateTestAudioAsync()
    {
        if (_lastGenerateRequest is null)
        {
            return;
        }

        _testLab = CloneTestRequest(_lastGenerateRequest);
        await GenerateTestAudioAsync();
    }

    private async Task PollTestStatusAsync(long jobId)
    {
        for (var i = 0; i < 20; i++)
        {
            await Task.Delay(2000);
            var status = await Api.GetTestAudioStatusAsync(jobId);
            if (status is null)
            {
                continue;
            }

            _currentTestStatus = status.Status;
            _currentTestTeamName = status.TeamName;

            if (string.Equals(status.Status, "completed", StringComparison.OrdinalIgnoreCase) && !string.IsNullOrWhiteSpace(status.AudioUrl))
            {
                _currentTestAudioUrl = status.AudioUrl;
                _testLab.OverrideTextPrompt = status.TextPrompt;
                _testRuns.Insert(0, new TestRunViewModel
                {
                    JobId = status.JobId,
                    AudioUrl = status.AudioUrl,
                    TextPrompt = status.TextPrompt,
                    TeamName = status.TeamName,
                    VoiceKey = _testLab.VoiceKey,
                    Intensity = _testLab.Intensity
                });
                await ApplyVolumeAsync();
                return;
            }

            if (string.Equals(status.Status, "failed", StringComparison.OrdinalIgnoreCase))
            {
                _error = $"Job de teste falhou: {status.ErrorMessage}";
                return;
            }
        }

        _feedback = "Polling encerrado antes da conclusao do teste.";
    }

    private async Task QueueRegenerationAsync(AudioAssetAdminListItemDto asset)
    {
