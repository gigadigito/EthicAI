@using CriptoVersus.Web.Services
@using DTOs
@using Microsoft.JSInterop
@inject CriptoVersusApiClient Api
@inject WalletSessionState WalletState
@inject IConfiguration Config
@inject IJSRuntime JS
@implements IDisposable
@implements IAsyncDisposable

@if (!IsAdminWallet)
{
    <div class="alert alert-danger">Esta area esta disponivel apenas para a carteira admin.</div>
}
else
{
    @if (_loading)
    {
        <div class="alert alert-info">Carregando diagnostico de audio...</div>
    }
    @if (!string.IsNullOrWhiteSpace(_feedback))
    {
        <div class="alert alert-success">@_feedback</div>
    }
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <strong>Filtros e Acoes</strong>
            <div class="btn-group btn-group-sm">
                <button class="btn btn-primary" @onclick="LoadAllAsync" disabled="@_loading">Atualizar</button>
                <button class="btn btn-outline-secondary" @onclick="RunSuspectDryRunAsync">Dry-run suspeitos</button>
                <button class="btn btn-outline-warning" @onclick="DisableSuspectsAsync">Disable suspeitos</button>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-2"><input class="form-control form-control-sm" placeholder="Event" @bind="_filters.EventType" /></div>
                <div class="col-md-2"><input class="form-control form-control-sm" placeholder="Language" @bind="_filters.Language" /></div>
                <div class="col-md-2"><input class="form-control form-control-sm" placeholder="TeamSymbol" @bind="_filters.TeamSymbol" /></div>
                <div class="col-md-2"><input class="form-control form-control-sm" placeholder="NormalizedSymbol" @bind="_filters.NormalizedSymbol" /></div>
                <div class="col-md-2"><input class="form-control form-control-sm" placeholder="TeamName" @bind="_filters.TeamName" /></div>
                <div class="col-md-2">
                    <select class="form-select form-select-sm" @bind="_filters.Status">
                        <option value="">Todos</option>
                        <option value="ready">ready</option>
                        <option value="disabled">disabled</option>
                        <option value="deprecated">deprecated</option>
                    </select>
                </div>
                <div class="col-md-4"><input class="form-control form-control-sm" placeholder="Texto contem" @bind="_filters.ContainsText" @bind:event="oninput" /></div>
                <div class="col-md-2"><input class="form-control form-control-sm" type="date" value="@_createdAfterText" @onchange="e => _createdAfterText = e.Value?.ToString() ?? string.Empty" /></div>
                <div class="col-md-2"><input class="form-control form-control-sm" type="date" value="@_createdBeforeText" @onchange="e => _createdBeforeText = e.Value?.ToString() ?? string.Empty" /></div>
                <div class="col-md-2 d-flex align-items-center">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" @bind="_filters.SuspectsOnly" id="audioAssetsSuspectsOnly" />
                        <label class="form-check-label" for="audioAssetsSuspectsOnly">Somente suspeitos</label>
                    </div>
                </div>
            </div>
            <div class="mt-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                <div>
                    <span class="me-3">Assets filtrados: <strong>@_assets.TotalCount</strong></span>
                    <span>Selecionados: <strong>@_selectedAssetIds.Count</strong></span>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleSelectAllVisible">Selecionar Todos</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="SelectVisibleAssets">Selecionar pagina</button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ClearSelection">Limpar selecao</button>
                    <button class="btn btn-outline-warning btn-sm" @onclick="BulkDisableAsync" disabled="@(_selectedAssetIds.Count == 0)">Desabilitar selecionados</button>
                    <button class="btn btn-outline-danger btn-sm" @onclick="BulkDeleteAsync" disabled="@(_selectedAssetIds.Count == 0)">Excluir selecionados</button>
                    <button class="btn btn-danger btn-sm" @onclick="DeleteOrphanRecordsAsync" disabled="@(_assets.Summary.TotalOrphans == 0)">Excluir todos os orfaos</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><strong>Resumo</strong></div>
        <div class="card-body">
            <div class="row row-cols-1 row-cols-md-3 row-cols-xl-6 g-3">
                <div class="col"><div class="border rounded p-2 h-100"><div class="small text-muted">Assets banco</div><div class="fw-bold">@_assets.Summary.TotalAssetsInDatabase</div></div></div>
                <div class="col"><div class="border rounded p-2 h-100"><div class="small text-muted">Arquivos fisicos</div><div class="fw-bold">@_assets.Summary.TotalPhysicalFiles</div></div></div>
                <div class="col"><div class="border rounded p-2 h-100"><div class="small text-muted">Orfaos</div><div class="fw-bold text-danger">@_assets.Summary.TotalOrphans</div></div></div>
                <div class="col"><div class="border rounded p-2 h-100"><div class="small text-muted">Disabled</div><div class="fw-bold">@_assets.Summary.TotalDisabled</div></div></div>
                <div class="col"><div class="border rounded p-2 h-100"><div class="small text-muted">Ready</div><div class="fw-bold">@_assets.Summary.TotalReady</div></div></div>
                <div class="col"><div class="border rounded p-2 h-100"><div class="small text-muted">Diretorio audio</div><div class="fw-bold">@FormatBytes(_assets.Summary.TotalDirectoryBytes)</div></div></div>
            </div>
            <div class="mt-3 small"><strong>Audio root:</strong> @_filesystem.AudioRootPath</div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Filesystem Audio Directory</strong>
            <span class="small text-muted">@_filesystem.TotalFiles arquivos</span>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-bordered align-middle admin-audio-table">
                    <thead>
                        <tr>
                            <th>FileName</th>
                            <th>Exists</th>
                            <th>Size</th>
                            <th>LastModifiedUtc</th>
                            <th>Paths</th>
                            <th>Playback</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_filesystem.Items.Count == 0)
                        {
                            <tr><td colspan="6" class="text-center text-muted">Nenhum arquivo encontrado no filesystem publicado.</td></tr>
                        }
                        else
                        {
                            @foreach (var file in _filesystem.Items)
                            {
                                <tr>
                                    <td>@file.FileName</td>
                                    <td>
                                        @if (file.Exists)
                                        {
                                            <span class="badge text-bg-success">PLAYABLE</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-danger">MISSING FILE</span>
                                        }
                                    </td>
                                    <td>@FormatBytes(file.SizeBytes)</td>
                                    <td>@FormatDate(file.LastModifiedUtc)</td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <button class="btn btn-outline-light icon-button" title="@file.PublicUrl" @onclick='() => CopyValueAsync(file.PublicUrl, "URL publica")'><i class="bi bi-globe2"></i></button>
                                            <button class="btn btn-outline-light icon-button" title="@file.RelativePath" @onclick='() => CopyValueAsync(file.RelativePath, "Relative path")'><i class="bi bi-folder2-open"></i></button>
                                            <button class="btn btn-outline-light icon-button" title="@file.FullPath" @onclick='() => CopyValueAsync(file.FullPath, "Path fisico")'><i class="bi bi-hdd-stack"></i></button>
                                            <button class="btn btn-outline-info icon-button" title="Abrir URL publica" @onclick='() => OpenUrlAsync(file.PublicUrl)' disabled="@(!file.Exists)"><i class="bi bi-box-arrow-up-right"></i></button>
                                        </div>
                                    </td>
                                    <td style="min-width:260px">
                                        @if (file.Exists)
                                        {
                                            var fileAudioId = GetFilesystemAudioElementId(file.RelativePath);
                                            <div class="d-flex flex-wrap gap-1 align-items-center">
                                                <button class="btn btn-outline-success btn-sm" @onclick='() => PlayAudioByIdAsync(fileAudioId)'>Play</button>
                                                <button class="btn btn-outline-secondary btn-sm" @onclick='() => StopAudioByIdAsync(fileAudioId)'>Stop</button>
                                                <audio id="@fileAudioId" controls preload="metadata" src="@file.PublicUrl"></audio>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-danger">ORPHAN</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Audio Assets Database</strong>
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <select class="form-select form-select-sm page-size-select" value="@_filters.PageSize" @onchange="ChangePageSizeAsync">
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                </select>
                <span class="small text-muted">@(_loading ? "Carregando..." : $"{_assets.Items.Count} itens na pagina / {_assets.TotalCount} total")</span>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm table-bordered align-middle admin-audio-table">
                    <thead>
                        <tr>
                            <th><input class="form-check-input" type="checkbox" checked="@(!AnyUnselectedVisible() && _assets.Items.Count > 0)" @onchange="_ => ToggleSelectAllVisible()" /></th>
                            <th><button class="btn btn-link table-sort" @onclick='() => ChangeSort("id")'>Id @SortIndicator("id")</button></th>
                            <th><button class="btn btn-link table-sort" @onclick='() => ChangeSort("status")'>Status @SortIndicator("status")</button></th>
                            <th><button class="btn btn-link table-sort" @onclick='() => ChangeSort("event")'>Event @SortIndicator("event")</button></th>
                            <th><button class="btn btn-link table-sort" @onclick='() => ChangeSort("language")'>Language @SortIndicator("language")</button></th>
                            <th><button class="btn btn-link table-sort" @onclick='() => ChangeSort("rawsymbol")'>RawSymbol @SortIndicator("rawsymbol")</button></th>
                            <th><button class="btn btn-link table-sort" @onclick='() => ChangeSort("normalizedsymbol")'>NormalizedSymbol @SortIndicator("normalizedsymbol")</button></th>
                            <th><button class="btn btn-link table-sort" @onclick='() => ChangeSort("teamname")'>TeamName @SortIndicator("teamname")</button></th>
                            <th>FileExists</th>
                            <th>PublicUrlValid</th>
                            <th>IsOrphan</th>
                            <th><button class="btn btn-link table-sort" @onclick='() => ChangeSort("usagecount")'>UsageCount @SortIndicator("usagecount")</button></th>
                            <th><button class="btn btn-link table-sort" @onclick='() => ChangeSort("createdat")'>CreatedAt @SortIndicator("createdat")</button></th>
                            <th>Duration</th>
                            <th>Paths</th>
                            <th>Playback</th>
                            <th>TextPrompt</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_assets.Items.Count == 0)
                        {
                            <tr><td colspan="18" class="text-center text-muted">Nenhum registro encontrado no banco.</td></tr>
                        }
                        else
                        {
                            @foreach (var asset in _assets.Items)
                            {
                                <tr class="@GetRowClass(asset)">
                                    <td><input class="form-check-input" type="checkbox" checked="@_selectedAssetIds.Contains(asset.Id)" @onchange="args => ToggleSelection(asset.Id, args.Value)" /></td>
                                    <td>@asset.Id</td>
                                    <td>
                                        <div class="d-flex flex-wrap gap-1">
                                            <span class="@GetStatusBadgeClass(asset.Status)">@asset.Status</span>
                                            @if (asset.IsSuspect){<span class="badge text-bg-warning">SUSPECT</span>}
                                            @if (asset.IsOrphan){<span class="badge text-bg-danger">ORPHAN</span>}
                                            @if (!asset.HasPhysicalFile){<span class="badge text-bg-danger">MISSING FILE</span>}
                                            @if (!asset.PublicUrlValid){<span class="badge text-bg-dark">INVALID URL</span>}
                                            @if (string.Equals(asset.Status, "ready", StringComparison.OrdinalIgnoreCase)){<span class="badge text-bg-success">READY</span>}
                                            @if (string.Equals(asset.Status, "disabled", StringComparison.OrdinalIgnoreCase)){<span class="badge text-bg-secondary">DISABLED</span>}
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(asset.OrphanReason))
                                        {
                                            <div class="small text-danger mt-1">@asset.OrphanReason</div>
                                        }
                                    </td>
                                    <td>@asset.EventType</td>
                                    <td>@asset.Language</td>
                                    <td>@asset.RawSymbol</td>
                                    <td>@asset.NormalizedSymbol</td>
                                    <td>
                                        <div>@asset.TeamName</div>
                                        <div class="small text-muted">@asset.TeamSymbol</div>
                                    </td>
                                    <td>@(asset.HasPhysicalFile ? "yes" : "no")</td>
                                    <td>@(asset.PublicUrlValid ? "yes" : "no")</td>
                                    <td>@(asset.IsOrphan ? "yes" : "no")</td>
                                    <td>@asset.UsageCount</td>
                                    <td>@FormatDate(asset.CreatedAtUtc)</td>
                                    <td>@FormatDuration(asset.DurationMs)</td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <button class="btn btn-outline-light icon-button" title="@asset.ResolvedAudioUrl" @onclick='() => CopyValueAsync(asset.ResolvedAudioUrl, "URL publica")' disabled="@string.IsNullOrWhiteSpace(asset.ResolvedAudioUrl)"><i class="bi bi-globe2"></i></button>
                                            <button class="btn btn-outline-light icon-button" title="@asset.RelativePath" @onclick='() => CopyValueAsync(asset.RelativePath, "Relative path")' disabled="@string.IsNullOrWhiteSpace(asset.RelativePath)"><i class="bi bi-folder2-open"></i></button>
                                            <button class="btn btn-outline-light icon-button" title="@asset.PhysicalPath" @onclick='() => CopyValueAsync(asset.PhysicalPath, "Path fisico")' disabled="@string.IsNullOrWhiteSpace(asset.PhysicalPath)"><i class="bi bi-hdd-stack"></i></button>
                                            <button class="btn btn-outline-info icon-button" title="Abrir URL publica" @onclick='() => OpenUrlAsync(asset.ResolvedAudioUrl)' disabled="@(!asset.PublicUrlValid)"><i class="bi bi-box-arrow-up-right"></i></button>
                                        </div>
                                    </td>
                                    <td style="min-width:260px">
                                        @if (asset.PublicUrlValid)
                                        {
                                            var assetAudioId = GetAssetAudioElementId(asset.Id);
                                            <div class="d-flex flex-wrap gap-1 align-items-center">
                                                <button class="btn btn-outline-success btn-sm" @onclick='() => PlayAudioByIdAsync(assetAudioId)'>Play</button>
                                                <button class="btn btn-outline-secondary btn-sm" @onclick='() => StopAudioByIdAsync(assetAudioId)'>Stop</button>
                                                <audio id="@assetAudioId" controls preload="metadata" src="@asset.ResolvedAudioUrl"></audio>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex flex-wrap gap-1">
                                                <span class="badge text-bg-danger">MISSING FILE</span>
                                                <span class="badge text-bg-dark">INVALID URL</span>
                                            </div>
                                        }
                                    </td>
                                    <td class="text-break">
                                        <div>@Truncate(asset.TextPrompt, 180)</div>
                                        @if (asset.IsSuspect && asset.SuspectRules.Count > 0)
                                        {
                                            <div class="small text-warning mt-1">@string.Join(", ", asset.SuspectRules)</div>
                                        }
                                    </td>
                                    <td style="min-width:320px">
                                        <div class="d-flex flex-wrap gap-1 mb-2">
                                            <button class="btn btn-outline-warning btn-sm" @onclick="() => DisableAssetAsync(asset.Id)">Disable</button>
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteRecordAsync(asset.Id)">Delete Record</button>
                                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteFileAndRecordAsync(asset.Id)">Delete File + Record</button>
                                            <button class="btn btn-outline-dark btn-sm" @onclick="() => QueueRegenerationAsync(asset)">Regenerate</button>
                                        </div>
                                        <div class="small text-muted">@asset.FileName</div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
                <div class="small text-muted">Pagina @_filters.Page de @TotalPages</div>
                <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-light" @onclick="() => GoToPageAsync(1)" disabled="@(_filters.Page <= 1)">Primeira</button>
                    <button class="btn btn-outline-light" @onclick="() => GoToPageAsync(_filters.Page - 1)" disabled="@(_filters.Page <= 1)">Anterior</button>
                    <button class="btn btn-outline-light" @onclick="() => GoToPageAsync(_filters.Page + 1)" disabled="@(_filters.Page >= TotalPages)">Proxima</button>
                    <button class="btn btn-outline-light" @onclick="() => GoToPageAsync(TotalPages)" disabled="@(_filters.Page >= TotalPages)">Ultima</button>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Audio Test Lab</strong>
            <span class="small text-muted">Assets de teste saem como <code>manual_test</code></span>
        </div>
        <div class="card-body">
            <div class="row g-2 mb-3">
                <div class="col-md-3"><label class="form-label small">Event type</label><input class="form-control form-control-sm" @bind="_testLab.EventType" /></div>
                <div class="col-md-2"><label class="form-label small">Language</label><select class="form-select form-select-sm" @bind="_testLab.Language"><option value="pt-BR">pt-BR</option><option value="en-US">en-US</option></select></div>
                <div class="col-md-2"><label class="form-label small">Team symbol</label><input class="form-control form-control-sm" @bind="_testLab.TeamSymbol" /></div>
                <div class="col-md-3"><label class="form-label small">Team name</label><input class="form-control form-control-sm" @bind="_testLab.TeamName" /></div>
                <div class="col-md-2"><label class="form-label small">Context key</label><input class="form-control form-control-sm" @bind="_testLab.ContextKey" /></div>
                <div class="col-md-2"><label class="form-label small">Intensity</label><input class="form-control form-control-sm" @bind="_testLab.Intensity" /></div>
                <div class="col-md-3"><label class="form-label small">Voice key</label><input class="form-control form-control-sm" @bind="_testLab.VoiceKey" /></div>
                <div class="col-md-3"><label class="form-label small">Volume</label><input class="form-range" type="range" min="0" max="100" step="1" value="@_testVolumePercent" @oninput="OnVolumeChanged" /></div>
            </div>
            <div class="d-flex flex-wrap gap-2 mb-3">
                <button class="btn btn-outline-secondary btn-sm" @onclick="PreviewNarrativeAsync">Resolver narrativa</button>
                <button class="btn btn-primary btn-sm" @onclick="GenerateTestAudioAsync" disabled="@_generatingTestAudio">Generate Test Audio</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="PlayTestAudioAsync" disabled="@string.IsNullOrWhiteSpace(_currentTestAudioUrl)">Play Test Audio</button>
                <button class="btn btn-outline-secondary btn-sm" @onclick="StopTestAudioAsync">Stop</button>
                <button class="btn btn-outline-dark btn-sm" @onclick="RegenerateTestAudioAsync" disabled="@(_lastGenerateRequest is null)">Regenerar</button>
            </div>
            <div class="mb-3">
                <label class="form-label small">Text prompt final</label>
                <textarea class="form-control form-control-sm" rows="5" @bind="_testLab.OverrideTextPrompt"></textarea>
            </div>
            @if (_testPreview is not null)
            {
                <div class="table-responsive mb-3">
                    <table class="table table-sm table-bordered align-middle">
                        <tbody>
                            <tr><th class="table-light">Team</th><td>@_testPreview.Request?.TeamName</td><th class="table-light">Resolved language</th><td>@_testPreview.ResolvedLanguage</td></tr>
                            <tr><th class="table-light">Score</th><td>@_testPreview.SpecificityScore</td><th class="table-light">Candidates</th><td>@_testPreview.CandidateCount</td></tr>
                        </tbody>
                    </table>
                </div>
            }
            @if (!string.IsNullOrWhiteSpace(_currentTestAudioUrl))
            {
                <div class="mb-3">
                    <audio controls src="@_currentTestAudioUrl" @ref="_testAudioElement"></audio>
                    <div class="small text-muted mt-2">Job: @_currentTestJobId | Status: @_currentTestStatus | Team: @_currentTestTeamName</div>
                </div>
            }
            @if (_testRuns.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped table-bordered align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Job</th>
                                <th>Voice</th>
                                <th>Intensity</th>
                                <th>Team</th>
                                <th>Audio</th>
                                <th>Prompt</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var run in _testRuns)
                            {
                                <tr>
                                    <td>@run.JobId</td>
                                    <td>@run.VoiceKey</td>
                                    <td>@run.Intensity</td>
                                    <td>@run.TeamName</td>
                                    <td style="min-width:220px"><audio controls preload="none" src="@run.AudioUrl"></audio></td>
                                    <td class="text-break">@run.TextPrompt</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@code {
    private readonly AudioAssetAdminQueryDto _filters = new() { PageSize = 100 };
    private readonly List<TestRunViewModel> _testRuns = [];
    private readonly HashSet<long> _selectedAssetIds = [];
    private AudioAssetAdminListResponseDto _assets = new();
    private AudioAssetFilesystemResponseDto _filesystem = new();
    private AudioAssetTestGenerateRequestDto _testLab = new() { EventType = "goal", Language = "pt-BR", TeamSymbol = "BTCUSDT", ContextKey = "pump", Intensity = "hype", VoiceKey = "narrator_pt_br" };
    private AudioAssetTestGenerateRequestDto? _lastGenerateRequest;
    private AudioResolveDiagnosticPreviewDto? _testPreview;
    private string _createdAfterText = string.Empty;
    private string _createdBeforeText = string.Empty;
    private string? _feedback;
    private string? _error;
    private bool _loading = true;
    private bool _generatingTestAudio;
    private long? _currentTestJobId;
    private string? _currentTestAudioUrl;
    private string? _currentTestStatus;
    private string? _currentTestTeamName;
    private int _testVolumePercent = 100;
    private ElementReference _testAudioElement;
    private IJSObjectReference? _audioModule;
    private bool IsAdminWallet => IsConfiguredWallet(WalletState.WalletPublicKey, Config["CriptoVersus:AdminWallet"]) || IsConfiguredWallet(WalletState.WalletPublicKey, Config["OnChainBetting:AuthorityWallet"]);

    protected override void OnInitialized() => WalletState.Changed += OnWalletStateChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !IsAdminWallet)
        {
            return;
        }

        _audioModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/adminAudioAssets.js?v=20260605-audio-admin-debug");
        await LoadAllAsync();
    }

    private async Task LoadAllAsync()
    {
        _loading = true;
        _error = null;
        _feedback = null;
        ApplyDateFilters();

        try
        {
            _assets = await Api.GetAudioAssetsAsync(BuildQueryString()) ?? new AudioAssetAdminListResponseDto();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            _error = "Sessao admin nao autenticada na API. Reconecte a wallet admin para carregar o diagnostico.";
        }
        catch (Exception ex)
        {
            _error = $"Nao foi possivel carregar a tabela do banco de audio: {ex.Message}";
        }

        try
        {
            _filesystem = await Api.GetAudioAssetFilesystemAsync() ?? new AudioAssetFilesystemResponseDto();
        }
        catch (Exception ex)
        {
            _filesystem = new AudioAssetFilesystemResponseDto();
            _error = string.IsNullOrWhiteSpace(_error)
                ? $"Nao foi possivel carregar o diagnostico de filesystem: {ex.Message}"
                : $"{_error} | Filesystem indisponivel: {ex.Message}";
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

