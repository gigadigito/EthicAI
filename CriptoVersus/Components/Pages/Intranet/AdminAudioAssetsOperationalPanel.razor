    private async Task<bool> ConfirmAsync(string message) => await JS.InvokeAsync<bool>("confirm", message);

    private static string FormatBytes(long? bytes)
    {
        var value = bytes ?? 0;
        string[] units = ["B", "KB", "MB", "GB"];
        double size = value;
        var unitIndex = 0;
        while (size >= 1024 && unitIndex < units.Length - 1)
        {
            size /= 1024;
            unitIndex++;
        }

        return $"{size:0.##} {units[unitIndex]}";
    }

    private static string FormatDate(DateTime? value) => value.HasValue ? value.Value.ToString("yyyy-MM-dd HH:mm:ss 'UTC'") : "unknown";

    private static string FormatDuration(int? durationMs)
    {
        if (!durationMs.HasValue || durationMs.Value <= 0)
        {
            return "unknown";
        }

        var timeSpan = TimeSpan.FromMilliseconds(durationMs.Value);
        return timeSpan.TotalHours >= 1 ? timeSpan.ToString(@"hh\:mm\:ss") : timeSpan.ToString(@"mm\:ss");
    }

    private static string Truncate(string? value, int maxLength)
    {
        if (string.IsNullOrWhiteSpace(value) || value.Length <= maxLength)
        {
            return value ?? string.Empty;
        }

        return value[..maxLength] + "...";
    }

    private string GetRowClass(AudioAssetAdminListItemDto asset)
    {
        if (asset.IsOrphan || !asset.HasPhysicalFile || !asset.PublicUrlValid)
        {
            return "table-danger";
        }

        if (string.Equals(asset.Status, "disabled", StringComparison.OrdinalIgnoreCase))
        {
            return "table-secondary";
        }

        if (asset.IsSuspect)
        {
            return "table-warning";
        }

        return string.Empty;
    }

    private static string GetStatusBadgeClass(string? status)
    {
        if (string.Equals(status, "ready", StringComparison.OrdinalIgnoreCase))
        {
            return "badge text-bg-success";
        }

        if (string.Equals(status, "disabled", StringComparison.OrdinalIgnoreCase))
        {
            return "badge text-bg-secondary";
        }

        return "badge text-bg-light";
    }

