@using System.Net.Http
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Text.Json
@using DTOs
@using CriptoVersus.Web.Services
@inject DashboardHubClient HubClient
@inject HttpClient Http
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject IJSRuntime JS
@inject IConfiguration Config

@if (Snapshot is null)
{
    <div class="alert alert-warning">Sem dados do snapshot.</div>
}
else
{
    <!-- Seleção de usuário para investimento -->
    @if (IsPrivilegedWallet)
    {
        <div class="card mb-3">
            <div class="card-header">
                <strong>Usuário do investimento</strong>
            </div>
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-md-6 col-lg-4">
                        <label for="betUserSelect" class="form-label">Escolha o usuário</label>
                        <select id="betUserSelect" class="form-select" @bind="SelectedUserId">
                            @foreach (var user in BettingUsers)
                            {
                                <option value="@user.Id">@user.DisplayName</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6 col-lg-4">
                        <div class="text-muted small">
                            Usuário selecionado:
                        </div>
                        <div class="fw-bold">
                            @SelectedUserDisplay
                        </div>
                    </div>

                    <div class="col-md-6 col-lg-4">
                        <div class="text-muted small">
                            Valor fixo do investimento:
                        </div>
                        <div class="fw-bold">
                            @TestAmount
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Cards: Matches -->
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <div class="text-muted">Pendentes</div>
                    <div class="fs-2 fw-bold">@Snapshot.Matches.Pending</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <div class="text-muted">Em andamento</div>
                    <div class="fs-2 fw-bold">@Snapshot.Matches.Ongoing</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <div class="text-muted">Finalizadas (24h)</div>
                    <div class="fs-2 fw-bold">@Snapshot.Matches.CompletedLast24h</div>
                </div>
            </div>
        </div>

        @if (IsPrivilegedWallet)
        {
            <div class="col-12">
                <div class="text-muted small">
                    HubState: @HubClient.State |
                    ConnId: @HubClient.ConnectionId |
                    Events: @EventCount |
                    Reloads: @ReloadCount |
                    LastReload: @LastReloadLocal.ToString("HH:mm:ss")
                </div>
            </div>
        }
    </div>

    <!-- Worker -->
    @if (IsPrivilegedWallet)
    {
        <div class="card mb-3">
            <div class="card-header d-flex align-items-center justify-content-between">
                <div>
                    <strong>@Snapshot.Worker.ServiceName</strong>
                    <span class="badge ms-2 @(Snapshot.Worker.IsAlive ? "bg-success" : "bg-danger")">
                        @(Snapshot.Worker.IsAlive ? "ONLINE" : "OFFLINE")
                    </span>
                </div>

                <button class="btn btn-sm btn-outline-primary" @onclick="OnReloadClicked">
                    Atualizar
                </button>
            </div>

            <div class="card-body">
                <div class="text-muted">
                    Server UTC: @Snapshot.ServerTimeUtc.ToString("yyyy-MM-dd HH:mm:ss")
                </div>
                <div class="text-muted">
                    Último heartbeat: @FmtUtc(Snapshot.Worker.LastHeartbeatUtc)
                </div>

                <div class="row mt-2">
                    <div class="col-md-4 text-muted">
                        Intervalo: <strong>@Snapshot.Worker.CycleIntervalSeconds</strong>s
                    </div>
                    <div class="col-md-4 text-muted">
                        Duração match: <strong>@Snapshot.Worker.MatchDurationMinutes</strong> min
                    </div>
                    <div class="col-md-4 text-muted">
                        Alvo próximas: <strong>@Snapshot.Worker.TargetUpcomingMatches</strong>
                    </div>
                </div>

                <div class="row mt-2">
                    <div class="col-md-6 text-muted">
                        Ciclo início: <strong>@FmtUtc(Snapshot.Worker.LastCycleStartUtc)</strong>
                    </div>
                    <div class="col-md-6 text-muted">
                        Ciclo fim: <strong>@FmtUtc(Snapshot.Worker.LastCycleEndUtc)</strong>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Snapshot.Worker.LastError))
                {
                    <div class="alert alert-warning mt-3 mb-0">
                        <strong>Último erro:</strong> @Snapshot.Worker.LastError
                        <div class="text-muted mt-1">Quando: @FmtUtc(Snapshot.Worker.LastErrorUtc)</div>
                    </div>
                }
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(BetStatusMessage))
    {
        <div class="alert @(BetRequestOk ? "alert-success" : "alert-danger") mb-3">
            @BetStatusMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(BetResponseBody))
    {
        <div class="card mb-3">
            <div class="card-header">
                <strong>Retorno do Investimento</strong>
            </div>
            <div class="card-body">
                <pre class="bg-dark text-white border rounded p-3 small mb-0" style="white-space: pre-wrap;">@BetResponseBody</pre>
            </div>
        </div>
    }

    var bettableMatches = GetBettableMatches();

    <div class="dashboard-listings">
        <section class="listing-panel">
            <div class="listing-panel-head">
                <div>
                    <div class="listing-eyebrow">Investimentos</div>
                    <h3>Partidas com mercado aberto</h3>
                </div>
                <span class="listing-count">@bettableMatches.Count</span>
            </div>

            @if (bettableMatches.Count == 0)
            {
                <div class="listing-empty">Nenhuma partida disponível para investimento.</div>
            }
            else
            {
                <div class="match-list-grid">
                    @foreach (var m in bettableMatches)
                    {
                        var canBetLive = CanBet(m.Status, m.ElapsedMinutes);
                        var disabledA = IsSendingBet || !canBetLive;
                        var disabledB = IsSendingBet || !canBetLive;

                        <article class="listing-match-card">
                            <div class="match-card-top">
                                <span>Match #@m.MatchId</span>
                                <span class="status-pill @GetStatusPillClass(m.Status)">@GetStatusLabel(m.Status)</span>
                            </div>

                            <div class="matchup-row">
                                <div class="team-cell">
                                    <span class="team-line">
                                        <span class="coin-mini" title="@m.TeamA">
                                            <img src="@GetCoinIconUrl(m.TeamA)"
                                                 alt="@m.TeamA"
                                                 loading="lazy"
                                                 onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                            <span class="coin-mini-fallback d-none">@GetInitials(m.TeamA)</span>
                                        </span>
                                        <span class="team-symbol">@m.TeamA</span>
                                    </span>
                                    <span class="@GetPctClass(m.PctA)">@FmtPct(m.PctA)</span>
                                </div>

                                <div class="score-cell">
                                    <span class="score-value">@FmtScore(m.ScoreA, m.ScoreB)</span>
                                    <span class="score-caption">@GetMatchClock(m)</span>
                                </div>

                                <div class="team-cell team-cell-right">
                                    <span class="team-line team-line-right">
                                        <span class="coin-mini" title="@m.TeamB">
                                            <img src="@GetCoinIconUrl(m.TeamB)"
                                                 alt="@m.TeamB"
                                                 loading="lazy"
                                                 onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                            <span class="coin-mini-fallback d-none">@GetInitials(m.TeamB)</span>
                                        </span>
                                        <span class="team-symbol">@m.TeamB</span>
                                    </span>
                                    <span class="@GetPctClass(m.PctB)">@FmtPct(m.PctB)</span>
                                </div>
                            </div>

                            <div class="match-progress" aria-label="Progresso da partida">
                                <span style="width: @GetProgressPercent(m.ElapsedMinutes, m.RemainingMinutes)%"></span>
                            </div>

                            <div class="match-card-footer">
                                @if (!canBetLive)
                                {
                                    <span class="closed-bet">Investimentos encerrados</span>
                                    <a class="btn btn-outline-light btn-sm" href="@GetMatchUrl(m.TeamA, m.TeamB)">Acompanhar</a>
                                }
                                else
                                {
                                    <button class="btn btn-success btn-sm"
                                            disabled="@disabledA"
                                            @onclick="() => SendBet(m, m.TeamAId, m.TeamA)">
                                        Investir @m.TeamA
                                    </button>

                                    <button class="btn btn-outline-light btn-sm"
                                            disabled="@disabledB"
                                            @onclick="() => SendBet(m, m.TeamBId, m.TeamB)">
                                        Investir @m.TeamB
                                    </button>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="listing-panel">
            <div class="listing-panel-head">
                <div>
                    <div class="listing-eyebrow">Ao vivo</div>
                    <h3>Partidas em andamento</h3>
                </div>
                <span class="listing-count">@Snapshot.Matches.OngoingList.Count</span>
            </div>

            @if (Snapshot.Matches.OngoingList.Count == 0)
            {
                <div class="listing-empty">Nenhuma partida em andamento.</div>
            }
            else
            {
                <div class="match-list-grid">
                    @foreach (var m in Snapshot.Matches.OngoingList)
                    {
                        <article class="listing-match-card listing-match-card-live">
                            <div class="match-card-top">
                                <span>Match #@m.MatchId</span>
                                <span class="status-pill status-live">AO VIVO</span>
                            </div>

                            <div class="matchup-row">
                                <div class="team-cell">
                                    <span class="team-line">
                                        <span class="coin-mini" title="@m.TeamA">
                                            <img src="@GetCoinIconUrl(m.TeamA)"
                                                 alt="@m.TeamA"
                                                 loading="lazy"
                                                 onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                            <span class="coin-mini-fallback d-none">@GetInitials(m.TeamA)</span>
                                        </span>
                                        <span class="team-symbol">@m.TeamA</span>
                                    </span>
                                    <span class="@GetPctClass(m.PctA)">@FmtPct(m.PctA)</span>
                                </div>

                                <div class="score-cell">
                                    <span class="score-value">@m.ScoreA x @m.ScoreB</span>
                                    <span class="score-caption">@m.ElapsedMinutes' jogados · -@m.RemainingMinutes'</span>
                                </div>

                                <div class="team-cell team-cell-right">
                                    <span class="team-line team-line-right">
                                        <span class="coin-mini" title="@m.TeamB">
                                            <img src="@GetCoinIconUrl(m.TeamB)"
                                                 alt="@m.TeamB"
                                                 loading="lazy"
                                                 onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                            <span class="coin-mini-fallback d-none">@GetInitials(m.TeamB)</span>
                                        </span>
                                        <span class="team-symbol">@m.TeamB</span>
                                    </span>
                                    <span class="@GetPctClass(m.PctB)">@FmtPct(m.PctB)</span>
                                </div>
                            </div>

                            <div class="match-progress" aria-label="Progresso da partida">
                                <span style="width: @GetProgressPercent(m.ElapsedMinutes, m.RemainingMinutes)%"></span>
                            </div>

                            <div class="match-card-footer">
                                <span class="match-meta">Mercado acompanha variação em tempo real</span>
                                <a class="btn btn-outline-light btn-sm" href="@GetMatchUrl(m.TeamA, m.TeamB)">Acompanhar</a>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="listing-panel listing-panel-wide">
            <div class="listing-panel-head">
                <div>
                    <div class="listing-eyebrow">Mercado</div>
                    <h3>Top gainers Binance</h3>
                </div>
                <span class="listing-count">@Snapshot.TopGainers.Count</span>
            </div>

            @if (Snapshot.TopGainers.Count == 0)
            {
                <div class="listing-empty">Sem dados.</div>
            }
            else
            {
                <div class="gainer-grid">
                    @foreach (var c in Snapshot.TopGainers)
                    {
                        <article class="gainer-card">
                            <div class="gainer-rank">#@c.Rank</div>
                            <span class="coin-mini coin-mini-market" title="@c.Symbol">
                                <img src="@GetCoinIconUrl(c.Symbol)"
                                     alt="@c.Symbol"
                                     loading="lazy"
                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                <span class="coin-mini-fallback d-none">@GetInitials(c.Symbol)</span>
                            </span>
                            <div class="gainer-identity">
                                <strong>@c.Symbol</strong>
                                <span>@c.Name</span>
                            </div>
                            <div class="gainer-change">+@c.PercentageChange.ToString("0.##")%</div>
                            <small>@FmtUtc(c.LastUpdatedUtc)</small>
                        </article>
                    }
                </div>
            }
        </section>
    </div>
}

<style>
    .dashboard-listings {
        display: grid;
        gap: 1rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .listing-panel {
        background: #111318;
        border: 1px solid #2b3138;
        border-radius: 8px;
        color: #f3f4f6;
        min-width: 0;
        padding: 1rem;
    }

    .listing-panel-wide {
        grid-column: 1 / -1;
    }

    .listing-panel-head {
        align-items: center;
        display: flex;
        gap: 1rem;
        justify-content: space-between;
        margin-bottom: 1rem;
    }

    .listing-panel-head h3 {
        color: #f9fafb;
        font-size: 1.05rem;
        font-weight: 700;
        line-height: 1.25;
        margin: 0;
    }

    .listing-eyebrow {
        color: #2dd4bf;
        font-size: .73rem;
        font-weight: 800;
        letter-spacing: 0;
        margin-bottom: .2rem;
        text-transform: uppercase;
    }

    .listing-count {
        align-items: center;
        background: #1f2933;
        border: 1px solid #374151;
        border-radius: 8px;
        color: #e5e7eb;
        display: inline-flex;
        font-weight: 800;
        justify-content: center;
        min-height: 2.25rem;
        min-width: 2.25rem;
        padding: .35rem .65rem;
    }

    .match-list-grid {
        display: grid;
        gap: .85rem;
    }

    .listing-match-card {
        background: #181b21;
        border: 1px solid #303741;
        border-radius: 8px;
        min-width: 0;
        padding: .95rem;
    }

    .listing-match-card-live {
        border-color: rgba(34, 197, 94, .55);
    }

    .match-card-top,
    .match-card-footer {
        align-items: center;
        display: flex;
        gap: .75rem;
        justify-content: space-between;
    }

    .match-card-top {
        color: #9ca3af;
        font-size: .78rem;
        font-weight: 700;
        margin-bottom: .9rem;
    }

    .status-pill,
    .closed-bet {
        border-radius: 8px;
        display: inline-flex;
        font-size: .72rem;
        font-weight: 800;
        line-height: 1;
        padding: .38rem .5rem;
        white-space: nowrap;
    }

    .status-pending {
        background: rgba(250, 204, 21, .16);
        color: #fde68a;
    }

    .status-live {
        background: rgba(34, 197, 94, .16);
        color: #86efac;
    }

    .status-closed,
    .closed-bet {
        background: rgba(148, 163, 184, .16);
        color: #cbd5e1;
    }

    .matchup-row {
        align-items: center;
        display: grid;
        gap: .8rem;
        grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    }

    .team-cell {
        display: grid;
        gap: .2rem;
        min-width: 0;
    }

    .team-cell-right {
        text-align: right;
    }

    .team-line {
        align-items: center;
        display: flex;
        gap: .5rem;
        min-width: 0;
    }

    .team-line-right {
        flex-direction: row-reverse;
    }

    .coin-mini {
        align-items: center;
        background: #111318;
        border: 1px solid #374151;
        border-radius: 8px;
        display: inline-flex;
        flex: 0 0 2.1rem;
        height: 2.1rem;
        justify-content: center;
        overflow: hidden;
        width: 2.1rem;
    }

    .coin-mini img {
        display: block;
        height: 1.55rem;
        object-fit: contain;
        width: 1.55rem;
    }

    .coin-mini-fallback {
        color: #2dd4bf;
        font-size: .72rem;
        font-weight: 900;
        line-height: 1;
    }

    .team-symbol {
        color: #ffffff;
        font-size: 1rem;
        font-weight: 800;
        overflow-wrap: anywhere;
    }

    .metric-positive {
        color: #86efac;
        font-size: .82rem;
        font-weight: 800;
    }

    .metric-negative {
        color: #fca5a5;
        font-size: .82rem;
        font-weight: 800;
    }

    .metric-muted {
        color: #9ca3af;
        font-size: .82rem;
        font-weight: 700;
    }

    .score-cell {
        border-left: 1px solid #303741;
        border-right: 1px solid #303741;
        display: grid;
        gap: .12rem;
        min-width: 6.25rem;
        padding: 0 .8rem;
        text-align: center;
    }

    .score-value {
        color: #f9fafb;
        font-size: 1.22rem;
        font-weight: 900;
        line-height: 1.1;
        white-space: nowrap;
    }

    .score-caption,
    .match-meta {
        color: #9ca3af;
        font-size: .78rem;
        font-weight: 700;
    }

    .match-progress {
        background: #252a32;
        border-radius: 8px;
        height: .42rem;
        margin: .9rem 0;
        overflow: hidden;
    }

    .match-progress span {
        background: linear-gradient(90deg, #2dd4bf, #22c55e);
        border-radius: 8px;
        display: block;
        height: 100%;
        min-width: .45rem;
    }

    .match-card-footer {
        min-height: 2rem;
    }

    .match-card-footer .btn {
        border-radius: 8px;
        font-weight: 800;
        min-height: 2rem;
    }

    .listing-empty {
        background: #181b21;
        border: 1px dashed #374151;
        border-radius: 8px;
        color: #9ca3af;
        padding: 1.25rem;
    }

    .gainer-grid {
        display: grid;
        gap: .75rem;
        grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    }

    .gainer-card {
        align-items: center;
        background: #181b21;
        border: 1px solid #303741;
        border-radius: 8px;
        display: grid;
        gap: .65rem;
        grid-template-columns: auto auto minmax(7rem, 1fr) auto;
        min-height: 5rem;
        padding: .8rem;
    }

    .coin-mini-market {
        flex-basis: 2.35rem;
        height: 2.35rem;
        width: 2.35rem;
    }

    .gainer-identity {
        min-width: 0;
    }

    .gainer-identity strong,
    .gainer-identity span {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .gainer-identity span,
    .gainer-card small {
        color: #9ca3af;
    }

    .gainer-rank {
        align-items: center;
        background: #222831;
        border-radius: 8px;
        color: #e5e7eb;
        display: inline-flex;
        font-weight: 800;
        height: 2.4rem;
        justify-content: center;
        width: 2.4rem;
    }

    .gainer-change {
        color: #86efac;
        font-weight: 900;
        text-align: right;
        white-space: nowrap;
    }

    .gainer-card small {
        grid-column: 3 / -1;
    }

    @@media (max-width: 992px) {
        .dashboard-listings {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 576px) {
        .listing-panel {
            padding: .85rem;
        }

        .matchup-row {
            grid-template-columns: 1fr;
            text-align: left;
        }

        .team-cell-right {
            text-align: left;
        }

        .score-cell {
            border-left: 0;
            border-right: 0;
            border-top: 1px solid #303741;
            border-bottom: 1px solid #303741;
            min-width: 0;
            padding: .65rem 0;
            text-align: left;
        }

        .match-card-footer {
            align-items: stretch;
            flex-direction: column;
        }

        .match-card-footer .btn {
            width: 100%;
        }

        .gainer-card {
            grid-template-columns: auto auto minmax(0, 1fr);
        }

        .gainer-card small {
            grid-column: 3 / -1;
            text-align: left;
        }

        .gainer-change {
            grid-column: 3 / -1;
            text-align: left;
        }
    }
</style>

@code {
    [Parameter] public DashboardSnapshotDto? Snapshot { get; set; }

    [Parameter] public int EventCount { get; set; }
    [Parameter] public int ReloadCount { get; set; }
    [Parameter] public DateTime LastReloadLocal { get; set; }
    [Parameter] public string? LastPayload { get; set; }
    [Parameter] public string DebugText { get; set; } = "";
    [Parameter] public bool DebugEnabled { get; set; }
    [Parameter] public bool IsPrivilegedWallet { get; set; }

    [Parameter] public EventCallback ReloadRequested { get; set; }

    private bool IsSendingBet { get; set; }
    private bool BetRequestOk { get; set; }
    private string BetStatusMessage { get; set; } = "";
    private string BetResponseBody { get; set; } = "";
    private IJSObjectReference? BettingModule { get; set; }

    private const decimal TestAmount = 1m;
    private const int LiveBetMaxMinutes = 45;

    private int SelectedUserId { get; set; } = 1;

    private List<BetUserOption> BettingUsers { get; set; } = new()
    {
        new BetUserOption { Id = 1, Wallet = "wallet_teste_001" },
        new BetUserOption { Id = 106, Wallet = "wallet_106" },
        new BetUserOption { Id = 107, Wallet = "wallet_107" },
        new BetUserOption { Id = 108, Wallet = "wallet_108" },
        new BetUserOption { Id = 109, Wallet = "wallet_109" },
        new BetUserOption { Id = 110, Wallet = "wallet_110" },
        new BetUserOption { Id = 100, Wallet = "wallet_100" },
        new BetUserOption { Id = 101, Wallet = "wallet_101" },
        new BetUserOption { Id = 102, Wallet = "wallet_102" },
        new BetUserOption { Id = 103, Wallet = "wallet_103" },
        new BetUserOption { Id = 104, Wallet = "wallet_104" },
        new BetUserOption { Id = 105, Wallet = "wallet_105" }
    };

    private string SelectedUserDisplay
        => BettingUsers.FirstOrDefault(x => x.Id == SelectedUserId)?.DisplayName
            ?? (SelectedUserId > 0 ? $"{SelectedUserId} - usuário autenticado" : "-");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadSessionUserAsync();
        }
    }

    private async Task LoadSessionUserAsync()
    {
        var userId = await SessionStorage.GetItemAsync<int?>("userId");
        if (userId.GetValueOrDefault() > 0)
        {
            if (!IsPrivilegedWallet)
                SelectedUserId = userId.Value;

            await InvokeAsync(StateHasChanged);
        }
    }

    private Task OnReloadClicked() => ReloadRequested.InvokeAsync();

    private async Task SendBet(BettableMatchViewModel match, int teamId, string teamName)
    {
        IsSendingBet = true;
        BetRequestOk = false;
        BetStatusMessage = "";
        BetResponseBody = "";

        try
        {
            var token = await SessionStorage.GetItemAsync<string>("authToken");

            if (string.IsNullOrWhiteSpace(token))
            {
                BetRequestOk = false;
                BetStatusMessage = "Faça login com a carteira Solana antes de investir.";
                return;
            }

            string? onChainSignature = null;
            var onChainBettingEnabled = Config.GetValue<bool>("OnChainBetting:Enabled");

            if (onChainBettingEnabled)
            {
                var onChainResult = await PlaceOnChainBetAsync(match, teamId, TestAmount);
                onChainSignature = onChainResult.Signature;
                BetResponseBody = PrettyJsonOrRaw(JsonSerializer.Serialize(onChainResult));
            }

            var payload = new
            {
                userId = SelectedUserId,
                teamId = teamId,
                amount = TestAmount,
                onChainSignature
            };

            var url = $"https://criptoversus-api.duckdns.org/api/match/{match.MatchId}/bet";
            using var request = new HttpRequestMessage(HttpMethod.Post, url)
            {
                Content = JsonContent.Create(payload)
            };
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            using var response = await Http.SendAsync(request);
            var body = await response.Content.ReadAsStringAsync();

            BetResponseBody = string.IsNullOrWhiteSpace(BetResponseBody)
                ? PrettyJsonOrRaw(body)
                : $"{BetResponseBody}\n\nAPI:\n{PrettyJsonOrRaw(body)}";

            if (response.IsSuccessStatusCode)
            {
                BetRequestOk = true;
                BetStatusMessage = $"Investimento enviado com sucesso para {teamName}. Usuário={SelectedUserDisplay}. MatchId={match.MatchId}, TeamId={teamId}.";
            }
            else
            {
                BetRequestOk = false;
                BetStatusMessage = $"Falha ao investir em {teamName}. Usuário={SelectedUserDisplay}. HTTP {(int)response.StatusCode} - {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            BetRequestOk = false;
            BetStatusMessage = GetBetExceptionMessage(ex, SelectedUserDisplay);
            BetResponseBody = ex.ToString();
        }
        finally
        {
            IsSendingBet = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<OnChainBetResult> PlaceOnChainBetAsync(BettableMatchViewModel match, int teamId, decimal amountSol)
    {
        BettingModule ??= await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "./js/solanaBetting.js");

        var programId = Config["OnChainBetting:ProgramId"];
        if (string.IsNullOrWhiteSpace(programId))
            throw new InvalidOperationException("OnChainBetting:ProgramId não configurado.");

        return await BettingModule.InvokeAsync<OnChainBetResult>(
            "placeBet",
            new
            {
                programId,
                cluster = Config["OnChainBetting:Cluster"] ?? "devnet",
                matchId = match.MatchId,
                teamId,
                teamAId = match.TeamAId,
                teamBId = match.TeamBId,
                bettingCloseUnix = match.BettingCloseTime?.ToUnixTimeSeconds(),
                autoCreateMatch = IsPrivilegedWallet,
                authorityPublicKey = Config["OnChainBetting:AuthorityWallet"] ?? Config["CriptoVersus:AdminWallet"],
                amountSol
            });
    }

    private List<BettableMatchViewModel> GetBettableMatches()
    {
        var result = new List<BettableMatchViewModel>();

        if (Snapshot is null)
            return result;

        if (Snapshot.Matches.Upcoming is not null)
        {
            result.AddRange(
                Snapshot.Matches.Upcoming.Select(m => new BettableMatchViewModel
                    {
                        MatchId = m.MatchId,
                        TeamAId = m.TeamAId,
                        TeamBId = m.TeamBId,
                        TeamA = m.TeamA,
                        TeamB = m.TeamB,
                        Status = m.Status ?? "Pending",
                        StartTime = m.StartTime,
                        BettingCloseTime = m.BettingCloseTime,
                        ElapsedMinutes = 0,
                        RemainingMinutes = m.RemainingMinutes,
                        ScoreA = m.ScoreA,
                        ScoreB = m.ScoreB,
                        PctA = m.PctA,
                        PctB = m.PctB
                    }));
        }

        if (Snapshot.Matches.OngoingList is not null)
        {
            result.AddRange(
                Snapshot.Matches.OngoingList.Select(m => new BettableMatchViewModel
                    {
                        MatchId = m.MatchId,
                        TeamAId = m.TeamAId,
                        TeamBId = m.TeamBId,
                        TeamA = m.TeamA,
                        TeamB = m.TeamB,
                        Status = m.Status ?? "Ongoing",
                        StartTime = null,
                        BettingCloseTime = m.BettingCloseTime,
                        ElapsedMinutes = m.ElapsedMinutes,
                        RemainingMinutes = m.RemainingMinutes,
                        ScoreA = m.ScoreA,
                        ScoreB = m.ScoreB,
                        PctA = m.PctA,
                        PctB = m.PctB
                    }));
        }

        return result
            .OrderBy(x => x.Status == "Pending" ? 0 : 1)
            .ThenBy(x => x.MatchId)
            .ToList();
    }

    private static bool CanBet(string? status, int elapsedMinutes)
    {
        if (string.Equals(status, "Pending", StringComparison.OrdinalIgnoreCase))
            return true;

        if (string.Equals(status, "Ongoing", StringComparison.OrdinalIgnoreCase))
            return elapsedMinutes >= 0 && elapsedMinutes < LiveBetMaxMinutes;

        return false;
    }

    private static string PrettyJsonOrRaw(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return "";

        try
        {
            using var doc = JsonDocument.Parse(text);
            return JsonSerializer.Serialize(doc, new JsonSerializerOptions
                {
                    WriteIndented = true
                });
        }
        catch
        {
            return text;
        }
    }

    private static string GetBetExceptionMessage(Exception ex, string selectedUserDisplay)
    {
        if (ex.ToString().Contains("ONCHAIN_MATCH_NOT_INITIALIZED", StringComparison.OrdinalIgnoreCase))
            return $"Partida ainda não criada on-chain na devnet. Conecte a carteira admin para publicar a partida antes de investir. Usuário={selectedUserDisplay}.";

        if (ex.ToString().Contains("Unauthorized", StringComparison.OrdinalIgnoreCase))
            return $"Carteira conectada não autorizada para criar a partida on-chain. Use a carteira admin configurada. Usuário={selectedUserDisplay}.";

        return $"Erro ao chamar o investimento. Usuário={selectedUserDisplay}.";
    }

    private static string FmtUtc(DateTime? dt)
        => dt is null ? "-" : dt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss");

    private static string FmtPct(decimal? v)
    {
        if (v is null) return "-";
        var sign = v.Value >= 0 ? "+" : "";
        return $"{sign}{v.Value:0.##}%";
    }

    private static string GetBaseSymbol(string pair)
    {
        if (string.IsNullOrWhiteSpace(pair))
            return "";

        pair = pair.Trim().ToUpperInvariant();

        var quotes = new[] { "USDT", "USDC", "BUSD", "BRL", "EUR", "BTC", "ETH" };

        foreach (var q in quotes)
        {
            if (pair.EndsWith(q, StringComparison.OrdinalIgnoreCase) && pair.Length > q.Length)
                return pair[..^q.Length];
        }

        return pair;
    }

    private static string GetCoinIconUrl(string pair)
        => $"https://criptoversus-api.duckdns.org/api/icons/binance/{GetBaseSymbol(pair)}";

    private static string GetInitials(string value)
    {
        var symbol = GetBaseSymbol(value);

        if (string.IsNullOrWhiteSpace(symbol))
            return "?";

        return symbol.Length <= 3 ? symbol : symbol[..3];
    }

    private static string FmtScore(int? scoreA, int? scoreB)
    {
        if (scoreA is null || scoreB is null)
            return "vs";

        return $"{scoreA} x {scoreB}";
    }

    private static string GetMatchClock(BettableMatchViewModel match)
    {
        if (string.Equals(match.Status, "Pending", StringComparison.OrdinalIgnoreCase))
            return match.StartTime is null ? "Aguardando inicio" : FmtUtc(match.StartTime);

        if (match.RemainingMinutes > 0)
            return $"{match.ElapsedMinutes}' jogados · -{match.RemainingMinutes}'";

        return $"{match.ElapsedMinutes}' jogados";
    }

    private static int GetProgressPercent(int elapsedMinutes, int remainingMinutes)
    {
        if (elapsedMinutes <= 0)
            return 0;

        var total = elapsedMinutes + Math.Max(remainingMinutes, 0);

        if (total <= 0)
            return 100;

        return Math.Clamp((int)Math.Round(elapsedMinutes * 100m / total), 0, 100);
    }

    private static string GetPctClass(decimal? value)
    {
        if (value is null)
            return "metric-muted";

        return value.Value >= 0 ? "metric-positive" : "metric-negative";
    }

    private static string GetStatusLabel(string? status)
    {
        if (string.Equals(status, "Pending", StringComparison.OrdinalIgnoreCase))
            return "ABERTA";

        if (string.Equals(status, "Ongoing", StringComparison.OrdinalIgnoreCase))
            return "AO VIVO";

        return "FECHADA";
    }

    private static string GetStatusPillClass(string? status)
    {
        if (string.Equals(status, "Pending", StringComparison.OrdinalIgnoreCase))
            return "status-pending";

        if (string.Equals(status, "Ongoing", StringComparison.OrdinalIgnoreCase))
            return "status-live";

        return "status-closed";
    }

    private static string GetMatchUrl(string teamA, string teamB)
    {
        return $"/match/{Slugify(teamA)}-vs-{Slugify(teamB)}";
    }

    private static string Slugify(string s)
    {
        if (string.IsNullOrWhiteSpace(s)) return "";

        var slug = s.Trim().ToLowerInvariant()
            .Replace(" ", "-")
            .Replace("_", "-");

        slug = new string(slug.Where(ch => char.IsLetterOrDigit(ch) || ch == '-').ToArray());

        return slug;
    }

