@using System.Net.Http
@using System.Net.Http.Json
@using System.Text.Json
@using DTOs
@using CriptoVersus.Web.Services
@inject DashboardHubClient HubClient
@inject HttpClient Http
@inject IJSRuntime JS

@if (Snapshot is null)
{
    <div class="alert alert-warning">Sem dados do snapshot.</div>
}
else
{
    <!-- Seleção de usuário para aposta -->
    <div class="card mb-3">
        <div class="card-header">
            <strong>Usuário da aposta</strong>
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-6 col-lg-4">
                    <label for="betUserSelect" class="form-label">Escolha o usuário</label>
                    <select id="betUserSelect" class="form-select" @bind="SelectedUserId">
                        @foreach (var user in BettingUsers)
                        {
                            <option value="@user.Id">@user.DisplayName</option>
                        }
                    </select>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="text-muted small">
                        Usuário selecionado:
                    </div>
                    <div class="fw-bold">
                        @SelectedUserDisplay
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="text-muted small">
                        Valor fixo da aposta:
                    </div>
                    <div class="fw-bold">
                        @TestAmount
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Cards: Matches -->
    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <div class="text-muted">Pendentes</div>
                    <div class="fs-2 fw-bold">@Snapshot.Matches.Pending</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <div class="text-muted">Em andamento</div>
                    <div class="fs-2 fw-bold">@Snapshot.Matches.Ongoing</div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <div class="text-muted">Finalizadas (24h)</div>
                    <div class="fs-2 fw-bold">@Snapshot.Matches.CompletedLast24h</div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="text-muted small">
                HubState: @HubClient.State |
                ConnId: @HubClient.ConnectionId |
                Events: @EventCount |
                Reloads: @ReloadCount |
                LastReload: @LastReloadLocal.ToString("HH:mm:ss")
            </div>
        </div>
    </div>

    <!-- Worker -->
    <div class="card mb-3">
        <div class="card-header d-flex align-items-center justify-content-between">
            <div>
                <strong>@Snapshot.Worker.ServiceName</strong>
                <span class="badge ms-2 @(Snapshot.Worker.IsAlive ? "bg-success" : "bg-danger")">
                    @(Snapshot.Worker.IsAlive ? "ONLINE" : "OFFLINE")
                </span>
            </div>

            <button class="btn btn-sm btn-outline-primary" @onclick="OnReloadClicked">
                Atualizar
            </button>
        </div>

        <div class="card-body">
            <div class="text-muted">
                Server UTC: @Snapshot.ServerTimeUtc.ToString("yyyy-MM-dd HH:mm:ss")
            </div>
            <div class="text-muted">
                Último heartbeat: @FmtUtc(Snapshot.Worker.LastHeartbeatUtc)
            </div>

            <div class="row mt-2">
                <div class="col-md-4 text-muted">
                    Intervalo: <strong>@Snapshot.Worker.CycleIntervalSeconds</strong>s
                </div>
                <div class="col-md-4 text-muted">
                    Duração match: <strong>@Snapshot.Worker.MatchDurationMinutes</strong> min
                </div>
                <div class="col-md-4 text-muted">
                    Alvo próximas: <strong>@Snapshot.Worker.TargetUpcomingMatches</strong>
                </div>
            </div>

            <div class="row mt-2">
                <div class="col-md-6 text-muted">
                    Ciclo início: <strong>@FmtUtc(Snapshot.Worker.LastCycleStartUtc)</strong>
                </div>
                <div class="col-md-6 text-muted">
                    Ciclo fim: <strong>@FmtUtc(Snapshot.Worker.LastCycleEndUtc)</strong>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Snapshot.Worker.LastError))
            {
                <div class="alert alert-warning mt-3 mb-0">
                    <strong>Último erro:</strong> @Snapshot.Worker.LastError
                    <div class="text-muted mt-1">Quando: @FmtUtc(Snapshot.Worker.LastErrorUtc)</div>
                </div>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(BetStatusMessage))
    {
        <div class="alert @(BetRequestOk ? "alert-success" : "alert-danger") mb-3">
            @BetStatusMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(BetResponseBody))
    {
        <div class="card mb-3">
            <div class="card-header">
                <strong>Retorno da Aposta</strong>
            </div>
            <div class="card-body">
                <pre class="bg-dark text-white border rounded p-3 small mb-0" style="white-space: pre-wrap;">@BetResponseBody</pre>
            </div>
        </div>
    }

    <div class="row g-3">
        <!-- Partidas com aposta liberada / controlada -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header"><strong>Apostas</strong></div>
                <div class="table-responsive">
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Times</th>
                                <th>Status</th>
                                <th class="text-end">Tempo / Início</th>
                                <th class="text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var bettableMatches = GetBettableMatches();
                            }

                            @if (bettableMatches.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="text-muted p-3">Nenhuma partida disponível para aposta.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var m in bettableMatches)
                                {
                                    var canBetLive = CanBet(m.Status, m.ElapsedMinutes);
                                    var disabledA = IsSendingBet || !canBetLive;
                                    var disabledB = IsSendingBet || !canBetLive;

                                    <tr>
                                        <td>@m.MatchId</td>
                                        <td>@m.TeamA <span class="text-muted">vs</span> @m.TeamB</td>
                                        <td>
                                            @m.Status
                                            @if (m.Status == "Ongoing")
                                            {
                                                <div class="small text-muted">@m.ElapsedMinutes' jogados</div>
                                            }
                                        </td>
                                        <td class="text-end">
                                            @if (m.Status == "Pending")
                                            {
                                                @FmtUtc(m.StartTime)
                                            }
                                            else
                                            {
                                                <span>@m.ElapsedMinutes'</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (!canBetLive)
                                            {
                                                <span class="badge bg-secondary">Apostas encerradas</span>
                                            }
                                            else
                                            {
                                                <div class="d-flex gap-2 justify-content-center flex-wrap">
                                                    <button class="btn btn-success btn-sm"
                                                            disabled="@disabledA"
                                                            @onclick="() => SendBet(m.MatchId, m.TeamAId, m.TeamA)">
                                                        Apostar @m.TeamA
                                                    </button>

                                                    <button class="btn btn-primary btn-sm"
                                                            disabled="@disabledB"
                                                            @onclick="() => SendBet(m.MatchId, m.TeamBId, m.TeamB)">
                                                        Apostar @m.TeamB
                                                    </button>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Partidas em andamento -->
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header"><strong>Ongoing</strong></div>
                <div class="table-responsive">
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Times</th>
                                <th>Placar</th>
                                <th class="text-end">Tempo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Snapshot.Matches.OngoingList.Count == 0)
                            {
                                <tr>
                                    <td colspan="4" class="text-muted p-3">Nenhuma partida em andamento.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var m in Snapshot.Matches.OngoingList)
                                {
                                    <tr>
                                        <td>
                                            <a href="@GetMatchUrl(m.TeamA, m.TeamB)">
                                                @m.MatchId
                                            </a>
                                        </td>
                                        <td>@m.TeamA <span class="text-muted">vs</span> @m.TeamB</td>
                                        <td>
                                            <div>
                                                <strong>@m.ScoreA</strong> x <strong>@m.ScoreB</strong>
                                            </div>

                                            <div class="text-muted small">
                                                @FmtPct(m.PctA) <span class="text-muted">vs</span> @FmtPct(m.PctB)
                                            </div>
                                        </td>

                                        <td class="text-end">
                                            @m.ElapsedMinutes' <span class="text-muted">(-@m.RemainingMinutes')</span>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Top Gainers -->
        <div class="col-12">
            <div class="card">
                <div class="card-header"><strong>Top Gainers</strong></div>
                <div class="table-responsive">
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Symbol</th>
                                <th>Name</th>
                                <th class="text-end">%</th>
                                <th class="text-end">Atualizado</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Snapshot.TopGainers.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="text-muted p-3">Sem dados.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var c in Snapshot.TopGainers)
                                {
                                    <tr>
                                        <td>@c.Rank</td>
                                        <td><strong>@c.Symbol</strong></td>
                                        <td>@c.Name</td>
                                        <td class="text-end text-success fw-bold">
                                            +@c.PercentageChange.ToString("0.##")%
                                        </td>
                                        <td class="text-end">@FmtUtc(c.LastUpdatedUtc)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public DashboardSnapshotDto? Snapshot { get; set; }

    [Parameter] public int EventCount { get; set; }
    [Parameter] public int ReloadCount { get; set; }
    [Parameter] public DateTime LastReloadLocal { get; set; }
    [Parameter] public string? LastPayload { get; set; }
    [Parameter] public string DebugText { get; set; } = "";
    [Parameter] public bool DebugEnabled { get; set; }

    [Parameter] public EventCallback ReloadRequested { get; set; }

    private bool IsSendingBet { get; set; }
    private bool BetRequestOk { get; set; }
    private string BetStatusMessage { get; set; } = "";
    private string BetResponseBody { get; set; } = "";

    private const decimal TestAmount = 1m;
    private const int LiveBetMaxMinutes = 45;

    private int SelectedUserId { get; set; } = 1;

    private List<BetUserOption> BettingUsers { get; set; } = new()
    {
        new BetUserOption { Id = 1, Wallet = "wallet_teste_001" },
        new BetUserOption { Id = 106, Wallet = "wallet_106" },
        new BetUserOption { Id = 107, Wallet = "wallet_107" },
        new BetUserOption { Id = 108, Wallet = "wallet_108" },
        new BetUserOption { Id = 109, Wallet = "wallet_109" },
        new BetUserOption { Id = 110, Wallet = "wallet_110" },
        new BetUserOption { Id = 100, Wallet = "wallet_100" },
        new BetUserOption { Id = 101, Wallet = "wallet_101" },
        new BetUserOption { Id = 102, Wallet = "wallet_102" },
        new BetUserOption { Id = 103, Wallet = "wallet_103" },
        new BetUserOption { Id = 104, Wallet = "wallet_104" },
        new BetUserOption { Id = 105, Wallet = "wallet_105" }
    };

    private string SelectedUserDisplay
        => BettingUsers.FirstOrDefault(x => x.Id == SelectedUserId)?.DisplayName ?? "-";

    private Task OnReloadClicked() => ReloadRequested.InvokeAsync();

    private async Task SendBet(int matchId, int teamId, string teamName)
    {
        IsSendingBet = true;
        BetRequestOk = false;
        BetStatusMessage = "";
        BetResponseBody = "";

        try
        {
            var payload = new
            {
                userId = SelectedUserId,
                teamId = teamId,
                amount = TestAmount
            };

            var url = $"https://criptoversus-api.duckdns.org/api/match/{matchId}/bet";

            using var response = await Http.PostAsJsonAsync(url, payload);
            var body = await response.Content.ReadAsStringAsync();

            BetResponseBody = PrettyJsonOrRaw(body);

            if (response.IsSuccessStatusCode)
            {
                BetRequestOk = true;
                BetStatusMessage = $"Aposta enviada com sucesso para {teamName}. Usuário={SelectedUserDisplay}. MatchId={matchId}, TeamId={teamId}.";
            }
            else
            {
                BetRequestOk = false;
                BetStatusMessage = $"Falha ao apostar em {teamName}. Usuário={SelectedUserDisplay}. HTTP {(int)response.StatusCode} - {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            BetRequestOk = false;
            BetStatusMessage = $"Erro ao chamar a API de aposta. Usuário={SelectedUserDisplay}.";
            BetResponseBody = ex.ToString();
        }
        finally
        {
            IsSendingBet = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private List<BettableMatchViewModel> GetBettableMatches()
    {
        var result = new List<BettableMatchViewModel>();

        if (Snapshot is null)
            return result;

        if (Snapshot.Matches.Upcoming is not null)
        {
            result.AddRange(
                Snapshot.Matches.Upcoming.Select(m => new BettableMatchViewModel
                    {
                        MatchId = m.MatchId,
                        TeamAId = m.TeamAId,
                        TeamBId = m.TeamBId,
                        TeamA = m.TeamA,
                        TeamB = m.TeamB,
                        Status = m.Status ?? "Pending",
                        StartTime = m.StartTime,
                        ElapsedMinutes = 0
                    }));
        }

        if (Snapshot.Matches.OngoingList is not null)
        {
            result.AddRange(
                Snapshot.Matches.OngoingList.Select(m => new BettableMatchViewModel
                    {
                        MatchId = m.MatchId,
                        TeamAId = m.TeamAId,
                        TeamBId = m.TeamBId,
                        TeamA = m.TeamA,
                        TeamB = m.TeamB,
                        Status = "Ongoing",
                        StartTime = null,
                        ElapsedMinutes = m.ElapsedMinutes
                    }));
        }

        return result
            .OrderBy(x => x.Status == "Pending" ? 0 : 1)
            .ThenBy(x => x.MatchId)
            .ToList();
    }

    private static bool CanBet(string? status, int elapsedMinutes)
    {
        if (string.Equals(status, "Pending", StringComparison.OrdinalIgnoreCase))
            return true;

        if (string.Equals(status, "Ongoing", StringComparison.OrdinalIgnoreCase))
            return elapsedMinutes >= 0 && elapsedMinutes < LiveBetMaxMinutes;

        return false;
    }

    private static string PrettyJsonOrRaw(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return "";

        try
        {
            using var doc = JsonDocument.Parse(text);
            return JsonSerializer.Serialize(doc, new JsonSerializerOptions
                {
                    WriteIndented = true
                });
        }
        catch
        {
            return text;
        }
    }

    private static string FmtUtc(DateTime? dt)
        => dt is null ? "-" : dt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss");

    private static string FmtPct(decimal? v)
    {
        if (v is null) return "-";
        var sign = v.Value >= 0 ? "+" : "";
        return $"{sign}{v.Value:0.##}%";
    }

    private static string GetMatchUrl(string teamA, string teamB)
    {
        return $"/match/{Slugify(teamA)}-vs-{Slugify(teamB)}";
    }

    private static string Slugify(string s)
    {
        if (string.IsNullOrWhiteSpace(s)) return "";

        var slug = s.Trim().ToLowerInvariant()
            .Replace(" ", "-")
            .Replace("_", "-");

        slug = new string(slug.Where(ch => char.IsLetterOrDigit(ch) || ch == '-').ToArray());

        return slug;
    }

    private sealed class BetUserOption
    {
        public int Id { get; set; }
        public string Wallet { get; set; } = "";
        public string DisplayName => $"{Id} - {Wallet}";
    }

    private sealed class BettableMatchViewModel
    {
        public int MatchId { get; set; }
        public int TeamAId { get; set; }
        public int TeamBId { get; set; }
        public string TeamA { get; set; } = "";
        public string TeamB { get; set; } = "";
        public string Status { get; set; } = "";
        public DateTime? StartTime { get; set; }
        public int ElapsedMinutes { get; set; }
    }
}