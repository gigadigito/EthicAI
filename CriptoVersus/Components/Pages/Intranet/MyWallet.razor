    private static string ShortWallet(string wallet)
    {
        const int start = 8;
        const int end = 6;

        if (wallet.Length <= start + end + 3)
            return wallet;

        return $"{wallet[..start]}...{wallet[^end..]}";
    }

    private static string FmtSol(decimal value)
        => $"{value:0.########} SOL";

    private static string FmtSol(double value)
        => $"{value:0.########} SOL";

    private static string FmtOptionalSol(decimal? value)
        => value.HasValue ? FmtSol(value.Value) : "-";

    private static string FmtSignedSol(decimal value)
        => value > 0m
            ? $"+{value:0.########} SOL"
            : value < 0m
                ? $"-{Math.Abs(value):0.########} SOL"
                : "0 SOL";

    private static string FmtSolCompact(decimal value)
        => $"{value:0.##} SOL";

    private static string FmtPercentage(decimal? value)
        => value.HasValue ? $"{value.Value:+0.##;-0.##;0.##}%" : "--";

    private static string GetPayoutClass(decimal value)
        => value > 0m
            ? "payout-positive"
            : value < 0m
                ? "payout-negative"
                : "payout-neutral";

    private static string GetPayoutClass(decimal? value)
        => value.HasValue ? GetPayoutClass(value.Value) : "payout-neutral";

    private string FmtDate(DateTime? value)
        => BrowserTimeZone.FormatDateTime(value, AppCulture.ToCultureCode(CurrentCulture));

    private string FmtElapsed(DateTime value)
    {
        var elapsed = DateTime.UtcNow - value;

        if (elapsed.TotalDays >= 1)
            return T("elapsed.days", (int)elapsed.TotalDays);

        if (elapsed.TotalHours >= 1)
            return T("elapsed.hours", (int)elapsed.TotalHours);

        var minutes = Math.Max(1, (int)elapsed.TotalMinutes);
        return T("elapsed.minutes", minutes);
    }

    private static string FmtPositionStatus(string status)
        => status switch
        {
            "Active" => "Ativa",
            "ClosingRequested" => "Saida solicitada",
            "Closed" => "Encerrada",
            "Paused" => "Pausada",
            _ => status
        };

    private int CountPositionsByStatus(string status)
        => _wallet?.ActivePositions.Count(p => string.Equals(p.Status, status, StringComparison.OrdinalIgnoreCase)) ?? 0;

    private static decimal GetSimplePnl(TeamPositionDto position)
        => position.TotalPnL != 0m
            ? position.TotalPnL
            : decimal.Round(position.CurrentCapital - position.PrincipalAllocated, 8, MidpointRounding.ToZero);

    private static string GetBaseSymbol(string pair)
    {
        if (string.IsNullOrWhiteSpace(pair))
            return "";

        pair = pair.Trim().ToUpperInvariant();

        var quotes = new[] { "USDT", "USDC", "BUSD", "BRL", "EUR", "BTC", "ETH" };

        foreach (var quote in quotes)
        {
            if (pair.EndsWith(quote, StringComparison.OrdinalIgnoreCase) && pair.Length > quote.Length)
                return pair[..^quote.Length];
        }

        return pair;
    }

    private string GetCoinIconUrl(string symbol)
        => EnvironmentIsolationGuard.BuildApiUrl(Config, $"/api/icons/binance/{GetBaseSymbol(symbol)}");

    private static string GetInitials(string value)
    {
        var symbol = GetBaseSymbol(value);

        if (string.IsNullOrWhiteSpace(symbol))
            return "?";

        return symbol.Length <= 3 ? symbol : symbol[..3];
    }

    private static bool TryParseAmount(string? raw, out decimal value)
    {
        var normalized = (raw ?? string.Empty).Trim().Replace(',', '.');
        return decimal.TryParse(
            normalized,
            System.Globalization.NumberStyles.AllowDecimalPoint,
            System.Globalization.CultureInfo.InvariantCulture,
            out value);
    }

    private static decimal ParseAmountOrDefault(string? raw)
        => TryParseAmount(raw, out var value) ? value : 0m;

    private static string GetTrendClass(string direction)
        => direction switch
        {
            "up" => "is-up",
            "down" => "is-down",
            _ => string.Empty
        };

    private string GetAssetAvailabilityLabel(PositionAssetOptionDto asset)
        => asset.CanInvestNow ? T("openPosition.availableNow") : T("openPosition.blockedNow");

    private string NormalizeInvestmentError(string message)
    {
        var normalized = (message ?? string.Empty).ToLowerInvariant();

        if (normalized.Contains("valor do investimento invalido"))
            return T("openPosition.invalidAmount");

        if (normalized.Contains("user rejected") || normalized.Contains("rejected") || normalized.Contains("cancel"))
            return T("openPosition.phantomRejected");

        if (normalized.Contains("wallet conectada e diferente") || normalized.Contains("does not match"))
            return T("openPosition.walletMismatch");

        if (normalized.Contains("carteira solana nao encontrada") || normalized.Contains("wallet"))
            return T("openPosition.walletFundingRequired");

        if (normalized.Contains("ja foi utilizada") || normalized.Contains("already used"))
            return T("openPosition.duplicateSignature");

        if (normalized.Contains("insufficient wallet balance") || normalized.Contains("saldo insuficiente na carteira"))
            return message;

        if (normalized.Contains("fase avancada") || normalized.Contains("advanced"))
            return _selectedAsset?.AccessMessage ?? message;

        return message;
    }

    private void ResetOpenPositionFeedback(bool clearHashOnly = false)
    {
        _openPositionStatusKey = null;
        if (!clearHashOnly)
            _openPositionTransactionHash = null;
    }

    private static string ShortTxHash(string? hash)
    {
        if (string.IsNullOrWhiteSpace(hash) || hash.Length <= 18)
            return hash ?? string.Empty;

        return $"{hash[..10]}...{hash[^8..]}";
    }

    private string T(string key, params object?[] args)
        => L.T($"walletPage.{key}", CurrentCulture, args);

    private async Task ShowToastAsync(string message, string type)
    {
        try
        {
            await JS.InvokeVoidAsync("html5Toast.show", message, type, 3200);
        }
        catch
        {
            // Feedback inline permanece em _actionMessage.
        }
    }

    public async ValueTask DisposeAsync()
    {
        WalletState.Changed -= HandleWalletStateChanged;
        HubClient.DashboardChanged -= HandleDashboardChanged;
        _assetSearchDebounceCts?.Cancel();
        _assetSearchDebounceCts?.Dispose();

        if (_walletBalanceModule is not null)
            await _walletBalanceModule.DisposeAsync();

        if (_walletActionsModule is not null)
            await _walletActionsModule.DisposeAsync();

        if (_investmentDiagnosticsModule is not null)
            await _investmentDiagnosticsModule.DisposeAsync();
    }
    private sealed class ChainWithdrawResult
    {
        public bool supported { get; set; }
        public string? signature { get; set; }
        public string? connectedWallet { get; set; }
        public string? confirmationStatus { get; set; }
        public string? proofMessage { get; set; }
        public string? proofSignature { get; set; }
    }

    private sealed class WalletBalanceGuardResult
    {
        public bool ok { get; set; }
        public string? code { get; set; }
        public double balanceSol { get; set; }
        public double requiredSol { get; set; }
        public double maxSpendableSol { get; set; }
        public string? message { get; set; }
    }

    private sealed class InvestmentPreparationResult
    {
        public string? Signature { get; set; }
        public string? Wallet { get; set; }
        public string? Result { get; set; }
        public string AmountLamports { get; set; } = "";
        public string? PositionPda { get; set; }
        public string? PositionVaultPda { get; set; }
    }

    private string ResolveWithdrawErrorMessage(Exception ex)
    {
        var message = ex.Message ?? "Erro desconhecido.";
        var normalized = message.ToLowerInvariant();

        if (normalized.Contains("wallet nao conectada"))
            return T("actions.walletNotConnected");

        if (normalized.Contains("carteira diferente da conta"))
            return T("actions.walletMismatch");

        if (normalized.Contains("insufficient wallet balance") || normalized.Contains("saldo insuficiente na carteira"))
            return message;

        if (normalized.Contains("saldo insuficiente"))
            return T("actions.insufficientBalance");

        if (normalized.Contains("signature") || normalized.Contains("assinatura"))
            return T("actions.confirmWithdrawError", message);

        return T("actions.confirmWithdrawError", message);
    }

    private void HandleWalletStateChanged()
    {
        if (!string.IsNullOrWhiteSpace(WalletState.AuthToken))
            return;

        _wallet = null;
        _loading = false;
        _error = T("actions.walletChanged");
        _actionMessage = null;
        _actionBusy = false;
        _onChainBalance = null;
        _onChainBalanceError = null;
        _copyMessage = null;

        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleDashboardChanged(string? payload)
    {
        _ = payload;

        if (_wallet is null)
            return;

        _ = InvokeAsync(async () =>
        {
            await LoadWalletAsync(false);
            await LoadOnChainBalanceAsync();
            StateHasChanged();
        });
    }
}

