@rendermode InteractiveServer
@page "/minha-carteira"
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersusApiClient Api
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject IConfiguration Config
@inject IJSRuntime JS
@inject BrowserTimeZoneService BrowserTimeZone
@implements IAsyncDisposable

<section class="wallet-page">
    <div class="wallet-heading">
        <span>Minha Carteira</span>
        <h2>Seus investimentos</h2>
        <p>Acompanhe o saldo do sistema, as moedas em que voce investiu e o retorno de cada posicao.</p>
    </div>

    @if (_loading)
    {
        <div class="wallet-message">Carregando sua carteira...</div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="wallet-message wallet-message-danger">@_error</div>
    }
    else if (_wallet is null)
    {
        <div class="wallet-message">
            Faca login com sua carteira Solana para ver seus investimentos.
        </div>
    }
    else
    {
        <div class="wallet-profile">
            <div>
                <span class="wallet-label">Carteira conectada</span>
                <strong title="@_wallet.Wallet">@ShortWallet(_wallet.Wallet)</strong>
            </div>
            <div>
                <span class="wallet-label">Usuario</span>
                <strong>@DisplayName</strong>
            </div>
            <div>
                <span class="wallet-label">@WalletNetworkBalanceLabel</span>
                <strong class="wallet-balance" title="@OnChainBalanceTitle">@OnChainBalanceText</strong>
            </div>
            <div>
                <span class="wallet-label">Ultimo acesso</span>
                <strong>@FmtDate(_wallet.LastLogin)</strong>
            </div>
        </div>

        @if (IsOffChainCustodyMode)
        {
            <div class="wallet-actions-card">
                <div class="wallet-actions-summary">
                    <div>
                        <span class="wallet-label">Modo operacional</span>
                        <strong>Modo Off-chain Custody</strong>
                    </div>
                    <div>
                        <span class="wallet-label">Carteira de custodia</span>
                        <strong>@GetCustodyLabel()</strong>
                    </div>
                </div>
                <div class="wallet-offchain-copy">
                    <div class="wallet-offchain-address">
                        <span class="wallet-label">Endereço publico</span>
                        <strong title="@GetCustodyWalletDisplayValue()">@GetCustodyWalletDisplayValue()</strong>
                    </div>
                    <button type="button"
                            class="wallet-history-button"
                            disabled="@string.IsNullOrWhiteSpace(_wallet.CustodyWalletPublicKey)"
                            @onclick="CopyCustodyWalletAsync">
                        Copiar carteira
                    </button>
                </div>
                <div class="wallet-message">
                    Neste modo, apostas usam apenas o saldo interno do banco. Transferencias SOL para a carteira de custodia precisam ser conciliadas para virar saldo interno antes de apostar.
                </div>
                <div class="wallet-message">
                    Saques automaticos para a carteira conectada ficam desativados neste modo para evitar debito sem transferencia on-chain confirmada.
                </div>
                @if (!string.IsNullOrWhiteSpace(_copyMessage))
                {
                    <div class="wallet-message">@_copyMessage</div>
                }
            </div>
        }

        <div class="wallet-metrics">
            <div class="wallet-metric">
                <span>Saldo no sistema</span>
                <strong>@FmtSol(_wallet.SystemBalance)</strong>
            </div>
            <div class="wallet-metric">
                <span>Capital alocado</span>
                <strong>@FmtSol(_wallet.TotalInvested)</strong>
            </div>
            <div class="wallet-metric">
                <span>Em aberto</span>
                <strong>@FmtSol(_wallet.OpenAmount)</strong>
            </div>
            <div class="wallet-metric">
                <span>Posicoes em saida</span>
                <strong>@CountPositionsByStatus("ClosingRequested")</strong>
            </div>
            <div class="wallet-metric">
                <span>Lucro realizado</span>
                <strong class="payout-positive">@FmtSol(_wallet.RealizedProfit)</strong>
            </div>
            <div class="wallet-metric">
                <span>Perda realizada</span>
                <strong class="payout-negative">@FmtSol(_wallet.RealizedLoss)</strong>
            </div>
            <div class="wallet-metric">
                <span>Resultado liquido realizado</span>
                <strong class="@GetPayoutClass(_wallet.RealizedNetResult)">@FmtSignedSol(_wallet.RealizedNetResult)</strong>
            </div>
        </div>

        <div class="wallet-actions-card">
            <div class="wallet-actions-summary">
                <div>
                    <span class="wallet-label">Saldo no sistema</span>
                    <strong>@FmtSol(_wallet.SystemBalance)</strong>
                </div>
                <div>
                    <span class="wallet-label">Posicoes em saida</span>
                    <strong>@CountPositionsByStatus("ClosingRequested")</strong>
                </div>
            </div>
            <div class="wallet-message">
                Para liberar saldo para saque, finalize uma posicao fora de jogo. Se ela ainda estiver vinculada a uma partida em andamento, a saida fica solicitada e o saldo volta automaticamente para o sistema quando essa partida for liquidada.
            </div>
            <div class="wallet-actions-buttons">
                @if (_wallet.CanWithdraw)
                {
                    <button type="button"
                            class="wallet-history-button is-primary"
                            disabled="@_actionBusy"
                            @onclick="WithdrawSystemBalanceAsync">
                        Sacar para carteira
                    </button>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(_actionMessage))
            {
                <div class="wallet-message">@_actionMessage</div>
            }
        </div>

        <div class="wallet-section-title">
            <h3>Posicoes ativas</h3>
            <span>@_wallet.ActivePositions.Count alocadas</span>
        </div>

        @if (_wallet.ActivePositions.Count == 0)
        {
            <div class="wallet-empty">
                Voce ainda nao tem posicoes recorrentes. Ao investir em um ativo, o capital passa a acompanhar os proximos ciclos desse time.
            </div>
        }
        else
        {
            <div class="wallet-positions">
                @foreach (var position in _wallet.ActivePositions)
                {
                    <article class="position-row">
                        <div class="investment-main">
                            <span class="coin-symbol" title="@position.Symbol">
                                <img src="@GetCoinIconUrl(position.Symbol)"
                                     alt="@position.Symbol"
                                     loading="lazy"
                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                <span class="coin-symbol-fallback d-none">@GetInitials(position.Symbol)</span>
                            </span>
                            <div>
                                <strong><MarketPairText Symbol="@position.Symbol" /></strong>
                                <span>@position.CurrencyName</span>
                            </div>
                        </div>

                        <div class="investment-data">
                            <span>Capital atual</span>
                            <strong>@FmtSol(position.CurrentCapital)</strong>
                        </div>

                        <div class="investment-data">
                            <span>Total alocado</span>
                            <strong>@FmtSol(position.PrincipalAllocated)</strong>
                        </div>

                        <div class="investment-data">
                            <span>Status</span>
                            <strong>@FmtPositionStatus(position.Status)</strong>
                        </div>

                        <div class="investment-data investment-data-action">
                            <span>Acao</span>
                            @if (string.Equals(position.Status, "ClosingRequested", StringComparison.OrdinalIgnoreCase))
                            {
                                <strong>Saida solicitada</strong>
                            }
                            else
                            {
                                <button type="button"
                                        class="wallet-history-button"
                                        disabled="@_actionBusy"
                                        @onclick="() => RequestClosePositionAsync(position)">
                                    @(position.CanCloseNow ? "Finalizar posicao" : "Solicitar saida")
                                </button>
                            }
                        </div>
                    </article>
                }
            </div>
        }

        <div class="wallet-section-title">
            <h3>Historico por token/time</h3>
            <span>@_wallet.OpenInvestments em aberto | @_wallet.SettledInvestments finalizadas</span>
        </div>

        @if (_wallet.InvestmentGroups.Count == 0)
        {
            <div class="wallet-empty">
                Voce ainda nao tem investimentos registrados. Escolha uma partida para iniciar sua primeira posicao.
            </div>
        }
        else
        {
            <div class="wallet-investments">
                @foreach (var group in _wallet.InvestmentGroups)
                {
                    <WalletMatchHistoryGroup UserId="@_wallet.UserId" Group="@group" />
                }
            </div>
        }
    }
</section>

