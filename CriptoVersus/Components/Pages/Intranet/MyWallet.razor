        => _openPositionStatusKey == "positionOpened"
            ? "status-success"
            : string.IsNullOrWhiteSpace(_openPositionStatusKey)
                ? string.Empty
                : "status-pending";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await BrowserTimeZone.EnsureInitializedAsync();
                await LoadWalletAsync();
                await LoadOnChainBalanceAsync();
                await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex) when (InteropSafety.IsDeferredInteropException(ex))
            {
                // Fluxo depende de SessionStorage/JS e será repetido no render interativo.
            }
        }

        if (_hubStarted)
            return;

        try
        {
            await HubClient.EnsureStartedAsync();
            _hubStarted = true;
        }
        catch
        {
            // Wallet continua funcional sem realtime.
        }
    }

    protected override void OnInitialized()
    {
        WalletState.Changed += HandleWalletStateChanged;
        HubClient.DashboardChanged += HandleDashboardChanged;
    }

    private async Task LoadWalletAsync(bool showLoadingState = true)
    {
        _loading = showLoadingState;
        _error = null;
        _copyMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var token = await SessionStorage.GetItemAsync<string>("authToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                _wallet = null;
                return;
            }

            _wallet = await Api.GetMyWalletAsync();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            _wallet = null;
            _error = T("actions.sessionExpired");
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            _wallet = null;
            _error = T("actions.walletLoadUnavailable");
        }
        catch (Exception ex)
        {
            _error = T("actions.walletLoadFailed", ex.Message);
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OpenPositionModalAsync()
    {
        _showOpenPositionModal = true;
        _selectedAsset = null;
        _investmentAmountInput = "0.10";
        _investmentAmountError = string.Empty;
        _assetSearchTerm = string.Empty;
        ResetOpenPositionFeedback();
        await LoadOnChainBalanceAsync();
        await LoadPositionAssetsAsync();
    }

    private void ClosePositionModal()
    {
        _showOpenPositionModal = false;
        _selectedAsset = null;
        _assetSearchError = null;
        _investmentAmountError = string.Empty;
        _openPositionBusy = false;
        ResetOpenPositionFeedback();
    }

    private void BackToAssetSelection()
    {
        _selectedAsset = null;
        _investmentAmountError = string.Empty;
        _openPositionBusy = false;
        ResetOpenPositionFeedback();
    }

    private async Task LoadPositionAssetsAsync(CancellationToken ct = default)
    {
        _assetSearchLoading = true;
        _assetSearchError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            _positionAssets = await Api.GetPositionAssetsAsync(_assetSearchTerm, 40, ct) ?? [];
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (Exception ex)
        {
            _positionAssets = [];
            _assetSearchError = $"{T("openPosition.loadAssetsError")} {ex.Message}";
        }
        finally
        {
            _assetSearchLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleAssetSearchInput(ChangeEventArgs args)
    {
        _assetSearchTerm = args.Value?.ToString() ?? string.Empty;
        _assetSearchDebounceCts?.Cancel();
        _assetSearchDebounceCts?.Dispose();
        _assetSearchDebounceCts = new CancellationTokenSource();

        try
        {
            await Task.Delay(250, _assetSearchDebounceCts.Token);
            await LoadPositionAssetsAsync(_assetSearchDebounceCts.Token);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void SelectAsset(PositionAssetOptionDto asset)
    {
        _selectedAsset = asset;
        _investmentAmountInput = "0.10";
        _investmentAmountError = string.Empty;
        ResetOpenPositionFeedback();
    }

    private void SetInvestmentAmount(decimal amount)
    {
        _investmentAmountInput = amount.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
        _investmentAmountError = string.Empty;
        ResetOpenPositionFeedback(clearHashOnly: true);
    }

    private void UseMaxInvestmentAmount()
    {
        SetInvestmentAmount(MaxSpendableInvestmentAmount);
    }

    private void HandleAmountInput(ChangeEventArgs args)
    {
        _investmentAmountInput = args.Value?.ToString() ?? string.Empty;
        _investmentAmountError = string.Empty;
        ResetOpenPositionFeedback(clearHashOnly: true);
    }

    private void HandleRangeInput(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var index))
            return;

        if (index < 0 || index >= QuickInvestmentAmounts.Length)
            return;

        SetInvestmentAmount(QuickInvestmentAmounts[index]);
    }

    private int _investmentAmountRangeIndex
        => GetClosestQuickInvestmentAmountIndex(_parsedInvestmentAmount);

    private static int GetClosestQuickInvestmentAmountIndex(decimal amount)
    {
        var closestIndex = 0;
        var closestDistance = decimal.MaxValue;

        for (var i = 0; i < QuickInvestmentAmounts.Length; i++)
        {
            var distance = Math.Abs(QuickInvestmentAmounts[i] - amount);
            if (distance >= closestDistance)
                continue;

            closestDistance = distance;
            closestIndex = i;
        }

        return closestIndex;
    }

    private bool IsSelectedQuickAmount(decimal amount)
        => TryParseAmount(_investmentAmountInput, out var parsed)
           && decimal.Round(parsed, 8, MidpointRounding.ToZero) == decimal.Round(amount, 8, MidpointRounding.ToZero);

    private async Task ConfirmOpenPositionAsync()
    {
        if (_wallet is null || _selectedAsset is null)
            return;

        if (!_selectedAsset.CanInvestNow)
        {
            _investmentAmountError = _selectedAsset.AccessMessage ?? T("openPosition.assetBlocked");
            return;
        }

        if (!TryParseAmount(_investmentAmountInput, out var amount) || amount <= 0m)
        {
            _investmentAmountError = T("openPosition.invalidAmount");
            return;
        }

        amount = decimal.Round(amount, 8, MidpointRounding.ToZero);
        if (!_maxSpendableSol.HasValue)
        {
            _investmentAmountError = T("openPosition.walletFundingRequired");
            return;
        }

        if (amount > MaxSpendableInvestmentAmount)
        {
            _investmentAmountError = T("openPosition.insufficientBalanceMessage", MaxSpendableText);
            return;
        }

        _openPositionBusy = true;
        _investmentAmountError = string.Empty;
        _openPositionStatusKey = "awaitingSignature";
        _openPositionTransactionHash = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var selectedSymbol = _selectedAsset.Symbol;
            var preparation = await PrepareInvestmentDiagnosticsAsync(_selectedAsset, amount);
            _openPositionTransactionHash = preparation.Signature;
            _openPositionStatusKey = "confirmingBlockchain";
            await InvokeAsync(StateHasChanged);

            _openPositionStatusKey = "openingPosition";
            if (ShouldUseDirectCustodyFlow)
            {
                await Api.OpenDirectPositionAsync(new OpenDirectPositionRequest
                {
                    Symbol = selectedSymbol,
                    AmountSol = amount,
                    Signature = preparation.Signature ?? string.Empty,
                    WalletAddress = preparation.Wallet ?? _wallet.Wallet
                });
            }
            else
            {
                await Api.CreateOrIncreasePositionAsync(new CreateTeamPositionRequest
                {
                    TeamId = _selectedAsset.TeamId,
                    Amount = amount,
                    AutoCompound = true,
                    OnChainPositionAccount = preparation.PositionPda,
                    OnChainPositionVault = preparation.PositionVaultPda,
                    OnChainSignature = preparation.Signature,
                    OnChainAmountLamports = preparation.AmountLamports
                });
            }

            _actionMessage = T("openPosition.successInline", selectedSymbol, FmtSolCompact(amount));
            _openPositionStatusKey = "positionOpened";
            await LoadWalletAsync(false);
            await LoadOnChainBalanceAsync();
            await ShowToastAsync(T("openPosition.successToast", selectedSymbol, FmtSolCompact(amount)), "success");
        }
        catch (Exception ex)
        {
            _investmentAmountError = NormalizeInvestmentError(ex.Message);
        }
        finally
        {
            _openPositionBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<InvestmentPreparationResult> PrepareInvestmentDiagnosticsAsync(PositionAssetOptionDto asset, decimal amountSol)
    {
        _investmentDiagnosticsModule ??= await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "./js/solanaInvestDiagnostics.js?v=20260505-rpc-config");

        var blockchainMode = Config["CriptoVersusBlockchain:Mode"] ?? "HybridContractCustody";
        var programId = string.Equals(blockchainMode, "FullOnChain", StringComparison.OrdinalIgnoreCase)
            ? Config["CriptoVersusBlockchain:FutureFullOnChainProgramId"]
            : Config["CriptoVersusBlockchain:CurrentHybridProgramId"] ?? Config["OnChainBetting:ProgramId"];

        if (!string.Equals(blockchainMode, "OffChainCustody", StringComparison.OrdinalIgnoreCase)
            && string.IsNullOrWhiteSpace(programId))
            throw new InvalidOperationException(T("actions.programIdMissing"));

        return await _investmentDiagnosticsModule.InvokeAsync<InvestmentPreparationResult>(
            "prepareInvestment",
            new
            {
                programId,
                origin = "Wallet",
                cluster = Config["CriptoVersusBlockchain:Cluster"] ?? Config["OnChainBetting:Cluster"] ?? "devnet",
                rpcUrl = Config["CriptoVersusBlockchain:RpcUrl"],
                matchId = (int?)null,
                teamId = asset.TeamId,
                teamName = asset.Symbol,
                amountSol,
                mode = blockchainMode,
                forceCustodyTransfer = ShouldUseDirectCustodyFlow,
                custodyWalletPublicKey = Config["CriptoVersusBlockchain:CustodyWalletPublicKey"],
                supportsLegacyPositionInvestments = Config.GetValue<bool>("OnChainBetting:EnableLegacyPositionInvestments")
            });
    }

    private async Task WithdrawSystemBalanceAsync()
    {
        if (_wallet is null || _wallet.SystemBalance <= 0m)
            return;

        _actionBusy = true;
        _actionMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            _walletActionsModule ??= await JS.InvokeAsync<IJSObjectReference>(
                "import",
                "./js/solanaWalletActions.js?v=20260505-rpc-config");

            _actionMessage = T("actions.validatingConnectedWallet");
            await InvokeAsync(StateHasChanged);

            var chainResult = await _walletActionsModule.InvokeAsync<ChainWithdrawResult>(
                "withdrawSystemBalance",
                new
                {
                    mode = BlockchainMode,
                    programId = OnChainProgramId,
                    cluster = OnChainCluster,
                    rpcUrl = Config["CriptoVersusBlockchain:RpcUrl"],
                    amountSol = _wallet.SystemBalance,
                    expectedWallet = _wallet.Wallet
                });

            if (!chainResult.supported)
            {
                _actionMessage = T("actions.modeUnsupported", BlockchainMode);
                return;
            }

            if (string.IsNullOrWhiteSpace(chainResult.connectedWallet))
            {
                _actionMessage = T("actions.walletNotConnected");
                return;
            }

            if (!string.Equals(chainResult.connectedWallet, _wallet.Wallet, StringComparison.Ordinal))
            {
                _actionMessage = T("actions.walletMismatch");
                return;
            }

            if (IsOffChainCustodyMode)
            {
                _actionMessage = T("actions.custodyWithdrawAuthorized");
                await InvokeAsync(StateHasChanged);
            }
            else if (string.IsNullOrWhiteSpace(chainResult.signature))
            {
                _actionMessage = T("actions.confirmWithdrawError");
                return;
            }
            else
            {
                _actionMessage = T("actions.transactionSent", chainResult.signature);
                await InvokeAsync(StateHasChanged);

                _actionMessage = T("actions.transactionConfirmed", chainResult.signature);
                await InvokeAsync(StateHasChanged);
            }

            var result = await Api.WithdrawSystemBalanceAsync(new WithdrawSystemBalanceRequest
            {
                Amount = _wallet.SystemBalance,
                OnChainSignature = chainResult.signature,
                ConnectedWalletPublicKey = chainResult.connectedWallet,
                WalletProofMessage = chainResult.proofMessage,
                WalletProofSignature = chainResult.proofSignature
            });

            _actionMessage = result?.Message ?? T("actions.withdrawCompleted");
            await LoadWalletAsync();
            await LoadOnChainBalanceAsync();
        }
        catch (Exception ex)
        {
            _actionMessage = ResolveWithdrawErrorMessage(ex);
        }
        finally
        {
            _actionBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RequestClosePositionAsync(TeamPositionDto position)
    {
        if (_wallet is null)
            return;

        _actionBusy = true;
        _actionMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Api.RequestClosePositionAsync(position.PositionId);
            _actionMessage = position.CanCloseNow
                ? T("actions.positionClosed", position.Symbol)
                : GetCloseRequestedMessage(position);
            await LoadWalletAsync();
            await LoadOnChainBalanceAsync();
        }
        catch (Exception ex)
        {
            _actionMessage = T("actions.positionCloseFailed", position.Symbol, ex.Message);
        }
        finally
        {
            _actionBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadOnChainBalanceAsync()
    {
        if (_wallet is null || string.IsNullOrWhiteSpace(_wallet.Wallet))
            return;

        _onChainBalanceLoading = true;
        _onChainBalanceError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            _walletBalanceModule ??= await JS.InvokeAsync<IJSObjectReference>(
                "import",
                "./js/solanaWalletBalance.js?v=20260513-wallet-guard");

            var guard = await _walletBalanceModule.InvokeAsync<WalletBalanceGuardResult>(
                "getMaxSpendableSol",
                new
                {
                    rpcUrl = Config["CriptoVersusBlockchain:RpcUrl"],
                    locale = AppCulture.ToCultureCode(CurrentCulture),
                    flowName = "MY_WALLET_BALANCE"
                });

            _onChainBalance = guard.balanceSol;
            _maxSpendableSol = guard.maxSpendableSol;
            if (!guard.ok && !string.Equals(guard.code, "INSUFFICIENT_BALANCE", StringComparison.OrdinalIgnoreCase))
                _onChainBalanceError = guard.message;
        }
        catch (Exception ex)
        {
            _onChainBalance = null;
            _maxSpendableSol = null;
            _onChainBalanceError = T("actions.balanceLookupFailed", ex.Message);
        }
        finally
        {
            _onChainBalanceLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string GetCloseRequestedMessage(TeamPositionDto position)
    {
        return position.OpenBetMatchStatus switch
        {
            "Ongoing" => T("actions.closeRequestedOngoing", position.Symbol),
            "Pending" => T("actions.closeRequestedPending", position.Symbol),
            _ => T("actions.closeRequestedDefault", position.Symbol)
        };
    }

    private async Task CopyCustodyWalletAsync()
    {
        if (_wallet is null || string.IsNullOrWhiteSpace(_wallet.CustodyWalletPublicKey))
            return;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _wallet.CustodyWalletPublicKey);
            _copyMessage = T("custody.copied");
        }
        catch (Exception ex)
        {
            _copyMessage = T("custody.copyFailed", ex.Message);
        }

        await InvokeAsync(StateHasChanged);
    }

