@rendermode InteractiveServer
@page "/minha-carteira"
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersusApiClient Api
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage

<section class="wallet-page">
    <div class="wallet-heading">
        <span>Minha Carteira</span>
        <h2>Seus investimentos</h2>
        <p>Acompanhe o saldo do sistema, as moedas em que voce investiu e o retorno de cada posicao.</p>
    </div>

    @if (_loading)
    {
        <div class="wallet-message">Carregando sua carteira...</div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="wallet-message wallet-message-danger">@_error</div>
    }
    else if (_wallet is null)
    {
        <div class="wallet-message">
            Faca login com sua carteira Solana para ver seus investimentos.
        </div>
    }
    else
    {
        <div class="wallet-profile">
            <div>
                <span class="wallet-label">Carteira conectada</span>
                <strong title="@_wallet.Wallet">@ShortWallet(_wallet.Wallet)</strong>
            </div>
            <div>
                <span class="wallet-label">Usuario</span>
                <strong>@DisplayName</strong>
            </div>
            <div>
                <span class="wallet-label">Ultimo acesso</span>
                <strong>@FmtDate(_wallet.LastLogin)</strong>
            </div>
        </div>

        <div class="wallet-metrics">
            <div class="wallet-metric">
                <span>Saldo no sistema</span>
                <strong>@FmtSol(_wallet.Balance)</strong>
            </div>
            <div class="wallet-metric">
                <span>Total investido</span>
                <strong>@FmtSol(_wallet.TotalInvested)</strong>
            </div>
            <div class="wallet-metric">
                <span>Em aberto</span>
                <strong>@FmtSol(_wallet.OpenAmount)</strong>
            </div>
            <div class="wallet-metric">
                <span>Retorno recebido</span>
                <strong>@FmtSol(_wallet.TotalPayout)</strong>
            </div>
        </div>

        <div class="wallet-section-title">
            <h3>Moedas investidas</h3>
            <span>@_wallet.OpenInvestments em aberto | @_wallet.SettledInvestments finalizados</span>
        </div>

        @if (_wallet.Investments.Count == 0)
        {
            <div class="wallet-empty">
                Voce ainda nao tem investimentos registrados. Escolha uma partida para iniciar sua primeira posicao.
            </div>
        }
        else
        {
            <div class="wallet-investments">
                @foreach (var item in _wallet.Investments)
                {
                    <article class="investment-row">
                        <div class="investment-main">
                            <span class="coin-symbol">@item.Symbol</span>
                            <div>
                                <strong>@item.CurrencyName</strong>
                                <span>contra @item.OpponentSymbol | Match #@item.MatchId</span>
                            </div>
                        </div>

                        <div class="investment-data">
                            <span>Valor</span>
                            <strong>@FmtSol(item.Amount)</strong>
                        </div>

                        <div class="investment-data">
                            <span>Status</span>
                            <strong>@item.InvestmentStatus</strong>
                        </div>

                        <div class="investment-data">
                            <span>Data</span>
                            <strong>@FmtDate(item.BetTime)</strong>
                        </div>

                        <div class="investment-data">
                            <span>Retorno</span>
                            <strong>@FmtOptionalSol(item.PayoutAmount)</strong>
                        </div>
                    </article>
                }
            </div>
        }
    }
</section>

<style>
    .wallet-page {
        display: grid;
        gap: 24px;
        max-width: 1180px;
        margin: 0 auto;
    }

    .wallet-heading {
        display: grid;
        gap: 8px;
    }

    .wallet-heading span,
    .wallet-label,
    .wallet-metric span,
    .investment-data span,
    .wallet-section-title span {
        color: #9ca3af;
        font-size: .9rem;
        font-weight: 800;
        letter-spacing: 0;
    }

    .wallet-heading h2 {
        margin: 0;
        color: #f9fafb;
        font-size: 2rem;
        font-weight: 900;
    }

    .wallet-heading p {
        margin: 0;
        max-width: 760px;
        color: #cbd5e1;
    }

    .wallet-profile,
    .wallet-metrics,
    .wallet-investments {
        display: grid;
        gap: 12px;
    }

    .wallet-profile {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        padding: 18px;
        border: 1px solid #303741;
        border-radius: 8px;
        background: #14171d;
    }

    .wallet-profile > div,
    .wallet-metric,
    .investment-data {
        display: grid;
        gap: 5px;
        min-width: 0;
    }

    .wallet-profile strong,
    .wallet-metric strong,
    .investment-data strong {
        overflow-wrap: anywhere;
    }

    .wallet-metrics {
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .wallet-metric {
        padding: 18px;
        border: 1px solid #303741;
        border-radius: 8px;
        background: #181b21;
    }

    .wallet-metric strong {
        color: #5eead4;
        font-size: 1.35rem;
    }

    .wallet-section-title {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: end;
    }

    .wallet-section-title h3 {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 900;
    }

    .investment-row {
        display: grid;
        grid-template-columns: minmax(220px, 1.6fr) repeat(4, minmax(130px, 1fr));
        gap: 14px;
        align-items: center;
        padding: 16px;
        border: 1px solid #303741;
        border-radius: 8px;
        background: #181b21;
    }

    .investment-main {
        display: flex;
        min-width: 0;
        gap: 12px;
        align-items: center;
    }

    .investment-main div {
        display: grid;
        gap: 4px;
        min-width: 0;
    }

    .investment-main span:last-child {
        color: #cbd5e1;
    }

    .coin-symbol {
        display: inline-grid;
        place-items: center;
        min-width: 54px;
        height: 38px;
        padding: 0 10px;
        border: 1px solid #2dd4bf;
        border-radius: 8px;
        color: #5eead4;
        font-weight: 900;
    }

    .wallet-message,
    .wallet-empty {
        padding: 18px;
        border: 1px solid #303741;
        border-radius: 8px;
        background: #181b21;
        color: #d1d5db;
    }

    .wallet-message-danger {
        border-color: #ef4444;
        color: #fecaca;
    }

    @@media (max-width: 980px) {
        .wallet-profile,
        .wallet-metrics,
        .investment-row {
            grid-template-columns: 1fr 1fr;
        }

        .investment-main {
            grid-column: 1 / -1;
        }
    }

    @@media (max-width: 640px) {
        .wallet-profile,
        .wallet-metrics,
        .investment-row {
            grid-template-columns: 1fr;
        }

        .wallet-section-title {
            display: grid;
            align-items: start;
        }
    }
</style>

@code {
    private MyWalletDto? _wallet;
    private bool _loading = true;
    private string? _error;

    private string DisplayName
        => !string.IsNullOrWhiteSpace(_wallet?.Name)
            ? _wallet.Name!
            : $"Usuario #{_wallet?.UserId}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await LoadWalletAsync();
    }

    private async Task LoadWalletAsync()
    {
        _loading = true;
        _error = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var token = await SessionStorage.GetItemAsync<string>("authToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                _wallet = null;
                return;
            }

            _wallet = await Api.GetMyWalletAsync();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            _wallet = null;
            _error = "Sua sessao expirou. Faca login novamente com sua carteira Solana.";
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            _wallet = null;
            _error = "A rota Minha Carteira ainda nao esta disponivel no API que esta rodando. Reinicie o projeto CriptoVersus.API local ou publique a API atualizada.";
        }
        catch (Exception ex)
        {
            _error = $"Nao foi possivel carregar sua carteira: {ex.Message}";
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string ShortWallet(string wallet)
    {
        const int start = 8;
        const int end = 6;

        if (wallet.Length <= start + end + 3)
            return wallet;

        return $"{wallet[..start]}...{wallet[^end..]}";
    }

    private static string FmtSol(decimal value)
        => $"{value:0.########} SOL";

    private static string FmtOptionalSol(decimal? value)
        => value.HasValue ? FmtSol(value.Value) : "-";

    private static string FmtDate(DateTime? value)
        => value.HasValue ? value.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "-";
}
