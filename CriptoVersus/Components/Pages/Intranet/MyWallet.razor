@rendermode InteractiveServer
@page "/minha-carteira"
@page "/pt/minha-carteira"
@page "/en/my-wallet"
@page "/zh/my-wallet"
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersusApiClient Api
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject IConfiguration Config
@inject IJSRuntime JS
@inject BrowserTimeZoneService BrowserTimeZone
@inject WalletSessionState WalletState
@inject IHttpContextAccessor HttpContextAccessor
@inject AppCultureService AppCulture
@inject LocalizationService L
@inject DashboardHubClient HubClient
@inject NavigationManager Nav
@inject RouteLocalizationService RouteLocalization
@implements IAsyncDisposable

<BasicSeoHead Title="@SeoTitle"
              Description="@SeoDescription"
              CanonicalUrl="@CanonicalUrl"
              EnglishUrl="@EnglishUrl"
              PortugueseUrl="@PortugueseUrl"
              XDefaultUrl="@EnglishUrl"
              OgLocale="@AppCulture.ToOgLocale(CurrentCulture)"
              OgAlternateLocale="@AppCulture.GetAlternateOgLocale(CurrentCulture)"
              ImageUrl="@SocialImageUrl"
              ImageAlt="@T("seo.imageAlt")"
              Robots="noindex,nofollow,noarchive" />

<section class="wallet-page">
    <div class="wallet-heading">
        <span>@T("heading.eyebrow")</span>
        <h2>@T("heading.title")</h2>
        <p>@T("heading.body")</p>
    </div>

    @if (_loading)
    {
        <div class="wallet-message">@T("states.loading")</div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="wallet-message wallet-message-danger">@_error</div>
    }
    else if (_wallet is null)
    {
        <div class="wallet-message">
            @T("states.walletRequired")
        </div>
    }
    else
    {
        <div class="wallet-profile">
            <div>
                <span class="wallet-label">@T("profile.connectedWallet")</span>
                <strong title="@_wallet.Wallet">@ShortWallet(_wallet.Wallet)</strong>
            </div>
            <div>
                <span class="wallet-label">@T("profile.user")</span>
                <strong>@DisplayName</strong>
            </div>
            <div>
                <span class="wallet-label">@WalletNetworkBalanceLabel</span>
                <strong class="wallet-balance" title="@OnChainBalanceTitle">@OnChainBalanceText</strong>
            </div>
            <div>
                <span class="wallet-label">@T("profile.lastAccess")</span>
                <strong>@FmtDate(_wallet.LastLogin)</strong>
            </div>
        </div>

        @if (IsOffChainCustodyMode)
        {
            <div class="wallet-actions-card">
                <div class="wallet-actions-summary">
                    <div>
                        <span class="wallet-label">@T("mode.operationalMode")</span>
                        <strong>@T("mode.offChainCustodyMode")</strong>
                    </div>
                    <div>
                        <span class="wallet-label">@T("custody.wallet")</span>
                        <strong>@GetCustodyLabel()</strong>
                    </div>
                </div>
                <div class="wallet-offchain-copy">
                    <div class="wallet-offchain-address">
                        <span class="wallet-label">@T("custody.publicAddress")</span>
                        <strong title="@GetCustodyWalletDisplayValue()">@GetCustodyWalletDisplayValue()</strong>
                    </div>
                    <button type="button"
                            class="wallet-history-button"
                            disabled="@string.IsNullOrWhiteSpace(_wallet.CustodyWalletPublicKey)"
                            @onclick="CopyCustodyWalletAsync">
                        @T("custody.copyWallet")
                    </button>
                </div>
                <div class="wallet-message">
                    @T("custody.explanation")
                </div>
                <div class="wallet-message">
                    @T("custody.withdrawalsDisabled")
                </div>
                @if (!string.IsNullOrWhiteSpace(_copyMessage))
                {
                    <div class="wallet-message">@_copyMessage</div>
                }
            </div>
        }

        <div class="wallet-metrics">
            <div class="wallet-metric">
                <span>@T("metrics.systemBalance")</span>
                <strong>@FmtSol(_wallet.SystemBalance)</strong>
            </div>
            <div class="wallet-metric">
                <span>@T("metrics.allocatedCapital")</span>
                <strong>@FmtSol(_wallet.TotalInvested)</strong>
            </div>
            <div class="wallet-metric">
                <span>@T("metrics.open")</span>
                <strong>@FmtSol(_wallet.OpenAmount)</strong>
            </div>
            <div class="wallet-metric">
                <span>@T("metrics.exitPositions")</span>
                <strong>@CountPositionsByStatus("ClosingRequested")</strong>
            </div>
            <div class="wallet-metric">
                <span>@T("metrics.realizedProfit")</span>
                <strong class="payout-positive">@FmtSol(_wallet.RealizedProfit)</strong>
            </div>
            <div class="wallet-metric">
                <span>@T("metrics.realizedLoss")</span>
                <strong class="payout-negative">@FmtSol(_wallet.RealizedLoss)</strong>
            </div>
            <div class="wallet-metric">
                <span>@T("metrics.realizedNetResult")</span>
                <strong class="@GetPayoutClass(_wallet.RealizedNetResult)">@FmtSignedSol(_wallet.RealizedNetResult)</strong>
            </div>
        </div>

        <div class="wallet-actions-card">
            <div class="wallet-actions-summary">
                <div>
                    <span class="wallet-label">@T("metrics.systemBalance")</span>
                    <strong>@FmtSol(_wallet.SystemBalance)</strong>
                </div>
                <div>
                    <span class="wallet-label">@T("metrics.exitPositions")</span>
                    <strong>@CountPositionsByStatus("ClosingRequested")</strong>
                </div>
            </div>
            <div class="wallet-message">
                @T("withdraw.releaseExplanation")
            </div>
            <div class="wallet-actions-buttons">
                <button type="button"
                        class="wallet-history-button wallet-open-position-trigger"
                        disabled="@_openPositionBusy"
                        @onclick="OpenPositionModalAsync">
                    @T("openPosition.cta")
                </button>
                @if (_wallet.SystemBalance > 0m)
                {
                    <button type="button"
                            class="wallet-history-button is-primary"
                            disabled="@(_actionBusy || !CanWithdrawToWallet)"
                            @onclick="WithdrawSystemBalanceAsync">
                        @(CanWithdrawToWallet ? T("actions.withdrawToWallet") : T("openPosition.insufficientBalance"))
                    </button>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(_actionMessage))
            {
                <div class="wallet-message">@_actionMessage</div>
            }
        </div>

        <div class="wallet-section-title">
            <h3>@T("openSelections.title")</h3>
            <span>@(_wallet.ActivePositions.Count == 1 ? T("openSelections.countOne", _wallet.ActivePositions.Count) : T("openSelections.countOther", _wallet.ActivePositions.Count))</span>
        </div>

        @if (_wallet.ActivePositions.Count == 0)
        {
            <div class="wallet-empty">
                @T("openSelections.empty")
            </div>
        }
        else
        {
            <div class="wallet-positions">
                @foreach (var position in _wallet.ActivePositions)
                {
                    <article class="position-row">
                        <div class="investment-main">
                            <span class="coin-symbol" title="@position.Symbol">
                                <img src="@GetCoinIconUrl(position.Symbol)"
                                     alt="@position.Symbol"
                                     loading="lazy"
                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                <span class="coin-symbol-fallback d-none">@GetInitials(position.Symbol)</span>
                            </span>
                            <div>
                                <strong><MarketPairText Symbol="@position.Symbol" /></strong>
                                <span>@position.CurrencyName</span>
                            </div>
                        </div>

                        <div class="investment-data">
                            <span>@T("openPositions.invested")</span>
                            <strong>@FmtSol(position.PrincipalAllocated)</strong>
                        </div>

                        <div class="investment-data">
                            <span>@T("openPositions.entry")</span>
                            <strong>@FmtDate(position.CreatedAt)</strong>
                        </div>

                        <div class="investment-data">
                            <span>@T("openPositions.pnl")</span>
                            <strong class="@GetPayoutClass(GetSimplePnl(position))">@FmtSignedSol(GetSimplePnl(position))</strong>
                        </div>

                        <div class="investment-data investment-data-action">
                            <span>@T("openPositions.time")</span>
                            <strong>@FmtElapsed(position.CreatedAt)</strong>
                        </div>

                        <div class="investment-data investment-data-action">
                            <span>@T("openPositions.action")</span>
                            @if (string.Equals(position.Status, "ClosingRequested", StringComparison.OrdinalIgnoreCase))
                            {
                                <strong>@T("openPositions.exitRequested")</strong>
                            }
                            else
                            {
                                <button type="button"
                                        class="wallet-history-button"
                                        disabled="@_actionBusy"
                                        @onclick="() => RequestClosePositionAsync(position)">
                                    @(position.CanCloseNow ? T("openPositions.closeNow") : T("openPositions.requestExit"))
                                </button>
                            }
                        </div>
                    </article>
                }
            </div>
        }

        <div class="wallet-section-title">
            <h3>@T("history.title")</h3>
            <span>@T("history.groupCount", _wallet.InvestmentGroups.Count)</span>
        </div>

        @if (_wallet.InvestmentGroups.Count == 0)
        {
            <div class="wallet-empty">
                @T("history.emptyGroups")
            </div>
        }
        else
        {
            <div class="wallet-investments">
                @foreach (var group in _wallet.InvestmentGroups)
                {
                    <WalletMatchHistoryGroup UserId="@_wallet.UserId" Group="@group" />
                }
            </div>
        }
    }
</section>

@if (_showOpenPositionModal)
{
    <div class="wallet-modal-backdrop" @onclick="ClosePositionModal"></div>
    <div class="wallet-modal-shell" role="dialog" aria-modal="true" aria-labelledby="wallet-open-position-title">
        <div class="wallet-modal-card" @onclick:stopPropagation="true">
            <div class="wallet-modal-header">
                <div>
                    <span class="wallet-modal-kicker">@T("modal.kicker")</span>
                    <h3 id="wallet-open-position-title">
                        @(_selectedAsset is null ? T("openPosition.modalTitle") : T("openPosition.amountTitle"))
                    </h3>
                </div>
                <div class="wallet-modal-header-actions">
                    @if (_selectedAsset is not null)
                    {
                        <button type="button" class="wallet-modal-icon-btn" @onclick="BackToAssetSelection">
                            @T("openPosition.back")
                        </button>
                    }
                    <button type="button" class="wallet-modal-icon-btn" @onclick="ClosePositionModal">
                        @T("openPosition.close")
                    </button>
                </div>
            </div>

            @if (_selectedAsset is null)
            {
                <div class="wallet-modal-body wallet-modal-body--asset-step">
                    <div class="wallet-search-sticky">
                        <label class="wallet-modal-label" for="wallet-position-search">@T("openPosition.searchLabel")</label>
                        <input id="wallet-position-search"
                               class="wallet-search-input"
                               type="search"
                               value="@_assetSearchTerm"
                               placeholder="@T("openPosition.searchPlaceholder")"
                               @oninput="HandleAssetSearchInput" />
                    </div>

                    @if (_assetSearchLoading)
                    {
                        <div class="wallet-empty">@T("openPosition.loadingAssets")</div>
                    }
                    else if (!string.IsNullOrWhiteSpace(_assetSearchError))
                    {
                        <div class="wallet-message wallet-message-danger">@_assetSearchError</div>
                    }
                    else if (_positionAssets.Count == 0)
                    {
                        <div class="wallet-empty">@T("openPosition.emptyAssets")</div>
                    }
                    else
                    {
                        <div class="wallet-asset-list">
                            @foreach (var asset in _positionAssets)
                            {
                                <button type="button"
                                        class="wallet-asset-item @(asset.CanInvestNow ? string.Empty : "wallet-asset-item--blocked")"
                                        @onclick="() => SelectAsset(asset)">
                                    <div class="wallet-asset-main">
                                        <span class="coin-symbol" title="@asset.Symbol">
                                            <img src="@GetCoinIconUrl(asset.Symbol)"
                                                 alt="@asset.Symbol"
                                                 loading="lazy"
                                                 onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                            <span class="coin-symbol-fallback d-none">@GetInitials(asset.Symbol)</span>
                                        </span>
                                        <div>
                                            <strong>@asset.Symbol</strong>
                                            <span>@asset.CurrencyName</span>
                                        </div>
                                    </div>
                                    <div class="wallet-asset-meta">
                                        @if (!string.IsNullOrWhiteSpace(asset.CurrentPriceDisplay))
                                        {
                                            <strong>@asset.CurrentPriceDisplay</strong>
                                        }
                                        else
                                        {
                                            <strong>@T("openPosition.priceUnavailable")</strong>
                                        }
                                        <span class="wallet-trend @(GetTrendClass(asset.TrendDirection))">
                                            @FmtPercentage(asset.PercentageChange)
                                        </span>
                                        <span class="wallet-asset-status @(asset.CanInvestNow ? "wallet-asset-status--ok" : "wallet-asset-status--blocked")">
                                            @GetAssetAvailabilityLabel(asset)
                                        </span>
                                        @if (!string.IsNullOrWhiteSpace(asset.AccessMessage))
                                        {
                                            <small class="wallet-asset-status-detail">@asset.AccessMessage</small>
                                        }
                                    </div>
                                </button>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="wallet-modal-body">
                    <div class="wallet-selected-asset-card">
                        <div class="investment-main">
                            <span class="coin-symbol" title="@_selectedAsset.Symbol">
                                <img src="@GetCoinIconUrl(_selectedAsset.Symbol)"
                                     alt="@_selectedAsset.Symbol"
                                     loading="lazy"
                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                <span class="coin-symbol-fallback d-none">@GetInitials(_selectedAsset.Symbol)</span>
                            </span>
                            <div>
                                <strong>@_selectedAsset.Symbol</strong>
                                <span>@_selectedAsset.CurrencyName</span>
                            </div>
                        </div>
                        <div class="wallet-selected-asset-copy">
                            <strong>@(_selectedAsset.CurrentPriceDisplay ?? T("openPosition.priceUnavailable"))</strong>
                            <span>@T("openPosition.openingOn", _selectedAsset.Symbol)</span>
                        </div>
                    </div>

                    <div class="wallet-investment-copy">
                        <span>@T("openPosition.investmentIn", _selectedAsset.Symbol)</span>
                        <strong>@T("openPosition.valueInSol")</strong>
                    </div>

                    <div class="wallet-balance-callout">
                        <div>
                            <span class="wallet-modal-label">@T("openPosition.walletBalanceLabel")</span>
                            <strong>@OnChainBalanceText</strong>
                        </div>
                        <div>
                            <span class="wallet-modal-label">@T("openPosition.maximumAvailableLabel")</span>
                            <strong>@MaxSpendableText</strong>
                        </div>
                        <div>
                            <span class="wallet-modal-label">@T("openPosition.custodyWalletLabel")</span>
                            <strong class="wallet-custody-address" title="@GetCustodyWalletDisplayValue()">@GetCustodyWalletDisplayValue()</strong>
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_selectedAsset.AccessMessage))
                    {
                        <div class="wallet-asset-access-callout @(_selectedAsset.CanInvestNow ? "wallet-asset-access-callout--ok" : "wallet-asset-access-callout--warn")">
                            @_selectedAsset.AccessMessage
                        </div>
                    }

                    <div class="wallet-direct-funding-copy">
                        <strong>@T("openPosition.directFundingTitle")</strong>
                        <span>@T("openPosition.directFundingLine1")</span>
                        <span>@T("openPosition.directFundingLine2")</span>
                    </div>

                    <label class="wallet-modal-label">@T("openPosition.chooseAmount")</label>
                    <div class="wallet-quick-grid" aria-label="@T("openPosition.quickValues")">
                        @foreach (var amount in QuickInvestmentAmounts)
                        {
                            <button type="button"
                                    class="wallet-quick-chip @(IsSelectedQuickAmount(amount) ? "wallet-quick-chip--active" : string.Empty)"
                                    @onclick="() => SetInvestmentAmount(amount)">
                                @FmtSolCompact(amount)
                            </button>
                        }
                    </div>

                    <label class="wallet-modal-label" for="walletInvestmentRange">
                        @T("openPosition.sliderLabel")
                    </label>
                    <input id="walletInvestmentRange"
                           class="form-range wallet-range"
                           type="range"
                           min="0"
                           max="@(QuickInvestmentAmounts.Length - 1)"
                           step="1"
                           value="@_investmentAmountRangeIndex"
                           @oninput="HandleRangeInput" />

                    <label class="wallet-modal-label" for="walletInvestmentAmount">@T("openPosition.amountInputLabel")</label>
                    <input id="walletInvestmentAmount"
                           class="form-control wallet-amount-input"
                           type="text"
                           inputmode="decimal"
                           value="@_investmentAmountInput"
                           @oninput="HandleAmountInput" />
                    <div class="wallet-max-row">
                        <span>@T("openPosition.networkFeeReserve")</span>
                        <button type="button"
                                class="wallet-history-button"
                                disabled="@(_onChainBalanceLoading || !_maxSpendableSol.HasValue || MaxSpendableInvestmentAmount <= 0m)"
                                @onclick="UseMaxInvestmentAmount">
                            @T("openPosition.useMax")
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(CurrentOpenPositionAmountError))
                    {
                        <div class="text-danger small">@CurrentOpenPositionAmountError</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(_openPositionStatusText) || !string.IsNullOrWhiteSpace(_openPositionTransactionHash))
                    {
                        <div class="wallet-open-position-status @OpenPositionStatusClass">
                            @if (!string.IsNullOrWhiteSpace(_openPositionStatusText))
                            {
                                <strong>@_openPositionStatusText</strong>
                            }
                            @if (!string.IsNullOrWhiteSpace(_openPositionTransactionHash))
                            {
                                <span>@T("openPosition.transactionHash", ShortTxHash(_openPositionTransactionHash))</span>
                                <small class="wallet-custody-address" title="@_openPositionTransactionHash">@_openPositionTransactionHash</small>
                            }
                        </div>
                    }
                </div>

                <div class="wallet-modal-footer">
                    <button type="button" class="wallet-history-button" @onclick="ClosePositionModal">
                        @T("openPosition.cancel")
                    </button>
                    <button type="button"
                            class="wallet-history-button is-primary wallet-invest-submit"
                            disabled="@(_openPositionBusy || _onChainBalanceLoading || !IsOpenPositionAmountValid)"
                            @onclick="ConfirmOpenPositionAsync">
                        @OpenPositionPrimaryButtonText
                    </button>
                </div>
            }
        </div>
    </div>
}

<style>
    .wallet-page {
        display: grid;
        gap: 24px;
        width: min(1180px, 100%);
        max-width: 1180px;
        margin: 0;
    }

    .wallet-heading {
        display: grid;
        gap: 8px;
    }

    .wallet-heading span,
    .wallet-label,
    .wallet-metric span,
    .investment-data span,
    .wallet-section-title span {
        color: #9ca3af;
        font-size: .9rem;
        font-weight: 800;
        letter-spacing: 0;
    }

    .wallet-heading h2 {
        margin: 0;
        color: #f9fafb;
        font-size: 2rem;
        font-weight: 900;
    }

    .wallet-heading p {
        margin: 0;
        max-width: 760px;
        color: #cbd5e1;
    }

    .wallet-max-row {
        align-items: center;
        color: #9ca3af;
        display: flex;
        gap: 12px;
        justify-content: space-between;
        margin-top: 10px;
    }

    .wallet-profile,
    .wallet-metrics,
    .wallet-positions,
    .wallet-investments,
    .wallet-actions-card {
        display: grid;
        gap: 12px;
    }

    .investment-group,
    .investment-group-details {
        display: grid;
        gap: 12px;
    }

    .wallet-profile {
        grid-template-columns: repeat(4, minmax(0, 1fr));
        padding: 18px;
        border: 1px solid #303741;
        border-radius: 8px;
        background: #14171d;
    }

    .wallet-profile > div,
    .wallet-metric,
    .investment-data {
        display: grid;
        gap: 5px;
        min-width: 0;
    }

    .wallet-profile strong,
    .wallet-metric strong,
    .investment-data strong {
        overflow-wrap: anywhere;
    }

    .wallet-balance {
        color: #5eead4;
    }

    .payout-positive {
        color: #4ade80;
    }

    .payout-negative {
        color: #f87171;
    }

    .payout-neutral {
        color: #f8fafc;
    }

    .wallet-metrics {
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .wallet-metric {
        padding: 18px;
        border: 1px solid #303741;
        border-radius: 8px;
        background: #181b21;
    }

    .wallet-actions-card {
        padding: 18px;
        border: 1px solid #1f766e;
        border-radius: 12px;
        background: linear-gradient(180deg, rgba(15, 118, 110, .14), rgba(17, 22, 29, .96));
    }

    .wallet-open-position-trigger {
        background: linear-gradient(135deg, #0ea5e9, #14b8a6);
        border-color: rgba(103, 232, 249, .9);
        box-shadow: 0 0 0 1px rgba(103, 232, 249, .28), 0 14px 30px rgba(20, 184, 166, .2);
        color: #f8feff;
        font-size: .98rem;
        font-weight: 900;
        padding-inline: 1.2rem;
    }

    .wallet-open-position-trigger:hover {
        background: linear-gradient(135deg, #22d3ee, #14b8a6);
        border-color: rgba(165, 243, 252, 1);
        color: #f8feff;
    }

    .wallet-actions-summary,
    .wallet-actions-buttons {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
    }

    .wallet-offchain-copy {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: end;
        justify-content: space-between;
    }

    .wallet-offchain-address {
        display: grid;
        gap: 4px;
        min-width: 0;
    }

    .wallet-offchain-address strong {
        overflow-wrap: anywhere;
    }

    .wallet-actions-summary > div {
        display: grid;
        gap: 4px;
    }

    .wallet-metric strong {
        color: #5eead4;
        font-size: 1.35rem;
    }

    .wallet-section-title {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: end;
    }

    .wallet-section-title h3 {
        margin: 0;
        font-size: 1.25rem;
        font-weight: 900;
    }

    .investment-row {
        display: grid;
        grid-template-columns: minmax(220px, 1.6fr) repeat(4, minmax(130px, 1fr));
        gap: 14px;
        align-items: center;
        padding: 16px;
        border: 1px solid #303741;
        border-radius: 8px;
        background: #181b21;
    }

    .position-row {
        display: grid;
        grid-template-columns: minmax(220px, 1.6fr) repeat(5, minmax(120px, 1fr));
        gap: 14px;
        align-items: center;
        padding: 16px;
        border: 1px solid #303741;
        border-radius: 8px;
        background: #181b21;
    }

    .wallet-modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: 1190;
        background:
            radial-gradient(circle at top, rgba(34, 197, 94, .08), transparent 22%),
            rgba(3, 7, 18, .82);
        backdrop-filter: blur(12px);
    }

    .wallet-modal-shell {
        position: fixed;
        inset: 0;
        z-index: 1200;
        display: grid;
        align-items: start;
        justify-items: center;
        padding: 20px;
        overflow: auto;
    }

    .wallet-modal-card {
        display: grid;
        grid-template-rows: auto minmax(0, 1fr) auto;
        gap: 0;
        width: min(100%, 840px);
        max-height: min(92vh, 920px);
        overflow: hidden;
