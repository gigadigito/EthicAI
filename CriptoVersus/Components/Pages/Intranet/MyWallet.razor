@code {
    private MyWalletDto? _wallet;
    private bool _loading = true;
    private string? _error;
    private string? _actionMessage;
    private bool _actionBusy;
    private IJSObjectReference? _walletBalanceModule;
    private IJSObjectReference? _walletActionsModule;
    private double? _onChainBalance;
    private bool _onChainBalanceLoading;
    private string? _onChainBalanceError;
    private string? _copyMessage;

    private string DisplayName
        => !string.IsNullOrWhiteSpace(_wallet?.Name)
            ? _wallet.Name!
            : $"Usuario #{_wallet?.UserId}";

    private string BlockchainMode
        => Config["CriptoVersusBlockchain:Mode"] ?? "HybridContractCustody";

    private string OnChainCluster
        => Config["CriptoVersusBlockchain:Cluster"] ?? Config["OnChainBetting:Cluster"] ?? "devnet";

    private string OnChainProgramId
        => string.Equals(BlockchainMode, "FullOnChain", StringComparison.OrdinalIgnoreCase)
            ? Config["CriptoVersusBlockchain:FutureFullOnChainProgramId"] ?? string.Empty
            : Config["CriptoVersusBlockchain:CurrentHybridProgramId"] ?? Config["OnChainBetting:ProgramId"] ?? string.Empty;

    private bool UsesOnChainContract
        => !string.Equals(BlockchainMode, "OffChainCustody", StringComparison.OrdinalIgnoreCase);

    private bool IsOffChainCustodyMode
        => string.Equals(BlockchainMode, "OffChainCustody", StringComparison.OrdinalIgnoreCase);

    private string WalletNetworkBalanceLabel
        => "Saldo on-chain";

    private string OnChainBalanceText
        => _onChainBalanceLoading
            ? "Carregando..."
            : _onChainBalanceError is not null
                ? "-"
                : _onChainBalance.HasValue
                    ? FmtSol(_onChainBalance.Value)
                    : "-";

    private string OnChainBalanceTitle
        => _onChainBalanceError is not null
            ? _onChainBalanceError
            : $"Saldo real na rede {OnChainCluster}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            await BrowserTimeZone.EnsureInitializedAsync();
            await LoadWalletAsync();
            await LoadOnChainBalanceAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex) when (InteropSafety.IsDeferredInteropException(ex))
        {
            // Fluxo depende de SessionStorage/JS e será repetido no render interativo.
        }
    }

    private async Task LoadWalletAsync()
    {
        _loading = true;
        _error = null;
        _copyMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var token = await SessionStorage.GetItemAsync<string>("authToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                _wallet = null;
                return;
            }

            _wallet = await Api.GetMyWalletAsync();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            _wallet = null;
            _error = "Sua sessao expirou. Faca login novamente com sua carteira Solana.";
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            _wallet = null;
            _error = "A rota Minha Carteira ainda nao esta disponivel no API que esta rodando. Reinicie o projeto CriptoVersus.API local ou publique a API atualizada.";
        }
        catch (Exception ex)
        {
            _error = $"Nao foi possivel carregar sua carteira: {ex.Message}";
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task WithdrawSystemBalanceAsync()
    {
        if (_wallet is null || !_wallet.CanWithdraw || _wallet.SystemBalance <= 0m)
            return;

        _actionBusy = true;
        _actionMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            string? onChainSignature = null;
            if (UsesOnChainContract)
            {
                if (string.IsNullOrWhiteSpace(OnChainProgramId))
                    throw new InvalidOperationException("CriptoVersusBlockchain program id nao configurado para o modo atual.");

                _walletActionsModule ??= await JS.InvokeAsync<IJSObjectReference>(
                    "import",
                    "./js/solanaWalletActions.js?v=20260426-claim-withdraw");

                var chainResult = await _walletActionsModule.InvokeAsync<ChainWithdrawResult>(
                    "withdrawSystemBalance",
                    new
                    {
                        programId = OnChainProgramId,
                        cluster = OnChainCluster,
                        amountSol = _wallet.SystemBalance
                    });

                onChainSignature = chainResult.signature;
            }

            var result = await Api.WithdrawSystemBalanceAsync(new WithdrawSystemBalanceRequest
            {
                Amount = _wallet.SystemBalance,
                OnChainSignature = onChainSignature
            });

            _actionMessage = result?.Message ?? "Saque registrado com sucesso.";
            await LoadWalletAsync();
            await LoadOnChainBalanceAsync();
        }
        catch (Exception ex)
        {
            _actionMessage = $"Nao foi possivel registrar o saque: {ex.Message}";
        }
        finally
        {
            _actionBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RequestClosePositionAsync(TeamPositionDto position)
    {
        if (_wallet is null)
            return;

        _actionBusy = true;
        _actionMessage = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Api.RequestClosePositionAsync(position.PositionId);
            _actionMessage = position.CanCloseNow
                ? $"A posicao {position.Symbol} foi encerrada e o saldo voltou para o sistema."
                : GetCloseRequestedMessage(position);
            await LoadWalletAsync();
            await LoadOnChainBalanceAsync();
        }
        catch (Exception ex)
        {
            _actionMessage = $"Nao foi possivel finalizar a posicao {position.Symbol}: {ex.Message}";
        }
        finally
        {
            _actionBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadOnChainBalanceAsync()
    {
        if (_wallet is null || string.IsNullOrWhiteSpace(_wallet.Wallet))
            return;

        _onChainBalanceLoading = true;
        _onChainBalanceError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            _walletBalanceModule ??= await JS.InvokeAsync<IJSObjectReference>(
                "import",
                "./js/solanaWalletBalance.js?v=20260419-onchain-balance");

            _onChainBalance = await _walletBalanceModule.InvokeAsync<double>(
                "getSolBalance",
                _wallet.Wallet,
                OnChainCluster);
        }
        catch (Exception ex)
        {
            _onChainBalance = null;
            _onChainBalanceError = $"Nao foi possivel consultar o saldo on-chain: {ex.Message}";
        }
        finally
        {
            _onChainBalanceLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string GetCloseRequestedMessage(TeamPositionDto position)
    {
        return position.OpenBetMatchStatus switch
        {
            "Ongoing" => $"A posicao {position.Symbol} ficou com saida solicitada. Como ela ainda participa de uma partida em andamento, o saldo sera liberado para o sistema assim que essa partida for liquidada.",
            "Pending" => $"A posicao {position.Symbol} ficou com saida solicitada. Ela ja esta vinculada a uma partida aberta e o saldo sera liberado para o sistema quando essa partida for encerrada.",
            _ => $"A posicao {position.Symbol} ficou com saida solicitada. O saldo sera liberado para o sistema quando a partida vinculada for encerrada."
        };
    }

    private async Task CopyCustodyWalletAsync()
    {
        if (_wallet is null || string.IsNullOrWhiteSpace(_wallet.CustodyWalletPublicKey))
            return;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", _wallet.CustodyWalletPublicKey);
            _copyMessage = "Carteira de custodia copiada.";
        }
        catch (Exception ex)
        {
            _copyMessage = $"Nao foi possivel copiar a carteira: {ex.Message}";
        }

        await InvokeAsync(StateHasChanged);
    }

    private string GetCustodyLabel()
        => string.IsNullOrWhiteSpace(_wallet?.CustodyWalletLabel)
            ? "Custodia configurada"
            : _wallet!.CustodyWalletLabel;

    private string GetCustodyWalletDisplayValue()
        => string.IsNullOrWhiteSpace(_wallet?.CustodyWalletPublicKey)
            ? "Nao configurada"
            : _wallet!.CustodyWalletPublicKey;

    private static string ShortWallet(string wallet)
    {
        const int start = 8;
        const int end = 6;

        if (wallet.Length <= start + end + 3)
            return wallet;

        return $"{wallet[..start]}...{wallet[^end..]}";
    }

    private static string FmtSol(decimal value)
        => $"{value:0.########} SOL";

    private static string FmtSol(double value)
        => $"{value:0.########} SOL";

    private static string FmtOptionalSol(decimal? value)
        => value.HasValue ? FmtSol(value.Value) : "-";

    private static string FmtSignedSol(decimal value)
        => value > 0m
            ? $"+{value:0.########} SOL"
            : value < 0m
                ? $"-{Math.Abs(value):0.########} SOL"
                : "0 SOL";

    private static string GetPayoutClass(decimal value)
        => value > 0m
            ? "payout-positive"
            : value < 0m
                ? "payout-negative"
                : "payout-neutral";

    private static string GetPayoutClass(decimal? value)
        => value.HasValue ? GetPayoutClass(value.Value) : "payout-neutral";

    private string FmtDate(DateTime? value)
        => BrowserTimeZone.FormatDateTime(value, "pt-BR");

    private static string FmtPositionStatus(string status)
        => status switch
        {
            "Active" => "Ativa",
            "ClosingRequested" => "Saida solicitada",
            "Closed" => "Encerrada",
            "Paused" => "Pausada",
            _ => status
        };

    private int CountPositionsByStatus(string status)
        => _wallet?.ActivePositions.Count(p => string.Equals(p.Status, status, StringComparison.OrdinalIgnoreCase)) ?? 0;

    private static string GetBaseSymbol(string pair)
    {
        if (string.IsNullOrWhiteSpace(pair))
            return "";

        pair = pair.Trim().ToUpperInvariant();

        var quotes = new[] { "USDT", "USDC", "BUSD", "BRL", "EUR", "BTC", "ETH" };

        foreach (var quote in quotes)
        {
            if (pair.EndsWith(quote, StringComparison.OrdinalIgnoreCase) && pair.Length > quote.Length)
                return pair[..^quote.Length];
        }

        return pair;
    }

    private static string GetCoinIconUrl(string symbol)
        => $"https://criptoversus-api.duckdns.org/api/icons/binance/{GetBaseSymbol(symbol)}";

    private static string GetInitials(string value)
    {
        var symbol = GetBaseSymbol(value);

        if (string.IsNullOrWhiteSpace(symbol))
            return "?";

        return symbol.Length <= 3 ? symbol : symbol[..3];
    }

    public async ValueTask DisposeAsync()
    {
        if (_walletBalanceModule is not null)
            await _walletBalanceModule.DisposeAsync();

        if (_walletActionsModule is not null)
            await _walletActionsModule.DisposeAsync();
    }
