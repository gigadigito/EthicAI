@rendermode InteractiveServer
@page "/minha-carteira"
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersusApiClient Api
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject IConfiguration Config
@inject IJSRuntime JS
@implements IAsyncDisposable

<section class="wallet-page">
    <div class="wallet-heading">
        <span>Minha Carteira</span>
        <h2>Seus investimentos</h2>
        <p>Acompanhe o saldo do sistema, as moedas em que voce investiu e o retorno de cada posicao.</p>
    </div>

    @if (_loading)
    {
        <div class="wallet-message">Carregando sua carteira...</div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="wallet-message wallet-message-danger">@_error</div>
    }
    else if (_wallet is null)
    {
        <div class="wallet-message">
            Faca login com sua carteira Solana para ver seus investimentos.
        </div>
    }
    else
    {
        <div class="wallet-profile">
            <div>
                <span class="wallet-label">Carteira conectada</span>
                <strong title="@_wallet.Wallet">@ShortWallet(_wallet.Wallet)</strong>
            </div>
            <div>
                <span class="wallet-label">Usuario</span>
                <strong>@DisplayName</strong>
            </div>
            <div>
                <span class="wallet-label">Saldo on-chain</span>
                <strong class="wallet-balance" title="@OnChainBalanceTitle">@OnChainBalanceText</strong>
            </div>
            <div>
                <span class="wallet-label">Ultimo acesso</span>
                <strong>@FmtDate(_wallet.LastLogin)</strong>
            </div>
        </div>

        <div class="wallet-metrics">
            <div class="wallet-metric">
                <span>Saldo no sistema</span>
                <strong>@FmtSol(_wallet.Balance)</strong>
            </div>
            <div class="wallet-metric">
                <span>Total investido</span>
                <strong>@FmtSol(_wallet.TotalInvested)</strong>
            </div>
            <div class="wallet-metric">
                <span>Em aberto</span>
                <strong>@FmtSol(_wallet.OpenAmount)</strong>
            </div>
            <div class="wallet-metric">
                <span>Lucro realizado</span>
                <strong class="payout-positive">@FmtSol(_wallet.RealizedProfit)</strong>
            </div>
            <div class="wallet-metric">
                <span>Perda realizada</span>
                <strong class="payout-negative">@FmtLossSol(_wallet.RealizedLoss)</strong>
            </div>
            <div class="wallet-metric">
                <span>Resultado liquido realizado</span>
                <strong class="@GetPayoutClass(_wallet.NetSettledResult)">@FmtSignedSol(_wallet.NetSettledResult)</strong>
            </div>
        </div>

        <div class="wallet-section-title">
            <h3>Posicoes ativas</h3>
            <span>@_wallet.ActivePositions.Count alocadas</span>
        </div>

        @if (_wallet.ActivePositions.Count == 0)
        {
            <div class="wallet-empty">
                Voce ainda nao tem posicoes recorrentes. Ao investir em um ativo, o capital passa a acompanhar os proximos ciclos desse time.
            </div>
        }
        else
        {
            <div class="wallet-positions">
                @foreach (var position in _wallet.ActivePositions)
                {
                    <article class="position-row">
                        <div class="investment-main">
                            <span class="coin-symbol" title="@position.Symbol">
                                <img src="@GetCoinIconUrl(position.Symbol)"
                                     alt="@position.Symbol"
                                     loading="lazy"
                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                <span class="coin-symbol-fallback d-none">@GetInitials(position.Symbol)</span>
                            </span>
                            <div>
                                <strong><MarketPairText Symbol="@position.Symbol" /></strong>
                                <span>@position.CurrencyName</span>
                            </div>
                        </div>

                        <div class="investment-data">
                            <span>Capital atual</span>
                            <strong>@FmtSol(position.CurrentCapital)</strong>
                        </div>

                        <div class="investment-data">
                            <span>Total alocado</span>
                            <strong>@FmtSol(position.PrincipalAllocated)</strong>
                        </div>

                        <div class="investment-data">
                            <span>Status</span>
                            <strong>@FmtPositionStatus(position.Status)</strong>
                        </div>
                    </article>
                }
            </div>
        }

        <div class="wallet-section-title">
            <h3>Moedas investidas</h3>
            <span>@_wallet.OpenInvestments em aberto | @_wallet.SettledInvestments finalizados</span>
        </div>

        @if (_wallet.Investments.Count == 0)
        {
            <div class="wallet-empty">
                Voce ainda nao tem investimentos registrados. Escolha uma partida para iniciar sua primeira posicao.
            </div>
        }
        else
        {
            <div class="wallet-investments">
                @foreach (var group in InvestmentGroups)
                {
                    var isExpanded = IsInvestmentGroupExpanded(group.Symbol);

                    <article class="investment-group">
                        <button type="button"
                                class="investment-group-header"
                                @onclick="() => ToggleInvestmentGroup(group.Symbol)"
                                aria-expanded="@isExpanded">
                            <div class="investment-main">
                                <span class="coin-symbol" title="@group.Symbol">
                                    <img src="@GetCoinIconUrl(group.Symbol)"
                                         alt="@group.Symbol"
                                         loading="lazy"
                                         onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                    <span class="coin-symbol-fallback d-none">@GetInitials(group.Symbol)</span>
                                </span>
                                <div>
                                    <strong>@group.CurrencyName</strong>
                                    <span class="investment-count-badge">@group.InvestmentCount partida@(group.InvestmentCount == 1 ? "" : "s") registrada@(group.InvestmentCount == 1 ? "" : "s")</span>
                                </div>
                            </div>

                            <div class="investment-data">
                                <span>Total</span>
                                <strong>@FmtSol(group.TotalAmount)</strong>
                            </div>

                            <div class="investment-data">
                                <span>Em aberto</span>
                                <strong>@group.OpenCount</strong>
                            </div>

                            <div class="investment-data">
                                <span>Ultima entrada</span>
                                <strong>@FmtDate(group.LastBetTime)</strong>
                            </div>

                            <div class="investment-data">
                                <span>Retorno</span>
                                <strong class="@GetPayoutClass(group.TotalPayout)">@FmtSignedSol(group.TotalPayout)</strong>
                            </div>

                            <span class="investment-toggle">@(isExpanded ? "Ocultar" : "Ver detalhes")</span>
                        </button>

                        @if (isExpanded)
                        {
                            <div class="investment-group-details">
                                @foreach (var item in group.Items)
                                {
                                    <article class="investment-row">
                                        <div class="investment-main">
                                            <span class="coin-symbol" title="@item.Symbol">
                                                <img src="@GetCoinIconUrl(item.Symbol)"
                                                     alt="@item.Symbol"
                                                     loading="lazy"
                                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                                <span class="coin-symbol-fallback d-none">@GetInitials(item.Symbol)</span>
                                            </span>
                                            <div>
                                                <strong>@item.CurrencyName</strong>
                                                <div class="investment-versus">
                                                    <span class="investment-versus-label">VS</span>
                                                    <span class="investment-versus-opponent">
                                                        <span class="investment-versus-icon" title="@item.OpponentSymbol">
                                                            <img src="@GetCoinIconUrl(item.OpponentSymbol)"
                                                                 alt="@item.OpponentSymbol"
                                                                 loading="lazy"
                                                                 onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                                            <span class="coin-symbol-fallback d-none">@GetInitials(item.OpponentSymbol)</span>
                                                        </span>
                                                        <MarketPairText Symbol="@item.OpponentSymbol" />
                                                    </span>
                                                    <span class="investment-match-id">| Match #@item.MatchId</span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="investment-data">
                                            <span>Valor</span>
                                            <strong>@FmtSol(item.Amount)</strong>
                                        </div>

                                        <div class="investment-data">
                                            <span>Status</span>
                                            <strong>@item.InvestmentStatus</strong>
                                        </div>

                                        <div class="investment-data">
                                            <span>Data</span>
                                            <strong>@FmtDate(item.BetTime)</strong>
                                        </div>

                                        <div class="investment-data">
                                            <span>Retorno</span>
                                            <strong class="@GetPayoutClass(item.PayoutAmount)">@FmtOptionalSignedSol(item.PayoutAmount)</strong>
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                    </article>
                }
            </div>
        }
    }
</section>

