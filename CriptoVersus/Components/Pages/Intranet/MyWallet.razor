@code {
    private MyWalletDto? _wallet;
    private bool _loading = true;
    private string? _error;
    private IJSObjectReference? _walletBalanceModule;
    private double? _onChainBalance;
    private bool _onChainBalanceLoading;
    private string? _onChainBalanceError;
    private readonly HashSet<string> _expandedInvestmentGroups = new(StringComparer.OrdinalIgnoreCase);

    private string DisplayName
        => !string.IsNullOrWhiteSpace(_wallet?.Name)
            ? _wallet.Name!
            : $"Usuario #{_wallet?.UserId}";

    private string OnChainCluster
        => Config["OnChainBetting:Cluster"] ?? "devnet";

    private string OnChainBalanceText
        => _onChainBalanceLoading
            ? "Carregando..."
            : _onChainBalanceError is not null
                ? "-"
                : _onChainBalance.HasValue
                    ? FmtSol(_onChainBalance.Value)
                    : "-";

    private string OnChainBalanceTitle
        => _onChainBalanceError is not null
            ? _onChainBalanceError
            : $"Saldo real na rede {OnChainCluster}";

    private IReadOnlyList<InvestmentGroupViewModel> InvestmentGroups
        => _wallet?.Investments
            .GroupBy(item => item.Symbol, StringComparer.OrdinalIgnoreCase)
            .Select(group =>
            {
                var orderedItems = group
                    .OrderByDescending(item => item.BetTime)
                    .ThenByDescending(item => item.MatchId)
                    .ToList();

                return new InvestmentGroupViewModel
                {
                    Symbol = group.Key,
                    CurrencyName = orderedItems[0].CurrencyName,
                    TotalAmount = orderedItems.Sum(item => item.Amount),
                    TotalPayout = orderedItems.Sum(item => item.PayoutAmount ?? 0m),
                    OpenCount = orderedItems.Count(IsOpenInvestment),
                    InvestmentCount = orderedItems.Count,
                    LastBetTime = orderedItems[0].BetTime,
                    Items = orderedItems
                };
            })
            .OrderByDescending(group => group.OpenCount)
            .ThenByDescending(group => group.TotalAmount)
            .ThenBy(group => group.Symbol, StringComparer.OrdinalIgnoreCase)
            .ToList()
            ?? [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await LoadWalletAsync();
        await LoadOnChainBalanceAsync();
    }

    private async Task LoadWalletAsync()
    {
        _loading = true;
        _error = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var token = await SessionStorage.GetItemAsync<string>("authToken");
            if (string.IsNullOrWhiteSpace(token))
            {
                _wallet = null;
                return;
            }

            _wallet = await Api.GetMyWalletAsync();
            SyncExpandedInvestmentGroups();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            _wallet = null;
            _error = "Sua sessao expirou. Faca login novamente com sua carteira Solana.";
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            _wallet = null;
            _error = "A rota Minha Carteira ainda nao esta disponivel no API que esta rodando. Reinicie o projeto CriptoVersus.API local ou publique a API atualizada.";
        }
        catch (Exception ex)
        {
            _error = $"Nao foi possivel carregar sua carteira: {ex.Message}";
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleInvestmentGroup(string symbol)
    {
        if (!_expandedInvestmentGroups.Add(symbol))
            _expandedInvestmentGroups.Remove(symbol);
    }

    private bool IsInvestmentGroupExpanded(string symbol)
        => _expandedInvestmentGroups.Contains(symbol);

    private void SyncExpandedInvestmentGroups()
    {
        if (_wallet is null)
        {
            _expandedInvestmentGroups.Clear();
            return;
        }

        var activeSymbols = _wallet.Investments
            .Select(item => item.Symbol)
            .Where(symbol => !string.IsNullOrWhiteSpace(symbol))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        _expandedInvestmentGroups.RemoveWhere(symbol => !activeSymbols.Contains(symbol));
    }

    private async Task LoadOnChainBalanceAsync()
    {
        if (_wallet is null || string.IsNullOrWhiteSpace(_wallet.Wallet))
            return;

        _onChainBalanceLoading = true;
        _onChainBalanceError = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            _walletBalanceModule ??= await JS.InvokeAsync<IJSObjectReference>(
                "import",
                "./js/solanaWalletBalance.js?v=20260419-onchain-balance");

            _onChainBalance = await _walletBalanceModule.InvokeAsync<double>(
                "getSolBalance",
                _wallet.Wallet,
                OnChainCluster);
        }
        catch (Exception ex)
        {
            _onChainBalance = null;
            _onChainBalanceError = $"Nao foi possivel consultar o saldo on-chain: {ex.Message}";
        }
        finally
        {
            _onChainBalanceLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string ShortWallet(string wallet)
    {
        const int start = 8;
        const int end = 6;

        if (wallet.Length <= start + end + 3)
            return wallet;

        return $"{wallet[..start]}...{wallet[^end..]}";
    }

    private static string FmtSol(decimal value)
        => $"{value:0.########} SOL";

    private static string FmtSol(double value)
        => $"{value:0.########} SOL";

    private static string FmtOptionalSol(decimal? value)
        => value.HasValue ? FmtSol(value.Value) : "-";

    private static string FmtSignedSol(decimal value)
        => value > 0m
            ? $"+{value:0.########} SOL"
            : value < 0m
                ? $"-{Math.Abs(value):0.########} SOL"
                : "0 SOL";

    private static string FmtOptionalSignedSol(decimal? value)
        => value.HasValue ? FmtSignedSol(value.Value) : "-";

    private static string FmtLossSol(decimal value)
        => value > 0m ? $"-{value:0.########} SOL" : "0 SOL";

    private static string GetPayoutClass(decimal value)
        => value > 0m
            ? "payout-positive"
            : value < 0m
                ? "payout-negative"
                : "payout-neutral";

    private static string GetPayoutClass(decimal? value)
        => value.HasValue ? GetPayoutClass(value.Value) : "payout-neutral";

    private static string FmtDate(DateTime? value)
        => value.HasValue ? value.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "-";

    private static string FmtPositionStatus(string status)
        => status switch
        {
            "Active" => "Ativa",
            "ClosingRequested" => "Saida solicitada",
            "Closed" => "Encerrada",
            "Paused" => "Pausada",
            _ => status
        };

    private static bool IsOpenInvestment(MyInvestmentDto investment)
        => investment.MatchStatus is "Pending" or "Ongoing";

    private static string GetBaseSymbol(string pair)
    {
        if (string.IsNullOrWhiteSpace(pair))
            return "";

        pair = pair.Trim().ToUpperInvariant();

        var quotes = new[] { "USDT", "USDC", "BUSD", "BRL", "EUR", "BTC", "ETH" };

        foreach (var quote in quotes)
        {
            if (pair.EndsWith(quote, StringComparison.OrdinalIgnoreCase) && pair.Length > quote.Length)
                return pair[..^quote.Length];
        }

        return pair;
    }

    private static string GetCoinIconUrl(string symbol)
        => $"https://criptoversus-api.duckdns.org/api/icons/binance/{GetBaseSymbol(symbol)}";

    private static string GetInitials(string value)
    {
        var symbol = GetBaseSymbol(value);

        if (string.IsNullOrWhiteSpace(symbol))
            return "?";

        return symbol.Length <= 3 ? symbol : symbol[..3];
    }

    public async ValueTask DisposeAsync()
    {
        if (_walletBalanceModule is not null)
            await _walletBalanceModule.DisposeAsync();
    }

