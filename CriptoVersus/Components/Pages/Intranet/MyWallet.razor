    private string? _openPositionStatusKey;
    private string? _openPositionTransactionHash;
    private List<PositionAssetOptionDto> _positionAssets = [];
    private PositionAssetOptionDto? _selectedAsset;
    private CancellationTokenSource? _assetSearchDebounceCts;

    private string CurrentCulture
        => AppCulture.DetectPreferredRouteCulture(HttpContextAccessor.HttpContext);
    private string SeoTitle => T("seo.title");
    private string SeoDescription => T("seo.description");
    private string CanonicalUrl => SeoDefaults.BuildAbsoluteUrl(Config, Nav, RouteLocalization.BuildWalletPath(CurrentCulture));
    private string EnglishUrl => SeoDefaults.BuildAbsoluteUrl(Config, Nav, RouteLocalization.BuildWalletPath("en"));
    private string PortugueseUrl => SeoDefaults.BuildAbsoluteUrl(Config, Nav, RouteLocalization.BuildWalletPath("pt"));
    private string SocialImageUrl => SeoDefaults.BuildAbsoluteUrl(Config, Nav, SeoDefaults.DefaultSocialImagePath);

    private string DisplayName
        => !string.IsNullOrWhiteSpace(_wallet?.Name)
            ? _wallet.Name!
            : T("fallbackUser", _wallet?.UserId ?? 0);

    private string BlockchainMode
        => Config["CriptoVersusBlockchain:Mode"] ?? "HybridContractCustody";

    private string OnChainCluster
        => Config["CriptoVersusBlockchain:Cluster"] ?? Config["OnChainBetting:Cluster"] ?? "devnet";

    private string OnChainProgramId
        => string.Equals(BlockchainMode, "FullOnChain", StringComparison.OrdinalIgnoreCase)
            ? Config["CriptoVersusBlockchain:FutureFullOnChainProgramId"] ?? string.Empty
            : Config["CriptoVersusBlockchain:CurrentHybridProgramId"] ?? Config["OnChainBetting:ProgramId"] ?? string.Empty;

    private bool UsesOnChainContract
        => !string.Equals(BlockchainMode, "OffChainCustody", StringComparison.OrdinalIgnoreCase);

    private bool IsOffChainCustodyMode
        => string.Equals(BlockchainMode, "OffChainCustody", StringComparison.OrdinalIgnoreCase);

    private bool ShouldUseDirectCustodyFlow
        => IsOffChainCustodyMode;

    private string WalletNetworkBalanceLabel
        => T("walletNetworkBalance");

    private string OnChainBalanceText
        => _onChainBalanceLoading
            ? T("states.loadingShort")
            : _onChainBalanceError is not null
                ? "-"
                : _onChainBalance.HasValue
                    ? FmtSol(_onChainBalance.Value)
                    : "-";

    private string OnChainBalanceTitle
        => _onChainBalanceError is not null
            ? _onChainBalanceError
            : T("onChainBalanceTitle", OnChainCluster);

    private decimal _parsedInvestmentAmount
        => ParseAmountOrDefault(_investmentAmountInput);

    private decimal MaxSpendableInvestmentAmount
        => _maxSpendableSol.HasValue
            ? decimal.Round((decimal)Math.Max(0d, _maxSpendableSol.Value), 8, MidpointRounding.ToZero)
            : 0m;

    private string MaxSpendableText
        => _onChainBalanceLoading
            ? T("states.loadingShort")
            : _maxSpendableSol.HasValue
                ? FmtSol(_maxSpendableSol.Value)
                : "-";

    private bool IsOpenPositionAmountInsufficient
        => TryParseAmount(_investmentAmountInput, out var amount)
           && amount > 0m
           && _maxSpendableSol.HasValue
           && amount > MaxSpendableInvestmentAmount;

    private bool IsOpenPositionAmountValid
        => TryParseAmount(_investmentAmountInput, out var amount)
           && amount > 0m
           && _maxSpendableSol.HasValue
           && amount <= MaxSpendableInvestmentAmount;

    private string OpenPositionPrimaryButtonText
        => _openPositionBusy
            ? T("openPosition.investing")
            : IsOpenPositionAmountInsufficient
                ? T("openPosition.insufficientBalance")
                : T("openPosition.investCta", FmtSolCompact(_parsedInvestmentAmount));

    private string? CurrentOpenPositionAmountError
        => !string.IsNullOrWhiteSpace(_investmentAmountError)
            ? _investmentAmountError
            : IsOpenPositionAmountInsufficient
                ? T("openPosition.insufficientBalanceMessage", MaxSpendableText)
                : null;

    private bool CanWithdrawToWallet
        => _wallet?.SystemBalance > 0m
           && !_onChainBalanceLoading
           && _onChainBalance.HasValue
           && _onChainBalance.Value >= 0.00001d;

    private string? _openPositionStatusText
        => _openPositionStatusKey switch
        {
            "awaitingSignature" => T("openPosition.statusAwaitingSignature"),
            "confirmingBlockchain" => T("openPosition.statusConfirmingBlockchain"),
            "openingPosition" => T("openPosition.statusOpeningPosition"),
            "positionOpened" => T("openPosition.statusPositionOpened"),
            _ => null
        };

