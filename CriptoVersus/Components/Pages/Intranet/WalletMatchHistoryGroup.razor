@using System.Globalization
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersusApiClient Api
@inject BrowserTimeZoneService BrowserTimeZone
@inject IConfiguration Config
@inject AppCultureService AppCulture
@inject LocalizationService L

<article class="investment-group wallet-history-group">
    <div class="wallet-history-summary">
        <div class="investment-main">
            <span class="coin-symbol" title="@Group.Symbol">
                <img src="@GetCoinIconUrl(Group.Symbol)"
                     alt="@Group.Symbol"
                     loading="lazy"
                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                <span class="coin-symbol-fallback d-none">@GetInitials(Group.Symbol)</span>
            </span>
            <div>
                <strong><MarketPairText Symbol="@Group.Symbol" /></strong>
                <span>@Group.CurrencyName</span>
                <span class="investment-count-badge">@SummaryText</span>
            </div>
        </div>

        <div class="wallet-history-grid">
            <div class="wallet-history-kpi">
                <span>@T("history.metrics.allocatedCapital")</span>
                <strong>@FmtSol(Group.TotalInvested)</strong>
            </div>
            <div class="wallet-history-kpi">
                <span>@T("history.metrics.open")</span>
                <strong>@FmtSol(Group.OpenAmount)</strong>
            </div>
            <div class="wallet-history-kpi">
                <span>@T("history.metrics.refundedMatches")</span>
                <strong>@Group.RefundedCount</strong>
            </div>
            <div class="wallet-history-kpi">
                <span>@T("history.metrics.realizedNetResult")</span>
                <strong class="@GetPayoutClass(Group.RealizedNetResult)">@FmtSignedSol(Group.RealizedNetResult)</strong>
            </div>
            <div class="wallet-history-kpi">
                <span>@T("history.metrics.wonMatches")</span>
                <strong>@Group.WonCount</strong>
            </div>
            <div class="wallet-history-kpi">
                <span>@T("history.metrics.lostMatches")</span>
                <strong>@Group.LostCount</strong>
            </div>
            <div class="wallet-history-kpi">
                <span>@T("history.metrics.lastEntry")</span>
                <strong>@FmtDate(Group.LastBetTime)</strong>
            </div>
        </div>

        <button type="button" class="wallet-history-button @(_expanded ? "is-primary" : "")" @onclick="ToggleAsync">
            @(_expanded ? T("history.hideMatches") : T("history.showMatches"))
        </button>
    </div>

    @if (_expanded)
    {
        <div class="wallet-history-body">
            <div class="wallet-history-toolbar">
                <div class="wallet-history-filters">
                    @foreach (var option in Filters)
                    {
                        <button type="button"
                                class="wallet-history-filter @(_status == option.Value ? "is-active" : "")"
                                @onclick="() => ChangeFilterAsync(option.Value)">
                            @T($"history.filters.{option.Value}")
                        </button>
                    }
                </div>
                @if (_page is not null)
                {
                    <span>@T("history.pageInfo", _page.Page, _page.TotalPages, _page.TotalItems)</span>
                }
            </div>

            @if (_loading)
            {
                <div class="wallet-message">@T("history.loading")</div>
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <div class="wallet-message wallet-message-danger">@_error</div>
            }
            else if (_page is null || _page.Items.Count == 0)
            {
                <div class="wallet-empty">@T("history.emptyResults")</div>
            }
            else
            {
                @foreach (var item in _page.Items)
                {
                    var detailsOpen = _expandedMatches.Contains(item.BetId);
                    <article class="wallet-match-card">
                        <div class="wallet-match-top">
                            <div>
                                <div class="wallet-match-line">
                                    <strong>@item.UserTeamSymbol</strong>
                                    <span>@T("history.vs")</span>
                                    <strong>@item.OpponentSymbol</strong>
                                    <span class="investment-count-badge">@T("history.matchNumber", item.MatchId)</span>
                                </div>
                                <div class="wallet-match-meta">
                                    <span>@T("history.myTeam", item.UserTeamSymbol)</span>
                                    <span>@item.MatchResultSummary</span>
                                    <span>@T("history.winner", item.WinnerTeamSymbol ?? "-")</span>
                                </div>
                            </div>
                            <span class="wallet-result-badge @GetResultBadgeClass(item)">@GetFinancialStatusLabel(item)</span>
                        </div>

                        <div class="wallet-history-grid">
                            <div class="wallet-history-kpi"><span>@T("history.betAmount")</span><strong>@FmtSol(item.BetAmount)</strong></div>
                            <div class="wallet-history-kpi"><span>@T("history.receivedAmount")</span><strong>@FmtSol(item.ReceivedAmount)</strong></div>
                            <div class="wallet-history-kpi"><span>@T("history.netResult")</span><strong class="@GetPayoutClass(item.IsOpen ? (decimal?)null : item.NetResult)">@(item.IsOpen ? T("history.open") : FmtSignedSol(item.NetResult))</strong></div>
                            <div class="wallet-history-kpi"><span>@T("history.refund")</span><strong>@FmtOptionalSol(item.RefundAmount > 0m ? item.RefundAmount : null)</strong></div>
                            <div class="wallet-history-kpi"><span>@T("history.houseFee")</span><strong>@FmtOptionalSol(item.HouseFeeAmount > 0m ? item.HouseFeeAmount : null)</strong></div>
                            <div class="wallet-history-kpi"><span>@T("history.financialStatus")</span><strong class="@GetFinancialStatusClass(item)">@GetFinancialStatusLabel(item)</strong></div>
                        </div>

                        <p class="wallet-history-summary-text @GetSummaryTextClass(item)">@item.HumanSummary</p>

                        <button type="button" class="wallet-history-button" @onclick="() => ToggleMatchDetail(item.BetId)">
                            @(detailsOpen ? T("history.hideMatchDetails") : T("history.showMatchDetails"))
                        </button>

                        @if (detailsOpen)
                        {
                            <div class="wallet-match-detail">
                                <div class="wallet-history-grid">
                                    <div class="wallet-history-kpi"><span>@T("history.start")</span><strong>@FmtDate(item.MatchStartTime)</strong></div>
                                    <div class="wallet-history-kpi"><span>@T("history.end")</span><strong>@FmtDate(item.MatchEndTime)</strong></div>
                                    <div class="wallet-history-kpi"><span>@T("history.matchStatus")</span><strong>@FmtMatchStatus(item.MatchStatus)</strong></div>
                                    <div class="wallet-history-kpi"><span>@T("history.teamAWallets")</span><strong>@item.WalletCountTeamA</strong></div>
                                    <div class="wallet-history-kpi"><span>@T("history.teamBWallets")</span><strong>@item.WalletCountTeamB</strong></div>
                                    <div class="wallet-history-kpi"><span>@T("history.teamABets")</span><strong>@item.BetCountTeamA</strong></div>
                                    <div class="wallet-history-kpi"><span>@T("history.teamBBets")</span><strong>@item.BetCountTeamB</strong></div>
                                    <div class="wallet-history-kpi"><span>@T("history.totalTeamA")</span><strong>@FmtSol(item.TotalBetOnTeamA)</strong></div>
                                    <div class="wallet-history-kpi"><span>@T("history.totalTeamB")</span><strong>@FmtSol(item.TotalBetOnTeamB)</strong></div>
                                    <div class="wallet-history-kpi"><span>@T("history.totalPool")</span><strong>@FmtSol(item.TotalPool)</strong></div>
                                    <div class="wallet-history-kpi"><span>@T("history.winningPool")</span><strong>@FmtSol(item.WinningPool)</strong></div>
                                    <div class="wallet-history-kpi"><span>@T("history.losingPool")</span><strong>@FmtSol(item.LosingPool)</strong></div>
                                    <div class="wallet-history-kpi"><span>@T("history.totalDistributed")</span><strong>@FmtSol(item.TotalDistributed)</strong></div>
                                    <div class="wallet-history-kpi"><span>@T("history.validDispute")</span><strong>@(item.HasValidFinancialDispute ? T("history.yes") : T("history.no"))</strong></div>
                                    <div class="wallet-history-kpi"><span>@T("history.settlementReason")</span><strong>@(item.SettlementReasonCode ?? "-")</strong></div>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(item.SettlementReasonDetail))
                                {
                                    <p class="wallet-history-summary-text mb-0">@item.SettlementReasonDetail</p>
                                }

                                <div class="wallet-history-steps">
                                    @foreach (var step in item.SettlementSteps)
                                    {
                                        <div class="wallet-history-step">@step</div>
                                    }
                                </div>

                                @if (item.Participants.Count > 0)
                                {
                                    <div class="wallet-history-steps">
                                        @foreach (var participant in item.Participants)
                                        {
                                            <div class="wallet-history-step">
                                                <strong>@participant.WalletMasked</strong> ? @participant.TeamSymbol ? @T("history.betPrefix", FmtSol(participant.BetAmount)) ? @T("history.resultPrefix", participant.ResultLabel) ? @T("history.receivedPrefix", FmtSol(participant.ReceivedAmount))
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </article>
                }

                <div class="wallet-history-toolbar">
                    <button type="button" class="wallet-history-button" disabled="@(_page.Page <= 1)" @onclick="() => LoadPageAsync(_page.Page - 1)">@T("history.previous")</button>
                    <span>@T("history.pageSummary", _page.Page, _page.TotalPages)</span>
                    <button type="button" class="wallet-history-button" disabled="@(_page.Page >= _page.TotalPages)" @onclick="() => LoadPageAsync(_page.Page + 1)">@T("history.next")</button>
                </div>
            }
        </div>
    }
</article>

@code {
    [Parameter, EditorRequired] public required int UserId { get; set; }
    [Parameter, EditorRequired] public required MyWalletInvestmentGroupDto Group { get; set; }

    private bool _expanded;
    private bool _loading;
    private string? _error;
    private string _status = "all";
    private UserMatchHistoryPageDto? _page;
    private readonly HashSet<int> _expandedMatches = [];

    private static readonly (string Value, string Label)[] Filters =
    [
        ("all", "all"),
        ("won", "won"),
        ("lost", "lost"),
        ("open", "open"),
        ("finalized", "finalized")
    ];

    private string CurrentCulture => CultureInfo.CurrentUICulture.Name;

    private string SummaryText => T("history.summaryText", Group.MatchCount, Group.WonCount, Group.LostCount, Group.OpenCount);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            await BrowserTimeZone.EnsureInitializedAsync();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex) when (InteropSafety.IsDeferredInteropException(ex))
        {
            // Timezone via JS n?o est? dispon?vel durante o prerender.
        }
    }

    private async Task ToggleAsync()
    {
        _expanded = !_expanded;
        if (_expanded && _page is null)
            await LoadPageAsync(1);
    }

    private async Task ChangeFilterAsync(string status)
    {
        _status = status;
        await LoadPageAsync(1);
    }

    private async Task LoadPageAsync(int page)
    {
        _loading = true;
        _error = null;
        try
        {
            _page = await Api.GetWalletHistoryMatchesAsync(UserId, Group.TeamId, page, 10, _status);
        }
        catch (Exception ex)
        {
            _error = T("history.loadError", ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ToggleMatchDetail(int betId)
    {
        if (!_expandedMatches.Add(betId))
            _expandedMatches.Remove(betId);
    }

    private static string GetResultBadgeClass(UserMatchHistoryItemDto item)
        => item.UserResult switch
        {
            "won" => "wallet-result-won",
            "won-no-opponent-pool" or "refunded" or "cancelled" or "draw-refunded" or "refunded-no-counterparty" or "draw" => "wallet-result-refunded",
            "lost" or "partial-loss" => "wallet-result-lost",
            "open" => "wallet-result-open",
            _ => "wallet-result-neutral"
        };

    private static string GetFinancialStatusClass(UserMatchHistoryItemDto item)
        => item.UserResult switch
        {
            "won" => "payout-positive",
            "lost" or "partial-loss" => "payout-negative",
            _ => "payout-neutral"
        };

    private string GetFinancialStatusLabel(UserMatchHistoryItemDto item)
        => string.IsNullOrWhiteSpace(item.UserResultLabel) ? T("history.unknown") : item.UserResultLabel;

    private static string GetSummaryTextClass(UserMatchHistoryItemDto item)
        => item.UserResult switch
        {
            "lost" or "partial-loss" => "wallet-history-summary-text-negative",
            "refunded" or "cancelled" or "draw-refunded" or "refunded-no-counterparty" or "won-no-opponent-pool" or "draw" => "wallet-history-summary-text-neutral",
            _ => string.Empty
        };

    private string FmtMatchStatus(string status)
        => status switch
        {
            "Pending" => T("history.matchStatusPending"),
            "Ongoing" => T("history.matchStatusOngoing"),
            "Completed" => T("history.matchStatusCompleted"),
            "Cancelled" => T("history.matchStatusCancelled"),
            _ => status
        };

    private static string FmtSol(decimal value) => $"{value:0.########} SOL";
    private static string FmtSignedSol(decimal value) => value > 0m ? $"+{value:0.########} SOL" : value < 0m ? $"-{Math.Abs(value):0.########} SOL" : "0 SOL";
    private static string FmtOptionalSol(decimal? value) => value.HasValue ? FmtSol(value.Value) : "-";
    private string FmtDate(DateTime? value) => BrowserTimeZone.FormatDateTime(value, AppCulture.ToCultureCode(CurrentCulture));
    private static string GetPayoutClass(decimal value) => value > 0m ? "payout-positive" : value < 0m ? "payout-negative" : "payout-neutral";
    private static string GetPayoutClass(decimal? value) => value.HasValue ? GetPayoutClass(value.Value) : "payout-neutral";
    private static string GetBaseSymbol(string pair) => string.IsNullOrWhiteSpace(pair) ? "" : new[] { "USDT", "USDC", "BUSD", "BRL", "EUR", "BTC", "ETH" }.FirstOrDefault(q => pair.Trim().ToUpperInvariant().EndsWith(q, StringComparison.OrdinalIgnoreCase) && pair.Length > q.Length) is string q ? pair.Trim().ToUpperInvariant()[..^q.Length] : pair.Trim().ToUpperInvariant();
    private string GetCoinIconUrl(string symbol) => EnvironmentIsolationGuard.BuildApiUrl(Config, $"/api/icons/binance/{GetBaseSymbol(symbol)}");
    private static string GetInitials(string value) => string.IsNullOrWhiteSpace(GetBaseSymbol(value)) ? "?" : GetBaseSymbol(value) is var symbol && symbol.Length <= 3 ? symbol : GetBaseSymbol(value)[..3];

    private string T(string key, params object?[] args)
        => L.T($"walletPage.{key}", CurrentCulture, args);
}
