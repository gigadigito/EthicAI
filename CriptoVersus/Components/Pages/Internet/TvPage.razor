@page "/tv"
@page "/{Culture}/tv"
@page "/tv/broadcast"
@page "/{Culture}/tv/broadcast"
@using System.Text.Json
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersusApiClient Api
@inject HotMatchService HotMatches
@inject AppCultureService AppCulture
@inject IConfiguration Config
@inject IHttpContextAccessor HttpContextAccessor
@inject IJSRuntime JS
@inject LocalizationService L
@inject MatchSlugHelper MatchSlugHelper
@inject NavigationManager Nav
@inject RouteLocalizationService RouteLocalization
@inject ILogger<TvPage> Logger
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <meta name="description" content="@MetaDescription" />
    <meta name="keywords" content="@MetaKeywords" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="en-US" href="@EnglishUrl" />
    <link rel="alternate" hreflang="pt-BR" href="@PortugueseUrl" />
    <link rel="alternate" hreflang="x-default" href="@EnglishUrl" />
    <meta property="og:title" content="@PageTitleText" />
    <meta property="og:description" content="@MetaDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="@SocialImageUrl" />
    <meta property="og:image:alt" content="@PageTitleText" />
    <meta property="og:locale" content="@AppCulture.ToOgLocale(_culture)" />
    <meta property="og:locale:alternate" content="@AppCulture.GetAlternateOgLocale(_culture)" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@PageTitleText" />
    <meta name="twitter:description" content="@MetaDescription" />
    <meta name="twitter:image" content="@SocialImageUrl" />
    <meta name="twitter:image:alt" content="@PageTitleText" />
    <script type="application/ld+json">@StructuredDataMarkup</script>
</HeadContent>

<TvStage Culture="@_culture"
         IsBroadcastMode="@_isBroadcastMode"
         HotMatch="@_selectedHotMatch"
         Match="@_selectedMatch"
         Stats="@_stats"
         Snapshot="@_snapshot"
         TopCoinsLoading="@_topCoinsState.IsLoading"
         TopCoinsError="@_topCoinsState.ErrorMessage"
         LatestBattlesLoading="@_latestBattlesState.IsLoading"
         LatestBattlesError="@_latestBattlesState.ErrorMessage"
         MarketPulseLoading="@_marketPulseState.IsLoading"
         MarketPulseError="@_marketPulseState.ErrorMessage"
         BroadcastRotationMinutes="@BroadcastRotationMinutes"
         BroadcastRotationRemainingSeconds="@BroadcastRotationRemainingSeconds"
         BroadcastRotationProgress="@BroadcastRotationProgress" />

@code {
    private const int RefreshIntervalSeconds = 15;
    private const int SwitchCooldownSeconds = 60;
    private const int SwitchThreshold = 12;
    private const int BreakingHotScoreThreshold = 90;
    private const decimal BreakingPriorityGap = 45m;
    private static readonly TimeSpan PrimarySelectionFeedTimeout = TimeSpan.FromSeconds(12);
    private static readonly TimeSpan AuxiliaryFeedTimeout = TimeSpan.FromSeconds(8);

    [Parameter] public string? Culture { get; set; }

    private string _culture = AppCultureService.DefaultRouteCulture;
    private bool _isBroadcastMode;
    private HotMatchDto? _selectedHotRanking;
    private TvHotMatchDto? _selectedHotMatch;
    private MatchDto? _selectedMatch;
    private StatsOverviewDto? _stats;
    private DashboardSnapshotDto? _snapshot;
    private IReadOnlyList<HotMatchDto> _hotMatches = [];
    private IJSObjectReference? _tvModule;
    private CancellationTokenSource? _refreshCts;
    private Task? _refreshLoopTask;
    private DateTime _lastSwitchUtc = DateTime.MinValue;
    private DateTime _lastBroadcastRotationUtc = DateTime.MinValue;
    private DateTime _nextRefreshAtUtc = DateTime.MinValue;
    private int _refreshInProgress;
    private PanelLoadState _topCoinsState = PanelLoadState.Loading();
    private PanelLoadState _latestBattlesState = PanelLoadState.Loading();
    private PanelLoadState _marketPulseState = PanelLoadState.Loading();

    private string PageTitleText => L.T(_isBroadcastMode ? "tv.seo.broadcastTitle" : "tv.seo.title", _culture);
    private string MetaDescription => L.T(_isBroadcastMode ? "tv.seo.broadcastDescription" : "tv.seo.description", _culture);
    private string CanonicalUrl => BuildAbsolute(_isBroadcastMode
        ? RouteLocalization.BuildTvBroadcastPath(_culture)
        : RouteLocalization.BuildTvPath(_culture));
    private string EnglishUrl => BuildAbsolute(_isBroadcastMode
        ? RouteLocalization.BuildTvBroadcastPath(AppCultureService.DefaultRouteCulture)
        : RouteLocalization.BuildTvPath(AppCultureService.DefaultRouteCulture));
    private string PortugueseUrl => BuildAbsolute(_isBroadcastMode
        ? RouteLocalization.BuildTvBroadcastPath(AppCultureService.SecondaryRouteCulture)
        : RouteLocalization.BuildTvPath(AppCultureService.SecondaryRouteCulture));
    private string MetaKeywords => _isBroadcastMode
        ? $"{SeoDefaults.GlobalKeywords}, CriptoVersus TV broadcast, #CriptoVersus TV, crypto broadcast, live crypto arena"
        : $"{SeoDefaults.GlobalKeywords}, CriptoVersus TV, #CriptoVersus TV, crypto match stream, live crypto battles";
    private string SocialImageUrl => SeoDefaults.BuildAbsoluteUrl(Config, Nav, SeoDefaults.DefaultSocialImagePath);
    private string StructuredDataMarkup
        => JsonSerializer.Serialize(new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "WebPage",
            ["name"] = PageTitleText,
            ["description"] = MetaDescription,
            ["url"] = CanonicalUrl,
            ["image"] = SocialImageUrl,
            ["keywords"] = MetaKeywords,
            ["inLanguage"] = _culture
        });
    private int BroadcastRotationMinutes
        => Math.Clamp(Config.GetValue<int?>("CriptoVersusTV:BroadcastRotationMinutes") ?? 5, 1, 30);
    private int BroadcastRotationRemainingSeconds
    {
        get
        {
            if (!_isBroadcastMode || _lastBroadcastRotationUtc == DateTime.MinValue)
                return 0;

            var remaining = TimeSpan.FromMinutes(BroadcastRotationMinutes) - (DateTime.UtcNow - _lastBroadcastRotationUtc);
            return Math.Max(0, (int)Math.Ceiling(remaining.TotalSeconds));
        }
    }
    private double BroadcastRotationProgress
    {
        get
        {
            if (!_isBroadcastMode || _lastBroadcastRotationUtc == DateTime.MinValue)
                return 0d;

            var totalSeconds = Math.Max(1d, TimeSpan.FromMinutes(BroadcastRotationMinutes).TotalSeconds);
            var elapsedSeconds = Math.Clamp((DateTime.UtcNow - _lastBroadcastRotationUtc).TotalSeconds, 0d, totalSeconds);
            return elapsedSeconds / totalSeconds;
        }
    }

    protected override void OnParametersSet()
    {
        _culture = !string.IsNullOrWhiteSpace(Culture)
            ? AppCulture.NormalizeRouteCulture(Culture)
            : AppCulture.DetectPreferredRouteCulture(HttpContextAccessor.HttpContext);

        var currentPath = "/" + Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].Trim('/');
        var isBroadcastAlias = currentPath.EndsWith("/tv/broadcast", StringComparison.OrdinalIgnoreCase);
        _isBroadcastMode = true;
        var expectedPath = isBroadcastAlias
            ? RouteLocalization.BuildTvBroadcastPath(_culture)
            : RouteLocalization.BuildTvPath(_culture);
        if (!currentPath.Equals(expectedPath, StringComparison.OrdinalIgnoreCase))
            Nav.NavigateTo(expectedPath, replace: true);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var initialLoadCts = new CancellationTokenSource(TimeSpan.FromSeconds(5));
            await RefreshAsync(forceInitialSelection: true, initialLoadCts.Token);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "TvPage initial load timed out or failed during prerender. Rendering partial TV shell.");
        }

        _nextRefreshAtUtc = DateTime.UtcNow.AddSeconds(RefreshIntervalSeconds);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _tvModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/tvMode.js?v=20260608-telemetry-cube-restore-1");
        await LogAsync("loaded");
        if (_selectedHotMatch is null || !_selectedHotMatch.HasMatch)
            await RefreshAsync(forceInitialSelection: true, CancellationToken.None);
        _nextRefreshAtUtc = DateTime.UtcNow.AddSeconds(RefreshIntervalSeconds);

        _refreshCts = new CancellationTokenSource();
        _refreshLoopTask = RunRefreshLoopAsync(_refreshCts.Token);
        Logger.LogInformation("TvPage refresh loop started. BroadcastMode={BroadcastMode} IntervalSeconds={IntervalSeconds}", _isBroadcastMode, RefreshIntervalSeconds);
    }

    private async Task RunRefreshLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                var now = DateTime.UtcNow;
                var rotationDue = _isBroadcastMode
                    && _selectedMatch is not null
                    && _lastBroadcastRotationUtc != DateTime.MinValue
                    && now - _lastBroadcastRotationUtc >= TimeSpan.FromMinutes(BroadcastRotationMinutes);

                if (rotationDue || now >= _nextRefreshAtUtc)
                {
                    await RefreshAsync(forceInitialSelection: false, ct);
                    _nextRefreshAtUtc = DateTime.UtcNow.AddSeconds(RefreshIntervalSeconds);
                    continue;
                }

                if (_isBroadcastMode)
                    await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task RefreshAsync(bool forceInitialSelection, CancellationToken ct)
    {
        if (Interlocked.Exchange(ref _refreshInProgress, 1) == 1)
        {
            Logger.LogInformation("TvPage refresh skipped because another refresh is already running. BroadcastMode={BroadcastMode}", _isBroadcastMode);
            return;
        }

        var startedAtUtc = DateTime.UtcNow;
        try
        {
            Logger.LogInformation("TvPage refresh started. BroadcastMode={BroadcastMode} ForceInitialSelection={ForceInitialSelection}", _isBroadcastMode, forceInitialSelection);
            var hotMatchesTask = TryLoadWithTimeoutAsync(
                token => HotMatches.GetHotMatchesAsync(token),
                ct,
                PrimarySelectionFeedTimeout);
            var statsTask = TryLoadWithTimeoutAsync(
                token => Api.GetStatsOverviewAsync(token),
                ct,
                AuxiliaryFeedTimeout);
            var snapshotTask = TryLoadWithTimeoutAsync(
                token => Api.GetDashboardSnapshotAsync(token),
                ct,
                AuxiliaryFeedTimeout);

            await Task.WhenAll(hotMatchesTask, statsTask, snapshotTask);

            ApplyStatsOverviewResult(statsTask.Result);
            ApplyDashboardSnapshotResult(snapshotTask.Result);
            ApplyHotMatchFeedResult(hotMatchesTask.Result);
            await InvokeAsync(StateHasChanged);

            try
            {
                await RefreshMatchSelectionAsync(hotMatchesTask.Result, forceInitialSelection, ct);
            }
            catch (OperationCanceledException)
            {
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "TvPage match selection refresh failed. BroadcastMode={BroadcastMode}", _isBroadcastMode);
                await LogAsync("[TV_ROTATION] selection error", ex.Message);
            }

            await InvokeAsync(StateHasChanged);
            Logger.LogInformation(
                "TvPage refresh completed. BroadcastMode={BroadcastMode} SelectedMatchId={SelectedMatchId} DurationMs={DurationMs}",
                _isBroadcastMode,
                _selectedMatch?.MatchId,
                (DateTime.UtcNow - startedAtUtc).TotalMilliseconds);
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "TvPage refresh failed. BroadcastMode={BroadcastMode}", _isBroadcastMode);
            await LogAsync("refresh error", ex.Message);
        }
        finally
        {
            Interlocked.Exchange(ref _refreshInProgress, 0);
        }
    }

    private async Task ResolveHotMatchSelectionAsync(HotMatchDto hotMatch, bool forceInitialSelection, CancellationToken ct)
    {
        if (forceInitialSelection || _selectedHotMatch is null || !_selectedHotMatch.HasMatch)
        {
            await SwitchToMatchAsync(hotMatch, hotMatch.MatchSnapshot);
            return;
        }

        if (_selectedHotMatch.MatchId == hotMatch.MatchId)
        {
            _selectedHotRanking = hotMatch;
            _selectedHotMatch = HotMatches.ToTvHotMatch(hotMatch, _culture, RouteLocalization);
            _selectedMatch = hotMatch.MatchSnapshot ?? _selectedMatch;
            return;
        }

        var currentFinished = await IsSelectedMatchFinishedAsync(ct);
        if (currentFinished)
        {
            await SwitchToMatchAsync(hotMatch, hotMatch.MatchSnapshot);
            return;
        }

        if (hotMatch.HotScore < _selectedHotMatch.HotScore + SwitchThreshold)
            return;

        if (IsSwitchCooldownActive())
        {
            await LogAsync("cooldown active", new
            {
                currentMatchId = _selectedHotMatch.MatchId,
                candidateMatchId = hotMatch.MatchId,
                secondsRemaining = Math.Max(0, SwitchCooldownSeconds - (int)(DateTime.UtcNow - _lastSwitchUtc).TotalSeconds)
            });
            return;
        }

        await SwitchToMatchAsync(hotMatch, hotMatch.MatchSnapshot);
    }

    private async Task RefreshMatchSelectionAsync(LoadAttemptResult<IReadOnlyList<HotMatchDto>> hotMatchesResult, bool forceInitialSelection, CancellationToken ct)
    {
        if (hotMatchesResult.IsSuccess)
        {
            var hotMatch = _hotMatches.FirstOrDefault();
            if (_isBroadcastMode)
            {
                await ResolveBroadcastSelectionAsync(_hotMatches, forceInitialSelection, ct);
            }
            else if (hotMatch is not null)
            {
                await LogAsync("[HOT_MATCH] refreshed", new { hotMatch.MatchId, hotMatch.HotScore, hotMatch.PriorityScore, hotMatch.Reason });
                await ResolveHotMatchSelectionAsync(hotMatch, forceInitialSelection, ct);
            }
            else
            {
                await LogAsync("[HOT_MATCH] no ranked match available");

                if (_selectedHotMatch?.HasMatch == true)
                {
                    var currentFinished = await IsSelectedMatchFinishedAsync(ct);
                    if (currentFinished)
                    {
                        _selectedHotMatch = null;
                        _selectedMatch = null;
                        _selectedHotRanking = null;
                    }
                }
            }
        }
        else
        {
            await LogAsync("[HOT_MATCH] feed unavailable", new
            {
                hotMatchesResult.IsTimeout,
                hotMatchesResult.ErrorMessage
            });
        }

        if (_isBroadcastMode && (_selectedHotMatch is null || !_selectedHotMatch.HasMatch))
            await TryResolveBroadcastFallbackAsync(ct);

        try
        {
            await RefreshSelectedMatchAsync(ct);
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "TvPage selected match refresh failed. MatchId={MatchId}", _selectedMatch?.MatchId ?? _selectedHotMatch?.MatchId ?? 0);
            await LogAsync("[TV_ROTATION] selected match refresh error", ex.Message);
        }
    }

    private async Task<bool> IsSelectedMatchFinishedAsync(CancellationToken ct)
    {
        if (_selectedHotMatch is null || !_selectedHotMatch.HasMatch)
            return true;

        var current = await Api.GetMatchByIdAsync(_selectedHotMatch.MatchId, includeParticipants: false, ct);
        return current is null
            || current.IsFinished
            || string.Equals(current.Status, "Completed", StringComparison.OrdinalIgnoreCase)
            || string.Equals(current.Status, "Cancelled", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsSwitchCooldownActive()
        => DateTime.UtcNow - _lastSwitchUtc < TimeSpan.FromSeconds(SwitchCooldownSeconds);

    private async Task SwitchToMatchAsync(HotMatchDto hotMatch, MatchDto? match = null, bool broadcastRotation = false, string? switchMode = null)
    {
        _selectedHotRanking = hotMatch;
        _selectedHotMatch = HotMatches.ToTvHotMatch(hotMatch, _culture, RouteLocalization);
        _selectedMatch = match ?? hotMatch.MatchSnapshot;
        _lastSwitchUtc = DateTime.UtcNow;
        if (broadcastRotation)
            _lastBroadcastRotationUtc = DateTime.UtcNow;

        await LogAsync("[TV_ROTATION] switching match", new
        {
            hotMatch.MatchId,
            hotMatch.HotScore,
            hotMatch.PriorityScore,
            switchMode,
            LocalizedWatchUrl = RouteLocalization.BuildTvMatchPath(_culture, hotMatch.MatchId, hotMatch.Slug)
        });
    }

    private async Task ResolveBroadcastSelectionAsync(IReadOnlyList<HotMatchDto> hotMatches, bool forceInitialSelection, CancellationToken ct)
    {
        var rankedCandidates = hotMatches
            .Where(IsBroadcastEligibleMatch)
            .OrderByDescending(x => x.PriorityScore)
            .ThenByDescending(x => x.HotScore)
            .ToList();

        await LogAsync("[TV_ROTATION] evaluation started", new
        {
            forceInitialSelection,
            candidateCount = rankedCandidates.Count
        });

        if (_selectedHotRanking is not null && !IsBroadcastEligibleMatch(_selectedHotRanking))
        {
            await LogAsync("[TV_ROTATION] current match skipped", new
            {
                _selectedHotRanking.MatchId,
                _selectedHotRanking.Status
            });

            _selectedMatch = null;
            _selectedHotMatch = null;
            _selectedHotRanking = null;
        }

        if (rankedCandidates.Count == 0)
        {
            await LogAsync("[TV_ROTATION] no candidates available", new { selectedMatchId = _selectedHotMatch?.MatchId ?? 0 });
            return;
        }

        foreach (var candidate in rankedCandidates.Take(5))
        {
            await LogAsync("[MATCH_PRIORITY]", new
            {
                candidate.MatchId,
                candidate.HotScore,
                candidate.PriorityScore,
                candidate.IsExplosive,
                candidate.ActivityLevel
            });
        }

        var topCandidate = rankedCandidates[0];
        var shouldRotate = forceInitialSelection
            || _selectedHotRanking is null
            || !IsBroadcastEligibleMatch(_selectedHotRanking)
            || _selectedHotRanking.IsFinished
            || DateTime.UtcNow - _lastBroadcastRotationUtc >= TimeSpan.FromMinutes(BroadcastRotationMinutes);

        if (!shouldRotate && _selectedHotRanking is not null)
        {
            _selectedHotRanking = rankedCandidates.FirstOrDefault(x => x.MatchId == _selectedHotRanking.MatchId) ?? _selectedHotRanking;
            _selectedHotMatch = HotMatches.ToTvHotMatch(_selectedHotRanking, _culture, RouteLocalization);
            _selectedMatch = _selectedHotRanking.MatchSnapshot ?? _selectedMatch;
            await LogAsync("[TV_ROTATION] hold current arena", new { selectedMatchId = _selectedHotMatch?.MatchId ?? 0, rotated = false });
            return;
        }

        var currentMatchId = _selectedHotRanking?.MatchId ?? _selectedMatch?.MatchId ?? _selectedHotMatch?.MatchId ?? 0;
        var currentPriority = _selectedHotRanking?.PriorityScore ?? 0m;
        var shouldBreakIn = _selectedHotRanking is null
            || topCandidate.MatchId != currentMatchId && (
                topCandidate.HotScore >= BreakingHotScoreThreshold
                || topCandidate.IsExplosive
                || topCandidate.PriorityScore >= currentPriority + BreakingPriorityGap);

        if (shouldBreakIn)
        {
            await LogAsync("[TV_ROTATION] BREAKING MATCH SIGNAL DETECTED", new
            {
                currentMatchId,
                nextMatchId = topCandidate.MatchId,
                topCandidate.HotScore,
                topCandidate.PriorityScore
            });

            await SwitchToMatchAsync(topCandidate, topCandidate.MatchSnapshot, broadcastRotation: true, switchMode: "breaking-live-arena-switch");
            await LogAsync("[TV_ROTATION] LIVE ARENA SWITCH", new { selectedMatchId = topCandidate.MatchId, rotated = true, mode = "breaking" });
            return;
        }

        var selected = rankedCandidates
            .FirstOrDefault(x => x.MatchId != currentMatchId && x.HotScore >= 30)
            ?? topCandidate;

        await SwitchToMatchAsync(selected, selected.MatchSnapshot, broadcastRotation: true, switchMode: "priority-scan");
        await LogAsync("[TV_ROTATION] rotation completed", new { selectedMatchId = selected.MatchId, rotated = true, mode = "priority" });
    }

    private async Task RefreshSelectedMatchAsync(CancellationToken ct)
    {
        var selectedMatchId = _selectedHotRanking?.MatchId ?? _selectedHotMatch?.MatchId ?? _selectedMatch?.MatchId ?? 0;
        if (selectedMatchId <= 0)
            return;

        _selectedHotRanking = _hotMatches.FirstOrDefault(x => x.MatchId == selectedMatchId) ?? _selectedHotRanking;
        _selectedMatch = _selectedHotRanking?.MatchSnapshot ?? _selectedMatch;
        _selectedMatch ??= await Api.GetMatchByIdAsync(selectedMatchId, includeParticipants: false, ct);
        if (_isBroadcastMode && _selectedHotRanking is not null && !IsBroadcastEligibleMatch(_selectedHotRanking))
        {
            await LogAsync("[TV_ROTATION] refresh skipped not live", new
            {
                _selectedHotRanking.MatchId,
                _selectedHotRanking.Status
            });

            _selectedMatch = null;
            _selectedHotMatch = null;
            _selectedHotRanking = null;
            return;
        }

        if (_selectedHotRanking is not null)
            _selectedHotMatch = HotMatches.ToTvHotMatch(_selectedHotRanking, _culture, RouteLocalization);
    }

    private async Task TryResolveBroadcastFallbackAsync(CancellationToken ct)
    {
        try
        {
            var legacyHotMatch = await Api.GetTvHotMatchAsync(ct);
            if (legacyHotMatch?.HasMatch == true)
            {
                var match = await Api.GetMatchByIdAsync(legacyHotMatch.MatchId, includeParticipants: false, ct);
                var fallback = BuildFallbackHotMatch(legacyHotMatch, match);
                if (IsBroadcastEligibleMatch(fallback))
                {
                    await SwitchToMatchAsync(fallback, match, broadcastRotation: true, switchMode: "legacy-hot-match-fallback");
                    await LogAsync("[TV_ROTATION] fallback selected from legacy hot match", new { fallback.MatchId, fallback.HotScore });
                    return;
                }
            }
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "TvPage legacy broadcast fallback failed.");
        }

        try
        {
            var ongoingMatches = await Api.GetMatchesAsync(includeParticipants: false, status: "Ongoing", take: 20, ct) ?? [];
            var fallback = ongoingMatches
                .Where(match => !match.IsFinished && !IsBroadcastTerminalStatus(match.Status))
                .OrderByDescending(CalculateFallbackPriorityScore)
                .Select(BuildFallbackHotMatch)
                .FirstOrDefault(IsBroadcastEligibleMatch);

            if (fallback is null)
                return;

            await SwitchToMatchAsync(fallback, fallback.MatchSnapshot, broadcastRotation: true, switchMode: "ongoing-match-fallback");
            await LogAsync("[TV_ROTATION] fallback selected from ongoing matches", new { fallback.MatchId, fallback.HotScore });
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "TvPage ongoing-match fallback failed.");
        }
    }

    private HotMatchDto BuildFallbackHotMatch(TvHotMatchDto hotMatch, MatchDto? match)
    {
        var slug = !string.IsNullOrWhiteSpace(hotMatch.Slug)
            ? hotMatch.Slug
            : MatchSlugHelper.BuildSlug(hotMatch.LeftSymbol, hotMatch.RightSymbol);
        var homeScore = match?.ScoreA ?? hotMatch.LeftScore;
        var awayScore = match?.ScoreB ?? hotMatch.RightScore;
        var elapsedMinutes = match?.ElapsedMinutes
            ?? Math.Max(0, 90 - ((hotMatch.RemainingSeconds ?? 0) / 60));
        var remainingMinutes = match?.RemainingMinutes
            ?? Math.Max(0, (int)Math.Ceiling((hotMatch.RemainingSeconds ?? 0) / 60d));
        var pctA = match?.PctA ?? hotMatch.LeftChangePercent;
        var pctB = match?.PctB ?? hotMatch.RightChangePercent;
        var totalPool = match?.TotalPoolAmount ?? match?.TotalPool ?? 0m;

        return new HotMatchDto
        {
            MatchId = hotMatch.MatchId,
            Slug = slug,
            HomeSymbol = match?.TeamA ?? hotMatch.LeftSymbol,
            AwaySymbol = match?.TeamB ?? hotMatch.RightSymbol,
            HomeScore = homeScore,
            AwayScore = awayScore,
            HotScore = hotMatch.HotScore,
            Momentum = Math.Clamp(Math.Abs((pctA ?? 0m) - (pctB ?? 0m)) * 10m, 0m, 100m),
            Fear = homeScore == awayScore ? 40m : 22m,
            ArenaPressure = Math.Clamp(hotMatch.HotScore, 0, 100),
            IsTrending = hotMatch.HotScore >= 60,
            IsExplosive = hotMatch.HotScore >= BreakingHotScoreThreshold,
            ActivityLevel = Math.Clamp(hotMatch.HotScore, 0, 100),
            ScoreDifference = Math.Abs(homeScore - awayScore),
            RecentGoals = homeScore + awayScore > 0 ? 1 : 0,
            Status = match?.Status ?? "Ongoing",
            Minute = elapsedMinutes,
            ElapsedMinutes = elapsedMinutes,
            RemainingMinutes = remainingMinutes,
            IsFinished = match?.IsFinished ?? false,
            PctA = pctA,
            PctB = pctB,
            TotalPool = match?.TotalPool ?? totalPool,
            TotalPoolAmount = totalPool,
            HasBetsOnBothSides = match?.HasBetsOnBothSides ?? false,
            PoolStrengthTeamA = match?.PoolStrengthTeamA ?? 0,
            PoolStrengthTeamB = match?.PoolStrengthTeamB ?? 0,
            TotalGoals = homeScore + awayScore,
            TotalBets = (match?.BetCountTeamA ?? 0) + (match?.BetCountTeamB ?? 0),
            HomeBetAmount = match?.TotalAmountTeamA ?? 0m,
            AwayBetAmount = match?.TotalAmountTeamB ?? 0m,
            Reason = !string.IsNullOrWhiteSpace(hotMatch.Reason)
                ? hotMatch.Reason
                : "Fallback broadcast selection from live arena feed.",
            PublicUrl = hotMatch.WatchUrl,
            HomeLogoUrl = hotMatch.LeftLogoUrl,
            AwayLogoUrl = hotMatch.RightLogoUrl,
            PriorityScore = hotMatch.HotScore,
            MatchSnapshot = match
        };
    }

    private HotMatchDto BuildFallbackHotMatch(MatchDto match)
    {
        var pctGap = Math.Abs((match.PctA ?? 0m) - (match.PctB ?? 0m));
        var scoreDifference = Math.Abs(match.ScoreA - match.ScoreB);
        var hotScore = Math.Clamp(
            32
            + Math.Min(30, (match.ScoreA + match.ScoreB) * 6)
            + (scoreDifference == 0 ? 16 : scoreDifference == 1 ? 10 : 2)
            + Math.Min(18, (int)Math.Round(pctGap * 2m, MidpointRounding.AwayFromZero)),
            0,
            100);

        return new HotMatchDto
        {
            MatchId = match.MatchId,
            Slug = MatchSlugHelper.BuildSlug(match.TeamA, match.TeamB),
            HomeSymbol = match.TeamA,
            AwaySymbol = match.TeamB,
            HomeScore = match.ScoreA,
            AwayScore = match.ScoreB,
            HotScore = hotScore,
            Momentum = Math.Clamp(pctGap * 8m, 0m, 100m),
            Fear = scoreDifference <= 1 ? 36m : 18m,
            ArenaPressure = hotScore,
            IsTrending = hotScore >= 60,
            IsExplosive = hotScore >= BreakingHotScoreThreshold,
            ActivityLevel = hotScore,
            ScoreDifference = scoreDifference,
            RecentGoals = match.ScoreA + match.ScoreB > 0 ? 1 : 0,
            Status = match.Status,
            Minute = match.ElapsedMinutes,
            ElapsedMinutes = match.ElapsedMinutes,
            RemainingMinutes = match.RemainingMinutes,
            IsFinished = match.IsFinished,
            PctA = match.PctA,
            PctB = match.PctB,
            TotalPool = match.TotalPool,
            TotalPoolAmount = match.TotalPoolAmount,
            HasBetsOnBothSides = match.HasBetsOnBothSides,
            PoolStrengthTeamA = match.PoolStrengthTeamA,
            PoolStrengthTeamB = match.PoolStrengthTeamB,
            TotalGoals = match.ScoreA + match.ScoreB,
            TotalBets = match.BetCountTeamA + match.BetCountTeamB,
            HomeBetAmount = match.TotalAmountTeamA,
            AwayBetAmount = match.TotalAmountTeamB,
            Reason = "Fallback broadcast selection from ongoing matches.",
            PublicUrl = RouteLocalization.BuildTvMatchPath(_culture, match.MatchId, MatchSlugHelper.BuildSlug(match.TeamA, match.TeamB)),
            HomeLogoUrl = Api.BuildBinanceIconUrl(match.TeamA),
            AwayLogoUrl = Api.BuildBinanceIconUrl(match.TeamB),
            PriorityScore = CalculateFallbackPriorityScore(match),
            MatchSnapshot = match
        };
    }

    private static decimal CalculateFallbackPriorityScore(MatchDto match)
    {
        var scoreDifference = Math.Abs(match.ScoreA - match.ScoreB);
        var closeness = scoreDifference switch
        {
            0 => 20m,
            1 => 14m,
            2 => 8m,
            _ => 2m
        };

        return 35m
            + closeness
            + Math.Min(24m, (match.ScoreA + match.ScoreB) * 6m)
            + Math.Min(20m, Math.Abs((match.PctA ?? 0m) - (match.PctB ?? 0m)) * 2m)
            + Math.Min(18m, match.TotalPoolAmount);
    }

    private static bool IsBroadcastEligibleMatch(HotMatchDto? match)
        => match is not null
            && !match.IsFinished
            && !IsBroadcastTerminalStatus(match.Status)
            && match.HotScore >= 30;

    private static bool IsBroadcastTerminalStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status))
            return false;

        return status.Trim().ToUpperInvariant() switch
        {
            "COMPLETED" => true,
            "CANCELLED" => true,
            "CANCELED" => true,
            "CLOSED" => true,
            "SETTLED" => true,
            "FINISHED" => true,
            "EXPIRED" => true,
            "ABORTED" => true,
            _ => false
        };
    }

    private string BuildAbsolute(string path)
        => $"{new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority)}{path}";

    private void ApplyHotMatchFeedResult(LoadAttemptResult<IReadOnlyList<HotMatchDto>> result)
    {
        if (result.IsSuccess)
        {
            _hotMatches = result.Value ?? [];
            return;
        }

        Logger.LogWarning(
            "TvPage hot match feed unavailable. Timeout={Timeout} Error={Error}",
            result.IsTimeout,
            result.ErrorMessage);
    }

    private void ApplyStatsOverviewResult(LoadAttemptResult<StatsOverviewDto?> result)
    {
        if (result.IsSuccess)
        {
            _stats = result.Value;
            _topCoinsState = PanelLoadState.Ready();
            _latestBattlesState = PanelLoadState.Ready();
            return;
        }

        _topCoinsState = PanelLoadState.Error("error");
        _latestBattlesState = PanelLoadState.Error("error");
        Logger.LogWarning(
            "TvPage stats overview unavailable. Timeout={Timeout} Error={Error}",
            result.IsTimeout,
            result.ErrorMessage);
    }

    private void ApplyDashboardSnapshotResult(LoadAttemptResult<DashboardSnapshotDto?> result)
    {
        if (result.IsSuccess)
        {
            _snapshot = result.Value;
            _marketPulseState = PanelLoadState.Ready();
            return;
        }

        _marketPulseState = PanelLoadState.Error("error");
        Logger.LogWarning(
            "TvPage dashboard snapshot unavailable. Timeout={Timeout} Error={Error}",
            result.IsTimeout,
            result.ErrorMessage);
    }

    private static async Task<LoadAttemptResult<T>> TryLoadWithTimeoutAsync<T>(
        Func<CancellationToken, Task<T>> loader,
        CancellationToken ct,
        TimeSpan timeout)
    {
        using var timeoutCts = CancellationTokenSource.CreateLinkedTokenSource(ct);
        timeoutCts.CancelAfter(timeout);

        try
        {
            var value = await loader(timeoutCts.Token);
            return LoadAttemptResult<T>.Success(value);
        }
        catch (OperationCanceledException) when (!ct.IsCancellationRequested && timeoutCts.IsCancellationRequested)
        {
            return LoadAttemptResult<T>.Timeout();
        }
        catch (OperationCanceledException)
        {
            throw;
        }
        catch (Exception ex)
        {
            return LoadAttemptResult<T>.Failure(ex.Message);
        }
    }

    private async Task LogAsync(string message, object? payload = null)
    {
        if (_tvModule is null)
            return;

        await _tvModule.InvokeVoidAsync("log", "TV_MODE", message, payload);
    }

    public async ValueTask DisposeAsync()
    {
        if (_refreshCts is not null)
        {
            _refreshCts.Cancel();
            _refreshCts.Dispose();
        }

        if (_refreshLoopTask is not null)
        {
            try
            {
                await _refreshLoopTask;
            }
            catch
            {
            }
        }

        Logger.LogInformation("TvPage refresh loop disposed. BroadcastMode={BroadcastMode}", _isBroadcastMode);

        if (_tvModule is not null)
            await _tvModule.DisposeAsync();
    }

    private sealed record PanelLoadState(bool IsLoading, string? ErrorMessage)
    {
        public static PanelLoadState Loading() => new(true, null);
        public static PanelLoadState Ready() => new(false, null);
        public static PanelLoadState Error(string message) => new(false, message);
    }

    private sealed record LoadAttemptResult<T>(bool IsSuccess, bool IsTimeout, string? ErrorMessage, T? Value)
    {
        public static LoadAttemptResult<T> Success(T? value) => new(true, false, null, value);
        public static LoadAttemptResult<T> Timeout() => new(false, true, "Timed out", default);
        public static LoadAttemptResult<T> Failure(string? errorMessage) => new(false, false, errorMessage, default);
    }
}
