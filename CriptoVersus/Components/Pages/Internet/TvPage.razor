@page "/tv"
@page "/{Culture}/tv"
@page "/tv/broadcast"
@page "/{Culture}/tv/broadcast"
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersusApiClient Api
@inject AppCultureService AppCulture
@inject IHttpContextAccessor HttpContextAccessor
@inject IJSRuntime JS
@inject LocalizationService L
@inject MatchSlugHelper MatchSlugHelper
@inject NavigationManager Nav
@inject RouteLocalizationService RouteLocalization
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <meta name="description" content="@MetaDescription" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="en-US" href="@EnglishUrl" />
    <link rel="alternate" hreflang="pt-BR" href="@PortugueseUrl" />
    <link rel="alternate" hreflang="x-default" href="@EnglishUrl" />
    <meta property="og:title" content="@PageTitleText" />
    <meta property="og:description" content="@MetaDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="@AppCulture.ToOgLocale(_culture)" />
    <meta property="og:locale:alternate" content="@AppCulture.GetAlternateOgLocale(_culture)" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@PageTitleText" />
    <meta name="twitter:description" content="@MetaDescription" />
</HeadContent>

<TvStage Culture="@_culture"
         IsBroadcastMode="@_isBroadcastMode"
         HotMatch="@_selectedHotMatch"
         Match="@_selectedMatch"
         Stats="@_stats"
         Snapshot="@_snapshot" />

@code {
    private const int RefreshIntervalSeconds = 15;
    private const int SwitchCooldownSeconds = 60;
    private const int SwitchThreshold = 10;

    [Parameter] public string? Culture { get; set; }

    private string _culture = AppCultureService.DefaultRouteCulture;
    private bool _isBroadcastMode;
    private TvHotMatchDto? _selectedHotMatch;
    private MatchDto? _selectedMatch;
    private StatsOverviewDto? _stats;
    private DashboardSnapshotDto? _snapshot;
    private IReadOnlyList<MatchDto> _matches = [];
    private IJSObjectReference? _tvModule;
    private CancellationTokenSource? _refreshCts;
    private Task? _refreshLoopTask;
    private DateTime _lastSwitchUtc = DateTime.MinValue;
    private DateTime _lastBroadcastRotationUtc = DateTime.MinValue;

    private string PageTitleText => L.T(_isBroadcastMode ? "tv.seo.broadcastTitle" : "tv.seo.title", _culture);
    private string MetaDescription => L.T(_isBroadcastMode ? "tv.seo.broadcastDescription" : "tv.seo.description", _culture);
    private string CanonicalUrl => BuildAbsolute(_isBroadcastMode
        ? RouteLocalization.BuildTvBroadcastPath(_culture)
        : RouteLocalization.BuildTvPath(_culture));
    private string EnglishUrl => BuildAbsolute(_isBroadcastMode
        ? RouteLocalization.BuildTvBroadcastPath(AppCultureService.DefaultRouteCulture)
        : RouteLocalization.BuildTvPath(AppCultureService.DefaultRouteCulture));
    private string PortugueseUrl => BuildAbsolute(_isBroadcastMode
        ? RouteLocalization.BuildTvBroadcastPath(AppCultureService.SecondaryRouteCulture)
        : RouteLocalization.BuildTvPath(AppCultureService.SecondaryRouteCulture));

    protected override void OnParametersSet()
    {
        _culture = !string.IsNullOrWhiteSpace(Culture)
            ? AppCulture.NormalizeRouteCulture(Culture)
            : AppCulture.DetectPreferredRouteCulture(HttpContextAccessor.HttpContext);

        var currentPath = "/" + Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].Trim('/');
        _isBroadcastMode = currentPath.EndsWith("/tv/broadcast", StringComparison.OrdinalIgnoreCase);
        var expectedPath = _isBroadcastMode
            ? RouteLocalization.BuildTvBroadcastPath(_culture)
            : RouteLocalization.BuildTvPath(_culture);
        if (!currentPath.Equals(expectedPath, StringComparison.OrdinalIgnoreCase))
            Nav.NavigateTo(expectedPath, replace: true);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _tvModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/tvMode.js?v=20260518-5");
        await LogAsync("loaded");
        await RefreshAsync(forceInitialSelection: true, CancellationToken.None);

        _refreshCts = new CancellationTokenSource();
        _refreshLoopTask = RunRefreshLoopAsync(_refreshCts.Token);
    }

    private async Task RunRefreshLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(RefreshIntervalSeconds));

        try
        {
            while (await timer.WaitForNextTickAsync(ct))
                await RefreshAsync(forceInitialSelection: false, ct);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task RefreshAsync(bool forceInitialSelection, CancellationToken ct)
    {
        try
        {
            var hotTask = Api.GetTvHotMatchAsync(ct);
            var statsTask = Api.GetStatsOverviewAsync(ct);
            var snapshotTask = Api.GetDashboardSnapshotAsync(ct);
            var matchesTask = Api.GetMatchesAsync(ct);

            await Task.WhenAll(hotTask, statsTask, snapshotTask, matchesTask);

            _stats = statsTask.Result ?? _stats;
            _snapshot = snapshotTask.Result ?? _snapshot;
            _matches = matchesTask.Result ?? [];

            var hotMatch = hotTask.Result;
            if (_isBroadcastMode)
            {
                await ResolveBroadcastSelectionAsync(hotMatch, _matches, forceInitialSelection, ct);
            }
            else if (hotMatch?.HasMatch == true)
            {
                await LogAsync("hot match refreshed", new { hotMatch.MatchId, hotMatch.HotScore, hotMatch.Reason });
                await ResolveHotMatchSelectionAsync(hotMatch, _matches, forceInitialSelection, ct);
            }
            else
            {
                await LogAsync("no hot match available");

                if (_selectedHotMatch?.HasMatch == true)
                {
                    var currentFinished = await IsSelectedMatchFinishedAsync(ct);
                    if (currentFinished)
                    {
                        _selectedHotMatch = null;
                        _selectedMatch = null;
                    }
                }
            }

            await RefreshSelectedMatchAsync(_matches, ct);
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            await LogAsync("refresh error", ex.Message);
        }
    }

    private async Task ResolveHotMatchSelectionAsync(TvHotMatchDto hotMatch, IReadOnlyList<MatchDto> matches, bool forceInitialSelection, CancellationToken ct)
    {
        if (forceInitialSelection || _selectedHotMatch is null || !_selectedHotMatch.HasMatch)
        {
            await SwitchToMatchAsync(hotMatch, FindMatch(matches, hotMatch.MatchId));
            return;
        }

        if (_selectedHotMatch.MatchId == hotMatch.MatchId)
        {
            _selectedHotMatch = hotMatch;
            _selectedMatch = FindMatch(matches, hotMatch.MatchId) ?? _selectedMatch;
            return;
        }

        var currentFinished = await IsSelectedMatchFinishedAsync(ct);
        if (currentFinished)
        {
            await SwitchToMatchAsync(hotMatch, FindMatch(matches, hotMatch.MatchId));
            return;
        }

        if (hotMatch.HotScore < _selectedHotMatch.HotScore + SwitchThreshold)
            return;

        if (IsSwitchCooldownActive())
        {
            await LogAsync("cooldown active", new
            {
                currentMatchId = _selectedHotMatch.MatchId,
                candidateMatchId = hotMatch.MatchId,
                secondsRemaining = Math.Max(0, SwitchCooldownSeconds - (int)(DateTime.UtcNow - _lastSwitchUtc).TotalSeconds)
            });
            return;
        }

        await SwitchToMatchAsync(hotMatch, FindMatch(matches, hotMatch.MatchId));
    }

    private async Task<bool> IsSelectedMatchFinishedAsync(CancellationToken ct)
    {
        if (_selectedHotMatch is null || !_selectedHotMatch.HasMatch)
            return true;

        var current = await Api.GetMatchByIdAsync(_selectedHotMatch.MatchId, ct);
        return current is null
            || current.IsFinished
            || string.Equals(current.Status, "Completed", StringComparison.OrdinalIgnoreCase)
            || string.Equals(current.Status, "Cancelled", StringComparison.OrdinalIgnoreCase);
    }

    private bool IsSwitchCooldownActive()
        => DateTime.UtcNow - _lastSwitchUtc < TimeSpan.FromSeconds(SwitchCooldownSeconds);

    private async Task SwitchToMatchAsync(TvHotMatchDto hotMatch, MatchDto? match = null, bool broadcastRotation = false)
    {
        _selectedHotMatch = hotMatch;
        _selectedMatch = match;
        _lastSwitchUtc = DateTime.UtcNow;
        if (broadcastRotation)
            _lastBroadcastRotationUtc = DateTime.UtcNow;

        await LogAsync("switching match", new
        {
            hotMatch.MatchId,
            hotMatch.HotScore,
            LocalizedWatchUrl = RouteLocalization.BuildTvMatchPath(_culture, hotMatch.MatchId, hotMatch.Slug)
        });
    }

    private async Task ResolveBroadcastSelectionAsync(TvHotMatchDto? hotMatch, IReadOnlyList<MatchDto> matches, bool forceInitialSelection, CancellationToken ct)
    {
        var liveMatches = matches.Where(IsBroadcastEligibleMatch).ToList();

        await LogAsync("TV_BROADCAST_ROTATION_STARTED", new
        {
            forceInitialSelection,
            candidateCount = liveMatches.Count,
            totalMatches = matches.Count
        });

        if (_selectedMatch is not null && !IsBroadcastEligibleMatch(_selectedMatch))
        {
            await LogAsync("TV_BROADCAST_CURRENT_MATCH_SKIPPED", new
            {
                _selectedMatch.MatchId,
                _selectedMatch.Status
            });

            _selectedMatch = null;
            _selectedHotMatch = null;
        }

        var rankedCandidates = BuildBroadcastCandidates(liveMatches, hotMatch).ToList();
        if (rankedCandidates.Count == 0)
        {
            if (hotMatch?.HasMatch == true)
            {
                var hotMatchEntity = FindMatch(matches, hotMatch.MatchId);
                if (hotMatchEntity is not null && IsBroadcastEligibleMatch(hotMatchEntity))
                    await SwitchToMatchAsync(hotMatch, hotMatchEntity, broadcastRotation: true);
            }

            await LogAsync("TV_BROADCAST_ROTATION_COMPLETED", new { selectedMatchId = _selectedHotMatch?.MatchId ?? 0 });
            return;
        }

        var shouldRotate = forceInitialSelection
            || _selectedMatch is null
            || !IsBroadcastEligibleMatch(_selectedMatch)
            || _selectedMatch.IsFinished
            || DateTime.UtcNow - _lastBroadcastRotationUtc >= TimeSpan.FromMinutes(5);

        if (!shouldRotate && _selectedMatch is not null)
        {
            _selectedMatch = FindMatch(matches, _selectedMatch.MatchId) ?? _selectedMatch;
            _selectedHotMatch = MergeHotMatchState(_selectedMatch, hotMatch);
            await LogAsync("TV_BROADCAST_ROTATION_COMPLETED", new { selectedMatchId = _selectedHotMatch?.MatchId ?? 0, rotated = false });
            return;
        }

        var currentMatchId = _selectedMatch?.MatchId ?? _selectedHotMatch?.MatchId ?? 0;
        var selected = rankedCandidates
            .FirstOrDefault(x => x.Match.MatchId != currentMatchId)
            ?? rankedCandidates[0];

        await LogAsync("TV_BROADCAST_MATCH_SELECTED", new
        {
            selected.Match.MatchId,
            selected.Score,
            selected.Match.Status
        });

        await SwitchToMatchAsync(MergeHotMatchState(selected.Match, hotMatch), selected.Match, broadcastRotation: true);
        await LogAsync("TV_BROADCAST_ROTATION_COMPLETED", new { selectedMatchId = selected.Match.MatchId, rotated = true });
    }

    private IEnumerable<BroadcastCandidate> BuildBroadcastCandidates(IReadOnlyList<MatchDto> matches, TvHotMatchDto? hotMatch)
    {
        foreach (var match in matches)
        {
            if (!IsBroadcastEligibleMatch(match))
            {
                _ = LogAsync("TV_BROADCAST_MATCH_SKIPPED_NOT_LIVE", new { match.MatchId, match.Status });
                continue;
            }

            yield return new BroadcastCandidate(match, ScoreBroadcastCandidate(match, hotMatch));
        }
    }

    private decimal ScoreBroadcastCandidate(MatchDto match, TvHotMatchDto? hotMatch)
    {
        var scoreGap = Math.Abs(match.ScoreA - match.ScoreB);
        var pctGap = Math.Abs((match.PctA ?? 0m) - (match.PctB ?? 0m));
        var baseScore = 0m;

        if (string.Equals(match.Status, "Ongoing", StringComparison.OrdinalIgnoreCase))
            baseScore += 120m;

        if (!match.IsFinished)
            baseScore += 40m;

        if (hotMatch?.HasMatch == true && hotMatch.MatchId == match.MatchId)
            baseScore += 60m + hotMatch.HotScore;

        baseScore += Math.Max(0, 28 - (scoreGap * 8));
        baseScore += Math.Max(0, 20 - (pctGap * 22m));
        baseScore += Math.Min(30m, match.TotalPoolAmount / 50m);
        baseScore += Math.Min(18m, match.TotalPool / 50m);
        baseScore += match.HasBetsOnBothSides ? 12m : 0m;
        baseScore += match.RemainingMinutes switch
        {
            > 2 and < 50 => 14m,
            >= 50 => 8m,
            _ => 2m
        };

        return baseScore;
    }

    private async Task RefreshSelectedMatchAsync(IReadOnlyList<MatchDto> matches, CancellationToken ct)
    {
        var selectedMatchId = _selectedHotMatch?.MatchId ?? _selectedMatch?.MatchId ?? 0;
        if (selectedMatchId <= 0)
            return;

        _selectedMatch = FindMatch(matches, selectedMatchId) ?? _selectedMatch;
        _selectedMatch ??= await Api.GetMatchByIdAsync(selectedMatchId, ct);
        if (_isBroadcastMode && _selectedMatch is not null && !IsBroadcastEligibleMatch(_selectedMatch))
        {
            await LogAsync("TV_BROADCAST_REFRESH_SKIPPED_NOT_LIVE", new
            {
                _selectedMatch.MatchId,
                _selectedMatch.Status
            });

            _selectedMatch = null;
            _selectedHotMatch = null;
            return;
        }

        if (_selectedMatch is not null)
            _selectedHotMatch = MergeHotMatchState(_selectedMatch, _selectedHotMatch);
    }

    private TvHotMatchDto MergeHotMatchState(MatchDto match, TvHotMatchDto? hotMatch)
    {
        if (hotMatch?.HasMatch == true && hotMatch.MatchId == match.MatchId)
            return hotMatch;

        var scoreGap = Math.Abs(match.ScoreA - match.ScoreB);
        var competitiveness = Math.Clamp(100 - (scoreGap * 18) - (int)(Math.Abs((match.PctA ?? 0m) - (match.PctB ?? 0m)) * 10m), 40, 96);
        var leader = ResolveLeaderSymbol(match);

        return new TvHotMatchDto
        {
            HasMatch = true,
            MatchId = match.MatchId,
            Slug = MatchSlugHelper.BuildSlug(match.TeamA, match.TeamB),
            LeftSymbol = match.TeamA,
            RightSymbol = match.TeamB,
            LeftName = match.TeamA,
            RightName = match.TeamB,
            LeftScore = match.ScoreA,
            RightScore = match.ScoreB,
            LeftLogoUrl = Api.BuildBinanceIconUrl(match.TeamA),
            RightLogoUrl = Api.BuildBinanceIconUrl(match.TeamB),
            HotScore = competitiveness,
            Reason = scoreGap <= 1
                ? L.T("tv.fallback.closeMatchReason", _culture)
                : L.T("tv.fallback.liveArenaReason", _culture),
            WatchUrl = RouteLocalization.BuildTvMatchPath(_culture, match.MatchId, MatchSlugHelper.BuildSlug(match.TeamA, match.TeamB)),
            VolumeLabel = FormatPoolVolume(match),
            MomentumLabel = BuildMomentumLabel(match),
            RemainingTimeLabel = $"{Math.Max(0, match.RemainingMinutes):00}:00",
            RemainingSeconds = Math.Max(0, match.RemainingMinutes) * 60,
            MatchStartTimeUtc = match.StartTime?.ToUniversalTime(),
            LeftChangePercent = match.PctA,
            RightChangePercent = match.PctB,
            LeaderSymbol = leader,
            PressureSymbol = leader,
            PoolStatusLabel = match.HasBetsOnBothSides
                ? L.T("tv.labels.poolStatusBalanced", _culture)
                : L.T("tv.labels.poolStatusIdle", _culture),
            HasRecentReversal = scoreGap <= 1 && Math.Abs((match.PctA ?? 0m) - (match.PctB ?? 0m)) <= 0.5m
        };
    }

    private string BuildMomentumLabel(MatchDto match)
    {
        var delta = (match.PctA ?? 0m) - (match.PctB ?? 0m);
        if (Math.Abs(delta) <= 0.2m)
            return L.T("tv.commentary.momentumEven", _culture);

        return delta > 0m
            ? L.T("tv.commentary.momentumFor", _culture, match.TeamA)
            : L.T("tv.commentary.momentumFor", _culture, match.TeamB);
    }

    private static string ResolveLeaderSymbol(MatchDto match)
    {
        if (match.ScoreA != match.ScoreB)
            return match.ScoreA > match.ScoreB ? match.TeamA : match.TeamB;

        if ((match.PctA ?? 0m) != (match.PctB ?? 0m))
            return (match.PctA ?? 0m) > (match.PctB ?? 0m) ? match.TeamA : match.TeamB;

        return match.TeamA;
    }

    private static string FormatPoolVolume(MatchDto match)
    {
        var total = match.TotalPoolAmount > 0m ? match.TotalPoolAmount : match.TotalPool;
        return total > 0m ? total.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) : "0";
    }

    private static MatchDto? FindMatch(IReadOnlyList<MatchDto> matches, int matchId)
        => matches.FirstOrDefault(x => x.MatchId == matchId);

    private static bool IsBroadcastEligibleMatch(MatchDto? match)
        => match is not null
            && !match.IsFinished
            && string.Equals(match.Status, "Ongoing", StringComparison.OrdinalIgnoreCase);

    private sealed record BroadcastCandidate(MatchDto Match, decimal Score);

    private string BuildAbsolute(string path)
        => $"{new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority)}{path}";

    private async Task LogAsync(string message, object? payload = null)
    {
        if (_tvModule is null)
            return;

        await _tvModule.InvokeVoidAsync("log", "TV_MODE", message, payload);
    }

    public async ValueTask DisposeAsync()
    {
        if (_refreshCts is not null)
        {
            _refreshCts.Cancel();
            _refreshCts.Dispose();
        }

        if (_refreshLoopTask is not null)
        {
            try
            {
                await _refreshLoopTask;
            }
            catch
            {
            }
        }

        if (_tvModule is not null)
            await _tvModule.DisposeAsync();
    }
}
