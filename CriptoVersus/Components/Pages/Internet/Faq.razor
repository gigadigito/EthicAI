                            <strong>@item.Question</strong>
                        </span>
                        <span class="cvfaq-item__chevron" aria-hidden="true">+</span>
                    </button>

                    <div class="cvfaq-item__answer" hidden="@(!IsOpen(item.Id))">
                        <p>@item.Answer</p>
                    </div>
                </article>
