@page "/faq"
@page "/en/faq"
@page "/pt/faq"
@rendermode InteractiveServer
@using System.Text.Json
@using CriptoVersus.Web.Services
@inject NavigationManager Nav
@inject AppCultureService AppCulture
@inject LocalizationService L
@inject RouteLocalizationService RouteLocalization

<PageTitle>@T("seo.title")</PageTitle>
<HeadContent>
    <meta name="description" content="@T("seo.description")" />
    <meta name="keywords" content="@MetaKeywords" />
    <link rel="canonical" href="@BuildAbsolute(RouteLocalization.BuildFaqPath(CurrentCulture))" />
    <link rel="alternate" hreflang="en-US" href="@BuildAbsolute(RouteLocalization.BuildFaqPath("en"))" />
    <link rel="alternate" hreflang="pt-BR" href="@BuildAbsolute(RouteLocalization.BuildFaqPath("pt"))" />
    <link rel="alternate" hreflang="x-default" href="@BuildAbsolute(RouteLocalization.BuildFaqPath("en"))" />
    <meta property="og:title" content="@T("seo.title")" />
    <meta property="og:description" content="@T("seo.description")" />
    <meta property="og:url" content="@BuildAbsolute(RouteLocalization.BuildFaqPath(CurrentCulture))" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="@SocialImageUrl" />
    <meta property="og:image:alt" content="@T("seo.title")" />
    <meta property="og:locale" content="@AppCulture.ToOgLocale(CurrentCulture)" />
    <meta property="og:locale:alternate" content="@AppCulture.GetAlternateOgLocale(CurrentCulture)" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@T("seo.title")" />
    <meta name="twitter:description" content="@T("seo.description")" />
    <meta name="twitter:image" content="@SocialImageUrl" />
    <meta name="twitter:image:alt" content="@T("seo.title")" />
    <script type="application/ld+json">@StructuredDataMarkup</script>
</HeadContent>

<section class="cvfaq-arena">
    <header class="cvfaq-hero">
        <div class="cvfaq-hero__copy">
            <span class="cvfaq-hero__eyebrow">@T("hero.eyebrow")</span>
            <h1>@T("hero.title")</h1>
            <p>@T("hero.description")</p>

            <div class="cvfaq-hero__chips" aria-label="@T("hero.chipsLabel")">
                @foreach (var chipKey in HeroChipKeys)

                {
                    <span class="cvfaq-chip">@T($"hero.chips.{chipKey}")</span>
                }
            </div>
        </div>

        <aside class="cvfaq-hero__intel">
            <article class="cvfaq-intel-card">
                <span>@T("hero.cards.liveReadingLabel")</span>
                <strong>@T("hero.cards.liveReadingTitle")</strong>
                <p>@T("hero.cards.liveReadingBody")</p>
            </article>

            <article class="cvfaq-intel-card">
                <span>@T("hero.cards.riskLabel")</span>
                <strong>@T("hero.cards.riskTitle")</strong>
                <p>@T("hero.cards.riskBody")</p>
            </article>

            <article class="cvfaq-intel-card cvfaq-intel-card--accent">
                <span>@T("hero.cards.strategyLabel")</span>
                <strong>@T("hero.cards.strategyTitle")</strong>
                <p>@T("hero.cards.strategyBody")</p>
            </article>
        </aside>
    </header>

    <section class="cvfaq-strip">
        <article class="cvfaq-strip__card">
            <span>@T("summary.quickStartLabel")</span>
            <strong>@T("summary.quickStartTitle")</strong>
            <p>@T("summary.quickStartBody")</p>
        </article>

        <article class="cvfaq-strip__card">
            <span>@T("summary.marketLogicLabel")</span>
            <strong>@T("summary.marketLogicTitle")</strong>
            <p>@T("summary.marketLogicBody")</p>
        </article>

        <article class="cvfaq-strip__card">
            <span>@T("summary.noPromiseLabel")</span>
            <strong>@T("summary.noPromiseTitle")</strong>
            <p>@T("summary.noPromiseBody")</p>
        </article>
    </section>

    <section class="cvfaq-section">
        <div class="cvfaq-section__head">
            <span>@T("sections.basics.eyebrow")</span>
            <h2>@T("sections.basics.title")</h2>
            <p>@T("sections.basics.description")</p>
        </div>

        <div class="cvfaq-accordion">
            @foreach (var item in BasicsItems)
            {
                <article class="cvfaq-item @(IsOpen(item.Id) ? "is-open" : null)">
                    <button type="button"
                            class="cvfaq-item__toggle"
                            @onclick="() => Toggle(item.Id)"
                            aria-expanded="@IsOpen(item.Id)">
                        <span class="cvfaq-item__icon cvfaq-item__icon--@item.Tone">@item.Icon</span>
                        <span class="cvfaq-item__title-wrap">
                            <span class="cvfaq-item__category">@item.Category</span>
                            <strong>@item.Question</strong>
                        </span>
                        <span class="cvfaq-item__chevron" aria-hidden="true">+</span>
                    </button>

                    <div class="cvfaq-item__answer" hidden="@(!IsOpen(item.Id))">
                        <p>@item.Answer</p>
                    </div>
                </article>
            }
        </div>
    </section>

    <section class="cvfaq-section">
        <div class="cvfaq-section__head">
            <span>@T("sections.betting.eyebrow")</span>
            <h2>@T("sections.betting.title")</h2>
