<style>
    .cvfaq-arena {
        --cvfaq-bg: #070a12;
        --cvfaq-panel: rgba(10, 14, 23, 0.96);
        --cvfaq-panel-soft: rgba(12, 18, 29, 0.88);
        --cvfaq-border: rgba(118, 131, 164, .18);
        --cvfaq-text: #edf5ff;
        --cvfaq-muted: #a9b8cc;
        --cvfaq-green: #4cf38d;
        --cvfaq-cyan: #7ff6df;
        --cvfaq-blue: #53c8ff;
        --cvfaq-purple: #9f5cff;
        --cvfaq-gold: #f6c85f;
        display: grid;
        gap: 1.35rem;
        width: min(1880px, calc(100vw - 24px));
        max-width: none;
        margin: 0 auto;
        padding-inline: 0;
        box-sizing: border-box;
        color: var(--cvfaq-text);
    }


    .cvfaq-hero,
    .cvfaq-strip,
    .cvfaq-section,
    .cvfaq-accordion,
    .cvfaq-footnote {
        width: 100%;
        max-width: none;
        box-sizing: border-box;
    }

    .cvfaq-hero__copy,
    .cvfaq-hero__intel,
    .cvfaq-strip__card,
    .cvfaq-item,
    .cvfaq-footnote {
        min-width: 0;
    }



    .cvfaq-hero,
    .cvfaq-strip__card,
    .cvfaq-item,
    .cvfaq-footnote {
        position: relative;
        overflow: hidden;
        border-radius: 28px;
        border: 1px solid var(--cvfaq-border);
        background: radial-gradient(circle at top left, rgba(76,243,141,.09), transparent 24%), radial-gradient(circle at top right, rgba(159,92,255,.1), transparent 28%), linear-gradient(180deg, rgba(10,14,23,.98), rgba(7,10,18,.99));
        box-shadow: 0 24px 70px rgba(0,0,0,.28);
    }

    .cvfaq-hero {
        display: grid;
        grid-template-columns: minmax(0, 1.25fr) minmax(300px, .85fr);
        gap: 1.25rem;
        padding: 1.6rem;
    }

    .cvfaq-hero__eyebrow,
    .cvfaq-section__head span,
    .cvfaq-item__category,
    .cvfaq-footnote span,
    .cvfaq-intel-card span,
    .cvfaq-strip__card span {
        color: var(--cvfaq-cyan);
        text-transform: uppercase;
        letter-spacing: .14em;
        font-size: .74rem;
        font-weight: 900;
    }

    .cvfaq-hero h1,
    .cvfaq-section__head h2 {
        margin: .6rem 0 .75rem;
        line-height: 1.02;
        letter-spacing: -.04em;
    }

    .cvfaq-hero h1 {
        font-size: clamp(2rem, 3vw, 3.5rem);
        max-width: 13ch;
    }

    .cvfaq-hero p,
    .cvfaq-section__head p,
    .cvfaq-intel-card p,
    .cvfaq-strip__card p,
    .cvfaq-item__answer p,
    .cvfaq-footnote p {
        margin: 0;
        color: var(--cvfaq-muted);
        line-height: 1.72;
    }

    .cvfaq-hero__chips {
        display: flex;
        flex-wrap: wrap;
        gap: .68rem;
        margin-top: 1.1rem;
    }

    .cvfaq-chip {
        display: inline-flex;
        align-items: center;
        min-height: 2.4rem;
        padding: 0 .9rem;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.09);
        background: rgba(255,255,255,.04);
        color: #dbe8f8;
        font-weight: 800;
        font-size: .82rem;
    }

    .cvfaq-hero__intel {
        display: grid;
        gap: .9rem;
    }

    .cvfaq-intel-card,
    .cvfaq-strip__card {
        position: relative;
        padding: 1rem 1.05rem;
        border-radius: 22px;
        border: 1px solid rgba(255,255,255,.08);
        background: var(--cvfaq-panel-soft);
    }

        .cvfaq-intel-card strong,
        .cvfaq-strip__card strong {
            display: block;
            margin: .45rem 0;
            color: #f8fbff;
            font-size: 1.12rem;
        }

    .cvfaq-intel-card--accent {
        box-shadow: inset 0 0 0 1px rgba(127,246,223,.12), 0 0 28px rgba(127,246,223,.08);
    }

    .cvfaq-strip {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
    }

    .cvfaq-section {
        display: grid;
        gap: 1rem;
    }

    .cvfaq-section__head {
        display: grid;
        gap: .35rem;
    }

        .cvfaq-section__head h2 {
            font-size: clamp(1.45rem, 2vw, 2.35rem);
        }

    .cvfaq-accordion {
        display: grid;
        gap: .9rem;
    }

    .cvfaq-item {
        transition: border-color .22s ease, transform .22s ease, box-shadow .22s ease;
    }

        .cvfaq-item.is-open {
            border-color: rgba(127,246,223,.28);
            box-shadow: 0 26px 76px rgba(0,0,0,.32), 0 0 0 1px rgba(127,246,223,.1);
        }

    .cvfaq-item__toggle {
        width: 100%;
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        gap: 1rem;
        align-items: start;
        text-align: left;
        padding: 1.15rem 1.2rem;
        border: 0;
        background: transparent;
        color: inherit;
    }

    .cvfaq-item__icon {
        width: 3rem;
        height: 3rem;
        border-radius: 16px;
        display: grid;
        place-items: center;
        font-size: 1.2rem;
        font-weight: 900;
        border: 1px solid rgba(255,255,255,.1);
        background: rgba(255,255,255,.04);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.04);
    }

    .cvfaq-item__icon--green {
        color: var(--cvfaq-green);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.04), 0 0 22px rgba(76,243,141,.1);
    }

    .cvfaq-item__icon--cyan {
        color: var(--cvfaq-blue);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.04), 0 0 22px rgba(83,200,255,.1);
    }

    .cvfaq-item__icon--purple {
        color: #c49bff;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.04), 0 0 22px rgba(159,92,255,.12);
    }

    .cvfaq-item__icon--gold {
        color: var(--cvfaq-gold);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.04), 0 0 22px rgba(246,200,95,.12);
    }

    .cvfaq-item__title-wrap strong {
        display: block;
        margin-top: .35rem;
        color: #f8fbff;
        font-size: clamp(1rem, 1vw + .85rem, 1.18rem);
        line-height: 1.35;
    }

    .cvfaq-item__chevron {
        font-size: 1.7rem;
        color: var(--cvfaq-cyan);
        line-height: 1;
        transition: transform .22s ease;
    }

    .cvfaq-item.is-open .cvfaq-item__chevron {
        transform: rotate(45deg);
    }

    .cvfaq-item__answer {
        padding: 0 1.2rem 1.2rem 5.2rem;
    }

    .cvfaq-footnote {
        padding: 1.25rem 1.2rem;
        border-color: rgba(246,200,95,.18);
        background: radial-gradient(circle at top left, rgba(246,200,95,.08), transparent 24%), linear-gradient(180deg, rgba(14,16,24,.98), rgba(9,12,18,.99));
    }

    @@media (max-width: 1080px) {
        .cvfaq-hero,
        .cvfaq-strip {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 760px) {
        .cvfaq-arena {
            gap: 1rem;
            width: min(1880px, calc(100vw - 24px));
            margin-inline: auto;
        }

        .cvfaq-hero,
        .cvfaq-strip__card,
        .cvfaq-item,
        .cvfaq-footnote {
            border-radius: 22px;
        }

        .cvfaq-hero {
            padding: 1.1rem;
        }

        .cvfaq-item__toggle {
            grid-template-columns: auto minmax(0, 1fr);
            padding: 1rem;
        }

        .cvfaq-item__chevron {
            grid-column: 2;
            justify-self: end;
            margin-top: -.2rem;
        }

        .cvfaq-item__answer {
            padding: 0 1rem 1rem 1rem;
        }
    }
</style>
@code {
    private readonly HashSet<string> _openIds = [];
    private IReadOnlyList<FaqEntry> _items = [];

    private string CurrentCulture => AppCulture.GetCurrentRouteCulture(Nav);
    private string MetaKeywords => $"{SeoDefaults.GlobalKeywords}, CriptoVersus FAQ, #CriptoVersus FAQ";
    private string SocialImageUrl => BuildAbsolute(SeoDefaults.DefaultSocialImagePath);
    private IEnumerable<FaqEntry> BasicsItems => _items.Where(item => string.Equals(item.Group, "basics", StringComparison.OrdinalIgnoreCase));
    private IEnumerable<FaqEntry> DeepItems => _items.Where(item => string.Equals(item.Group, "deep", StringComparison.OrdinalIgnoreCase));

    private string StructuredDataMarkup => BuildStructuredData();
    private static readonly string[] HeroChipKeys =
    [
        "strategy",
        "risk",
        "momentum",
        "poolDynamics",
        "liveReading"
    ];

    protected override void OnParametersSet()
    {
        _items = L.GetSection<List<FaqEntry>>("faq.items", CurrentCulture) ?? [];

        if (_items.Count > 0 && _openIds.Count == 0)
        {
            foreach (var item in _items.Take(3))
                _openIds.Add(item.Id);
        }
    }



    private IEnumerable<FaqEntry> BettingItems => _items

     .Where(item => string.Equals(item.Group, "betting", StringComparison.OrdinalIgnoreCase));



    private IEnumerable<FaqEntry> ScoreItems => _items

        .Where(item => string.Equals(item.Group, "score", StringComparison.OrdinalIgnoreCase));



    private IEnumerable<FaqEntry> WalletItems => _items

        .Where(item => string.Equals(item.Group, "wallet", StringComparison.OrdinalIgnoreCase));



    private IEnumerable<FaqEntry> RiskItems => _items

        .Where(item => string.Equals(item.Group, "risk", StringComparison.OrdinalIgnoreCase));



    private IEnumerable<FaqEntry> TvItems => _items

        .Where(item => string.Equals(item.Group, "tv", StringComparison.OrdinalIgnoreCase));



    private IEnumerable<FaqEntry> StatsItems => _items

        .Where(item => string.Equals(item.Group, "stats", StringComparison.OrdinalIgnoreCase));





    private string T(string key, params object?[] args)
        => L.T($"faq.{key}", CurrentCulture, args);

    private string BuildAbsolute(string relativePath)
        => new Uri(new Uri(Nav.BaseUri), relativePath.TrimStart('/')).ToString();

    private void Toggle(string id)
    {
        if (!_openIds.Add(id))
            _openIds.Remove(id);
    }

    private bool IsOpen(string id)
        => _openIds.Contains(id);

    private string BuildStructuredData()
    {
        var pageUrl = BuildAbsolute(RouteLocalization.BuildFaqPath(CurrentCulture));
        var homeUrl = BuildAbsolute(RouteLocalization.BuildHomePath(CurrentCulture));

        var schema = new object[]
        {
            new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@graph"] = new object[]
                {
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "WebPage",
                        ["@id"] = $"{pageUrl}#webpage",
                        ["url"] = pageUrl,
                        ["name"] = T("seo.title"),
                        ["description"] = T("seo.description"),
                        ["inLanguage"] = AppCulture.ToHrefLang(CurrentCulture)
                    },
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "BreadcrumbList",
                        ["itemListElement"] = new object[]
                        {
                            new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 1, ["name"] = "CriptoVersus", ["item"] = homeUrl },
                            new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 2, ["name"] = T("structuredData.breadcrumbFaq"), ["item"] = pageUrl }
                        }
                    },
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "FAQPage",
                        ["mainEntity"] = _items.Select(item => new Dictionary<string, object?>
                        {
                            ["@type"] = "Question",
                            ["name"] = item.Question,
                            ["acceptedAnswer"] = new Dictionary<string, object?>
                            {
                                ["@type"] = "Answer",
                                ["text"] = item.Answer
                            }
                        }).ToArray()
                    }
                }
            }
        };

        return JsonSerializer.Serialize(schema[0]);
    }

    private sealed class FaqEntry
    {
        public string Id { get; set; } = string.Empty;
        public string Group { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public string Icon { get; set; } = "?";
        public string Tone { get; set; } = "cyan";
        public string Question { get; set; } = string.Empty;
        public string Answer { get; set; } = string.Empty;
    }
}

