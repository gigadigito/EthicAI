@layout BlankLayout
@page "/social/hot-matches"
@page "/{Culture}/social/hot-matches"
@using System.Globalization
@using System.Text.Json
@using DTOs
@using CriptoVersus.Web.Services
@inject DailyHotMatchesService DailyHotMatches
@inject CriptoVersusApiClient Api
@inject RouteLocalizationService RouteLocalization
@inject AppCultureService AppCulture
@inject LocalizationService L
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpContextAccessor
@inject IConfiguration Config
@inject MatchSlugHelper MatchSlugHelper
@inject ILogger<HotMatchesSocial> Logger
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <meta name="robots" content="noindex,nofollow,noarchive" />
    <meta name="description" content="@SeoDescription" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="en-US" href="@EnglishUrl" />
    <link rel="alternate" hreflang="pt-BR" href="@PortugueseUrl" />
    <link rel="alternate" hreflang="zh-CN" href="@ChineseUrl" />
    <link rel="alternate" hreflang="x-default" href="@EnglishUrl" />
    <meta property="og:title" content="@PageTitleText" />
    <meta property="og:description" content="@SeoDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="@SocialImageUrl" />
    <meta property="og:image:alt" content="@PageTitleText" />
    <meta property="og:locale" content="@AppCulture.ToOgLocale(ResolvedCulture)" />
    <meta property="og:locale:alternate" content="@AppCulture.GetAlternateOgLocale(ResolvedCulture)" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@PageTitleText" />
    <meta name="twitter:description" content="@SeoDescription" />
    <meta name="twitter:image" content="@SocialImageUrl" />
    <meta name="twitter:image:alt" content="@PageTitleText" />
    <script type="application/ld+json">@((MarkupString)StructuredDataMarkup)</script>
</HeadContent>

<style>
    .hot-matches-social {
        --team-a-color: #ff9100;
        --team-a-hot: #ff5a00;
        --team-a-rgb: 255, 145, 0;
        --team-b-color: #18d8d2;
        --team-b-bright: #18f5ff;
        --team-b-rgb: 24, 216, 210;
        --surface-0: #02050a;
        --surface-1: #07101a;
        --surface-2: #0b1622;
        --text-main: #f7fbff;
        --text-muted: #a8b6c8;
        --text-soft: #72859b;
        --line: rgba(255, 255, 255, .085);
        --line-strong: rgba(255, 255, 255, .15);
        position: relative;
        min-height: 100vh;
        overflow: hidden;
        display: grid;
        place-items: center;
        padding: clamp(10px, 1.6vw, 24px);
        color: var(--text-main);
        background: radial-gradient(circle at 10% 35%, rgba(var(--team-a-rgb), .18), transparent 30%), radial-gradient(circle at 90% 35%, rgba(var(--team-b-rgb), .16), transparent 30%), linear-gradient(180deg, #01040a 0%, #06101a 54%, #02050a 100%);
        font-family: "Arial Narrow", "Segoe UI", Arial, sans-serif;
    }

        .hot-matches-social *,
        .hot-matches-social *::before,
        .hot-matches-social *::after {
            box-sizing: border-box;
        }

    .hot-matches-social__backdrop,
    .hot-matches-social__backdrop::before,
    .hot-matches-social__backdrop::after {
        position: absolute;
        inset: 0;
        pointer-events: none;
        content: "";
    }

    .hot-matches-social__backdrop {
        background: linear-gradient(rgba(255,255,255,.018) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.018) 1px, transparent 1px);
        background-size: 38px 38px;
        mask-image: linear-gradient(to bottom, rgba(0,0,0,.8), transparent 90%);
    }

        .hot-matches-social__backdrop::before {
            top: 52%;
            background: linear-gradient(rgba(var(--team-b-rgb), .12) 1px, transparent 1px), linear-gradient(90deg, rgba(var(--team-b-rgb), .10) 1px, transparent 1px);
            background-size: 72px 44px;
            transform: perspective(680px) rotateX(63deg) scale(1.45);
            transform-origin: bottom;
            opacity: .16;
            mask-image: linear-gradient(to top, #000, transparent 90%);
        }

        .hot-matches-social__backdrop::after {
            background: repeating-linear-gradient( 0deg, rgba(255,255,255,.016) 0, rgba(255,255,255,.016) 1px, transparent 1px, transparent 4px ), radial-gradient(circle at 0 55%, rgba(var(--team-a-rgb), .10), transparent 34%), radial-gradient(circle at 100% 55%, rgba(var(--team-b-rgb), .10), transparent 34%);
            opacity: .55;
        }

    .hot-matches-social__card {
        position: relative;
        z-index: 1;
        width: min(100%, 1600px);
        aspect-ratio: 16 / 9;
        min-height: 0;
        display: grid;
        grid-template-rows: 126px minmax(0, 1fr) 78px;
        gap: 14px;
        padding: 38px 48px 28px;
        overflow: hidden;
        isolation: isolate;
        clip-path: polygon( 24px 0, calc(100% - 24px) 0, 100% 24px, 100% calc(100% - 24px), calc(100% - 24px) 100%, 24px 100%, 0 calc(100% - 24px), 0 24px );
        background: radial-gradient(circle at 0 0, rgba(var(--team-a-rgb), .13), transparent 28%), radial-gradient(circle at 100% 0, rgba(var(--team-b-rgb), .13), transparent 28%), linear-gradient(180deg, rgba(5, 10, 17, .99), rgba(2, 6, 11, .995));
        box-shadow: 0 42px 110px rgba(0,0,0,.62), inset 0 1px 0 rgba(255,255,255,.045), inset 0 -80px 120px rgba(0,0,0,.38);
    }

        .hot-matches-social__card::before {
            content: "";
            position: absolute;
            inset: 0;
            padding: 2px;
            pointer-events: none;
            clip-path: inherit;
            background: linear-gradient( 90deg, rgba(var(--team-a-rgb), .95), rgba(255,255,255,.08) 34%, rgba(255,255,255,.08) 66%, rgba(var(--team-b-rgb), .95) );
            -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            filter: drop-shadow(-8px 0 16px rgba(var(--team-a-rgb), .20)) drop-shadow(8px 0 16px rgba(var(--team-b-rgb), .20));
        }

        .hot-matches-social__card::after {
            content: "";
            position: absolute;
            inset: 0;
            z-index: -1;
            pointer-events: none;
            background: linear-gradient(115deg, rgba(255,255,255,.035), transparent 22%, transparent 76%, rgba(255,255,255,.025)), radial-gradient(circle at 12% 84%, rgba(var(--team-a-rgb), .09), transparent 24%), radial-gradient(circle at 88% 84%, rgba(var(--team-b-rgb), .09), transparent 24%);
        }

    .hot-matches-social__header {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: 250px minmax(0, 1fr) 250px;
        align-items: center;
        gap: 24px;
        min-width: 0;
    }

        .hot-matches-social__header::after {
            content: "";
            position: absolute;
            left: 0;
            right: 0;
            bottom: -7px;
            height: 1px;
            background: linear-gradient( 90deg, rgba(var(--team-a-rgb), .55), rgba(255,255,255,.06) 38%, rgba(255,255,255,.06) 62%, rgba(var(--team-b-rgb), .55) );
            box-shadow: -160px 0 18px rgba(var(--team-a-rgb), .18), 160px 0 18px rgba(var(--team-b-rgb), .18);
        }

    .hot-matches-social__brand {
        display: grid;
        gap: 12px;
        align-content: center;
        justify-items: start;
    }

    .hot-matches-social__brand-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        min-width: 170px;
        padding: 11px 20px;
        clip-path: polygon(13px 0, calc(100% - 13px) 0, 100% 50%, calc(100% - 13px) 100%, 13px 100%, 0 50%);
        border: 1px solid rgba(var(--team-b-rgb), .58);
        background: linear-gradient(180deg, rgba(5, 38, 44, .92), rgba(3, 20, 27, .96));
        color: var(--team-b-bright);
        font-size: 14px;
        font-weight: 950;
        letter-spacing: .22em;
        text-transform: uppercase;
        text-shadow: 0 0 10px rgba(var(--team-b-rgb), .42);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.06), 0 0 20px rgba(var(--team-b-rgb), .12);
    }

    .hot-matches-social__period {
        color: #d8e1ec;
        font-size: 15px;
        font-weight: 900;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .hot-matches-social__title-block {
        min-width: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 18px;
        text-align: center;
    }

    .hot-matches-social__flame {
        flex: 0 0 76px;
        width: 76px;
        height: 92px;
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 0;
        overflow: visible;
        transform: translateY(1px);
    }

    .hot-matches-social__title-copy {
        min-width: 0;
        display: grid;
        align-content: center;
        gap: 7px;
    }

    .hot-matches-social__title-block h1 {
        margin: 0;
        max-width: 100%;
        overflow: hidden;
        font-size: clamp(46px, 4.65vw, 78px);
        font-weight: 950;
        font-style: italic;
        line-height: .92;
        letter-spacing: -.035em;
        text-overflow: ellipsis;
        white-space: nowrap;
        background: linear-gradient( 180deg, #ffffff 0%, #f8fbff 27%, #bac5d0 52%, #ffffff 72%, #727b84 100% );
        -webkit-background-clip: text;
        color: transparent;
        text-shadow: 0 2px 0 rgba(255,255,255,.14), 0 7px 0 rgba(0,0,0,.34), 0 12px 24px rgba(0,0,0,.60), 0 0 18px rgba(114,203,255,.15);
    }

    .hot-matches-social__subtitle {
        margin: 0;
        color: #d7e1ec;
        font-size: 17px;
        font-weight: 500;
        line-height: 1.3;
    }

    .hot-matches-social__meta {
        display: grid;
        justify-items: end;
        align-content: center;
    }

    .hot-matches-social__updated {
        color: #f2f7ff;
        font-size: 15px;
        font-weight: 950;
        letter-spacing: .08em;
        text-align: right;
        text-transform: uppercase;
        white-space: nowrap;
        text-shadow: 0 0 12px rgba(var(--team-b-rgb), .18);
    }

    .hot-matches-social__board {
        position: relative;
        z-index: 2;
        min-width: 0;
        min-height: 0;
    }

    .hot-matches-social__list {
        height: 100%;
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        grid-template-rows: repeat(5, minmax(0, 1fr));
        gap: 10px;
    }

    .hot-matches-social__item {
        min-width: 0;
        min-height: 0;
    }

    .hot-matches-social__link,
    .hot-matches-social__placeholder-row {
        position: relative;
        height: 100%;
        min-width: 0;
        display: grid;
        grid-template-columns: 92px minmax(220px, 1fr) 350px minmax(220px, 1fr) 360px;
        align-items: center;
        gap: 18px;
        padding: 11px 22px;
        overflow: hidden;
        clip-path: polygon( 16px 0, calc(100% - 16px) 0, 100% 16px, 100% calc(100% - 16px), calc(100% - 16px) 100%, 16px 100%, 0 calc(100% - 16px), 0 16px );
        background: linear-gradient( 90deg, rgba(var(--team-a-rgb), .14), rgba(7, 13, 20, .97) 27%, rgba(7, 13, 20, .98) 73%, rgba(var(--team-b-rgb), .13) );
        box-shadow: inset 0 1px 0 rgba(255,255,255,.05), inset 0 -1px 0 rgba(0,0,0,.75);
    }

        .hot-matches-social__link::before,
        .hot-matches-social__placeholder-row::before {
            content: "";
            position: absolute;
            inset: 0;
            padding: 1px;
            pointer-events: none;
            clip-path: inherit;
            background: linear-gradient( 90deg, rgba(var(--team-a-rgb), .92), rgba(255,145,0,.10) 35%, rgba(24,216,210,.10) 65%, rgba(var(--team-b-rgb), .92) );
            -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
        }

        .hot-matches-social__link::after {
            content: "";
            position: absolute;
            inset: 4px 12px auto;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,.11), transparent);
            pointer-events: none;
        }

    .hot-matches-social__link {
        color: inherit;
        text-decoration: none;
        transition: transform .18s ease, filter .18s ease;
    }

        .hot-matches-social__link:hover,
        .hot-matches-social__link:focus-visible {
            transform: translateY(-1px);
            filter: brightness(1.08);
            outline: none;
        }

    .hot-matches-social__item--rank-1 .hot-matches-social__link {
        background: linear-gradient( 90deg, rgba(var(--team-a-rgb), .20), rgba(7, 13, 20, .99) 28%, rgba(7, 13, 20, .99) 72%, rgba(var(--team-b-rgb), .18) );
        filter: drop-shadow(-4px 0 7px rgba(var(--team-a-rgb), .18)) drop-shadow(4px 0 7px rgba(var(--team-b-rgb), .16));
    }

    .hot-matches-social__rank {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 66px;
        height: 66px;
        margin-inline: auto;
        border-radius: 50%;
        color: #fff;
        font-weight: 950;
        background: radial-gradient(circle at 34% 26%, #3e4650, #151a20 58%, #05070a 100%);
        border: 1px solid rgba(255,255,255,.20);
        box-shadow: inset 0 2px 2px rgba(255,255,255,.12), inset 0 -8px 12px rgba(0,0,0,.58), 0 6px 16px rgba(0,0,0,.45);
    }

    .hot-matches-social__item--rank-1 .hot-matches-social__rank {
        background: radial-gradient(circle at 34% 26%, #fff4a3 0%, #ffc62c 28%, #9e5e00 67%, #2d1400 100%);
        border-color: rgba(255,218,86,.88);
        box-shadow: inset 0 2px 2px rgba(255,255,255,.36), inset 0 -8px 12px rgba(84,35,0,.54), 0 0 18px rgba(255,182,0,.30);
    }

    .hot-matches-social__item--rank-2 .hot-matches-social__rank {
        background: radial-gradient(circle at 34% 26%, #ffffff 0%, #d9e2ea 34%, #6f7780 70%, #1c2229 100%);
        border-color: rgba(224,234,244,.82);
    }

    .hot-matches-social__item--rank-3 .hot-matches-social__rank {
        background: radial-gradient(circle at 34% 26%, #ffd49d 0%, #c87b2d 38%, #703613 70%, #241005 100%);
        border-color: rgba(209,126,51,.82);
    }

    .hot-matches-social__medal {
        font-size: 37px;
        line-height: 1;
        filter: drop-shadow(0 2px 3px rgba(0,0,0,.35));
    }

    .hot-matches-social__position {
        font-size: 22px;
        line-height: 1;
    }

    .hot-matches-social__team {
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .hot-matches-social__team--b {
        justify-content: flex-end;
        text-align: right;
    }

    .hot-matches-social__team strong {
        min-width: 0;
        overflow: hidden;
        font-size: clamp(28px, 2vw, 40px);
        font-weight: 950;
        letter-spacing: .035em;
        line-height: .95;
        text-overflow: ellipsis;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .hot-matches-social__team--a strong {
        color: var(--team-a-color);
        text-shadow: 0 0 14px rgba(var(--team-a-rgb), .28);
    }

    .hot-matches-social__team--b strong {
        color: var(--team-b-bright);
        text-shadow: 0 0 14px rgba(var(--team-b-rgb), .28);
    }

    .hot-matches-social__coin {
        position: relative;
        flex: 0 0 auto;
        width: 70px;
        height: 70px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-radius: 50%;
        background: radial-gradient(circle at 36% 28%, rgba(255,255,255,.16), rgba(255,255,255,.04) 58%, rgba(0,0,0,.40));
        box-shadow: inset 0 1px 0 rgba(255,255,255,.10), inset 0 -8px 14px rgba(0,0,0,.48);
    }

        .hot-matches-social__coin::before {
            content: "";
            position: absolute;
            inset: 4px;
            border-radius: inherit;
            border: 1px solid rgba(255,255,255,.10);
            pointer-events: none;
        }

    .hot-matches-social__coin--a {
        border: 3px solid rgba(var(--team-a-rgb), .95);
        box-shadow: 0 0 0 4px rgba(var(--team-a-rgb), .10), 0 0 22px rgba(var(--team-a-rgb), .30), inset 0 0 15px rgba(var(--team-a-rgb), .10);
    }

    .hot-matches-social__coin--b {
        border: 3px solid rgba(var(--team-b-rgb), .95);
        box-shadow: 0 0 0 4px rgba(var(--team-b-rgb), .10), 0 0 22px rgba(var(--team-b-rgb), .30), inset 0 0 15px rgba(var(--team-b-rgb), .10);
    }

    .hot-matches-social__coin-image {
        width: 100%;
        height: 100%;
        padding: 8px;
        object-fit: contain;
        border-radius: 50%;
    }

    .hot-matches-social__coin-fallback {
        display: none;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        color: var(--text-main);
        font-size: 18px;
        font-weight: 950;
        letter-spacing: .06em;
    }

        .hot-matches-social__coin-fallback.is-visible {
            display: inline-flex;
        }

    .hot-matches-social__score {
        position: relative;
        min-width: 0;
        height: 78px;
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 18px;
        padding: 8px 42px;
        overflow: visible;
        clip-path: polygon( 28px 0, calc(100% - 28px) 0, 100% 50%, calc(100% - 28px) 100%, 28px 100%, 0 50% );
        background: linear-gradient( 90deg, rgba(var(--team-a-rgb), .18), #02070d 26%, #040a11 50%, #02070d 74%, rgba(var(--team-b-rgb), .18) );
        box-shadow: inset 0 1px 0 rgba(255,255,255,.08), inset 0 -10px 20px rgba(0,0,0,.48);
    }

        .hot-matches-social__score::before {
            content: "";
            position: absolute;
            inset: 0;
            padding: 2px;
            clip-path: inherit;
            background: linear-gradient( 90deg, var(--team-a-color), rgba(var(--team-a-rgb), .20) 40%, rgba(var(--team-b-rgb), .20) 60%, var(--team-b-bright) );
            -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
        }

        .hot-matches-social__score::after {
            content: "";
            position: absolute;
            left: 18%;
            right: 18%;
            top: 50%;
            height: 2px;
            transform: translateY(-50%);
            background: linear-gradient( 90deg, transparent, var(--team-a-color), #ffffff, var(--team-b-bright), transparent );
            opacity: .42;
            filter: blur(.2px);
            box-shadow: 0 0 16px rgba(255,255,255,.30), -54px 0 20px rgba(var(--team-a-rgb), .26), 54px 0 20px rgba(var(--team-b-rgb), .26);
        }

    .hot-matches-social__score-value,
    .hot-matches-social__score-separator {
        position: relative;
        z-index: 1;
    }

    .hot-matches-social__score-value {
        font-size: clamp(45px, 3.6vw, 68px);
        font-weight: 950;
        font-style: italic;
        line-height: 1;
    }

    .hot-matches-social__score-value--a {
        color: var(--team-a-color);
        text-align: right;
        text-shadow: 0 0 14px rgba(var(--team-a-rgb), .34), 0 4px 0 rgba(104,43,0,.55);
    }

    .hot-matches-social__score-value--b {
        color: var(--team-b-bright);
        text-align: left;
        text-shadow: 0 0 14px rgba(var(--team-b-rgb), .34), 0 4px 0 rgba(0,74,82,.55);
    }

    .hot-matches-social__score-separator {
        color: #f7fbff;
        font-size: 33px;
        font-weight: 950;
        letter-spacing: .04em;
        text-shadow: 0 0 12px rgba(255,255,255,.18);
    }

    .hot-matches-social__insights {
        min-width: 0;
        display: grid;
        gap: 9px;
        justify-items: end;
        align-content: center;
    }

    .hot-matches-social__insights-main {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 9px;
        min-width: 0;
    }

    .hot-matches-social__insights-meta {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 9px;
        min-width: 0;
        color: #d7e1ec;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: .04em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .hot-matches-social__temperature,
    .hot-matches-social__balance {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        min-height: 38px;
        padding: 8px 17px;
        clip-path: polygon(10px 0, calc(100% - 10px) 0, 100% 50%, calc(100% - 10px) 100%, 10px 100%, 0 50%);
        border: 1px solid rgba(255,255,255,.12);
        font-size: 12px;
        font-weight: 950;
        letter-spacing: .055em;
        line-height: 1;
        text-transform: uppercase;
        white-space: nowrap;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.08);
    }

    .hot-matches-social__hot-score::before,
    .hot-matches-social__last-goal::before {
        content: "•";
        margin-right: 9px;
        color: rgba(var(--team-b-rgb), .70);
        text-shadow: 0 0 6px rgba(var(--team-b-rgb), .45);
    }

    .hot-matches-social__temperature--cold {
        color: #dff5ff;
        background: linear-gradient(180deg, rgba(34,83,120,.88), rgba(15,42,67,.94));
        border-color: rgba(83,160,255,.48);
    }

    .hot-matches-social__temperature--warm {
        color: #fff0cf;
        background: linear-gradient(180deg, rgba(95,64,15,.90), rgba(48,31,6,.95));
        border-color: rgba(255,191,92,.48);
    }

    .hot-matches-social__temperature--hot {
        color: #fff0d8;
        background: linear-gradient(180deg, rgba(117,66,5,.92), rgba(59,34,4,.96));
        border-color: rgba(var(--team-a-rgb), .60);
    }

    .hot-matches-social__temperature--explosive {
        color: #ffe9ee;
        background: linear-gradient(180deg, rgba(111,28,31,.92), rgba(55,11,16,.96));
        border-color: rgba(255,95,125,.62);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.09), 0 0 14px rgba(255,66,40,.10);
    }

    .hot-matches-social__temperature--historic {
        color: #fff5c7;
        background: linear-gradient(180deg, rgba(116,83,19,.92), rgba(58,39,5,.96));
        border-color: rgba(255,221,126,.60);
    }

    .hot-matches-social__balance--tied {
        color: #f5f8ff;
        background: linear-gradient(180deg, rgba(56,65,77,.90), rgba(25,30,37,.96));
        border-color: rgba(255,255,255,.30);
    }

    .hot-matches-social__balance--veryClose {
        color: #e9fffd;
        background: linear-gradient(180deg, rgba(4,70,85,.92), rgba(3,38,51,.96));
        border-color: rgba(var(--team-b-rgb), .58);
    }

    .hot-matches-social__balance--close {
        color: #fff1d7;
        background: linear-gradient(180deg, rgba(101,67,14,.92), rgba(53,34,4,.96));
        border-color: rgba(var(--team-a-rgb), .56);
    }

    .hot-matches-social__balance--clearLead {
        color: #f3eaff;
        background: linear-gradient(180deg, rgba(72,41,116,.92), rgba(37,21,67,.96));
        border-color: rgba(141,87,255,.60);
    }

    .hot-matches-social__status {
        color: #dce7f5;
    }

    .hot-matches-social__status--live {
        color: var(--team-b-bright);
    }

    .hot-matches-social__status--closing {
        color: #ffc96f;
    }

    .hot-matches-social__status--final {
        color: #f4f7fb;
    }

    .hot-matches-social__status--scheduled {
        color: #b7c5d8;
    }

    .hot-matches-social__status--cancelled {
        color: #ff9baa;
    }

    .hot-matches-social__item--placeholder {
        opacity: .64;
    }

    .hot-matches-social__placeholder-team {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .hot-matches-social__placeholder-team--b {
        justify-content: flex-end;
    }

    .hot-matches-social__placeholder-coin,
    .hot-matches-social__placeholder-line,
    .hot-matches-social__placeholder-score,
    .hot-matches-social__placeholder-pill {
        position: relative;
        overflow: hidden;
        background: linear-gradient(90deg, rgba(255,255,255,.04), rgba(255,255,255,.11), rgba(255,255,255,.04));
        background-size: 200% 100%;
        animation: hotMatchesShimmer 1.6s linear infinite;
    }

    .hot-matches-social__placeholder-coin {
        width: 70px;
        height: 70px;
        border-radius: 50%;
    }

    .hot-matches-social__placeholder-line {
        height: 16px;
        border-radius: 999px;
    }

    .hot-matches-social__placeholder-line--short {
        width: 120px;
    }

    .hot-matches-social__placeholder-score {
        min-height: 78px;
        clip-path: polygon(28px 0, calc(100% - 28px) 0, 100% 50%, calc(100% - 28px) 100%, 28px 100%, 0 50%);
        color: transparent;
    }

    .hot-matches-social__placeholder-copy {
        color: var(--text-soft);
        font-size: 13px;
        font-weight: 900;
        letter-spacing: .07em;
        text-align: right;
        text-transform: uppercase;
    }

    .hot-matches-social__footer {
        position: relative;
        z-index: 2;
        display: grid;
        grid-template-columns: auto minmax(80px, 1fr) auto;
        align-items: end;
        gap: 28px;
    }

        .hot-matches-social__footer::before {
            content: "";
            height: 1px;
            margin-bottom: 16px;
            background: linear-gradient( 90deg, rgba(var(--team-a-rgb), .34), rgba(255,255,255,.07), rgba(var(--team-b-rgb), .34) );
            grid-column: 2;
        }

        .hot-matches-social__footer > div {
            grid-column: 1;
            grid-row: 1;
        }

    .hot-matches-social__footer-domain {
        display: block;
        margin-bottom: 5px;
        color: var(--text-main);
        font-size: 29px;
        font-weight: 950;
        letter-spacing: .04em;
        text-transform: lowercase;
        text-shadow: 0 2px 0 rgba(0,0,0,.45);
    }

    .hot-matches-social__footer p {
        margin: 0;
        color: #c8d2dd;
        font-size: 14px;
        line-height: 1.35;
    }

    .hot-matches-social__footer-tag {
        grid-column: 3;
        grid-row: 1;
        color: var(--team-b-bright);
        font-size: 25px;
        font-weight: 950;
        font-style: italic;
        letter-spacing: .12em;
        text-transform: uppercase;
        white-space: nowrap;
        text-shadow: 0 0 14px rgba(var(--team-b-rgb), .25);
    }



    /* Texturas externas: copie o pacote para wwwroot/images/social/hot-matches/ */
    .hot-matches-social__texture {
        position: absolute;
        inset: 0;
        pointer-events: none;
        user-select: none;
    }

    .hot-matches-social__noise {
        z-index: 0;
        background: url('/images/social/hot-matches/arena-noise.webp') repeat;
        opacity: .052;
        mix-blend-mode: screen;
    }

    .hot-matches-social__circuit {
        z-index: 0;
        background: url('/images/social/hot-matches/arena-circuit.svg') center / cover no-repeat;
        opacity: .30;
        mix-blend-mode: screen;
    }

    .hot-matches-social__particles {
        z-index: 0;
        background-repeat: no-repeat;
        background-size: contain;
        opacity: .66;
        mix-blend-mode: screen;
    }

    .hot-matches-social__particles--orange {
        background-image: url('/images/social/hot-matches/arena-particles-orange.webp');
        background-position: left center;
    }

    .hot-matches-social__particles--cyan {
        background-image: url('/images/social/hot-matches/arena-particles-cyan.webp');
        background-position: right center;
    }

    .hot-matches-social__corner {
        position: absolute;
        z-index: 3;
        width: 250px;
        height: 142px;
        pointer-events: none;
        opacity: .82;
        background-repeat: no-repeat;
        background-size: contain;
        filter: drop-shadow(0 0 12px currentColor);
    }

    .hot-matches-social__corner--top-left {
        top: 12px;
        left: 16px;
        color: rgba(var(--team-a-rgb), .38);
        background-image: url('/images/social/hot-matches/corner-orange.svg');
    }

    .hot-matches-social__corner--bottom-right {
        right: 16px;
        bottom: 12px;
        color: rgba(var(--team-b-rgb), .38);
        background-image: url('/images/social/hot-matches/corner-cyan.svg');
        transform: rotate(180deg);
    }

    .hot-matches-social__flame-image {
        display: block;
        width: 68px;
        height: 84px;
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        object-position: center;
        vertical-align: middle;
        filter: drop-shadow(0 0 10px rgba(255, 68, 24, .92)) drop-shadow(0 0 24px rgba(var(--team-a-rgb), .42));
    }

    .hot-matches-social__score-sparks {
        position: absolute;
        top: 50%;
        z-index: 0;
        width: 118px;
        height: 58px;
        transform: translateY(-50%);
        background-position: center;
        background-repeat: no-repeat;
        background-size: contain;
        opacity: .72;
        pointer-events: none;
        mix-blend-mode: screen;
    }

    .hot-matches-social__score-sparks--a {
        left: -62px;
        background-image: url('/images/social/hot-matches/sparks-orange.svg');
    }

    .hot-matches-social__score-sparks--b {
        right: -62px;
        background-image: url('/images/social/hot-matches/sparks-cyan.svg');
    }

    .hot-matches-social__card > :not(.hot-matches-social__texture):not(.hot-matches-social__corner) {
        position: relative;
        z-index: 2;
    }

    .hot-matches-social[data-capture="true"] *,
    .hot-matches-social[data-capture="true"] *::before,
    .hot-matches-social[data-capture="true"] *::after {
        animation: none !important;
        transition: none !important;
    }

    @@media (max-width: 1320px) {
        .hot-matches-social__card {
            grid-template-rows: 108px minmax(0, 1fr) 68px;
            padding: 30px 34px 24px;
        }

        .hot-matches-social__header {
            grid-template-columns: 210px minmax(0, 1fr) 210px;
        }

        .hot-matches-social__link,
        .hot-matches-social__placeholder-row {
            grid-template-columns: 76px minmax(180px, 1fr) 290px minmax(180px, 1fr) 300px;
            gap: 13px;
            padding-inline: 16px;
        }

        .hot-matches-social__rank {
            width: 58px;
            height: 58px;
        }

        .hot-matches-social__coin {
            width: 58px;
            height: 58px;
        }

        .hot-matches-social__score {
            height: 68px;
            padding-inline: 34px;
        }

        .hot-matches-social__insights-meta {
            font-size: 10px;
        }

        .hot-matches-social__temperature,
        .hot-matches-social__balance {
            min-height: 33px;
            padding: 7px 13px;
            font-size: 10px;
        }
    }

    @@media (max-width: 980px) {
        .hot-matches-social {
            place-items: start center;
            overflow: auto;
        }

        .hot-matches-social__card {
            width: 1200px;
            min-width: 1200px;
            aspect-ratio: 16 / 9;
        }
    }

    @@media (prefers-reduced-motion: reduce) {
        .hot-matches-social__link,
        .hot-matches-social__placeholder-coin,
        .hot-matches-social__placeholder-line,
        .hot-matches-social__placeholder-score,
        .hot-matches-social__placeholder-pill {
            animation: none !important;
            transition: none !important;
        }
    }

    @@keyframes hotMatchesShimmer {
        0% {
            background-position: 200% 0;
        }

        100% {
            background-position: -200% 0;
        }
    }
</style>

<main id="hot-matches-social-card"
      class="hot-matches-social"
      data-loading="@_loading.ToString().ToLowerInvariant()"
      data-ready="@((!_loading).ToString().ToLowerInvariant())"
      data-capture="@CaptureMode.ToString().ToLowerInvariant()"
      aria-labelledby="hot-matches-social-title">
    <div class="hot-matches-social__backdrop" aria-hidden="true"></div>
    <div class="hot-matches-social__texture hot-matches-social__noise" aria-hidden="true"></div>
    <div class="hot-matches-social__texture hot-matches-social__circuit" aria-hidden="true"></div>
    <div class="hot-matches-social__texture hot-matches-social__particles hot-matches-social__particles--orange" aria-hidden="true"></div>
    <div class="hot-matches-social__texture hot-matches-social__particles hot-matches-social__particles--cyan" aria-hidden="true"></div>

    <section class="hot-matches-social__card" aria-label="@PageTitleText">
        <div class="hot-matches-social__texture hot-matches-social__noise" aria-hidden="true"></div>
        <div class="hot-matches-social__texture hot-matches-social__circuit" aria-hidden="true"></div>
        <div class="hot-matches-social__corner hot-matches-social__corner--top-left" aria-hidden="true"></div>
        <div class="hot-matches-social__corner hot-matches-social__corner--bottom-right" aria-hidden="true"></div>
        <header class="hot-matches-social__header">
            <div class="hot-matches-social__brand">
                <span class="hot-matches-social__brand-mark">CriptoVersus</span>
                <span class="hot-matches-social__period">@T("social.hotMatches.last24Hours")</span>
            </div>

            <div class="hot-matches-social__title-block">
                <span class="hot-matches-social__flame" aria-hidden="true">
                    <img class="hot-matches-social__flame-image"
                         src="/images/social/hot-matches/flame-premium.svg?v=4"
                         alt=""
                         width="68"
                         height="84"
                         loading="eager"
                         decoding="sync" />
                </span>
                <div class="hot-matches-social__title-copy">
                    <h1 id="hot-matches-social-title">@VisualTitleText</h1>
                    <p class="hot-matches-social__subtitle">@SeoDescription</p>
                </div>
            </div>

            <div class="hot-matches-social__meta">
                <span class="hot-matches-social__updated">
                    @T("social.hotMatches.updatedAt", _updatedAtUtc.ToString("HH:mm", CultureInfo.InvariantCulture))
                </span>
            </div>
        </header>

        <section class="hot-matches-social__board" aria-label="@T("social.hotMatches.listAriaLabel")">
            <ol class="hot-matches-social__list">
                @for (var index = 0; index < DisplayLimit; index++)
                {
                    var match = index < _rankedMatches.Count ? _rankedMatches[index] : null;

                    if (match is not null)
                    {
                        <li class="hot-matches-social__item hot-matches-social__item--rank-@(index + 1) hot-matches-social__item--@HotMatchesSocialCardRules.GetTemperatureKey(match.HotScore)">
                            <a class="hot-matches-social__link"
                               href="@GetPublicMatchUrl(match)"
                               target="_blank"
                               rel="noopener noreferrer"
                               aria-label="@T("social.hotMatches.openMatchAria", GetDisplaySymbol(match.HomeSymbol), GetDisplaySymbol(match.AwaySymbol), match.MatchId)">

                                <span class="hot-matches-social__rank" aria-hidden="true">
                                    @if (index < 3)
                                    {
                                        <span class="hot-matches-social__medal">@GetMedal(index)</span>
                                    }
                                    else
                                    {
                                        <span class="hot-matches-social__position">@(index + 1)</span>
                                    }
                                </span>

                                <span class="hot-matches-social__team hot-matches-social__team--a">
                                    <span class="hot-matches-social__coin hot-matches-social__coin--a" aria-hidden="true">
                                        <img class="hot-matches-social__coin-image"
                                             src="@GetCoinIconUrl(match, true)"
                                             alt="@GetDisplaySymbol(match.HomeSymbol)"
                                             width="70"
                                             height="70"
                                             loading="eager"
                                             decoding="async"
                                             onerror="this.remove(); this.nextElementSibling?.classList.add('is-visible');" />
                                        <span class="hot-matches-social__coin-fallback">@GetInitials(match.HomeSymbol)</span>
                                    </span>
                                    <strong>@GetDisplaySymbol(match.HomeSymbol)</strong>
                                </span>

                                <span class="hot-matches-social__score"
                                      aria-label="@T("social.hotMatches.scoreAria", match.HomeScore, match.AwayScore)">
                                    <span class="hot-matches-social__score-sparks hot-matches-social__score-sparks--a" aria-hidden="true"></span>
                                    <span class="hot-matches-social__score-sparks hot-matches-social__score-sparks--b" aria-hidden="true"></span>
                                    <span class="hot-matches-social__score-value hot-matches-social__score-value--a">@match.HomeScore</span>
                                    <span class="hot-matches-social__score-separator">×</span>
                                    <span class="hot-matches-social__score-value hot-matches-social__score-value--b">@match.AwayScore</span>
                                </span>

                                <span class="hot-matches-social__team hot-matches-social__team--b">
                                    <strong>@GetDisplaySymbol(match.AwaySymbol)</strong>
                                    <span class="hot-matches-social__coin hot-matches-social__coin--b" aria-hidden="true">
                                        <img class="hot-matches-social__coin-image"
                                             src="@GetCoinIconUrl(match, false)"
                                             alt="@GetDisplaySymbol(match.AwaySymbol)"
                                             width="70"
                                             height="70"
                                             loading="eager"
                                             decoding="async"
                                             onerror="this.remove(); this.nextElementSibling?.classList.add('is-visible');" />
                                        <span class="hot-matches-social__coin-fallback">@GetInitials(match.AwaySymbol)</span>
                                    </span>
                                </span>

                                <span class="hot-matches-social__insights">
                                    <span class="hot-matches-social__insights-main">
                                        <span class="hot-matches-social__temperature hot-matches-social__temperature--@HotMatchesSocialCardRules.GetTemperatureKey(match.HotScore)">
                                            @GetTemperatureText(match.HotScore)
                                        </span>
                                        <span class="hot-matches-social__balance hot-matches-social__balance--@HotMatchesSocialCardRules.GetBalanceKey(match.ScoreDifference)">
                                            @GetBalanceText(match.ScoreDifference)
                                        </span>
                                    </span>

                                    <span class="hot-matches-social__insights-meta">
                                        <span class="hot-matches-social__status hot-matches-social__status--@HotMatchesSocialCardRules.GetStatusKey(match.Status)">
                                            @GetStatusText(match)
                                        </span>
                                        <span class="hot-matches-social__hot-score">@T("social.hotMatches.hotScore", match.HotScore)</span>
                                        <span class="hot-matches-social__last-goal">@GetLastGoalText(match)</span>
                                    </span>
                                </span>
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="hot-matches-social__item hot-matches-social__item--placeholder" aria-hidden="true">
                            <div class="hot-matches-social__placeholder-row">
                                <span class="hot-matches-social__rank">
                                    <span class="hot-matches-social__position">@(index + 1)</span>
                                </span>

                                <span class="hot-matches-social__placeholder-team">
                                    <span class="hot-matches-social__placeholder-coin"></span>
                                    <span class="hot-matches-social__placeholder-line hot-matches-social__placeholder-line--short"></span>
                                </span>

                                <span class="hot-matches-social__placeholder-score">-- × --</span>

                                <span class="hot-matches-social__placeholder-team hot-matches-social__placeholder-team--b">
                                    <span class="hot-matches-social__placeholder-line hot-matches-social__placeholder-line--short"></span>
                                    <span class="hot-matches-social__placeholder-coin"></span>
                                </span>

                                <span class="hot-matches-social__placeholder-copy">
                                    @T("social.hotMatches.waiting")
                                </span>
                            </div>
                        </li>
                    }
                }
            </ol>
        </section>

        <footer class="hot-matches-social__footer">
            <div>
                <span class="hot-matches-social__footer-domain">#criptoversus</span>
                <p>@T("social.hotMatches.disclaimer")</p>
            </div>
            <span class="hot-matches-social__footer-tag">#CRIPTOVERSUS</span>
        </footer>
    </section>
</main>

@code {
    [Parameter] public string? Culture { get; set; }
    [SupplyParameterFromQuery(Name = "hours")] public int? Hours { get; set; }
    [SupplyParameterFromQuery(Name = "limit")] public int? Limit { get; set; }
    [SupplyParameterFromQuery(Name = "capture")] public int? Capture { get; set; }

    private const int CardLimit = HotMatchesSocialCardRules.DefaultDisplayLimit;
    private string _loadKey = string.Empty;
    private string _resolvedCulture = AppCultureService.DefaultRouteCulture;
    private bool _loading = true;
    private string? _error;
    private DateTime _updatedAtUtc = DateTime.UtcNow;
    private IReadOnlyList<HotMatchDto> _rankedMatches = [];

    private string ResolvedCulture => _resolvedCulture;
    private bool CaptureMode => Capture == 1;
    private int WindowHours => Math.Clamp(Hours ?? HotMatchesSocialCardRules.DefaultWindowHours, 1, 72);
    private int DisplayLimit => Math.Clamp(Limit ?? CardLimit, 1, CardLimit);
    private string PageTitleText => T("social.hotMatches.title");
    private string VisualTitleText => RemoveLeadingFireEmoji(PageTitleText);
    private string SeoDescription => T("social.hotMatches.subtitle");
    private string CanonicalUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildHotMatchesSocialPath(ResolvedCulture));
    private string EnglishUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildHotMatchesSocialPath(AppCultureService.DefaultRouteCulture));
    private string PortugueseUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildHotMatchesSocialPath(AppCultureService.SecondaryRouteCulture));
    private string ChineseUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildHotMatchesSocialPath(AppCultureService.TertiaryRouteCulture));
    private string SocialImageUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, SeoDefaults.DefaultSocialImagePath);
    private string StructuredDataMarkup => JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "WebPage",
        ["name"] = PageTitleText,
        ["description"] = SeoDescription,
        ["url"] = CanonicalUrl,
        ["image"] = SocialImageUrl,
        ["inLanguage"] = AppCulture.ToHrefLang(ResolvedCulture)
    });

    protected override async Task OnParametersSetAsync()
    {
        // A rota já informa a cultura quando usa /pt, /en ou /zh.
        // Não fazemos NavigateTo aqui: redirecionar durante OnParametersSetAsync
        // pode criar um ciclo de navegação/hidratação no Interactive Server.
        _resolvedCulture = !string.IsNullOrWhiteSpace(Culture)
            ? AppCulture.NormalizeRouteCulture(Culture)
            : AppCulture.DetectPreferredRouteCulture(HttpContextAccessor.HttpContext);

        var nextLoadKey = $"{_resolvedCulture}|{WindowHours}|{DisplayLimit}|{CaptureMode}";
        if (string.Equals(nextLoadKey, _loadKey, StringComparison.Ordinal))
            return;

        _loadKey = nextLoadKey;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _rankedMatches = [];

        try
        {
            var loadTask = DailyHotMatches.GetTopMatchesAsync(
                WindowHours,
                DisplayLimit);

            var completedTask = await Task.WhenAny(
                loadTask,
                Task.Delay(TimeSpan.FromSeconds(20)));

            if (completedTask != loadTask)
                throw new TimeoutException("Timeout ao carregar os Hot Matches do dia.");

            _rankedMatches = await loadTask;
            _updatedAtUtc = DateTime.UtcNow;
        }
        catch (Exception ex)
        {
            _error = ex.Message;

            Logger.LogWarning(
                ex,
                "Daily hot matches social card load failed. WindowHours={WindowHours} DisplayLimit={DisplayLimit}",
                WindowHours,
                DisplayLimit);
        }
        finally
        {
            _loading = false;
        }
    }


    private static string RemoveLeadingFireEmoji(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        var normalized = value.Trim();

        while (normalized.StartsWith("🔥", StringComparison.Ordinal))
            normalized = normalized["🔥".Length..].TrimStart();

        return normalized;
    }

    private string GetPublicMatchUrl(HotMatchDto match)
    {
        if (!string.IsNullOrWhiteSpace(match.PublicUrl))
            return match.PublicUrl;

        var slug = !string.IsNullOrWhiteSpace(match.Slug)
            ? match.Slug
            : MatchSlugHelper.BuildSlug(match.HomeSymbol, match.AwaySymbol);

        return RouteLocalization.BuildBestPath(ResolvedCulture, match.MatchId, slug);
    }

    private string GetCoinIconUrl(HotMatchDto match, bool isHome)
    {
        var candidate = isHome ? match.HomeLogoUrl : match.AwayLogoUrl;
        if (!string.IsNullOrWhiteSpace(candidate))
            return candidate;

        return Api.BuildBinanceIconUrl(isHome ? match.HomeSymbol : match.AwaySymbol);
    }

    private string GetDisplaySymbol(string? symbol)
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return string.Empty;

        var normalized = MatchSlugHelper.NormalizeTicker(symbol);
        return string.IsNullOrWhiteSpace(normalized)
            ? symbol.Trim().ToUpperInvariant()
            : normalized.ToUpperInvariant();
    }

    private static string GetInitials(string? symbol)
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return "--";

        var normalized = new string(symbol.Trim().Where(char.IsLetterOrDigit).ToArray());
        if (normalized.Length == 0)
            return "--";

        return normalized.Length <= 3
            ? normalized.ToUpperInvariant()
            : normalized[..3].ToUpperInvariant();
    }

    private string GetStatusText(HotMatchDto match)
        => T($"social.hotMatches.status.{HotMatchesSocialCardRules.GetStatusKey(match.Status)}");

    private string GetTemperatureText(int hotScore)
        => $"{HotMatchesSocialCardRules.GetTemperatureEmoji(hotScore)} {T($"social.hotMatches.temperature.{HotMatchesSocialCardRules.GetTemperatureKey(hotScore)}")}";

    private string GetBalanceText(int scoreDifference)
        => T($"social.hotMatches.balance.{HotMatchesSocialCardRules.GetBalanceKey(scoreDifference)}");

    private string GetLastGoalText(HotMatchDto match)
        => match.LastGoalAt.HasValue
            ? T("social.hotMatches.lastGoal", HotMatchesSocialCardRules.FormatLastGoalLabel(match.LastGoalAt, _updatedAtUtc, T("social.hotMatches.waiting")))
            : T("social.hotMatches.noLastGoal");

    private string GetMedal(int index)
        => index switch
        {
            0 => "🥇",
            1 => "🥈",
            2 => "🥉",
            _ => string.Empty
        };

    private string T(string key, params object?[] args)
        => L.T(key, ResolvedCulture, args);


}
