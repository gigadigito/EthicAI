@layout BlankLayout
@page "/social/hot-matches"
@page "/{Culture}/social/hot-matches"
@using System.Globalization
@using System.Text.Json
@using DTOs
@using CriptoVersus.Web.Services
@inject DailyHotMatchesService DailyHotMatches
@inject CriptoVersusApiClient Api
@inject RouteLocalizationService RouteLocalization
@inject AppCultureService AppCulture
@inject LocalizationService L
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpContextAccessor
@inject IConfiguration Config
@inject MatchSlugHelper MatchSlugHelper
@inject ILogger<HotMatchesSocial> Logger
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <meta name="robots" content="noindex,nofollow,noarchive" />
    <meta name="description" content="@SeoDescription" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="en-US" href="@EnglishUrl" />
    <link rel="alternate" hreflang="pt-BR" href="@PortugueseUrl" />
    <link rel="alternate" hreflang="zh-CN" href="@ChineseUrl" />
    <link rel="alternate" hreflang="x-default" href="@EnglishUrl" />
    <meta property="og:title" content="@PageTitleText" />
    <meta property="og:description" content="@SeoDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="@SocialImageUrl" />
    <meta property="og:image:alt" content="@PageTitleText" />
    <meta property="og:locale" content="@AppCulture.ToOgLocale(ResolvedCulture)" />
    <meta property="og:locale:alternate" content="@AppCulture.GetAlternateOgLocale(ResolvedCulture)" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@PageTitleText" />
    <meta name="twitter:description" content="@SeoDescription" />
    <meta name="twitter:image" content="@SocialImageUrl" />
    <meta name="twitter:image:alt" content="@PageTitleText" />
    <script type="application/ld+json">@((MarkupString)StructuredDataMarkup)</script>
</HeadContent>

<style>
    .hot-matches-social {
        --team-a-color: #ff9100;
        --team-a-rgb: 255, 145, 0;
        --team-b-color: #18d8d2;
        --team-b-rgb: 24, 216, 210;
        --surface-0: #03060b;
        --surface-1: #07101a;
        --surface-2: #0b1420;
        --text-main: #f7fbff;
        --text-muted: #a9b8ca;
        --text-soft: #72859b;
        --line: rgba(255, 255, 255, .085);
        --line-strong: rgba(255, 255, 255, .13);
        position: relative;
        min-height: 100vh;
        overflow: hidden;
        display: grid;
        place-items: center;
        padding: clamp(12px, 2vw, 28px);
        color: var(--text-main);
        background: radial-gradient(circle at 4% 8%, rgba(var(--team-a-rgb), .18), transparent 27%), radial-gradient(circle at 96% 10%, rgba(var(--team-b-rgb), .17), transparent 27%), linear-gradient(180deg, #020409 0%, #06101a 55%, #02050a 100%);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

        .hot-matches-social *,
        .hot-matches-social *::before,
        .hot-matches-social *::after {
            box-sizing: border-box;
        }

    .hot-matches-social__backdrop {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: linear-gradient(rgba(255,255,255,.018) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.018) 1px, transparent 1px);
        background-size: 34px 34px;
        mask-image: linear-gradient(to bottom, rgba(0,0,0,.6), transparent 88%);
    }

    .hot-matches-social__card {
        position: relative;
        z-index: 1;
        width: min(100%, 1200px);
        aspect-ratio: 1200 / 675;
        min-height: 0;
        display: grid;
        grid-template-rows: auto minmax(0, 1fr) auto;
        gap: 16px;
        padding: 26px 28px 22px;
        overflow: hidden;
        border: 1px solid var(--line-strong);
        border-radius: 28px;
        background: radial-gradient(circle at 0 0, rgba(var(--team-a-rgb), .09), transparent 24%), radial-gradient(circle at 100% 0, rgba(var(--team-b-rgb), .09), transparent 24%), linear-gradient(180deg, rgba(8, 13, 21, .985), rgba(4, 8, 14, .99));
        box-shadow: 0 36px 90px rgba(0,0,0,.52), inset 0 1px 0 rgba(255,255,255,.035);
    }

        .hot-matches-social__card::after {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            border-radius: inherit;
            background: linear-gradient(115deg, rgba(255,255,255,.025), transparent 24%, transparent 76%, rgba(255,255,255,.018));
        }

    .hot-matches-social__header {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 170px minmax(0, 1fr) 210px;
        align-items: center;
        gap: 22px;
        min-width: 0;
    }

    .hot-matches-social__brand {
        display: grid;
        gap: 8px;
        align-content: center;
    }

    .hot-matches-social__brand-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        padding: 8px 13px;
        border-radius: 999px;
        border: 1px solid rgba(var(--team-b-rgb), .34);
        background: rgba(6, 27, 31, .9);
        color: var(--team-b-color);
        font-size: 11px;
        font-weight: 900;
        letter-spacing: .22em;
        text-transform: uppercase;
        box-shadow: inset 0 0 18px rgba(var(--team-b-rgb), .05);
    }

    .hot-matches-social__period {
        color: var(--text-muted);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: .14em;
        text-transform: uppercase;
    }

    .hot-matches-social__title-block {
        min-width: 0;
        display: grid;
        gap: 6px;
        justify-items: center;
        text-align: center;
    }

        .hot-matches-social__title-block h1 {
            margin: 0;
            max-width: 100%;
            overflow: hidden;
            color: var(--text-main);
            font-size: clamp(32px, 4vw, 54px);
            font-weight: 500;
            line-height: .98;
            letter-spacing: -.055em;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

    .hot-matches-social__subtitle {
        margin: 0;
        color: var(--text-muted);
        font-size: 15px;
        line-height: 1.4;
    }

    .hot-matches-social__meta {
        display: grid;
        justify-items: end;
        align-content: center;
    }

    .hot-matches-social__updated {
        color: #e7eef8;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: .08em;
        text-align: right;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .hot-matches-social__board {
        position: relative;
        z-index: 1;
        min-width: 0;
        min-height: 0;
    }

    .hot-matches-social__list {
        height: 100%;
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        grid-template-rows: repeat(5, minmax(0, 1fr));
        gap: 10px;
    }

    .hot-matches-social__item {
        min-width: 0;
        min-height: 0;
    }

    .hot-matches-social__link,
    .hot-matches-social__placeholder-row {
        position: relative;
        height: 100%;
        min-width: 0;
        display: grid;
        grid-template-columns: 50px minmax(0, 1fr) 148px minmax(0, 1fr) 250px;
        align-items: center;
        gap: 14px;
        padding: 10px 14px;
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: 18px;
        background: linear-gradient(90deg, rgba(var(--team-a-rgb), .055), transparent 36%, transparent 64%, rgba(var(--team-b-rgb), .052)), rgba(9, 15, 24, .92);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.025);
    }

        .hot-matches-social__link::before {
            content: "";
            position: absolute;
            inset: 0 auto 0 0;
            width: 3px;
            opacity: .7;
            background: linear-gradient(180deg, var(--team-a-color), var(--team-b-color));
        }

    .hot-matches-social__link {
        color: inherit;
        text-decoration: none;
        transition: transform .18s ease, border-color .18s ease, background .18s ease;
    }

        .hot-matches-social__link:hover,
        .hot-matches-social__link:focus-visible {
            transform: translateY(-1px);
            border-color: rgba(var(--team-b-rgb), .28);
            background: linear-gradient(90deg, rgba(var(--team-a-rgb), .075), transparent 36%, transparent 64%, rgba(var(--team-b-rgb), .07)), rgba(11, 18, 29, .98);
            outline: none;
        }

    .hot-matches-social__rank {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        margin-inline: auto;
        border: 1px solid rgba(255,255,255,.09);
        border-radius: 50%;
        background: rgba(255,255,255,.035);
        color: var(--text-main);
        font-weight: 900;
        box-shadow: inset 0 1px 0 rgba(255,255,255,.03);
    }

    .hot-matches-social__medal {
        font-size: 20px;
        line-height: 1;
    }

    .hot-matches-social__position {
        font-size: 14px;
        line-height: 1;
    }

    .hot-matches-social__team {
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .hot-matches-social__team--b {
        justify-content: flex-end;
        text-align: right;
    }

    .hot-matches-social__team strong {
        min-width: 0;
        overflow: hidden;
        font-size: clamp(17px, 1.65vw, 22px);
        font-weight: 900;
        letter-spacing: .045em;
        line-height: 1;
        text-overflow: ellipsis;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .hot-matches-social__team--a strong {
        color: var(--team-a-color);
    }

    .hot-matches-social__team--b strong {
        color: var(--team-b-color);
    }

    .hot-matches-social__coin {
        position: relative;
        flex: 0 0 auto;
        width: 42px;
        height: 42px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-radius: 14px;
        background: rgba(255,255,255,.045);
    }

    .hot-matches-social__coin--a {
        border: 2px solid rgba(var(--team-a-rgb), .95);
        box-shadow: 0 0 0 3px rgba(var(--team-a-rgb), .10), 0 0 20px rgba(var(--team-a-rgb), .12);
    }

    .hot-matches-social__coin--b {
        border: 2px solid rgba(var(--team-b-rgb), .95);
        box-shadow: 0 0 0 3px rgba(var(--team-b-rgb), .10), 0 0 20px rgba(var(--team-b-rgb), .12);
    }

    .hot-matches-social__coin-image {
        width: 100%;
        height: 100%;
        padding: 4px;
        object-fit: contain;
    }

    .hot-matches-social__coin-fallback {
        display: none;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        color: var(--text-main);
        font-size: 11px;
        font-weight: 900;
        letter-spacing: .08em;
    }

        .hot-matches-social__coin-fallback.is-visible {
            display: inline-flex;
        }

    .hot-matches-social__score {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: 8px;
        min-width: 0;
        padding: 8px 13px;
        border: 1px solid rgba(255,255,255,.075);
        border-radius: 15px;
        background: rgba(3, 7, 12, .78);
        box-shadow: inset 0 1px 0 rgba(255,255,255,.02);
    }

    .hot-matches-social__score-value {
        font-size: clamp(24px, 2.3vw, 32px);
        font-weight: 950;
        line-height: 1;
    }

    .hot-matches-social__score-value--a {
        color: var(--team-a-color);
        text-align: right;
    }

    .hot-matches-social__score-value--b {
        color: var(--team-b-color);
        text-align: left;
    }

    .hot-matches-social__score-separator {
        color: #f7fbff;
        font-size: 16px;
        font-weight: 900;
        letter-spacing: .08em;
    }

    .hot-matches-social__insights {
        min-width: 0;
        display: grid;
        gap: 5px;
        justify-items: end;
        align-content: center;
    }

    .hot-matches-social__insights-main {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 6px;
        min-width: 0;
    }

    .hot-matches-social__insights-meta {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 8px;
        min-width: 0;
        color: var(--text-muted);
        font-size: 10px;
        font-weight: 800;
        letter-spacing: .055em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .hot-matches-social__temperature,
    .hot-matches-social__balance {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        min-height: 26px;
        padding: 5px 10px;
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 999px;
        font-size: 10px;
        font-weight: 900;
        letter-spacing: .06em;
        line-height: 1;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .hot-matches-social__status,
    .hot-matches-social__status {
        color: var(--team-b-color);
    }


    .hot-matches-social__hot-score::before,
    .hot-matches-social__last-goal::before {
        content: "•";
        margin-right: 8px;
        color: rgba(255,255,255,.25);
    }

    .hot-matches-social__temperature--cold {
        color: #cfefff;
        background: rgba(83,160,255,.10);
        border-color: rgba(83,160,255,.18);
    }

    .hot-matches-social__temperature--warm {
        color: #ffe6ba;
        background: rgba(255,191,92,.10);
        border-color: rgba(255,191,92,.20);
    }

    .hot-matches-social__temperature--hot {
        color: #ffe7c4;
        background: rgba(var(--team-a-rgb), .13);
        border-color: rgba(var(--team-a-rgb), .24);
    }

    .hot-matches-social__temperature--explosive {
        color: #ffdbe2;
        background: rgba(255,95,125,.12);
        border-color: rgba(255,95,125,.22);
    }

    .hot-matches-social__temperature--historic {
        color: #fff0b9;
        background: rgba(255,221,126,.12);
        border-color: rgba(255,221,126,.22);
    }

    .hot-matches-social__balance--tied {
        color: #eef5ff;
        background: rgba(255,255,255,.055);
    }

    .hot-matches-social__balance--veryClose {
        color: #e5fffb;
        background: rgba(var(--team-b-rgb), .10);
        border-color: rgba(var(--team-b-rgb), .19);
    }

    .hot-matches-social__balance--close {
        color: #fff0d2;
        background: rgba(var(--team-a-rgb), .10);
        border-color: rgba(var(--team-a-rgb), .19);
    }

    .hot-matches-social__balance--clearLead {
        color: #ffd6dd;
        background: rgba(255,99,132,.10);
        border-color: rgba(255,99,132,.18);
    }







    .hot-matches-social__status--live {
        color: var(--team-b-color);
    }

    .hot-matches-social__status--closing {
        color: #ffc96f;
    }

    .hot-matches-social__status--final {
        color: #dce7f5;
    }

    .hot-matches-social__status--scheduled {
        color: #b7c5d8;
    }

    .hot-matches-social__status--cancelled {
        color: #ff9baa;
    }

    .hot-matches-social__item--placeholder {
        opacity: .72;
    }

    .hot-matches-social__placeholder-team {
        display: flex;
        align-items: center;
        gap: 10px;
        min-width: 0;
    }

    .hot-matches-social__placeholder-team--b {
        justify-content: flex-end;
    }

    .hot-matches-social__placeholder-coin,
    .hot-matches-social__placeholder-line,
    .hot-matches-social__placeholder-score,
    .hot-matches-social__placeholder-pill {
        position: relative;
        overflow: hidden;
        background: linear-gradient(90deg, rgba(255,255,255,.04), rgba(255,255,255,.10), rgba(255,255,255,.04));
        background-size: 200% 100%;
        animation: hotMatchesShimmer 1.6s linear infinite;
    }

    .hot-matches-social__placeholder-coin {
        width: 42px;
        height: 42px;
        border-radius: 14px;
    }

    .hot-matches-social__placeholder-line {
        height: 13px;
        border-radius: 999px;
    }

    .hot-matches-social__placeholder-line--short {
        width: 105px;
    }

    .hot-matches-social__placeholder-score {
        min-height: 47px;
        border-radius: 15px;
        color: transparent;
    }

    .hot-matches-social__placeholder-pill {
        width: 88px;
        height: 23px;
        border-radius: 999px;
    }

    .hot-matches-social__placeholder-copy {
        color: var(--text-soft);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: .06em;
        text-align: right;
        text-transform: uppercase;
    }

    .hot-matches-social__footer {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 20px;
    }

    .hot-matches-social__footer-domain {
        display: block;
        margin-bottom: 3px;
        color: var(--text-main);
        font-size: 20px;
        font-weight: 950;
        letter-spacing: .12em;
        text-transform: lowercase;
    }

    .hot-matches-social__footer p {
        margin: 0;
        color: var(--text-muted);
        font-size: 12px;
        line-height: 1.4;
    }

    .hot-matches-social__footer-tag {
        color: var(--team-b-color);
        font-size: 12px;
        font-weight: 950;
        letter-spacing: .18em;
        text-transform: uppercase;
        white-space: nowrap;
    }

    @@media (max-width: 980px) {
        .hot-matches-social__card {
            aspect-ratio: auto;
            min-height: min(calc(100vh - 24px), 675px);
        }

        .hot-matches-social__header {
            grid-template-columns: 150px minmax(0, 1fr);
        }

        .hot-matches-social__meta {
            grid-column: 1 / -1;
            justify-items: start;
        }

        .hot-matches-social__link,
        .hot-matches-social__placeholder-row {
            grid-template-columns: 42px minmax(0, 1fr) 120px minmax(0, 1fr);
        }

        .hot-matches-social__insights,
        .hot-matches-social__placeholder-copy {
            grid-column: 2 / -1;
            justify-items: start;
            text-align: left;
        }

        .hot-matches-social__insights-main,
        .hot-matches-social__insights-meta {
            justify-content: flex-start;
            flex-wrap: wrap;
        }
    }

    @@media (max-width: 680px) {
        .hot-matches-social {
            padding: 8px;
        }

        .hot-matches-social__card {
            padding: 16px;
            border-radius: 22px;
        }

        .hot-matches-social__header {
            grid-template-columns: 1fr;
            text-align: left;
        }

        .hot-matches-social__title-block {
            justify-items: start;
            text-align: left;
        }

            .hot-matches-social__title-block h1 {
                white-space: normal;
            }

        .hot-matches-social__meta {
            justify-items: start;
        }

        .hot-matches-social__link,
        .hot-matches-social__placeholder-row {
            grid-template-columns: 36px minmax(0, 1fr) 96px;
            gap: 9px;
            padding: 9px;
        }

        .hot-matches-social__team--b {
            grid-column: 2 / 3;
            justify-content: flex-start;
            text-align: left;
        }

        .hot-matches-social__insights,
        .hot-matches-social__placeholder-copy {
            grid-column: 1 / -1;
        }

        .hot-matches-social__coin {
            width: 36px;
            height: 36px;
            border-radius: 12px;
        }

        .hot-matches-social__footer {
            align-items: flex-start;
            flex-direction: column;
        }
    }

    @@media (prefers-reduced-motion: reduce) {
        .hot-matches-social__link,
        .hot-matches-social__placeholder-coin,
        .hot-matches-social__placeholder-line,
        .hot-matches-social__placeholder-score,
        .hot-matches-social__placeholder-pill {
            animation: none !important;
            transition: none !important;
        }
    }

    @@keyframes hotMatchesShimmer {
        0% {
            background-position: 200% 0;
        }

        100% {
            background-position: -200% 0;
        }
    }
</style>


<main id="hot-matches-social-card"
      class="hot-matches-social"
      data-loading="@_loading.ToString().ToLowerInvariant()"
      data-ready="@((!_loading).ToString().ToLowerInvariant())"
      aria-labelledby="hot-matches-social-title">
    <div class="hot-matches-social__backdrop" aria-hidden="true"></div>

    <section class="hot-matches-social__card" aria-label="@PageTitleText">
        <header class="hot-matches-social__header">
            <div class="hot-matches-social__brand">
                <span class="hot-matches-social__brand-mark">CriptoVersus</span>
                <span class="hot-matches-social__period">@T("social.hotMatches.last24Hours")</span>
            </div>

            <div class="hot-matches-social__title-block">
                <h1 id="hot-matches-social-title">@PageTitleText</h1>
                <p class="hot-matches-social__subtitle">@SeoDescription</p>
            </div>

            <div class="hot-matches-social__meta">
                <span class="hot-matches-social__updated">@T("social.hotMatches.updatedAt", _updatedAtUtc.ToString("HH:mm", CultureInfo.InvariantCulture))</span>
            </div>
        </header>

        <section class="hot-matches-social__board" aria-label="@T("social.hotMatches.listAriaLabel")">
            <ol class="hot-matches-social__list">
                @for (var index = 0; index < DisplayLimit; index++)
                {
                    var match = index < _rankedMatches.Count ? _rankedMatches[index] : null;

                    if (match is not null)
                    {
                        <li class="hot-matches-social__item hot-matches-social__item--rank-@(index + 1) hot-matches-social__item--@HotMatchesSocialCardRules.GetTemperatureKey(match.HotScore)">
                            <a class="hot-matches-social__link"
                               href="@GetPublicMatchUrl(match)"
                               target="_blank"
                               rel="noopener noreferrer"
                               aria-label="@T("social.hotMatches.openMatchAria", GetDisplaySymbol(match.HomeSymbol), GetDisplaySymbol(match.AwaySymbol), match.MatchId)">

                                <span class="hot-matches-social__rank" aria-hidden="true">
                                    @if (index < 3)
                                    {
                                        <span class="hot-matches-social__medal">@GetMedal(index)</span>
                                    }
                                    else
                                    {
                                        <span class="hot-matches-social__position">@(index + 1)</span>
                                    }
                                </span>

                                <span class="hot-matches-social__team hot-matches-social__team--a">
                                    <span class="hot-matches-social__coin hot-matches-social__coin--a" aria-hidden="true">
                                        <img class="hot-matches-social__coin-image"
                                             src="@GetCoinIconUrl(match, true)"
                                             alt="@GetDisplaySymbol(match.HomeSymbol)"
                                             width="40"
                                             height="40"
                                             loading="eager"
                                             decoding="async"
                                             onerror="this.remove(); this.nextElementSibling?.classList.add('is-visible');" />
                                        <span class="hot-matches-social__coin-fallback">@GetInitials(match.HomeSymbol)</span>
                                    </span>
                                    <strong>@GetDisplaySymbol(match.HomeSymbol)</strong>
                                </span>

                                <span class="hot-matches-social__score"
                                      aria-label="@T("social.hotMatches.scoreAria", match.HomeScore, match.AwayScore)">
                                    <span class="hot-matches-social__score-value hot-matches-social__score-value--a">@match.HomeScore</span>
                                    <span class="hot-matches-social__score-separator">x</span>
                                    <span class="hot-matches-social__score-value hot-matches-social__score-value--b">@match.AwayScore</span>
                                </span>

                                <span class="hot-matches-social__team hot-matches-social__team--b">
                                    <strong>@GetDisplaySymbol(match.AwaySymbol)</strong>
                                    <span class="hot-matches-social__coin hot-matches-social__coin--b" aria-hidden="true">
                                        <img class="hot-matches-social__coin-image"
                                             src="@GetCoinIconUrl(match, false)"
                                             alt="@GetDisplaySymbol(match.AwaySymbol)"
                                             width="40"
                                             height="40"
                                             loading="eager"
                                             decoding="async"
                                             onerror="this.remove(); this.nextElementSibling?.classList.add('is-visible');" />
                                        <span class="hot-matches-social__coin-fallback">@GetInitials(match.AwaySymbol)</span>
                                    </span>
                                </span>

                                <span class="hot-matches-social__insights">
                                    <span class="hot-matches-social__insights-main">
                                        <span class="hot-matches-social__temperature hot-matches-social__temperature--@HotMatchesSocialCardRules.GetTemperatureKey(match.HotScore)">
                                            @GetTemperatureText(match.HotScore)
                                        </span>
                                        <span class="hot-matches-social__balance hot-matches-social__balance--@HotMatchesSocialCardRules.GetBalanceKey(match.ScoreDifference)">
                                            @GetBalanceText(match.ScoreDifference)
                                        </span>
                                    </span>

                                    <span class="hot-matches-social__insights-meta">
                                        <span class="hot-matches-social__status hot-matches-social__status--@HotMatchesSocialCardRules.GetStatusKey(match.Status)">
                                            @GetStatusText(match)
                                        </span>
                                        <span class="hot-matches-social__hot-score">@T("social.hotMatches.hotScore", match.HotScore)</span>
                                        <span class="hot-matches-social__last-goal">@GetLastGoalText(match)</span>
                                    </span>
                                </span>
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="hot-matches-social__item hot-matches-social__item--placeholder" aria-hidden="true">
                            <div class="hot-matches-social__placeholder-row">
                                <span class="hot-matches-social__rank">
                                    <span class="hot-matches-social__position">@(index + 1)</span>
                                </span>

                                <span class="hot-matches-social__placeholder-team">
                                    <span class="hot-matches-social__placeholder-coin"></span>
                                    <span class="hot-matches-social__placeholder-line hot-matches-social__placeholder-line--short"></span>
                                </span>

                                <span class="hot-matches-social__placeholder-score">-- x --</span>

                                <span class="hot-matches-social__placeholder-team hot-matches-social__placeholder-team--b">
                                    <span class="hot-matches-social__placeholder-line hot-matches-social__placeholder-line--short"></span>
                                    <span class="hot-matches-social__placeholder-coin"></span>
                                </span>

                                <span class="hot-matches-social__placeholder-copy">
                                    @T("social.hotMatches.waiting")
                                </span>
                            </div>
                        </li>
                    }
                }
            </ol>
        </section>

        <footer class="hot-matches-social__footer">
            <div>
                <span class="hot-matches-social__footer-domain">#Criptoversus</span>
                <p>@T("social.hotMatches.disclaimer")</p>
            </div>
            <span class="hot-matches-social__footer-tag">#CriptoVersus</span>
        </footer>
    </section>
</main>

@code {
    [Parameter] public string? Culture { get; set; }
    [SupplyParameterFromQuery(Name = "hours")] public int? Hours { get; set; }
    [SupplyParameterFromQuery(Name = "limit")] public int? Limit { get; set; }

    private const int CardLimit = HotMatchesSocialCardRules.DefaultDisplayLimit;
    private string _loadKey = string.Empty;
    private string _resolvedCulture = AppCultureService.DefaultRouteCulture;
    private bool _loading = true;
    private string? _error;
    private DateTime _updatedAtUtc = DateTime.UtcNow;
    private IReadOnlyList<HotMatchDto> _rankedMatches = [];

    private string ResolvedCulture => _resolvedCulture;
    private int WindowHours => Math.Clamp(Hours ?? HotMatchesSocialCardRules.DefaultWindowHours, 1, 72);
    private int DisplayLimit => Math.Clamp(Limit ?? CardLimit, 1, CardLimit);
    private string PageTitleText => T("social.hotMatches.title");
    private string SeoDescription => T("social.hotMatches.subtitle");
    private string CanonicalUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildHotMatchesSocialPath(ResolvedCulture));
    private string EnglishUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildHotMatchesSocialPath(AppCultureService.DefaultRouteCulture));
    private string PortugueseUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildHotMatchesSocialPath(AppCultureService.SecondaryRouteCulture));
    private string ChineseUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildHotMatchesSocialPath(AppCultureService.TertiaryRouteCulture));
    private string SocialImageUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, SeoDefaults.DefaultSocialImagePath);
    private string StructuredDataMarkup => JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "WebPage",
        ["name"] = PageTitleText,
        ["description"] = SeoDescription,
        ["url"] = CanonicalUrl,
        ["image"] = SocialImageUrl,
        ["inLanguage"] = AppCulture.ToHrefLang(ResolvedCulture)
    });

    protected override async Task OnParametersSetAsync()
    {
        // A rota já informa a cultura quando usa /pt, /en ou /zh.
        // Não fazemos NavigateTo aqui: redirecionar durante OnParametersSetAsync
        // pode criar um ciclo de navegação/hidratação no Interactive Server.
        _resolvedCulture = !string.IsNullOrWhiteSpace(Culture)
            ? AppCulture.NormalizeRouteCulture(Culture)
            : AppCulture.DetectPreferredRouteCulture(HttpContextAccessor.HttpContext);

        var nextLoadKey = $"{_resolvedCulture}|{WindowHours}|{DisplayLimit}";
        if (string.Equals(nextLoadKey, _loadKey, StringComparison.Ordinal))
            return;

        _loadKey = nextLoadKey;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _rankedMatches = [];

        try
        {
            var loadTask = DailyHotMatches.GetTopMatchesAsync(
                WindowHours,
                DisplayLimit);

            var completedTask = await Task.WhenAny(
                loadTask,
                Task.Delay(TimeSpan.FromSeconds(20)));

            if (completedTask != loadTask)
                throw new TimeoutException("Timeout ao carregar os Hot Matches do dia.");

            _rankedMatches = await loadTask;
            _updatedAtUtc = DateTime.UtcNow;
        }
        catch (Exception ex)
        {
            _error = ex.Message;

            Logger.LogWarning(
                ex,
                "Daily hot matches social card load failed. WindowHours={WindowHours} DisplayLimit={DisplayLimit}",
                WindowHours,
                DisplayLimit);
        }
        finally
        {
            _loading = false;
        }
    }

    private string GetPublicMatchUrl(HotMatchDto match)
    {
        if (!string.IsNullOrWhiteSpace(match.PublicUrl))
            return match.PublicUrl;

        var slug = !string.IsNullOrWhiteSpace(match.Slug)
            ? match.Slug
            : MatchSlugHelper.BuildSlug(match.HomeSymbol, match.AwaySymbol);

        return RouteLocalization.BuildBestPath(ResolvedCulture, match.MatchId, slug);
    }

    private string GetCoinIconUrl(HotMatchDto match, bool isHome)
    {
        var candidate = isHome ? match.HomeLogoUrl : match.AwayLogoUrl;
        if (!string.IsNullOrWhiteSpace(candidate))
            return candidate;

        return Api.BuildBinanceIconUrl(isHome ? match.HomeSymbol : match.AwaySymbol);
    }

    private string GetDisplaySymbol(string? symbol)
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return string.Empty;

        var normalized = MatchSlugHelper.NormalizeTicker(symbol);
        return string.IsNullOrWhiteSpace(normalized)
            ? symbol.Trim().ToUpperInvariant()
            : normalized.ToUpperInvariant();
    }

    private static string GetInitials(string? symbol)
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return "--";

        var normalized = new string(symbol.Trim().Where(char.IsLetterOrDigit).ToArray());
        if (normalized.Length == 0)
            return "--";

        return normalized.Length <= 3
            ? normalized.ToUpperInvariant()
            : normalized[..3].ToUpperInvariant();
    }

    private string GetStatusText(HotMatchDto match)
        => T($"social.hotMatches.status.{HotMatchesSocialCardRules.GetStatusKey(match.Status)}");

    private string GetTemperatureText(int hotScore)
        => $"{HotMatchesSocialCardRules.GetTemperatureEmoji(hotScore)} {T($"social.hotMatches.temperature.{HotMatchesSocialCardRules.GetTemperatureKey(hotScore)}")}";

    private string GetBalanceText(int scoreDifference)
        => T($"social.hotMatches.balance.{HotMatchesSocialCardRules.GetBalanceKey(scoreDifference)}");

    private string GetLastGoalText(HotMatchDto match)
        => match.LastGoalAt.HasValue
            ? T("social.hotMatches.lastGoal", HotMatchesSocialCardRules.FormatLastGoalLabel(match.LastGoalAt, _updatedAtUtc, T("social.hotMatches.waiting")))
            : T("social.hotMatches.noLastGoal");

    private string GetMedal(int index)
        => index switch
        {
            0 => "🥇",
            1 => "🥈",
            2 => "🥉",
            _ => string.Empty
        };

    private string T(string key, params object?[] args)
        => L.T(key, ResolvedCulture, args);


}
