@code {
    private RoadmapPageContent _page = new();

    protected override void OnParametersSet()
    {
        _page = RoadmapContentService.BuildPage(GetCultureFromRoute());
    }

    private string? GetCultureFromRoute()
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri).Trim('/');

        if (relativePath.StartsWith("en/", StringComparison.OrdinalIgnoreCase) || string.Equals(relativePath, "en/roadmap", StringComparison.OrdinalIgnoreCase))
            return "en";

        if (relativePath.StartsWith("pt/", StringComparison.OrdinalIgnoreCase) || string.Equals(relativePath, "pt/roadmap", StringComparison.OrdinalIgnoreCase))
            return "pt";

        if (relativePath.StartsWith("zh/", StringComparison.OrdinalIgnoreCase) || string.Equals(relativePath, "zh/roadmap", StringComparison.OrdinalIgnoreCase))
            return "zh";

        return "en";
    }

    private string MetaKeywords
        => $"{SeoDefaults.GlobalKeywords}, CriptoVersus roadmap, #CriptoVersus roadmap, crypto platform roadmap, live crypto product roadmap";

    private string SocialImageUrl
        => SeoDefaults.BuildAbsoluteUrl(Config, Nav, "/img/roadmap-arena-evolution.webp");

    private string StructuredDataMarkup
        => JsonSerializer.Serialize(new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "WebPage",
            ["name"] = _page.PageTitle,
            ["description"] = _page.MetaDescription,
            ["url"] = _page.CanonicalUrl,
            ["image"] = SocialImageUrl,
            ["keywords"] = MetaKeywords,
            ["inLanguage"] = _page.Culture
        });

    private string T(string key, params object?[] args)
        => L.T($"roadmap.{key}", _page.Culture, args);

    private string GetStatusSummary()
        => T("labels.statusSummary");

    private int GetTrackedInitiativeCount()
        => _page.StatusCards.Count + _page.Principles.Count + _page.Phases.Count(x => x.Status is RoadmapPhaseStatus.InProgress or RoadmapPhaseStatus.Experimental);

    private RoadmapPhase? GetCurrentFocusPhase()
        => _page.Phases
            .OrderBy(x => x.SortOrder)
            .FirstOrDefault(x => x.Status is RoadmapPhaseStatus.InProgress or RoadmapPhaseStatus.Experimental)
           ?? _page.Phases.OrderBy(x => x.SortOrder).FirstOrDefault();

    private RoadmapPhase? GetNextMilestonePhase()
        => _page.Phases
            .OrderBy(x => x.SortOrder)
            .FirstOrDefault(x => x.Status == RoadmapPhaseStatus.Planned)
           ?? _page.Phases.OrderBy(x => x.SortOrder).FirstOrDefault(x => x.Status == RoadmapPhaseStatus.Future)
           ?? _page.Phases.OrderBy(x => x.SortOrder).LastOrDefault();

    private string GetCurrentFocusTitle()
        => GetCurrentFocusPhase()?.Title
           ?? T("labels.currentFocusFallback");

    private string GetCurrentFocusDescription()
        => GetCurrentFocusPhase()?.Description
           ?? _page.Hero.Subtitle;

    private string GetNextMilestoneTitle()
        => GetNextMilestonePhase()?.Title
           ?? T("labels.nextMilestoneFallback");

    private IReadOnlyList<string> GetNextMilestoneItems()
        => GetNextMilestonePhase()?.Items.Take(3).ToArray()
           ?? [T("labels.nextMilestoneFallbackItem")];

    private string GetStatusLabel(RoadmapPhaseStatus status)
        => status switch
        {
            RoadmapPhaseStatus.Completed => T("status.completed"),
            RoadmapPhaseStatus.InProgress => T("status.inProgress"),
            RoadmapPhaseStatus.Planned => T("status.planned"),
            RoadmapPhaseStatus.Future => T("status.future"),
            _ => T("status.experimental")
        };

    private static string GetStatusCssClass(RoadmapPhaseStatus status)
        => status switch
        {
            RoadmapPhaseStatus.Completed => "roadmap-badge-completed",
            RoadmapPhaseStatus.InProgress => "roadmap-badge-progress",
            RoadmapPhaseStatus.Planned => "roadmap-badge-planned",
            RoadmapPhaseStatus.Future => "roadmap-badge-future",
            _ => "roadmap-badge-experimental"
        };

    private IReadOnlyList<(string Icon, string Accent, string Title, string Subtitle)> GetBrandPillars()
        => [
            ("✦", "purple", T("pillars.competition.title"), T("pillars.competition.subtitle")),
            ("↗", "green", T("pillars.strategy.title"), T("pillars.strategy.subtitle")),
            ("⬢", "cyan", T("pillars.technology.title"), T("pillars.technology.subtitle")),
            ("🏆", "gold", T("pillars.ranking.title"), T("pillars.ranking.subtitle")),
            ("◎", "purple", T("pillars.global.title"), T("pillars.global.subtitle"))
        ];
}
