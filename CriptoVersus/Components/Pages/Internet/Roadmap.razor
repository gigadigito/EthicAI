@page "/roadmap"
@page "/pt/roadmap"
@page "/en/roadmap"
@page "/zh/roadmap"
@using System.Text.Json
@using CriptoVersus.Web.Services
@inject NavigationManager Nav
@inject IConfiguration Config
@inject RoadmapContentService RoadmapContentService
@inject AppCultureService AppCulture
@inject LocalizationService L

<PageTitle>@_page.PageTitle</PageTitle>

<HeadContent>
    <meta name="description" content="@_page.MetaDescription" />
    <meta name="keywords" content="@MetaKeywords" />
    <link rel="canonical" href="@_page.CanonicalUrl" />
    @foreach (var alternate in _page.AlternateLinks)
    {
        <link rel="alternate" hreflang="@alternate.HrefLang" href="@alternate.Href" />
    }
    <link rel="alternate" hreflang="x-default" href="@SeoDefaults.BuildPublicAbsoluteUrl(Config, "/en/roadmap")" />
    <meta property="og:title" content="@_page.OpenGraph.Title" />
    <meta property="og:description" content="@_page.OpenGraph.Description" />
    <meta property="og:type" content="@_page.OpenGraph.Type" />
    <meta property="og:url" content="@_page.OpenGraph.Url" />
    <meta property="og:image" content="@SocialImageUrl" />
    <meta property="og:image:alt" content="@_page.PageTitle" />
    <meta property="og:locale" content="@AppCulture.ToOgLocale(_page.Culture)" />
    <meta property="og:locale:alternate" content="@AppCulture.GetAlternateOgLocale(_page.Culture)" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@_page.OpenGraph.Title" />
    <meta name="twitter:description" content="@_page.OpenGraph.Description" />
    <meta name="twitter:image" content="@SocialImageUrl" />
    <meta name="twitter:image:alt" content="@_page.PageTitle" />
    <script type="application/ld+json">@((MarkupString)StructuredDataMarkup)</script>
</HeadContent>

<section class="cvroadmap-page">
    <div class="roadmap-hero">
        <div class="roadmap-banner">
            <div class="roadmap-banner__frame" aria-hidden="true"></div>
            <div class="roadmap-banner__glow roadmap-banner__glow--left"></div>
            <div class="roadmap-banner__glow roadmap-banner__glow--right"></div>

            <div class="roadmap-banner__art" aria-hidden="true">
                <img class="roadmap-banner__visual" src="/img/roadmap-arena-evolution.webp" alt="" />
                <div class="roadmap-banner__core">
                    <span class="roadmap-banner__crown">♛</span>
                    <span class="roadmap-banner__monogram roadmap-banner__monogram--c">C</span>
                    <span class="roadmap-banner__monogram roadmap-banner__monogram--v">V</span>
                    <span class="roadmap-banner__slash"></span>
                </div>
                <div class="roadmap-banner__candles roadmap-banner__candles--left">
                    <span></span><span></span><span></span><span></span><span></span>
                </div>
                <div class="roadmap-banner__candles roadmap-banner__candles--right">
                    <span></span><span></span><span></span><span></span><span></span>
                </div>
            </div>

            <div class="roadmap-banner__copy">
                <span class="roadmap-eyebrow">@_page.Hero.Eyebrow</span>
                <h1 class="roadmap-hero__wordmark">
                    <span class="roadmap-hero__wordmark-core">Cripto</span><span class="roadmap-hero__wordmark-accent">Versus</span>
                </h1>

                <p class="roadmap-banner__summary">@_page.Hero.Subtitle</p>

                <div class="roadmap-hero__identity roadmap-hero__identity--banner">
                    <span class="roadmap-hero__identity-word roadmap-hero__identity-word--purple">Arena financeira.</span>
                    <span class="roadmap-hero__identity-word">Estratégia.</span>
                    <span class="roadmap-hero__identity-word roadmap-hero__identity-word--green">Vitória.</span>
                </div>

                <div class="roadmap-banner__divider" aria-hidden="true">
                    <span class="roadmap-banner__divider-line"></span>
                    <div class="roadmap-hero__solana-mark">
                        <span></span>
                        <span></span>
                        <span></span>
                    </div>
                    <span class="roadmap-banner__divider-line"></span>
                </div>

                <div class="roadmap-banner__intel">
                    <article class="roadmap-banner__intel-card roadmap-banner__intel-card--metric">
                        <span class="roadmap-banner__intel-label">@T("labels.phasesMapped")</span>
                        <strong class="roadmap-banner__intel-value">@_page.Phases.Count</strong>
                        <p>@T("labels.publicEvolution")</p>
                    </article>

                    <article class="roadmap-banner__intel-card roadmap-banner__intel-card--metric">
                        <span class="roadmap-banner__intel-label">@T("labels.workstreamsActive")</span>
                        <strong class="roadmap-banner__intel-value">@GetTrackedInitiativeCount()</strong>
                        <p>@T("labels.workstreamsDescription")</p>
                    </article>

                    <article class="roadmap-banner__intel-card roadmap-banner__intel-card--focus">
                        <span class="roadmap-banner__intel-label">@T("labels.currentFocus")</span>
                        <strong class="roadmap-banner__intel-title">@GetCurrentFocusTitle()</strong>
                        <p>@GetCurrentFocusDescription()</p>
                    </article>

                    <article class="roadmap-banner__intel-card roadmap-banner__intel-card--next">
                        <span class="roadmap-banner__intel-label">@T("labels.nextMilestone")</span>
                        <strong class="roadmap-banner__intel-title">@GetNextMilestoneTitle()</strong>
                        <ul class="roadmap-banner__intel-list">
                            @foreach (var item in GetNextMilestoneItems())
                            {
                                <li>@item</li>
                            }
                        </ul>
                    </article>
                </div>
            </div>
        </div>
    </div>

    <section class="roadmap-strip" aria-label="@T("labels.brandPillars")">
        <article class="roadmap-strip__item roadmap-strip__item--status">
            <div class="roadmap-strip__icon roadmap-strip__icon--purple" aria-hidden="true">◈</div>
            <div>
                <strong>@GetStatusSummary()</strong>
                <span>@_page.Hero.Subtitle</span>
            </div>
        </article>

        <article class="roadmap-strip__item roadmap-strip__item--cta">
            <a class="roadmap-cta roadmap-cta-primary" href="@_page.Hero.PrimaryCtaHref">@_page.Hero.PrimaryCtaLabel</a>
            <a class="roadmap-cta roadmap-cta-secondary" href="@_page.Hero.SecondaryCtaHref">@_page.Hero.SecondaryCtaLabel</a>
        </article>

        @foreach (var pillar in GetBrandPillars())
        {
            <article class="roadmap-strip__item">
                <div class="roadmap-strip__icon roadmap-strip__icon--@pillar.Accent" aria-hidden="true">@pillar.Icon</div>
                <div>
                    <strong>@pillar.Title</strong>
                    <span>@pillar.Subtitle</span>
                </div>
            </article>
        }
    </section>

    <section class="roadmap-section">
        <div class="roadmap-section__head">
            <span>@T("section.projectStatus")</span>
            <h2>@T("section.currentPlatformDirection")</h2>
        </div>

        <div class="roadmap-info-grid">
            @foreach (var card in _page.StatusCards)
            {
                <article class="roadmap-info-card">
                    <span class="roadmap-info-card__tag">@card.Tag</span>
                    <h3>@card.Title</h3>
                    <p>@card.Description</p>
                </article>
            }
        </div>
    </section>

    <section class="roadmap-section">
        <div class="roadmap-section__head">
            <span>@T("section.roadmap")</span>
            <h2>@T("section.plannedEvolutionByPhase")</h2>
        </div>

        <div class="roadmap-timeline">
            @foreach (var phase in _page.Phases.OrderBy(x => x.SortOrder))
            {
                <article class="roadmap-phase-card">
                    <div class="roadmap-phase-card__rail" aria-hidden="true">
                        <span></span>
                    </div>
                    <div class="roadmap-phase-card__header">
                        <div>
                            <span class="roadmap-phase-card__eyebrow">@phase.PhaseLabel</span>
                            <h3>@phase.Title</h3>
                        </div>
                        <span class="roadmap-badge @GetStatusCssClass(phase.Status)">@GetStatusLabel(phase.Status)</span>
                    </div>

                    <p class="roadmap-phase-card__description">@phase.Description</p>

                    <ul class="roadmap-phase-card__list">
                        @foreach (var item in phase.Items)
                        {
                            <li>@item</li>
                        }
                    </ul>
                </article>
            }
        </div>
    </section>

    <section class="roadmap-section">
        <div class="roadmap-section__head">
            <span>@T("section.guidingPrinciples")</span>
            <h2>@T("section.howProductDecisionsAreFramed")</h2>
        </div>

        <div class="roadmap-info-grid roadmap-info-grid--principles">
            @foreach (var principle in _page.Principles)
            {
                <article class="roadmap-info-card roadmap-info-card--principle">
                    <span class="roadmap-info-card__tag">@principle.Tag</span>
                    <h3>@principle.Title</h3>
                    <p>@principle.Description</p>
                </article>
            }
        </div>
    </section>

    <section class="roadmap-notice">
        <span>@_page.NoticeTitle</span>
        <p>@_page.NoticeText</p>
    </section>
</section>

<style>
    .cvroadmap-page {
        --rm-left: #ff9100;
        --rm-right: #18d8d2;
        --rm-left-soft: rgba(255, 145, 0, 0.18);
        --rm-right-soft: rgba(24, 216, 210, 0.18);
        --rm-left-border: rgba(255, 145, 0, 0.34);
        --rm-right-border: rgba(24, 216, 210, 0.34);
        --rm-bg: #05080e;
        --rm-panel: rgba(7, 10, 18, 0.84);
        --rm-panel-strong: rgba(8, 12, 22, 0.94);
        --rm-border: rgba(148, 163, 184, 0.16);
        --rm-text: #f4f8ff;
        --rm-muted: #aab9cf;
        --rm-warning: #fbbf24;
        display: grid;
        gap: 26px;
        position: relative;
        width: min(1880px, calc(100vw - 24px));
        max-width: none;
        margin: 0 auto;
        padding-inline: 0;
        box-sizing: border-box;
        color: var(--rm-text);
    }

        .cvroadmap-page,
        .cvroadmap-page * {
            box-sizing: border-box;
        }

    .roadmap-hero,
    .roadmap-strip,
    .roadmap-section,
    .roadmap-notice {
        width: 100%;
        box-sizing: border-box;
    }

    .roadmap-hero {
        position: relative;
        overflow: hidden;
        border-radius: 28px;
        border: 1px solid rgba(24, 216, 210, 0.18);
        background: linear-gradient(90deg, rgba(255, 145, 0, 0.18), transparent 32%, rgba(24, 216, 210, 0.16)), linear-gradient(180deg, rgba(5, 8, 14, 0.9), rgba(5, 8, 14, 0.98));
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.42), inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .roadmap-banner {
        position: relative;
        min-height: 660px;
        overflow: hidden;
        border-radius: 28px;
        background: linear-gradient(90deg, rgba(5, 8, 14, 0.88) 0%, rgba(5, 8, 14, 0.36) 34%, rgba(5, 8, 14, 0.34) 62%, rgba(5, 8, 14, 0.88) 100%), linear-gradient(180deg, rgba(5, 8, 14, 0.10) 0%, rgba(5, 8, 14, 0.22) 46%, rgba(5, 8, 14, 0.93) 100%), url("/img/roadmap-arena-evolution.webp") center center / cover no-repeat;
    }

        .roadmap-banner::before {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            background: radial-gradient(circle at 18% 18%, rgba(255, 145, 0, 0.18), transparent 32%), radial-gradient(circle at 82% 16%, rgba(24, 216, 210, 0.16), transparent 32%), linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent 44%);
            mix-blend-mode: screen;
        }

        .roadmap-banner::after {
            content: "";
            position: absolute;
            inset: 22px;
            pointer-events: none;
            border-radius: 24px;
            border: 1px solid rgba(255, 255, 255, 0.08);
            box-shadow: inset 0 0 0 1px rgba(24, 216, 210, 0.06), 0 0 46px rgba(24, 216, 210, 0.08);
        }

    /*
           A nova imagem já é o banner completo.
           A arte antiga ficava como miniatura dentro do lado esquerdo,
           por isso os elementos abaixo ficam escondidos.
        */
    .roadmap-banner__frame,
    .roadmap-banner__glow,
    .roadmap-banner__art,
    .roadmap-banner__visual,
    .roadmap-banner__core,
    .roadmap-banner__candles {
        display: none !important;
    }

    .roadmap-banner__copy {
        position: relative;
        z-index: 2;
        min-height: 660px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        gap: 18px;
        padding: clamp(28px, 4vw, 64px);
    }

    .roadmap-eyebrow,
    .roadmap-section__head span,
    .roadmap-phase-card__eyebrow,
    .roadmap-notice span,
    .roadmap-info-card__tag,
    .roadmap-banner__intel-label {
        display: inline-flex;
        width: fit-content;
        align-items: center;
        gap: 8px;
        padding: 6px 12px;
        border-radius: 999px;
        background: linear-gradient(90deg, rgba(255, 145, 0, 0.12), rgba(24, 216, 210, 0.12));
        border: 1px solid rgba(24, 216, 210, 0.22);
        color: #dffcff;
        font-size: .76rem;
        font-weight: 900;
        letter-spacing: .1em;
        text-transform: uppercase;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .roadmap-hero__wordmark {
        margin: 0;
        color: #f8fbff;
        font-size: clamp(2.7rem, 7vw, 7rem);
        line-height: .9;
        font-weight: 950;
        letter-spacing: -.07em;
        text-transform: uppercase;
        text-shadow: 0 12px 46px rgba(0, 0, 0, 0.75);
    }

    .roadmap-hero__wordmark-core {
        color: #f6f8ff;
        font-style: italic;
    }

    .roadmap-hero__wordmark-accent {
        color: var(--rm-right);
        font-style: italic;
        text-shadow: 0 0 28px rgba(24, 216, 210, 0.32);
    }

    .roadmap-banner__summary {
        max-width: 720px;
        margin: 0;
        color: #d6e4f7;
        font-size: clamp(1rem, 1.2vw, 1.25rem);
        line-height: 1.65;
        text-shadow: 0 4px 22px rgba(0, 0, 0, 0.88);
    }

    .roadmap-hero__identity {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: .7rem;
        color: #f3f7ff;
        font-weight: 950;
        letter-spacing: .14em;
        text-transform: uppercase;
    }

    .roadmap-hero__identity-word--purple {
        color: var(--rm-left);
        text-shadow: 0 0 24px rgba(255, 145, 0, 0.32);
    }

    .roadmap-hero__identity-word--green {
        color: var(--rm-right);
        text-shadow: 0 0 24px rgba(24, 216, 210, 0.32);
    }

    .roadmap-banner__divider {
        display: grid;
        grid-template-columns: minmax(80px, 1fr) auto minmax(80px, 1fr);
        gap: 18px;
        align-items: center;
        max-width: 880px;
    }

    .roadmap-banner__divider-line {
        height: 1px;
        background: linear-gradient(90deg, var(--rm-left), rgba(24, 216, 210, 0.85));
        box-shadow: 0 0 20px rgba(24, 216, 210, 0.18);
    }

    .roadmap-hero__solana-mark {
        display: grid;
        gap: 4px;
        width: 42px;
    }

        .roadmap-hero__solana-mark span {
            display: block;
            height: 6px;
            border-radius: 999px;
            background: linear-gradient(90deg, var(--rm-left), var(--rm-right));
            box-shadow: 0 0 14px rgba(24, 216, 210, 0.28);
        }

    .roadmap-banner__intel {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
        max-width: 1180px;
        margin-top: 10px;
    }

    .roadmap-banner__intel-card {
        position: relative;
        overflow: hidden;
        display: grid;
        gap: 10px;
        min-height: 138px;
        padding: 18px;
        border-radius: 18px;
        border: 1px solid rgba(255, 255, 255, 0.10);
        background: linear-gradient(180deg, rgba(8, 12, 22, 0.84), rgba(6, 9, 16, 0.94));
        backdrop-filter: blur(12px);
        box-shadow: 0 18px 46px rgba(0, 0, 0, 0.36), inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

        .roadmap-banner__intel-card::before {
            content: "";
            position: absolute;
            inset: 0 auto 0 0;
            width: 3px;
            background: linear-gradient(180deg, var(--rm-left), var(--rm-right));
        }

        .roadmap-banner__intel-card:nth-child(1)::before,
        .roadmap-banner__intel-card:nth-child(3)::before {
            background: linear-gradient(180deg, var(--rm-left), rgba(255, 145, 0, 0.36));
        }

        .roadmap-banner__intel-card:nth-child(2)::before,
        .roadmap-banner__intel-card:nth-child(4)::before {
            background: linear-gradient(180deg, var(--rm-right), rgba(24, 216, 210, 0.36));
        }

    .roadmap-banner__intel-value {
        color: var(--rm-right);
        font-size: clamp(2rem, 3vw, 3.4rem);
        line-height: 1;
        font-weight: 950;
        text-shadow: 0 0 26px rgba(24, 216, 210, 0.24);
    }

    .roadmap-banner__intel-title {
        color: #ffffff;
        font-size: 1.1rem;
        line-height: 1.25;
        font-weight: 950;
    }

    .roadmap-banner__intel-card p,
    .roadmap-banner__intel-list {
        margin: 0;
        color: var(--rm-muted);
        line-height: 1.55;
    }

    .roadmap-banner__intel-list {
        display: grid;
        gap: 6px;
        padding-left: 18px;
    }

        .roadmap-banner__intel-list li::marker {
            color: var(--rm-right);
        }

    .roadmap-strip {
        display: grid;
        grid-template-columns: minmax(280px, 1.2fr) minmax(280px, .85fr) repeat(5, minmax(150px, 1fr));
        gap: 12px;
    }

    .roadmap-strip__item {
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        gap: 12px;
        min-height: 86px;
        padding: 14px;
        border-radius: 18px;
        border: 1px solid var(--rm-border);
        background: linear-gradient(180deg, rgba(8, 12, 22, 0.94), rgba(6, 9, 16, 0.98));
        box-shadow: 0 16px 42px rgba(0, 0, 0, 0.22);
    }

        .roadmap-strip__item::before {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            background: radial-gradient(circle at top left, rgba(255, 145, 0, 0.10), transparent 48%), radial-gradient(circle at bottom right, rgba(24, 216, 210, 0.10), transparent 48%);
        }

        .roadmap-strip__item > * {
            position: relative;
            z-index: 1;
        }

    .roadmap-strip__item--cta {
        justify-content: center;
        flex-wrap: wrap;
    }

    .roadmap-strip__item strong {
        display: block;
        color: #f7fbff;
        font-weight: 950;
        line-height: 1.2;
    }

    .roadmap-strip__item span {
        display: block;
        margin-top: 4px;
        color: var(--rm-muted);
        font-size: .9rem;
        line-height: 1.35;
    }

    .roadmap-strip__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        flex: 0 0 42px;
        border-radius: 14px;
        color: #061019;
        font-weight: 950;
        background: linear-gradient(135deg, var(--rm-left), var(--rm-right));
        box-shadow: 0 0 24px rgba(24, 216, 210, 0.16);
    }

    .roadmap-strip__icon--purple,
    .roadmap-strip__icon--green,
    .roadmap-strip__icon--gold {
        background: linear-gradient(135deg, var(--rm-left), var(--rm-right));
    }

    .roadmap-strip__icon--cyan {
        background: var(--rm-right);
    }

    .roadmap-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0 16px;
        border-radius: 999px;
        font-weight: 900;
        text-decoration: none;
        transition: transform .18s ease, border-color .18s ease, background .18s ease, box-shadow .18s ease;
    }

        .roadmap-cta:hover {
            transform: translateY(-1px);
        }

    .roadmap-cta-primary {
        background: linear-gradient(90deg, var(--rm-left), var(--rm-right));
        color: #041015;
        box-shadow: 0 0 28px rgba(24, 216, 210, 0.14);
    }

    .roadmap-cta-secondary {
        border: 1px solid rgba(24, 216, 210, 0.28);
        background: rgba(8, 12, 22, 0.82);
        color: #f8fbff;
    }

    .roadmap-section {
        display: grid;
        gap: 18px;
    }

    .roadmap-section__head {
        display: grid;
        gap: 10px;
    }

        .roadmap-section__head h2 {
            margin: 0;
            color: #f8fbff;
            font-size: clamp(1.5rem, 2.2vw, 2.4rem);
            font-weight: 950;
            letter-spacing: -0.03em;
        }

    .roadmap-info-grid,
    .roadmap-timeline {
        display: grid;
        gap: 18px;
    }

    .roadmap-info-grid {
        grid-template-columns: repeat(5, minmax(0, 1fr));
    }

    .roadmap-info-grid--principles {
        grid-template-columns: repeat(5, minmax(0, 1fr));
    }

    .roadmap-phase-card,
    .roadmap-info-card,
    .roadmap-notice {
        position: relative;
        overflow: hidden;
        border: 1px solid var(--rm-border);
        border-radius: 22px;
        background: radial-gradient(circle at top left, rgba(255, 145, 0, 0.10), transparent 36%), radial-gradient(circle at bottom right, rgba(24, 216, 210, 0.09), transparent 38%), linear-gradient(180deg, rgba(10, 14, 24, 0.96), rgba(6, 9, 16, 0.98));
        box-shadow: 0 18px 55px rgba(0, 0, 0, 0.26), inset 0 1px 0 rgba(255, 255, 255, 0.03);
    }

    .roadmap-info-card {
        display: grid;
        gap: 14px;
        padding: 18px;
    }

        .roadmap-info-card h3,
        .roadmap-phase-card h3 {
            margin: 0;
            color: #f8fbff;
            font-weight: 950;
            letter-spacing: -0.025em;
        }

        .roadmap-info-card h3 {
            font-size: 1.08rem;
        }

        .roadmap-info-card p,
        .roadmap-phase-card__description,
        .roadmap-notice p {
            margin: 0;
            color: var(--rm-muted);
            line-height: 1.7;
        }

    .roadmap-info-card--principle {
        background: radial-gradient(circle at top left, rgba(24, 216, 210, 0.10), transparent 36%), linear-gradient(180deg, rgba(10, 14, 24, 0.96), rgba(6, 9, 16, 0.98));
    }

    .roadmap-phase-card {
        display: grid;
        gap: 16px;
        padding: 22px;
    }

        .roadmap-phase-card::before {
            content: "";
            position: absolute;
            inset: 0 auto 0 0;
            width: 4px;
            background: linear-gradient(180deg, var(--rm-left), var(--rm-right));
        }

