@page "/en/scoring-rules"
@page "/pt/scoring-rules"
@page "/zh/scoring-rules"
@using System.Text.Json
@using CriptoVersus.Web.Services
@inject NavigationManager Nav
@inject IConfiguration Config
@inject AppCultureService AppCulture
@inject LocalizationService L
@inject RouteLocalizationService RouteLocalization
@rendermode InteractiveServer

<PageTitle>@T("seo.title")</PageTitle>

<HeadContent>
    <meta name="description" content="@MetaDescription" />
    <meta name="keywords" content="@MetaKeywords" />
    <meta name="robots" content="index, follow" />

    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="en-US" href="@EnglishUrl" />
    <link rel="alternate" hreflang="pt-BR" href="@PortugueseUrl" />
    <link rel="alternate" hreflang="zh-CN" href="@ZhUrl" />
    <link rel="alternate" hreflang="x-default" href="@EnglishUrl" />

    <meta property="og:title" content="@TitleText" />
    <meta property="og:description" content="@MetaDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="@SocialImageUrl" />
    <meta property="og:image:alt" content="@TitleText" />
    <meta property="og:locale" content="@AppCulture.ToOgLocale(CurrentCulture)" />
    <meta property="og:locale:alternate" content="@AppCulture.GetAlternateOgLocale(CurrentCulture)" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@TitleText" />
    <meta name="twitter:description" content="@MetaDescription" />
    <meta name="twitter:image" content="@SocialImageUrl" />
    <meta name="twitter:image:alt" content="@TitleText" />

    <script type="application/ld+json">@((MarkupString)StructuredDataMarkup)</script>
</HeadContent>

<section class="scoring-page">
    <header class="scoring-hero">
        <div class="scoring-hero__copy">
            <span class="scoring-eyebrow">@T("hero.eyebrow")</span>
            <h1>@T("hero.title")</h1>
            <p class="scoring-hero__lead">@T("hero.lead")</p>

            <div class="scoring-hero__actions">
                <a class="scoring-button scoring-button--primary" href="@RouteLocalization.BuildAboutPath(CurrentCulture)">
                    @T("hero.backToAbout")
                </a>
                <a class="scoring-button scoring-button--secondary" href="@RouteLocalization.BuildHomePath(CurrentCulture)">
                    @T("hero.backToArena")
                </a>
            </div>
        </div>

        <aside class="scoring-scoreboard" aria-label="@T("hero.panelLabel")">
            <div class="scoring-scoreboard__topline">
                <span>@T("hero.panel.signalsLabel")</span>
                <strong>@T("hero.panel.signalsTitle")</strong>
            </div>

            <div class="scoring-scoreboard__match">
                <div class="scoring-team scoring-team--left">
                    <span>@T("hero.panel.leftTeam")</span>
                    <strong>2</strong>
                </div>

                <div class="scoring-scoreboard__versus">
                    <span>@T("hero.panel.versus")</span>
                    <small>@T("hero.panel.simulated")</small>
                </div>

                <div class="scoring-team scoring-team--right">
                    <span>@T("hero.panel.rightTeam")</span>
                    <strong>1</strong>
                </div>
            </div>

            <p>@T("hero.panel.signalsBody")</p>

            <div class="scoring-mini-grid">
                <article>
                    <span>@T("hero.panel.scoringLabel")</span>
                    <strong>@T("hero.panel.scoringTitle")</strong>
                    <p>@T("hero.panel.scoringBody")</p>
                </article>

                <article>
                    <span>@T("hero.panel.resultLabel")</span>
                    <strong>@T("hero.panel.resultTitle")</strong>
                    <p>@T("hero.panel.resultBody")</p>
                </article>
            </div>
        </aside>
    </header>

    <section class="scoring-section scoring-section--intro" aria-label="@T("sections.overviewLabel")">
        <div class="scoring-section__heading">
            <span class="scoring-eyebrow">@T("sections.overviewEyebrow")</span>
            <h2>@T("sections.overviewTitle")</h2>
            <p>@T("sections.overviewLead")</p>
        </div>

        <div class="scoring-grid scoring-grid--three">
            <article class="scoring-card">
                <span>@T("cards.signals.label")</span>
                <h3>@T("cards.signals.title")</h3>
                <p>@T("cards.signals.body")</p>
            </article>

            <article class="scoring-card">
                <span>@T("cards.scoring.label")</span>
                <h3>@T("cards.scoring.title")</h3>
                <p>@T("cards.scoring.body")</p>
            </article>

            <article class="scoring-card">
                <span>@T("cards.settlement.label")</span>
                <h3>@T("cards.settlement.title")</h3>
                <p>@T("cards.settlement.body")</p>
            </article>
        </div>
    </section>

    <section class="scoring-section" aria-label="@T("sections.realRulesLabel")">
        <div class="scoring-section__heading">
            <span class="scoring-eyebrow">@T("sections.realRulesEyebrow")</span>
            <h2>@T("sections.realRulesTitle")</h2>
            <p>@T("sections.realRulesLead")</p>
        </div>

        <div class="scoring-grid scoring-grid--two">
            <article class="scoring-rule-card scoring-rule-card--primary">
                <div class="scoring-rule-card__icon">%</div>
                <div>
                    <span>@T("rules.percentage.label")</span>
                    <h3>@T("rules.percentage.title")</h3>
                    <p>@T("rules.percentage.body")</p>
                    <ul>
                        <li>@T("rules.percentage.point1")</li>
                        <li>@T("rules.percentage.point2")</li>
                        <li>@T("rules.percentage.point3")</li>
                    </ul>
                </div>
            </article>

            <article class="scoring-rule-card">
                <div class="scoring-rule-card__icon">?</div>
                <div>
                    <span>@T("rules.crossover.label")</span>
                    <h3>@T("rules.crossover.title")</h3>
                    <p>@T("rules.crossover.body")</p>
                    <ul>
                        <li>@T("rules.crossover.point1")</li>
                        <li>@T("rules.crossover.point2")</li>
                        <li>@T("rules.crossover.point3")</li>
                    </ul>
                </div>
            </article>

            <article class="scoring-rule-card">
                <div class="scoring-rule-card__icon">?</div>
                <div>
                    <span>@T("rules.candleBattle.label")</span>
                    <h3>@T("rules.candleBattle.title")</h3>
                    <p>@T("rules.candleBattle.body")</p>
                    <ul>
                        <li>@T("rules.candleBattle.point1")</li>
                        <li>@T("rules.candleBattle.point2")</li>
                        <li>@T("rules.candleBattle.point3")</li>
                    </ul>
                </div>
            </article>

            <article class="scoring-rule-card scoring-rule-card--accent">
                <div class="scoring-rule-card__icon">+3</div>
                <div>
                    <span>@T("rules.dominance.label")</span>
                    <h3>@T("rules.dominance.title")</h3>
                    <p>@T("rules.dominance.body")</p>
                    <ul>
                        <li>@T("rules.dominance.point1")</li>
                        <li>@T("rules.dominance.point2")</li>
                        <li>@T("rules.dominance.point3")</li>
                    </ul>
                </div>
            </article>
        </div>
    </section>

    <section class="scoring-section" aria-label="@T("sections.simulationsLabel")">
        <div class="scoring-feature">
            <div class="scoring-feature__copy">
                <span class="scoring-eyebrow">@T("sections.simulationsEyebrow")</span>
                <h2>@T("sections.simulationsTitle")</h2>
                <p>@T("sections.simulationsLead")</p>
            </div>

            <div class="scoring-timeline" aria-label="@T("sections.simulationsTimelineLabel")">
                <article>
                    <span>01</span>
                    <strong>@T("simulations.step1.title")</strong>
                    <p>@T("simulations.step1.body")</p>
                </article>

                <article>
                    <span>02</span>
                    <strong>@T("simulations.step2.title")</strong>
                    <p>@T("simulations.step2.body")</p>
                </article>

                <article>
                    <span>03</span>
                    <strong>@T("simulations.step3.title")</strong>
                    <p>@T("simulations.step3.body")</p>
                </article>
            </div>
        </div>
    </section>

    <section class="scoring-section" aria-label="@T("sections.visualIndicatorsLabel")">
        <div class="scoring-section__heading">
            <span class="scoring-eyebrow">@T("sections.visualIndicatorsEyebrow")</span>
            <h2>@T("sections.visualIndicatorsTitle")</h2>
            <p>@T("sections.visualIndicatorsLead")</p>
        </div>

        <div class="scoring-grid scoring-grid--three">
            <article class="scoring-card scoring-card--indicator">
                <span>@T("indicators.arenaPressure.label")</span>
                <h3>@T("indicators.arenaPressure.title")</h3>
                <p>@T("indicators.arenaPressure.body")</p>
            </article>

            <article class="scoring-card scoring-card--indicator">
                <span>@T("indicators.momentum.label")</span>
                <h3>@T("indicators.momentum.title")</h3>
                <p>@T("indicators.momentum.body")</p>
            </article>

            <article class="scoring-card scoring-card--indicator">
                <span>@T("indicators.marketFlow.label")</span>
                <h3>@T("indicators.marketFlow.title")</h3>
                <p>@T("indicators.marketFlow.body")</p>
            </article>
        </div>
    </section>

    <section class="scoring-section scoring-section--meaning" aria-label="@T("sections.meaningLabel")">
        <div class="scoring-meaning-card">
            <div>
                <span class="scoring-eyebrow">@T("noPrediction.label")</span>
                <h2>@T("noPrediction.title")</h2>
                <p>@T("noPrediction.body")</p>
            </div>

            <div class="scoring-meaning-list">
                <article>
                    <strong>@T("meaning.notAdvice.title")</strong>
                    <p>@T("meaning.notAdvice.body")</p>
                </article>

                <article>
                    <strong>@T("meaning.notPrediction.title")</strong>
                    <p>@T("meaning.notPrediction.body")</p>
                </article>

                <article>
                    <strong>@T("meaning.notGuarantee.title")</strong>
                    <p>@T("meaning.notGuarantee.body")</p>
                </article>
            </div>
        </div>
    </section>

    <section class="scoring-source-card">
        <span class="scoring-eyebrow">@T("dataSourcesNoticeLabel")</span>
        <h2>@T("dataSourcesNoticeTitle")</h2>
        <p>@T("dataSourcesNotice")</p>
    </section>
</section>

<style>
    .scoring-page {
        width: 100%;
        max-width: min(1880px, calc(100vw - 24px));
        margin-inline: auto;
        display: grid;
        gap: 1rem;
        padding: 1.2rem 0 1.4rem;
        color: #eef5ff;
    }

        .scoring-page *,
        .scoring-page *::before,
        .scoring-page *::after {
            box-sizing: border-box;
        }

    .scoring-hero,
    .scoring-section,
    .scoring-source-card {
        border: 1px solid rgba(127, 246, 223, 0.14);
        background: radial-gradient(circle at top left, rgba(255, 145, 0, 0.12), transparent 25%), radial-gradient(circle at top right, rgba(24, 216, 210, 0.12), transparent 24%), linear-gradient(180deg, rgba(11, 16, 28, 0.98), rgba(6, 10, 20, 0.98));
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.32);
        overflow: hidden;
    }

    .scoring-hero {
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(320px, .8fr);
        gap: 1rem;
        min-height: 420px;
        padding: clamp(1.2rem, 2.4vw, 2rem);
        border-radius: 30px;
        position: relative;
    }

        .scoring-hero::before {
            content: "";
            position: absolute;
            inset: 0;
            opacity: .14;
            pointer-events: none;
            background-image: linear-gradient(rgba(255,255,255,.08) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.08) 1px, transparent 1px);
            background-size: 34px 34px;
        }

    .scoring-hero__copy,
    .scoring-scoreboard,
    .scoring-section,
    .scoring-source-card {
        position: relative;
        z-index: 1;
    }

    .scoring-hero__copy {
        display: grid;
        gap: .95rem;
        align-content: center;
        max-width: 920px;
    }

    .scoring-eyebrow,
    .scoring-card span,
    .scoring-rule-card span,
    .scoring-scoreboard__topline span,
    .scoring-mini-grid span {
        font-size: .76rem;
        font-weight: 900;
        letter-spacing: .16em;
        text-transform: uppercase;
        color: #7ff6df;
    }

    .scoring-hero h1,
    .scoring-section__heading h2,
    .scoring-feature h2,
    .scoring-meaning-card h2,
    .scoring-source-card h2 {
        margin: 0;
        letter-spacing: -.04em;
        line-height: 1;
    }

    .scoring-hero h1 {
        font-size: clamp(2.35rem, 5vw, 5.1rem);
        max-width: 900px;
    }

    .scoring-hero__lead {
        max-width: 780px;
        margin: 0;
        color: #bfd0e4;
        line-height: 1.72;
        font-size: clamp(1rem, 1.4vw, 1.16rem);
    }

    .scoring-hero__actions {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        margin-top: .35rem;
    }

    .scoring-button {
        min-height: 2.95rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: .76rem 1.08rem;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,.1);
        text-decoration: none;
        font-weight: 900;
        letter-spacing: .03em;
    }

    .scoring-button--primary {
        color: #170b00;
        background: linear-gradient(90deg, #ff9100, #ffd36a);
        border-color: rgba(255, 211, 106, .42);
    }

    .scoring-button--secondary {
        color: #eef5ff;
        background: rgba(255,255,255,.05);
    }

    .scoring-scoreboard {
        align-self: stretch;
        display: grid;
        gap: 1rem;
        align-content: center;
        padding: 1rem;
        border-radius: 26px;
        border: 1px solid rgba(255,255,255,.1);
        background: radial-gradient(circle at top left, rgba(255,145,0,.13), transparent 30%), radial-gradient(circle at bottom right, rgba(24,216,210,.13), transparent 32%), rgba(255,255,255,.035);
    }

    .scoring-scoreboard__topline strong {
        display: block;
        margin-top: .35rem;
        font-size: clamp(1.15rem, 2vw, 1.65rem);
        line-height: 1.12;
    }

    .scoring-scoreboard__match {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: .8rem;
        align-items: center;
    }

    .scoring-team,
    .scoring-scoreboard__versus {
        min-height: 118px;
        display: grid;
        align-content: center;
        justify-items: center;
        gap: .25rem;
        border-radius: 22px;
        border: 1px solid rgba(255,255,255,.1);
        background: rgba(0,0,0,.22);
    }

        .scoring-team span,
        .scoring-scoreboard__versus span,
        .scoring-scoreboard__versus small {
            color: #9fb1c7;
            font-size: .78rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .08em;
        }

        .scoring-team strong {
            font-size: clamp(2.4rem, 4vw, 4rem);
            line-height: .9;
        }

    .scoring-team--left strong {
        color: #ffb23f;
    }

    .scoring-team--right strong {
        color: #18d8d2;
    }

    .scoring-scoreboard__versus {
        min-width: 76px;
        padding: .75rem;
    }

        .scoring-scoreboard__versus span {
            color: #eef5ff;
            font-size: 1rem;
        }

    .scoring-scoreboard p,
    .scoring-card p,
    .scoring-rule-card p,
    .scoring-rule-card li,
    .scoring-section__heading p,
    .scoring-feature p,
    .scoring-timeline p,
    .scoring-meaning-card p,
    .scoring-source-card p {
        margin: 0;
        color: #bfd0e4;
        line-height: 1.7;
        font-size: .98rem;
    }

    .scoring-mini-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .75rem;
    }

        .scoring-mini-grid article {
            padding: .95rem;
            border-radius: 20px;
            border: 1px solid rgba(255,255,255,.09);
            background: rgba(255,255,255,.035);
        }

        .scoring-mini-grid strong {
            display: block;
            margin: .3rem 0 .25rem;
            line-height: 1.18;
        }

    .scoring-section,
    .scoring-source-card {
        display: grid;
        gap: 1rem;
        padding: clamp(1.05rem, 2vw, 1.45rem);
        border-radius: 28px;
    }

    .scoring-section__heading {
        display: grid;
        gap: .55rem;
        max-width: 980px;
    }

        .scoring-section__heading h2,
        .scoring-feature h2,
        .scoring-meaning-card h2,
        .scoring-source-card h2 {
            font-size: clamp(1.55rem, 3vw, 2.6rem);
        }

    .scoring-grid {
        display: grid;
        gap: 1rem;
    }

    .scoring-grid--three {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .scoring-grid--two {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .scoring-card,
    .scoring-rule-card,
    .scoring-timeline article,
    .scoring-meaning-list article {
        border: 1px solid rgba(127, 246, 223, 0.12);
        background: radial-gradient(circle at top right, rgba(127, 246, 223, 0.08), transparent 30%), linear-gradient(180deg, rgba(13, 19, 32, 0.96), rgba(8, 12, 22, 0.96));
        box-shadow: 0 18px 60px rgba(0,0,0,.24);
    }

    .scoring-card {
        display: grid;
        gap: .45rem;
        min-height: 190px;
        align-content: start;
        padding: 1.1rem;
        border-radius: 24px;
    }

        .scoring-card h3,
        .scoring-rule-card h3 {
            margin: 0;
            font-size: clamp(1.08rem, 1.5vw, 1.34rem);
            line-height: 1.15;
        }

    .scoring-rule-card {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        gap: 1rem;
        padding: 1.1rem;
        border-radius: 26px;
    }

    .scoring-rule-card--primary {
        border-color: rgba(255,145,0,.24);
    }

    .scoring-rule-card--accent {
        border-color: rgba(24,216,210,.25);
    }

    .scoring-rule-card__icon {
        width: 3rem;
        height: 3rem;
        display: grid;
        place-items: center;
        border-radius: 18px;
        color: #06120f;
        background: linear-gradient(135deg, #ff9100, #18d8d2);
        font-weight: 1000;
        box-shadow: 0 16px 32px rgba(0,0,0,.26);
    }

    .scoring-rule-card ul {
        display: grid;
        gap: .45rem;
        margin: .8rem 0 0;
        padding-left: 1.1rem;
    }

    .scoring-feature {
        display: grid;
        grid-template-columns: minmax(0, .82fr) minmax(320px, 1.18fr);
        gap: 1rem;
        align-items: stretch;
    }

    .scoring-feature__copy {
        display: grid;
        gap: .65rem;
        align-content: center;
        padding: .5rem 0;
    }

    .scoring-timeline {
        display: grid;
        gap: .75rem;
    }

        .scoring-timeline article {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr);
            column-gap: .9rem;
            row-gap: .25rem;
            padding: 1rem;
            border-radius: 22px;
        }

            .scoring-timeline article span {
                grid-row: span 2;
                width: 2.65rem;
                height: 2.65rem;
                display: grid;
                place-items: center;
                border-radius: 16px;
                color: #04110f;
                background: linear-gradient(135deg, #7ff6df, #ffd36a);
                font-weight: 1000;
            }

            .scoring-timeline article strong {
                font-size: 1.05rem;
                line-height: 1.18;
            }

    .scoring-card--indicator {
        min-height: 168px;
        border-color: rgba(255,255,255,.09);
    }

    .scoring-meaning-card {
        display: grid;
        grid-template-columns: minmax(0, .9fr) minmax(320px, 1.1fr);
        gap: 1rem;
        align-items: start;
    }

        .scoring-meaning-card > div:first-child {
            display: grid;
            gap: .65rem;
        }

    .scoring-meaning-list {
        display: grid;
        gap: .75rem;
    }

        .scoring-meaning-list article {
            padding: 1rem;
            border-radius: 20px;
        }

        .scoring-meaning-list strong {
            display: block;
            margin-bottom: .3rem;
            color: #eef5ff;
        }

    @@media (max-width: 1080px) {
        .scoring-hero,
        .scoring-feature,
        .scoring-meaning-card {
            grid-template-columns: 1fr;
        }

        .scoring-grid--three,
        .scoring-grid--two {
            grid-template-columns: 1fr;
        }

        .scoring-hero {
            min-height: auto;
        }
    }

    @@media (max-width: 680px) {
        .scoring-page {
            max-width: min(100%, calc(100vw - 16px));
            padding-top: .85rem;
        }

        .scoring-hero,
        .scoring-section,
        .scoring-source-card {
            border-radius: 22px;
        }

        .scoring-hero {
            padding: 1rem;
        }

        .scoring-hero__actions,
        .scoring-mini-grid,
        .scoring-scoreboard__match {
            grid-template-columns: 1fr;
            display: grid;
        }

        .scoring-button {
            width: 100%;
        }

        .scoring-scoreboard__versus {
            min-height: 58px;
        }

        .scoring-rule-card {
            grid-template-columns: 1fr;
        }

        .scoring-rule-card__icon {
            width: 2.8rem;
            height: 2.8rem;
        }

        .scoring-timeline article {
            grid-template-columns: 1fr;
        }

            .scoring-timeline article span {
                grid-row: auto;
            }
    }
</style>

@code {
    private string CurrentCulture => AppCulture.GetCurrentRouteCulture(Nav);
    private string TitleText => T("seo.title");
    private string MetaDescription => T("seo.description");

    private string MetaKeywords =>
        "CriptoVersus, crypto scoring rules, public market signals, candle battle, candle dominance, percentage movement, market simulation, arena pressure, momentum indicators";

    private string CanonicalUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildScoringRulesPath(CurrentCulture));
    private string EnglishUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildScoringRulesPath("en"));
    private string PortugueseUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildScoringRulesPath("pt"));
    private string ZhUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildScoringRulesPath("zh"));
    private string SocialImageUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, SeoDefaults.DefaultSocialImagePath);
    private string StructuredDataMarkup => BuildStructuredDataMarkup();

    private string T(string key)
        => L.T($"public.scoringRules.{key}", CurrentCulture);

    private string BuildStructuredDataMarkup()
    {
        var data = new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "WebPage",
            ["name"] = TitleText,
            ["description"] = MetaDescription,
            ["about"] = new[]
            {
                "public crypto market data",
                "football-style simulated matches",
                "percentage movement scoring",
                "candle battle comparison",
                "candle dominance scoring",
                "simulated scoring events",
                "visual market indicators",
                "Binance-traded pairs when available",
                "not financial advice"
            },
            ["keywords"] = MetaKeywords,
            ["url"] = CanonicalUrl,
            ["inLanguage"] = AppCulture.ToHrefLang(CurrentCulture)
        };

        return JsonSerializer.Serialize(data);
    }
}