@using DTOs
@inject CriptoVersus.Web.Services.CriptoVersusApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IConfiguration Config
@inject CriptoVersus.Web.Services.LocalizationService L
@inject ILogger<CommunityMatchCreationCard> Logger
@implements IDisposable

@{
    var enabled = IsEnabled;
}

@if (enabled)
{
    <section class="community-match-cta" aria-labelledby="community-match-cta-title">
        <div class="community-match-cta__glow" aria-hidden="true"></div>
        <div class="community-match-cta__content">
            <div>
                <span class="community-match-cta__eyebrow">@T("eyebrow")</span>
                <h2 id="community-match-cta-title">@T("title")</h2>
                <p>@T("body")</p>
            </div>

            <button id="@_openButtonId"
                    type="button"
                    class="btn community-match-cta__button"
                    @onclick="OpenAsync">
                @T("button")
            </button>
        </div>
    </section>

    @if (_open)
    {
        <div class="modal-backdrop fade show community-match-modal__backdrop" @onclick="() => HandleBackdropClickAsync()"></div>
        <div class="modal fade show d-block community-match-modal" id="@_modalId" tabindex="-1" role="dialog" aria-modal="true" aria-labelledby="@_modalTitleId">
            <div class="modal-dialog modal-dialog-centered modal-lg community-match-modal__dialog">
                <div class="modal-content community-match-modal__panel">
                    <div class="modal-header community-match-modal__header">
                        <div class="community-match-modal__heading">
                            <p class="community-match-modal__eyebrow">
                                <span aria-hidden="true">◎</span>
                                @T("modal.eyebrow")
                            </p>
                            <h3 class="modal-title" id="@_modalTitleId">@T("modal.title")</h3>
                            <p class="community-match-modal__subtitle">@T("body")</p>
                        </div>

                        <button type="button"
                                class="community-match-modal__close"
                                aria-label="@T("modal.close")"
                                @onclick="() => CloseAsync()"
                                disabled="@_submitting">
                            <span aria-hidden="true">×</span>
                        </button>
                    </div>

                    <div class="community-match-modal__steps" aria-hidden="true">
                        <div class="community-match-modal__step community-match-modal__step--orange">
                            <span>1</span>
                            <strong>@T("modal.orange")</strong>
                        </div>
                        <i></i>
                        <div class="community-match-modal__step community-match-modal__step--neutral">
                            <span>2</span>
                            <strong>VS</strong>
                        </div>
                        <i></i>
                        <div class="community-match-modal__step community-match-modal__step--cyan">
                            <span>3</span>
                            <strong>@T("modal.cyan")</strong>
                        </div>
                    </div>

                    <div class="modal-body community-match-modal__body">
                        <div class="community-match-modal__grid">
                            <div class="community-match-picker community-match-picker--orange">
                                <div class="community-match-picker__label">@T("modal.orange")</div>
                                <input class="form-control community-match-picker__search"
                                       placeholder="@T("modal.searchPlaceholder")"
                                       @bind="_homeSearch"
                                       @bind:event="oninput"
                                       @onfocus="EnsureTeamsLoadedAsync" />
                                <div class="community-match-picker__list" role="listbox" aria-label="@T("modal.orange")">
                                    @if (_loadingTeams)
                                    {
                                        <div class="community-match-picker__state">@T("modal.loading")</div>
                                    }
                                    else if (!GetFilteredTeams(_homeSearch, _awayTeam?.TeamId).Any())
                                    {
                                        <div class="community-match-picker__state">@T("modal.empty")</div>
                                    }
                                    else
                                    {
                                        @foreach (var team in GetFilteredTeams(_homeSearch, _awayTeam?.TeamId))
                                        {
                                            <button type="button"
                                                    class="community-match-picker__option @(IsSelected(team, _homeTeam) ? "is-active" : string.Empty)"
                                                    role="option"
                                                    aria-selected="@(IsSelected(team, _homeTeam))"
                                                    @onclick="() => SelectHomeAsync(team)">
                                                <span class="community-match-picker__icon">
                                                    <img src="@GetIconUrl(team)"
                                                         alt=""
                                                         loading="lazy"
                                                         width="36"
                                                         height="36"
                                                         onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                                    <span class="community-match-picker__fallback" aria-hidden="true">@GetAssetMonogram(ResolveDisplaySymbol(team))</span>
                                                </span>
                                                <span>
                                                    <strong>@ResolveDisplaySymbol(team)</strong>
                                                    <small>@ResolveDisplayName(team)</small>
                                                </span>
                                            </button>
                                        }
                                    }
                                </div>
                            </div>

                            <div class="community-match-modal__vs-panel">
                                <div class="community-match-modal__side community-match-modal__side--orange">
                                    @if (_homeTeam is null)
                                    {
                                        <span class="community-match-modal__placeholder">@T("modal.selectLeft")</span>
                                    }
                                    else
                                    {
                                        <span class="community-match-modal__side-icon">
                                            <img src="@GetIconUrl(_homeTeam)"
                                                 alt=""
                                                 loading="lazy"
                                                 width="46"
                                                 height="46"
                                                 onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                            <span class="community-match-modal__fallback" aria-hidden="true">@GetAssetMonogram(ResolveDisplaySymbol(_homeTeam))</span>
                                        </span>
                                        <strong>@ResolveDisplaySymbol(_homeTeam)</strong>
                                        <small>@ResolveDisplayName(_homeTeam)</small>
                                    }
                                </div>

                                <div class="community-match-modal__vs">VS</div>

                                <div class="community-match-modal__side community-match-modal__side--cyan">
                                    @if (_awayTeam is null)
                                    {
                                        <span class="community-match-modal__placeholder">@T("modal.selectRight")</span>
                                    }
                                    else
                                    {
                                        <span class="community-match-modal__side-icon">
                                            <img src="@GetIconUrl(_awayTeam)"
                                                 alt=""
                                                 loading="lazy"
                                                 width="46"
                                                 height="46"
                                                 onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                            <span class="community-match-modal__fallback" aria-hidden="true">@GetAssetMonogram(ResolveDisplaySymbol(_awayTeam))</span>
                                        </span>
                                        <strong>@ResolveDisplaySymbol(_awayTeam)</strong>
                                        <small>@ResolveDisplayName(_awayTeam)</small>
                                    }
                                </div>
                            </div>

                            <div class="community-match-picker community-match-picker--cyan">
                                <div class="community-match-picker__label">@T("modal.cyan")</div>
                                <input class="form-control community-match-picker__search"
                                       placeholder="@T("modal.searchPlaceholder")"
                                       @bind="_awaySearch"
                                       @bind:event="oninput"
                                       @onfocus="EnsureTeamsLoadedAsync" />
                                <div class="community-match-picker__list" role="listbox" aria-label="@T("modal.cyan")">
                                    @if (_loadingTeams)
                                    {
                                        <div class="community-match-picker__state">@T("modal.loading")</div>
                                    }
                                    else if (!GetFilteredTeams(_awaySearch, _homeTeam?.TeamId).Any())
                                    {
                                        <div class="community-match-picker__state">@T("modal.empty")</div>
                                    }
                                    else
                                    {
                                        @foreach (var team in GetFilteredTeams(_awaySearch, _homeTeam?.TeamId))
                                        {
                                            <button type="button"
                                                    class="community-match-picker__option @(IsSelected(team, _awayTeam) ? "is-active" : string.Empty)"
                                                    role="option"
                                                    aria-selected="@(IsSelected(team, _awayTeam))"
                                                    @onclick="() => SelectAwayAsync(team)">
                                                <span class="community-match-picker__icon">
                                                    <img src="@GetIconUrl(team)"
                                                         alt=""
                                                         loading="lazy"
                                                         width="36"
                                                         height="36"
                                                         onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                                    <span class="community-match-picker__fallback" aria-hidden="true">@GetAssetMonogram(ResolveDisplaySymbol(team))</span>
                                                </span>
                                                <span>
                                                    <strong>@ResolveDisplaySymbol(team)</strong>
                                                    <small>@ResolveDisplayName(team)</small>
                                                </span>
                                            </button>
                                        }
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="community-match-modal__preview">
                            <div class="community-match-modal__preview-team community-match-modal__preview-team--orange">
                                @if (_homeTeam is null)
                                {
                                    <span>@T("modal.previewLeft")</span>
                                }
                                else
                                {
                                    <span class="community-match-modal__side-icon">
                                        <img src="@GetIconUrl(_homeTeam)"
                                             alt=""
                                             loading="lazy"
                                             width="46"
                                             height="46"
                                             onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                        <span class="community-match-modal__fallback" aria-hidden="true">@GetAssetMonogram(ResolveDisplaySymbol(_homeTeam))</span>
                                    </span>
                                    <div>
                                        <strong>@ResolveDisplaySymbol(_homeTeam)</strong>
                                        <small>@ResolveDisplayName(_homeTeam)</small>
                                    </div>
                                }
                            </div>
                            <div class="community-match-modal__preview-vs">VS</div>
                            <div class="community-match-modal__preview-team community-match-modal__preview-team--cyan">
                                @if (_awayTeam is null)
                                {
                                    <span>@T("modal.previewRight")</span>
                                }
                                else
                                {
                                    <span class="community-match-modal__side-icon">
                                        <img src="@GetIconUrl(_awayTeam)"
                                             alt=""
                                             loading="lazy"
                                             width="46"
                                             height="46"
                                             onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                        <span class="community-match-modal__fallback" aria-hidden="true">@GetAssetMonogram(ResolveDisplaySymbol(_awayTeam))</span>
                                    </span>
                                    <div>
                                        <strong>@ResolveDisplaySymbol(_awayTeam)</strong>
                                        <small>@ResolveDisplayName(_awayTeam)</small>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="community-match-modal__captcha-wrap">
                            <div class="community-match-modal__captcha" id="@_captchaId"></div>
                            @if (_captchaError is not null)
                            {
                                <div class="community-match-modal__message community-match-modal__message--error">@_captchaError</div>
                            }
                        </div>

                        @if (_message is not null)
                        {
                            <div class="community-match-modal__message @(string.IsNullOrWhiteSpace(_messageKind) ? string.Empty : $"community-match-modal__message--{_messageKind}")">
                                @_message
                            </div>
                        }
                    </div>

                    <div class="modal-footer community-match-modal__footer">
                        <div class="community-match-modal__footnote">
                            <span aria-hidden="true">◉</span>
                            @T("modal.footnote")
                        </div>

                        <div class="community-match-modal__actions">
                            <button type="button"
                                    class="btn community-match-modal__cancel"
                                    @onclick="() => CloseAsync()"
                                    disabled="@_submitting">
                                @T("modal.close")
                            </button>

                            <button type="button"
                                    class="btn community-match-modal__submit"
                                    @onclick="SubmitAsync"
                                    disabled="@(!CanSubmit)">
                                @if (_submitting)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>@T("modal.submitting")</span>
                                }
                                else
                                {
                                    <span>@T("modal.submit")</span>
                                }
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
}


<style>
    .community-match-modal__backdrop {
        position: fixed;
        inset: 0;
        z-index: 1080;
        background: radial-gradient(circle at 18% 18%, rgba(255, 145, 0, .10), transparent 30%), radial-gradient(circle at 82% 24%, rgba(24, 216, 210, .10), transparent 32%), rgba(1, 6, 14, .84);
        backdrop-filter: blur(7px);
    }

    .community-match-modal {
        z-index: 1090;
        overflow-x: hidden;
        overflow-y: auto;
        padding: clamp(10px, 2vh, 24px);
    }

    .community-match-modal__dialog {
        width: min(1280px, calc(100vw - 28px));
        max-width: none;
        min-height: calc(100% - 20px);
        margin: 10px auto;
    }

    .community-match-modal__panel {
        --orange: #ff9500;
        --orange-soft: rgba(255, 149, 0, .16);
        --orange-glow: rgba(255, 149, 0, .32);
        --cyan: #25d9f5;
        --cyan-soft: rgba(37, 217, 245, .14);
        --cyan-glow: rgba(37, 217, 245, .30);
        position: relative;
        isolation: isolate;
        overflow: hidden;
        border: 1px solid transparent;
        border-radius: 26px;
        color: #f6f9ff;
        background: radial-gradient(circle at 8% 12%, rgba(255, 149, 0, .08), transparent 28%), radial-gradient(circle at 92% 18%, rgba(37, 217, 245, .08), transparent 30%), linear-gradient(145deg, rgba(9, 17, 30, .985), rgba(3, 10, 20, .99));
        box-shadow: 0 30px 90px rgba(0, 0, 0, .58), inset 0 1px 0 rgba(255, 255, 255, .055);
    }

        .community-match-modal__panel::before {
            content: "";
            position: absolute;
            inset: 0;
            padding: 1px;
            border-radius: inherit;
            background: linear-gradient( 90deg, rgba(255, 149, 0, .92) 0%, rgba(255, 183, 63, .55) 16%, rgba(173, 194, 214, .16) 38%, rgba(173, 194, 214, .16) 62%, rgba(75, 231, 255, .55) 84%, rgba(37, 217, 245, .92) 100% );
            -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            pointer-events: none;
            z-index: 0;
        }

        .community-match-modal__panel::after {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: inherit;
            pointer-events: none;
            background: linear-gradient(90deg, rgba(255, 149, 0, .06), transparent 18%, transparent 82%, rgba(37, 217, 245, .06)), linear-gradient(180deg, rgba(255,255,255,.035), transparent 18%);
            box-shadow: inset 6px 0 22px rgba(255, 149, 0, .08), inset -6px 0 22px rgba(37, 217, 245, .08);
            z-index: 0;
        }

    .community-match-modal__header {
        position: relative;
        z-index: 1;
        align-items: flex-start;
        gap: 18px;
        padding: 24px 30px 18px;
        border-bottom: 0;
    }

    .community-match-modal__heading {
        min-width: 0;
    }

    .community-match-modal__eyebrow {
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 0 0 7px;
        color: var(--orange);
        font-size: .72rem;
        font-weight: 900;
        letter-spacing: .17em;
        text-transform: uppercase;
    }

    .community-match-modal__header .modal-title {
        margin: 0;
        color: #f7f9ff;
        font-size: clamp(1.8rem, 3vw, 2.65rem);
        font-weight: 950;
        letter-spacing: -.035em;
        line-height: 1.05;
    }

    .community-match-modal__subtitle {
        max-width: 720px;
        margin: 10px 0 0;
        color: rgba(210, 222, 239, .68);
        font-size: clamp(.86rem, 1.15vw, 1rem);
        line-height: 1.55;
    }

    .community-match-modal__close {
        flex: 0 0 auto;
        width: 48px;
        height: 48px;
        display: grid;
        place-items: center;
        padding: 0;
        border: 1px solid rgba(165, 196, 223, .22);
        border-radius: 13px;
        background: rgba(7, 14, 25, .72);
        color: rgba(240, 247, 255, .88);
        font-size: 2rem;
        font-weight: 300;
        line-height: 1;
        transition: .18s ease;
    }

        .community-match-modal__close:hover:not(:disabled),
        .community-match-modal__close:focus-visible {
            border-color: rgba(255, 255, 255, .48);
            background: rgba(255, 255, 255, .08);
            color: #fff;
            transform: translateY(-1px);
        }

        .community-match-modal__close:focus-visible,
        .community-match-picker__search:focus,
        .community-match-picker__option:focus-visible,
        .community-match-modal__cancel:focus-visible,
        .community-match-modal__submit:focus-visible {
            outline: 3px solid rgba(255, 255, 255, .22);
            outline-offset: 2px;
        }

    .community-match-modal__steps {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: auto minmax(36px, 1fr) auto minmax(36px, 1fr) auto;
        align-items: center;
        gap: 14px;
        padding: 0 30px 18px;
    }

        .community-match-modal__steps > i {
            height: 1px;
            background: linear-gradient(90deg, rgba(255,255,255,.05), rgba(255,255,255,.22), rgba(255,255,255,.05));
        }

    .community-match-modal__step {
        display: flex;
        align-items: center;
        gap: 9px;
        min-width: 0;
        color: rgba(205, 217, 233, .55);
        font-size: .7rem;
        font-weight: 900;
        letter-spacing: .12em;
        text-transform: uppercase;
    }

        .community-match-modal__step > span {
            width: 31px;
            height: 31px;
            display: grid;
            place-items: center;
            border: 1px solid currentColor;
            border-radius: 50%;
            color: inherit;
        }

    .community-match-modal__step--orange {
        color: var(--orange);
    }

    .community-match-modal__step--cyan {
        color: var(--cyan);
    }

    .community-match-modal__body {
        position: relative;
        z-index: 1;
        padding: 0 30px 24px;
    }

    .community-match-modal__grid {
        display: grid;
        grid-template-columns: minmax(245px, .85fr) minmax(300px, 1.1fr) minmax(245px, .85fr);
        gap: 18px;
        align-items: stretch;
    }

    .community-match-picker,
    .community-match-modal__vs-panel {
        min-width: 0;
        border: 1px solid rgba(138, 173, 204, .18);
        border-radius: 20px;
        background: linear-gradient(180deg, rgba(14, 23, 38, .88), rgba(7, 14, 26, .91));
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, .035);
    }

    .community-match-picker {
        display: grid;
        grid-template-rows: auto auto minmax(0, 1fr);
        gap: 12px;
        min-height: 360px;
        padding: 18px;
    }

    .community-match-picker--orange {
        border-color: rgba(255, 149, 0, .22);
        box-shadow: inset 0 1px 0 rgba(255, 149, 0, .08);
    }

    .community-match-picker--cyan {
        border-color: rgba(37, 217, 245, .22);
        box-shadow: inset 0 1px 0 rgba(37, 217, 245, .07);
    }

    .community-match-picker__label {
        font-size: .77rem;
        font-weight: 950;
        letter-spacing: .13em;
        text-transform: uppercase;
    }

    .community-match-picker--orange .community-match-picker__label {
        color: var(--orange);
    }

    .community-match-picker--cyan .community-match-picker__label {
        color: var(--cyan);
    }

    .community-match-picker__search {
        min-height: 48px;
        border: 1px solid rgba(169, 193, 217, .18);
        border-radius: 12px;
        background: rgba(255, 255, 255, .045);
        color: #f8fbff;
        font-weight: 700;
        box-shadow: none;
    }

        .community-match-picker__search::placeholder {
            color: rgba(201, 215, 233, .46);
        }

    .community-match-picker--orange .community-match-picker__search:focus {
        border-color: rgba(255, 149, 0, .72);
        background: rgba(255, 149, 0, .055);
        box-shadow: 0 0 0 3px rgba(255, 149, 0, .09);
        color: #fff;
    }

    .community-match-picker--cyan .community-match-picker__search:focus {
        border-color: rgba(37, 217, 245, .72);
        background: rgba(37, 217, 245, .05);
        box-shadow: 0 0 0 3px rgba(37, 217, 245, .09);
        color: #fff;
    }

    .community-match-picker__list {
        min-height: 0;
        max-height: 242px;
        display: grid;
        align-content: start;
        gap: 8px;
        overflow: auto;
        padding-right: 3px;
        scrollbar-width: thin;
    }

        .community-match-picker__list::-webkit-scrollbar {
            width: 10px;
        }

        .community-match-picker__list::-webkit-scrollbar-track {
            border-radius: 999px;
            background: rgba(255, 255, 255, .06);
        }

        .community-match-picker__list::-webkit-scrollbar-thumb {
            border: 2px solid rgba(7, 14, 26, .95);
            border-radius: 999px;
        }

    .community-match-picker--orange .community-match-picker__list {
        scrollbar-color: rgba(255, 149, 0, .92) rgba(255, 255, 255, .08);
    }

        .community-match-picker--orange .community-match-picker__list::-webkit-scrollbar-track {
            background: linear-gradient(180deg, rgba(255, 149, 0, .12), rgba(255, 255, 255, .04));
            box-shadow: inset 0 0 0 1px rgba(255, 149, 0, .10);
        }

        .community-match-picker--orange .community-match-picker__list::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, rgba(255, 188, 78, .98), rgba(255, 149, 0, .86));
            box-shadow: 0 0 12px rgba(255, 149, 0, .22);
        }

    .community-match-picker--cyan .community-match-picker__list {
        scrollbar-color: rgba(37, 217, 245, .92) rgba(255, 255, 255, .08);
    }

        .community-match-picker--cyan .community-match-picker__list::-webkit-scrollbar-track {
            background: linear-gradient(180deg, rgba(37, 217, 245, .12), rgba(255, 255, 255, .04));
            box-shadow: inset 0 0 0 1px rgba(37, 217, 245, .10);
        }

        .community-match-picker--cyan .community-match-picker__list::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, rgba(106, 238, 255, .98), rgba(37, 217, 245, .86));
            box-shadow: 0 0 12px rgba(37, 217, 245, .22);
        }

    .community-match-picker__option {
        position: relative;
        width: 100%;
        min-width: 0;
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        align-items: center;
        gap: 12px;
        padding: 12px 44px 12px 12px;
        border: 1px solid rgba(163, 187, 211, .15);
        border-radius: 13px;
        background: rgba(255, 255, 255, .035);
        color: #f5f8fd;
        text-align: left;
        transition: .18s ease;
    }

        .community-match-picker__option:hover {
            transform: translateY(-1px);
            background: rgba(255, 255, 255, .065);
        }

    .community-match-picker--orange .community-match-picker__option.is-active {
        border-color: var(--orange);
        background: linear-gradient(90deg, rgba(255,149,0,.16), rgba(255,149,0,.055));
        box-shadow: 0 0 22px rgba(255, 149, 0, .14), inset 0 0 0 1px rgba(255, 188, 78, .14);
    }

    .community-match-picker--cyan .community-match-picker__option.is-active {
        border-color: var(--cyan);
        background: linear-gradient(90deg, rgba(37,217,245,.15), rgba(37,217,245,.045));
        box-shadow: 0 0 22px rgba(37, 217, 245, .13), inset 0 0 0 1px rgba(89, 231, 255, .13);
    }

    .community-match-picker__option.is-active::after {
        content: "✓";
        position: absolute;
        right: 13px;
        top: 50%;
        width: 24px;
        height: 24px;
        display: grid;
        place-items: center;
        border: 1px solid currentColor;
        border-radius: 50%;
        transform: translateY(-50%);
        font-size: .78rem;
        font-weight: 950;
    }

