@code {
    private const int SelectionLimit = 8;
    private readonly string _openButtonId = $"community-match-open-{Guid.NewGuid():N}";
    private readonly string _modalId = $"community-match-modal-{Guid.NewGuid():N}";
    private readonly string _captchaId = $"community-match-captcha-{Guid.NewGuid():N}";
    private readonly string _modalTitleId = $"community-match-title-{Guid.NewGuid():N}";
    private DotNetObjectReference<CommunityMatchCreationCard>? _dotNetRef;
    private List<StatsArenaTeamDto> _teams = [];
    private bool _open;
    private bool _loadingTeams;
    private bool _submitting;
    private string _homeSearch = string.Empty;
    private string _awaySearch = string.Empty;
    private StatsArenaTeamDto? _homeTeam;
    private StatsArenaTeamDto? _awayTeam;
    private string _captchaToken = string.Empty;
    private string? _message;
    private string? _messageKind;
    private string? _error;
    private string? _captchaError;
    private bool _loadedTeams;
    private bool _captchaReady;
    private bool _modalMounted;

    private bool IsEnabled => Config.GetValue<bool?>("CommunityMatch:Enabled") ?? true;
    private string? SiteKey => Config["Captcha:SiteKey"];
    private bool HasCaptcha => !string.IsNullOrWhiteSpace(SiteKey);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_open || !HasCaptcha || _modalMounted)
            return;

        _dotNetRef ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("CriptoVersusCommunityMatch.mount", _modalId, _captchaId, _dotNetRef, SiteKey, _openButtonId);
        _modalMounted = true;
        if (!_captchaReady)
            _captchaReady = true;
    }

    private async Task OpenAsync()
    {
        _open = true;
        _error = null;
        _captchaError = null;
        _message = null;
        _messageKind = null;
        await EnsureTeamsLoadedAsync();
    }

    private async Task EnsureTeamsLoadedAsync()
    {
        if (_loadedTeams || _loadingTeams)
            return;

        _loadingTeams = true;
        StateHasChanged();

        try
        {
            _teams = (await Api.GetStatsTeamsAsync())?.ToList() ?? [];
            _loadedTeams = true;
        }
        finally
        {
            _loadingTeams = false;
            StateHasChanged();
        }
    }

    private IEnumerable<StatsArenaTeamDto> GetFilteredTeams(string search, int? excludedTeamId)
    {
        if (_teams.Count == 0)
            return [];

        var query = (search ?? string.Empty).Trim();
        var items = _teams.Where(team => excludedTeamId is null || team.TeamId != excludedTeamId.Value);
        if (!string.IsNullOrWhiteSpace(query))
        {
            items = items.Where(team =>
                Contains(team.Symbol, query) ||
                Contains(team.DisplaySymbol, query) ||
                Contains(team.DisplayName, query));
        }

        return items
            .OrderByDescending(team => MatchesExact(team, query))
            .ThenByDescending(team => team.Rank > 0 ? -team.Rank : 0)
            .ThenBy(team => team.DisplaySymbol)
            .Take(SelectionLimit)
            .ToList();
    }

    private async Task SelectHomeAsync(StatsArenaTeamDto team)
    {
        _homeTeam = team;
        _homeSearch = team.DisplaySymbol;
        _message = null;
        _messageKind = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task SelectAwayAsync(StatsArenaTeamDto team)
    {
        _awayTeam = team;
        _awaySearch = team.DisplaySymbol;
        _message = null;
        _messageKind = null;
        await InvokeAsync(StateHasChanged);
    }

    private bool CanSubmit =>
        !_submitting &&
        _homeTeam is not null &&
        _awayTeam is not null &&
        _homeTeam.TeamId != _awayTeam.TeamId &&
        HasCaptcha &&
        !string.IsNullOrWhiteSpace(_captchaToken);

    private async Task SubmitAsync()
    {
        if (!CanSubmit || _homeTeam is null || _awayTeam is null)
            return;

        _submitting = true;
        _message = null;
        _messageKind = null;
        _error = null;
        _captchaError = null;
        StateHasChanged();

        try
        {
            var request = new CommunityMatchCreateRequestDto
            {
                HomeSymbol = _homeTeam.Symbol,
                AwaySymbol = _awayTeam.Symbol,
                CaptchaToken = await GetCaptchaTokenAsync()
            };

            if (string.IsNullOrWhiteSpace(request.CaptchaToken))
            {
                _captchaError = T("modal.captchaRequired");
                await ResetCaptchaAsync();
                return;
            }

            var result = await Api.CreateCommunityMatchAsync(request);

            Logger.LogWarning(
                "[COMMUNITY_MATCH_RESULT] Success={Success} MessageCode={MessageCode} Message={Message} HasResponse={HasResponse}",
                result.Success,
                result.MessageCode,
                result.Message,
                result.Response is not null);

            if (!result.Success || result.Response is null)
            {
                _messageKind = "error";
                _message = ResolveResultMessage(result);

                if (!string.Equals(
                        result.MessageCode,
                        "battleAlreadyExists",
                        StringComparison.OrdinalIgnoreCase))
                {
                    await ResetCaptchaAsync();
                }

                return;
            }

            _messageKind = "success";
            _message = result.Response.Created ? T("modal.created") : T("modal.existing");
            await CloseAsync(force: true);
            Nav.NavigateTo(result.Response.PublicUrl);
        }
        catch (Exception ex)
        {
            Logger.LogError(
                ex,
                "[COMMUNITY_MATCH_SUBMIT_ERROR] Home={Home} Away={Away}",
                _homeTeam?.Symbol,
                _awayTeam?.Symbol);

            _messageKind = "error";
            _message = $"{T("errors.network")}";

            await ResetCaptchaAsync();
        }
        finally
        {
            _submitting = false;
            StateHasChanged();
        }
    }

    private async Task<string> GetCaptchaTokenAsync()
    {
        if (!HasCaptcha)
            return string.Empty;

        if (!string.IsNullOrWhiteSpace(_captchaToken))
            return _captchaToken;

        return await JS.InvokeAsync<string>("CriptoVersusCommunityMatch.getCaptchaToken", _captchaId) ?? string.Empty;
    }

    private async Task ResetCaptchaAsync()
    {
        _captchaToken = string.Empty;
        if (HasCaptcha)
            await JS.InvokeVoidAsync("CriptoVersusCommunityMatch.resetCaptcha", _captchaId);
    }

    private async Task CloseAsync(bool force = false)
    {
        if (_submitting && !force)
            return;

        _open = false;
        _error = null;
        _message = null;
        _messageKind = null;
        _captchaError = null;
        _captchaToken = string.Empty;
        _homeTeam = null;
        _awayTeam = null;
        _homeSearch = string.Empty;
        _awaySearch = string.Empty;
        if (_modalMounted && HasCaptcha)
            await JS.InvokeVoidAsync("CriptoVersusCommunityMatch.unmount", _modalId, _openButtonId);
        _modalMounted = false;
        await ResetCaptchaAsync();
        StateHasChanged();
    }

    [JSInvokable]
    public Task OnCaptchaSuccess(string token)
    {
        _captchaToken = token ?? string.Empty;
        _captchaError = null;
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnCaptchaExpired()
    {
        _captchaToken = string.Empty;
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnCaptchaError(string _)
    {
        _captchaToken = string.Empty;
        _captchaError = T("modal.captchaError");
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task RequestCloseFromJs() => CloseAsync();


    private Task HandleBackdropClickAsync()
        => CloseAsync();
    private static bool Contains(string? value, string query)
        => !string.IsNullOrWhiteSpace(value) && value.Contains(query, StringComparison.OrdinalIgnoreCase);

    private static bool MatchesExact(StatsArenaTeamDto team, string query)
        => !string.IsNullOrWhiteSpace(query) && (
            string.Equals(team.Symbol, query, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(team.DisplaySymbol, query, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(team.DisplayName, query, StringComparison.OrdinalIgnoreCase));

    private static bool IsSelected(StatsArenaTeamDto candidate, StatsArenaTeamDto? selected)
        => selected is not null && candidate.TeamId == selected.TeamId;

    private string GetIconUrl(StatsArenaTeamDto team)
    {
        if (!string.IsNullOrWhiteSpace(team.IconUrl))
        {
            var iconSymbol = CleanAssetSymbol(team.IconUrl[(team.IconUrl.LastIndexOf('/') + 1)..]);
            if (!string.IsNullOrWhiteSpace(iconSymbol))
                return Api.BuildBinanceIconUrl(iconSymbol);

            return Api.BuildApiUrl(team.IconUrl);
        }

        return Api.BuildBinanceIconUrl(ResolveDisplaySymbol(team));
    }

    private static string ResolveDisplaySymbol(StatsArenaTeamDto team)
        => string.IsNullOrWhiteSpace(team.DisplaySymbol) ? team.Symbol : team.DisplaySymbol;

    private static string ResolveDisplayName(StatsArenaTeamDto team)
        => string.IsNullOrWhiteSpace(team.DisplayName) ? ResolveDisplaySymbol(team) : team.DisplayName;

    private static string GetAssetMonogram(string? symbol)
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return "?";

        var normalized = CleanAssetSymbol(symbol);
        return normalized.Length >= 2 ? normalized[..2] : normalized;
