    private async Task LoadAsync()

    {

        _loading = true;

        _error = null;
        _coinProfile = null;



        try

        {

            var response = await Api.GetStatsTeamDetailAsync(NormalizedSlug);

            if (response is null)

            {

                _error = T("states.notFoundBody");

            }

            else

            {

                _detail.Symbol = response.Symbol;

                _detail.DisplaySymbol = response.DisplaySymbol;

                _detail.DisplayName = response.DisplayName;

                _detail.Rank = response.Rank;

                _detail.Matches = response.Matches;

                _detail.Wins = response.Wins;

                _detail.Losses = response.Losses;

                _detail.Draws = response.Draws;

                _detail.WinRate = response.WinRate;

                _detail.AverageScore = response.AverageScore;

                _detail.TotalScore = response.TotalScore;

                _detail.CurrentStreak = response.CurrentStreak;

                _detail.Momentum = response.Momentum;

                _detail.IconUrl = response.IconUrl;

                _detail.LastMatchUtc = response.LastMatchUtc;

                _detail.MatchActivity.Clear();

                _detail.MatchActivity.AddRange(response.MatchActivity ?? []);

                _detail.LatestMatches.Clear();

                _detail.LatestMatches.AddRange(response.LatestMatches ?? []);

                _detail.Rivalries.Clear();

                _detail.Rivalries.AddRange(response.Rivalries ?? []);

                await TryLoadCoinSocialProfileAsync();

                await ResolveInvestmentContextAsync();

                _chartPendingRender = true;

            }

        }

        catch (HttpRequestException ex) when (ex.StatusCode == HttpStatusCode.NotFound)

        {

            _error = T("states.notFoundBody");

        }

        catch (Exception ex)

        {

            _error = T("states.errorBody");

            Console.WriteLine($"Stats team detail page load error: {ex.Message}");

        }

        finally

        {

            _loading = false;

            await InvokeAsync(StateHasChanged);

        }

    }



    private async Task ResolveInvestmentContextAsync()

    {

        _investmentContextLoading = true;

        _investmentMatch = null;

        _investmentTeamId = 0;

        _investmentOpponentName = string.Empty;

        _investmentContextFailureReason = string.Empty;



        try

        {

            var resolution = await TeamInvestmentContextResolver.ResolveAsync(_detail.Symbol);

            if (!resolution.IsAvailable)

            {
                if (_detail.TeamId > 0)
                {
                    _investmentTeamId = _detail.TeamId;
                    _pendingBetTeamName = !string.IsNullOrWhiteSpace(_detail.DisplaySymbol) ? _detail.DisplaySymbol : _detail.Symbol;
                    _investmentContextFailureReason = resolution.FailureReason;
                    return;
                }

                _investmentContextFailureReason = resolution.FailureReason;

                return;

            }



            _investmentMatch = resolution.Match;

            _investmentTeamId = resolution.TeamId;

            _pendingBetTeamName = resolution.TeamName;

            _investmentOpponentName = resolution.OpponentName;

            _investmentContextFailureReason = resolution.FailureReason;

        }

        catch (Exception ex)

        {
            if (_detail.TeamId > 0)
            {
                _investmentTeamId = _detail.TeamId;
                _pendingBetTeamName = !string.IsNullOrWhiteSpace(_detail.DisplaySymbol) ? _detail.DisplaySymbol : _detail.Symbol;
            }

            _investmentContextFailureReason = "team_match_lookup_error";

            Console.WriteLine($"Stats team investment context error: {ex.Message}");

        }

        finally

        {

            _investmentContextLoading = false;

        }

    }

