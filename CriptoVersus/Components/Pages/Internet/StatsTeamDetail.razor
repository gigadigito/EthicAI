    private int _investmentAmountRangeIndex

    {

        get => GetClosestQuickInvestmentAmountIndex(_investmentAmount);

        set

        {

            if (value < 0 || value >= QuickInvestmentAmounts.Length)

                return;



            _investmentAmount = QuickInvestmentAmounts[value];

            _investmentAmountError = string.Empty;

        }

    }



    private static int GetClosestQuickInvestmentAmountIndex(decimal amount)

    {

        var closestIndex = 0;

        var closestDistance = decimal.MaxValue;



        for (var i = 0; i < QuickInvestmentAmounts.Length; i++)

        {

            var distance = Math.Abs(QuickInvestmentAmounts[i] - amount);

            if (distance >= closestDistance)

                continue;



            closestDistance = distance;

            closestIndex = i;

        }



        return closestIndex;

    }



    private async Task ConfirmInvestmentAmountAsync()

    {

        if (_pendingBetTeamId <= 0 || string.IsNullOrWhiteSpace(_pendingBetTeamName))

        {

            _investmentAmountError = InvestmentT("chooseACoinToInvestIn");

            return;

        }



        _investmentAmount = decimal.Round(_investmentAmount, 8, MidpointRounding.ToZero);



        if (_investmentAmount <= 0)

        {

            _investmentAmountError = InvestmentT("enterAnAmountGreaterThanZero");

            return;

        }



        if (!_walletMaxSpendableSol.HasValue)

        {

            _investmentAmountError = _walletBalanceLoadError;

            return;

        }

        if (_investmentAmount > WalletMaxSpendableAmount)

        {

            _investmentAmountError = InvestmentT("walletBalanceGuardInsufficientMessage", WalletMaxSpendableText);

            return;

        }

        var validation = await ValidateWalletBalanceBeforeSendAsync(_investmentAmount);

        if (!validation.ok)

        {

            _investmentAmountError = validation.message ?? InvestmentT("walletBalanceGuardInsufficientMessage", WalletMaxSpendableText);

            await LoadWalletGuardSnapshotAsync();

            return;

        }

        _showInvestmentAmountModal = false;

        await SendPositionAsync(_pendingBetTeamId, _pendingBetTeamName, _investmentAmount);

    }



    private async Task LoadWalletGuardSnapshotAsync()

    {

        _walletBalanceLoading = true;

        _walletBalanceLoadError = string.Empty;

        await InvokeAsync(StateHasChanged);

        try

        {

            _walletBalanceModule ??= await JS.InvokeAsync<IJSObjectReference>(

                "import",

                "./js/solanaWalletBalance.js?v=20260513-wallet-guard");

            var result = await _walletBalanceModule.InvokeAsync<WalletBalanceGuardResult>(

                "getMaxSpendableSol",

                new

                {

                    rpcUrl = Config["CriptoVersusBlockchain:RpcUrl"],

                    locale = CurrentCulture == "en" ? "en-US" : "pt-BR",

                    flowName = "STATS_TEAM_DETAIL_MODAL"

                });

            _walletBalanceSol = result.balanceSol;

            _walletMaxSpendableSol = result.maxSpendableSol;

            _walletBalanceLoadError = result.ok || string.Equals(result.code, "INSUFFICIENT_BALANCE", StringComparison.OrdinalIgnoreCase)

                ? string.Empty

                : result.message ?? string.Empty;

        }

        catch (Exception ex)

        {

            _walletBalanceSol = null;

            _walletMaxSpendableSol = null;

            _walletBalanceLoadError = ex.Message;

        }

        finally

        {

            _walletBalanceLoading = false;

            await InvokeAsync(StateHasChanged);

        }

    }

    private async Task<WalletBalanceGuardResult> ValidateWalletBalanceBeforeSendAsync(decimal amountSol)

    {

        _walletBalanceModule ??= await JS.InvokeAsync<IJSObjectReference>(

            "import",

            "./js/solanaWalletBalance.js?v=20260513-wallet-guard");

        return await _walletBalanceModule.InvokeAsync<WalletBalanceGuardResult>(

