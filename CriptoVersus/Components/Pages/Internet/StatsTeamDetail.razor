    private static string CleanAssetSymbol(string? symbol)

    {

        if (string.IsNullOrWhiteSpace(symbol))

            return "-";



        var normalized = new string(symbol.Trim().ToUpperInvariant().Where(char.IsLetterOrDigit).ToArray());

        foreach (var suffix in VisualSuffixes)

        {

            if (normalized.Length > suffix.Length + 1 && normalized.EndsWith(suffix, StringComparison.Ordinal))

                return normalized[..^suffix.Length];

        }



        return normalized;

    }



    private static string BuildAssetSlug(string? symbol)

        => new string((symbol ?? string.Empty).Trim().ToLowerInvariant().Where(char.IsLetterOrDigit).ToArray());



    private static string GetAssetMonogram(string? symbol)

    {

        if (string.IsNullOrWhiteSpace(symbol))

            return "?";



        var normalized = symbol.Trim().ToUpperInvariant();

        return normalized.Length >= 2 ? normalized[..2] : normalized;

    }



