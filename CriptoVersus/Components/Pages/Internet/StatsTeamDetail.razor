    private static DateTime EnsureUtc(DateTime value) => value.Kind switch { DateTimeKind.Utc => value, DateTimeKind.Local => value.ToUniversalTime(), _ => DateTime.SpecifyKind(value, DateTimeKind.Utc) };

    private static string ResolveAccentColor(string? value, string fallback)
    {
        if (string.IsNullOrWhiteSpace(value))
            return fallback;

        var trimmed = value.Trim();
        return trimmed.Length is 4 or 7 && trimmed.StartsWith('#') && trimmed[1..].All(Uri.IsHexDigit)
            ? trimmed
            : fallback;
    }

    private static bool IsValidAbsoluteHttpUrl(string? value)
        => Uri.TryCreate(value, UriKind.Absolute, out var uri)
           && (uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps);

    private static string? FirstValidAbsoluteHttpUrl(params string?[] candidates)
        => candidates.FirstOrDefault(IsValidAbsoluteHttpUrl);

    private static string? BuildTwitterUrl(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        var trimmed = value.Trim();
        if (IsValidAbsoluteHttpUrl(trimmed))
            return trimmed;

        var handle = trimmed.TrimStart('@');
        return string.IsNullOrWhiteSpace(handle) ? null : $"https://x.com/{handle}";
    }

    private static string FormatContractAddress(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "-";

        var trimmed = value.Trim();
        return trimmed.Length <= 14 ? trimmed : $"{trimmed[..6]}...{trimmed[^4..]}";
    }

