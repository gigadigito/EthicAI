@page "/stats/teams/{Slug}"
@page "/en/stats/teams/{Slug}"
@page "/pt/estatisticas/times/{Slug}"
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Globalization
@using System.Net
@using System.Text.Json
@using Blazored.SessionStorage
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersusApiClient Api
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpContextAccessor
@inject HttpClient Http
@inject IConfiguration Config
@inject ISessionStorageService SessionStorage
@inject AppCultureService AppCulture
@inject LocalizationService L
@inject RouteLocalizationService RouteLocalization
@inject MatchSlugHelper MatchSlugHelper
@inject TeamInvestmentContextResolver TeamInvestmentContextResolver
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <meta name="description" content="@MetaDescription" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="en-US" href="@EnglishUrl" />
    <link rel="alternate" hreflang="pt-BR" href="@PortugueseUrl" />
    <link rel="alternate" hreflang="x-default" href="@CanonicalUrl" />
    <meta property="og:title" content="@PageTitleText" />
    <meta property="og:description" content="@MetaDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="website" />
    <script type="application/ld+json">@StructuredDataMarkup</script>
</HeadContent>

<section class="team-detail-page">
    @if (_loading)
    {
        <section class="team-detail-feedback">
            <div class="team-detail-spinner" aria-hidden="true"></div>
            <div>
                <strong>@T("states.loadingTitle")</strong>
                <p>@T("states.loadingBody")</p>
            </div>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <section class="team-detail-feedback team-detail-feedback--error" role="alert">
            <div>
                <strong>@T("states.errorTitle")</strong>
                <p>@_error</p>
            </div>
        </section>
    }
    else
    {
        <header class="team-detail-hero">
            <div class="team-detail-hero__copy">
                <span class="team-detail-hero__eyebrow">@T("hero.eyebrow")</span>
                <div class="team-detail-hero__identity">
                    <img src="@GetIconUrl()" alt="" width="28" height="28" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                    <span class="team-detail__fallback" aria-hidden="true">@GetAssetMonogram(_detail.DisplaySymbol)</span>
                    <h1>@_detail.DisplaySymbol</h1>
                </div>
                <p class="team-detail-hero__lead">@T("hero.subtitle", _detail.DisplaySymbol)</p>
                <p class="team-detail-hero__seo-copy">@T("hero.seoCopy", _detail.DisplaySymbol)</p>
                <div class="team-detail-invest-card">
                    <div class="team-detail-invest-card__copy">
                        <span class="team-detail-invest-card__eyebrow">@T("investment.eyebrow")</span>
                        <strong>@T("investment.title", _detail.DisplaySymbol)</strong>
                        <p>@GetInvestmentMessage()</p>
                    </div>
                    <div class="team-detail-invest-card__actions">
                        <span class="team-detail-invest-state @GetInvestmentStateClass()">@GetInvestmentStateLabel()</span>
                        <button class="team-detail-invest-button"
                                disabled="@IsInvestmentButtonDisabled"
                                @onclick="OpenInvestmentAmountModal">
                            @(IsInvestmentBusy ? T("investment.loadingCta") : T("investment.cta", _detail.DisplaySymbol))
                        </button>
                        @if (_investmentMatch is not null)
                        {
                            <a class="team-detail-invest-link"
                               href="@BuildMatchUrl(_investmentMatch)">
                                @T("investment.openMatch")
                            </a>
                        }
                    </div>
                </div>
                <div class="team-detail-hero__actions">
                    <a class="team-detail-pill-link" href="@RouteLocalization.BuildStatsTeamsPath(CurrentCulture)">@T("hero.backToTeams")</a>
                    <a class="team-detail-pill-link team-detail-pill-link--accent" href="@RouteLocalization.BuildStatsPath(CurrentCulture)">@T("hero.backToStats")</a>
                </div>
            </div>
            <div class="team-detail-hero__panel">
                <article>
                    <span>@T("hero.rank")</span>
                    <strong>#@_detail.Rank</strong>
                    <small>@T("hero.rankHint")</small>
                </article>
                <article>
                    <span>@T("hero.momentum")</span>
                    <strong>@FormatMomentum(_detail.Momentum)</strong>
                    <small>@T("hero.momentumHint")</small>
                </article>
                <article>
                    <span>@T("hero.lastMatch")</span>
                    <strong>@DisplayDate(_detail.LastMatchUtc)</strong>
                    <small>@T("hero.lastMatchHint")</small>
                </article>
            </div>
        </header>

        <section class="team-detail-summary-grid">
            <article class="team-detail-card"><span>@T("summary.matches")</span><strong>@DisplayNumber(_detail.Matches)</strong></article>
            <article class="team-detail-card"><span>@T("summary.wins")</span><strong>@DisplayNumber(_detail.Wins)</strong></article>
            <article class="team-detail-card"><span>@T("summary.losses")</span><strong>@DisplayNumber(_detail.Losses)</strong></article>
            <article class="team-detail-card"><span>@T("summary.winRate")</span><strong>@FormatPercent(_detail.WinRate)</strong></article>
            <article class="team-detail-card"><span>@T("summary.averageScore")</span><strong>@FormatDecimal(_detail.AverageScore)</strong></article>
            <article class="team-detail-card"><span>@T("summary.totalScore")</span><strong>@DisplayNumber(_detail.TotalScore)</strong></article>
        </section>

        <section class="team-detail-grid">
            <article class="team-detail-chart-card">
                <div class="team-detail-section-head">
                    <div>
                        <span>@T("activity.eyebrow")</span>
                        <h2>@T("activity.title")</h2>
                    </div>
                    <p>@T("activity.description", _detail.DisplaySymbol)</p>
                </div>
                <div id="@ActivityChartId" class="team-detail-chart-shell" role="img" aria-label="@T("activity.ariaLabel", _detail.DisplaySymbol)"></div>
            </article>

            <article class="team-detail-rivals-card">
                <div class="team-detail-section-head">
                    <div>
                        <span>@T("rivals.eyebrow")</span>
                        <h2>@T("rivals.title")</h2>
                    </div>
                    <p>@T("rivals.description")</p>
                </div>
                <div class="team-detail-rivals-list">
                    @if (_detail.Rivalries.Count == 0)
                    {
                        <p class="team-detail-empty">@T("rivals.empty")</p>
                    }
                    else
                    {
                        @foreach (var rival in _detail.Rivalries)
                        {
                            <a class="team-detail-rival-item" href="@RouteLocalization.BuildStatsTeamDetailPath(CurrentCulture, BuildAssetSlug(rival.DisplaySymbol))" aria-label="@T("rivals.openAria", rival.DisplaySymbol)">
                                <img src="@GetIconUrl(rival.IconUrl, rival.DisplaySymbol)" alt="" width="18" height="18" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                <span class="team-detail__fallback" aria-hidden="true">@GetAssetMonogram(rival.DisplaySymbol)</span>
                                <strong>@rival.DisplaySymbol</strong>
                                <small>@T("rivals.record", rival.Wins, rival.Losses, rival.Matches)</small>
                            </a>
                        }
                    }
                </div>
            </article>
        </section>

        <section class="team-detail-table-section">
            <div class="team-detail-section-head">
                <div>
                    <span>@T("latest.eyebrow")</span>
                    <h2>@T("latest.title")</h2>
                </div>
                <p>@T("latest.description", _detail.DisplaySymbol)</p>
            </div>
            <div class="team-detail-table-wrap">
                <table class="team-detail-table">
                    <thead>
                        <tr>
                            <th>@T("latest.columns.match")</th>
                            <th>@T("latest.columns.score")</th>
                            <th>@T("latest.columns.status")</th>
                            <th>@T("latest.columns.startedAt")</th>
                            <th>@T("latest.columns.finishedAt")</th>
                            <th>@T("latest.columns.publicPage")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_detail.LatestMatches.Count == 0)
                        {
                            <tr><td colspan="6" class="team-detail-empty">@T("latest.empty")</td></tr>
                        }
                        else
                        {
                            @foreach (var match in _detail.LatestMatches)
                            {
                                <tr>
                                    <td>@GetDisplaySymbol(match.HomeSymbol) vs @GetDisplaySymbol(match.AwaySymbol)</td>
                                    <td>@match.HomeScore x @match.AwayScore</td>
                                    <td><span class="@GetStatusBadgeClass(match.Status)">@FormatStatus(match.Status)</span></td>
                                    <td>@DisplayDateTime(match.StartedAtUtc)</td>
                                    <td>@DisplayDateTime(match.FinishedAtUtc)</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(GetMatchUrl(match)))
                                        {
                                            <a class="team-detail-cta-link" href="@GetMatchUrl(match)">@T("latest.openMatch")</a>
                                        }
                                        else
                                        {
                                            <span class="team-detail-muted">@T("latest.unavailable")</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</section>

@if (_showSimplePopup)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-light border border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title">@_simplePopupTitle</h5>
                    <button type="button" class="btn-close btn-close-white" aria-label="@InvestmentT("close")" @onclick="CloseSimplePopup"></button>
                </div>
                <div class="modal-body text-light-emphasis">
                    <p class="mb-0">@_simplePopupMessage</p>
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-primary" @onclick="CloseSimplePopup">@InvestmentT("understood")</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showInvestmentAmountModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-light border border-secondary">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title">@InvestmentT("chooseTheAmountInSol")</h5>
                    <button type="button" class="btn-close btn-close-white" aria-label="@InvestmentT("close")" @onclick="CloseInvestmentAmountModal"></button>
                </div>
                <div class="modal-body">
                    <div class="team-detail-amount-modal-team">
                        <span>@InvestmentT("investmentIn")</span>
                        <strong><MarketPairText Symbol="@_pendingBetTeamName" /></strong>
                    </div>

                    <div class="team-detail-amount-quick-grid" aria-label="@InvestmentT("quickValuesInSol")">
                        @foreach (var amount in QuickInvestmentAmounts)
                        {
                            <button type="button"
                                    class="team-detail-amount-chip @(_investmentAmount == amount ? "team-detail-amount-chip-active" : "")"
                                    @onclick="() => SetInvestmentAmount(amount)">
                                @FmtSolAmount(amount)
                            </button>
                        }
                    </div>

                    <label class="form-label mt-3" for="teamStatsInvestmentAmountRange">
                        @InvestmentT("quickAdjustment") <strong>@FmtSolAmount(_investmentAmount)</strong>
                    </label>
                    <input id="teamStatsInvestmentAmountRange"
                           class="form-range"
                           type="range"
                           min="0"
                           max="@(QuickInvestmentAmounts.Length - 1)"
                           step="1"
                           @bind="_investmentAmountRangeIndex"
                           @bind:event="oninput" />

                    <label class="form-label mt-3" for="teamStatsInvestmentAmountInput">
                        @InvestmentT("orEnterAnyAmountInSol")
                    </label>
                    <input id="teamStatsInvestmentAmountInput"
                           class="form-control"
                           type="number"
                           min="0.00000001"
                           step="0.00000001"
                           @bind="_investmentAmount"
                           @bind:event="oninput" />

                    @if (!string.IsNullOrWhiteSpace(_investmentAmountError))
                    {
                        <div class="text-danger small mt-2">@_investmentAmountError</div>
                    }
                </div>
                <div class="modal-footer border-secondary">
                    <button type="button" class="btn btn-outline-light" @onclick="CloseInvestmentAmountModal">@InvestmentT("cancel")</button>
                    <button type="button" class="btn btn-primary" disabled="@_isSendingBet" @onclick="ConfirmInvestmentAmountAsync">
                        @(_isSendingBet ? InvestmentT("sending") : $"{InvestmentT("invest")} {FmtSolAmount(_investmentAmount)}")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;
    [Parameter] public string? Culture { get; set; }

    private const string ActivityChartId = "team-detail-activity-chart";
    private static readonly decimal[] QuickInvestmentAmounts = [0.01m, 0.05m, 0.1m, 0.25m, 0.5m, 1m];
    private readonly StatsArenaTeamDetailDto _detail = new();
    private bool _loading = true;
    private bool _chartPendingRender;
    private string? _error;
    private bool _investmentContextLoading = true;
    private MatchDto? _investmentMatch;
    private int _investmentTeamId;
    private string _investmentOpponentName = string.Empty;
    private string _investmentContextFailureReason = string.Empty;
    private int? _loggedUserId;
    private string? _loggedWalletPublicKey;
    private IJSObjectReference? _bettingModule;
    private bool _showSimplePopup;
    private string _simplePopupTitle = string.Empty;
    private string _simplePopupMessage = string.Empty;
    private bool _showInvestmentAmountModal;
    private bool _isSendingBet;
    private int _pendingBetTeamId;
    private string _pendingBetTeamName = string.Empty;
    private decimal _investmentAmount = 0.1m;
    private string _investmentAmountError = string.Empty;
    private string _investmentStatusMessage = string.Empty;

    private string CurrentCulture => !string.IsNullOrWhiteSpace(Culture)
        ? AppCulture.NormalizeRouteCulture(Culture)
        : AppCulture.DetectPreferredRouteCulture(HttpContextAccessor.HttpContext);
    private string NormalizedSlug => BuildAssetSlug(Slug);
    private string PageTitleText => T("seo.title", SeoSymbol);
    private string MetaDescription => T("seo.description", SeoSymbol);
    private string CanonicalUrl => BuildAbsolute($"/stats/teams/{NormalizedSlug}");
    private string EnglishUrl => BuildAbsolute($"/stats/teams/{NormalizedSlug}");
    private string PortugueseUrl => BuildAbsolute($"/pt/estatisticas/times/{NormalizedSlug}");
    private string StructuredDataMarkup => BuildStructuredDataMarkup();
    private string SeoSymbol => !string.IsNullOrWhiteSpace(_detail.DisplaySymbol) ? _detail.DisplaySymbol : NormalizedSlug.ToUpperInvariant();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await RefreshAuthenticatedUserAsync();
                await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex) when (InteropSafety.IsDeferredInteropException(ex))
            {
                _ = ex;
            }
        }

        if (!_chartPendingRender || _loading || !string.IsNullOrWhiteSpace(_error))
            return;

        _chartPendingRender = false;
        await JS.InvokeVoidAsync("criptoVersusStatsCharts.renderMatchActivityChart", ActivityChartId, _detail.MatchActivity);
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            var response = await Api.GetStatsTeamDetailAsync(NormalizedSlug);
            if (response is null)
            {
                _error = T("states.notFoundBody");
            }
            else
            {
                _detail.Symbol = response.Symbol;
                _detail.DisplaySymbol = response.DisplaySymbol;
                _detail.DisplayName = response.DisplayName;
                _detail.Rank = response.Rank;
                _detail.Matches = response.Matches;
                _detail.Wins = response.Wins;
                _detail.Losses = response.Losses;
                _detail.WinRate = response.WinRate;
                _detail.AverageScore = response.AverageScore;
                _detail.TotalScore = response.TotalScore;
                _detail.Momentum = response.Momentum;
                _detail.IconUrl = response.IconUrl;
                _detail.LastMatchUtc = response.LastMatchUtc;
                _detail.MatchActivity.Clear();
                _detail.MatchActivity.AddRange(response.MatchActivity ?? []);
                _detail.LatestMatches.Clear();
                _detail.LatestMatches.AddRange(response.LatestMatches ?? []);
                _detail.Rivalries.Clear();
                _detail.Rivalries.AddRange(response.Rivalries ?? []);
                await ResolveInvestmentContextAsync();
                _chartPendingRender = true;
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == HttpStatusCode.NotFound)
        {
            _error = T("states.notFoundBody");
        }
        catch (Exception ex)
        {
            _error = T("states.errorBody");
            Console.WriteLine($"Stats team detail page load error: {ex.Message}");
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ResolveInvestmentContextAsync()
    {
        _investmentContextLoading = true;
        _investmentMatch = null;
        _investmentTeamId = 0;
        _investmentOpponentName = string.Empty;
        _investmentContextFailureReason = string.Empty;

        try
        {
            var resolution = await TeamInvestmentContextResolver.ResolveAsync(_detail.Symbol);
            if (!resolution.IsAvailable || resolution.Match is null)
            {
                _investmentContextFailureReason = resolution.FailureReason;
                return;
            }

            _investmentMatch = resolution.Match;
            _investmentTeamId = resolution.TeamId;
            _pendingBetTeamName = resolution.TeamName;
            _investmentOpponentName = resolution.OpponentName;
        }
        catch (Exception ex)
        {
            _investmentContextFailureReason = "team_match_lookup_error";
            Console.WriteLine($"Stats team investment context error: {ex.Message}");
        }
        finally
        {
            _investmentContextLoading = false;
        }
    }

    private string BuildStructuredDataMarkup()
    {
        var graph = new object[]
        {
            new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "WebPage",
                ["name"] = T("hero.title", SeoSymbol),
                ["description"] = T("hero.subtitle", SeoSymbol),
                ["url"] = CanonicalUrl
            },
            new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "BreadcrumbList",
                ["itemListElement"] = new object[]
                {
                    new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 1, ["name"] = "CriptoVersus", ["item"] = BuildAbsolute(RouteLocalization.BuildHomePath(CurrentCulture)) },
                    new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 2, ["name"] = T("structuredData.breadcrumbStats"), ["item"] = BuildAbsolute(RouteLocalization.BuildStatsPath(CurrentCulture)) },
                    new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 3, ["name"] = T("structuredData.breadcrumbTeams"), ["item"] = BuildAbsolute(RouteLocalization.BuildStatsTeamsPath(CurrentCulture)) },
                    new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 4, ["name"] = SeoSymbol, ["item"] = CanonicalUrl }
                }
            }
        };

        return JsonSerializer.Serialize(graph);
    }

    private string GetIconUrl()
        => GetIconUrl(_detail.IconUrl, SeoSymbol);

    private string GetIconUrl(string? explicitUrl, string fallbackSymbol)
        => !string.IsNullOrWhiteSpace(explicitUrl)
            ? Api.BuildApiUrl(explicitUrl)
            : Api.BuildBinanceIconUrl(fallbackSymbol);

    private string GetDisplaySymbol(string symbol)
        => CleanAssetSymbol(symbol);

    private string GetMatchUrl(StatsLatestMatchDto match)
    {
        var slug = MatchSlugHelper.BuildSlug(match.HomeSymbol, match.AwaySymbol);
        if (!string.IsNullOrWhiteSpace(slug))
            return RouteLocalization.BuildBestPath(CurrentCulture, match.MatchId, slug);

        return match.PublicUrl ?? string.Empty;
    }

    private string BuildMatchUrl(MatchDto match)
    {
        var slug = MatchSlugHelper.BuildSlug(match.TeamA, match.TeamB);
        return !string.IsNullOrWhiteSpace(slug)
            ? RouteLocalization.BuildBestPath(CurrentCulture, match.MatchId, slug)
            : string.Empty;
    }

    private async Task RefreshAuthenticatedUserAsync()
    {
        _loggedUserId = await SessionStorage.GetItemAsync<int?>("userId");
        _loggedWalletPublicKey = await SessionStorage.GetItemAsync<string>("walletPublicKey");
    }

    private bool HasWalletSession => _loggedUserId.GetValueOrDefault() > 0 && !string.IsNullOrWhiteSpace(_loggedWalletPublicKey);
    private bool IsInvestmentBusy => _investmentContextLoading || _isSendingBet;
    private bool IsInvestmentAvailable => _investmentMatch is not null && _investmentTeamId > 0 && PublicInvestmentRules.IsBettingWindowOpen(_investmentMatch);
    private bool IsInvestmentButtonDisabled => IsInvestmentBusy || !IsInvestmentAvailable;

    private string GetInvestmentStateLabel()
    {
        if (_investmentContextLoading)
            return T("investment.states.loading");

        if (!IsInvestmentAvailable)
            return T("investment.states.unavailable");

        if (!HasWalletSession)
            return T("investment.states.walletRequired");

        return T("investment.states.available");
    }

    private string GetInvestmentStateClass()
    {
        if (_investmentContextLoading)
            return "is-loading";

        if (!IsInvestmentAvailable)
            return "is-unavailable";

        if (!HasWalletSession)
            return "is-blocked";

        return "is-available";
    }

    private string GetInvestmentMessage()
    {
        if (_investmentContextLoading)
            return T("investment.messages.loading");

        if (!IsInvestmentAvailable)
        {
            return _investmentContextFailureReason switch
            {
                "team_match_advanced_live" => T("investment.messages.advancedLive"),
                "team_match_missing" => T("investment.messages.noMatch"),
                "team_match_closed" => T("investment.messages.closed"),
                "team_match_lookup_error" => T("investment.messages.error"),
                _ => T("investment.messages.unavailable")
            };
        }

        if (!HasWalletSession)
            return T("investment.messages.walletRequired", _detail.DisplaySymbol);

        return T("investment.messages.available", _detail.DisplaySymbol, _investmentOpponentName);
    }

    private void OpenInvestmentAmountModal()
    {
        if (!IsInvestmentAvailable || _investmentMatch is null)
            return;

        _pendingBetTeamId = _investmentTeamId;
        _pendingBetTeamName = _detail.Symbol;
        _investmentAmount = 0.1m;
        _investmentAmountError = string.Empty;
        _showSimplePopup = false;
        _showInvestmentAmountModal = true;
    }

    private void CloseInvestmentAmountModal()
    {
        if (_isSendingBet)
            return;

        _showInvestmentAmountModal = false;
        _pendingBetTeamId = 0;
        _pendingBetTeamName = string.Empty;
        _investmentAmountError = string.Empty;
    }

    private void SetInvestmentAmount(decimal amount)
    {
        _investmentAmount = amount;
        _investmentAmountError = string.Empty;
    }

    private int _investmentAmountRangeIndex
    {
        get => GetClosestQuickInvestmentAmountIndex(_investmentAmount);
        set
        {
            if (value < 0 || value >= QuickInvestmentAmounts.Length)
                return;

            _investmentAmount = QuickInvestmentAmounts[value];
            _investmentAmountError = string.Empty;
        }
    }

    private static int GetClosestQuickInvestmentAmountIndex(decimal amount)
    {
        var closestIndex = 0;
        var closestDistance = decimal.MaxValue;

        for (var i = 0; i < QuickInvestmentAmounts.Length; i++)
        {
            var distance = Math.Abs(QuickInvestmentAmounts[i] - amount);
            if (distance >= closestDistance)
                continue;

            closestDistance = distance;
            closestIndex = i;
        }

        return closestIndex;
    }

    private async Task ConfirmInvestmentAmountAsync()
    {
        if (_investmentMatch is null || _pendingBetTeamId <= 0 || string.IsNullOrWhiteSpace(_pendingBetTeamName))
        {
            _investmentAmountError = InvestmentT("chooseACoinToInvestIn");
            return;
        }

        _investmentAmount = decimal.Round(_investmentAmount, 8, MidpointRounding.ToZero);

        if (_investmentAmount <= 0)
        {
            _investmentAmountError = InvestmentT("enterAnAmountGreaterThanZero");
            return;
        }

        _showInvestmentAmountModal = false;
        await SendBetAsync(_investmentMatch, _pendingBetTeamId, _pendingBetTeamName, _investmentAmount);
    }

    private async Task SendBetAsync(MatchDto match, int teamId, string teamName, decimal amountSol)
    {
        _isSendingBet = true;
        _investmentStatusMessage = string.Empty;
        _showSimplePopup = false;

        try
        {
            await RefreshAuthenticatedUserAsync();
            var token = await SessionStorage.GetItemAsync<string>("authToken");

            if (string.IsNullOrWhiteSpace(token) || !_loggedUserId.HasValue || _loggedUserId.Value <= 0)
            {
                _investmentStatusMessage = T("investment.messages.walletRequired", _detail.DisplaySymbol);
                ShowInvestmentPopup("Conecte sua carteira", "Faça login com sua carteira Solana para continuar com o investimento.");
                return;
            }

            var investDiagnostics = await PrepareInvestmentDiagnosticsAsync(match, teamId, teamName, amountSol);
            var payload = new
            {
                userId = _loggedUserId.Value,
                teamId,
                amount = amountSol,
                onChainSignature = investDiagnostics.Signature,
                onChainAmountLamports = investDiagnostics.AmountLamports
            };

            var url = EnvironmentIsolationGuard.BuildApiUrl(Config, $"/api/match/{match.MatchId}/bet");
            using var request = new HttpRequestMessage(HttpMethod.Post, url)
            {
                Content = JsonContent.Create(payload)
            };
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            using var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                _investmentStatusMessage = T("investment.messages.success", _detail.DisplaySymbol);
                ShowInvestmentPopup("Investimento confirmado", $"Seu investimento de {FmtSolAmount(amountSol)} em {teamName} foi registrado com sucesso.");
                await ResolveInvestmentContextAsync();
            }
            else
            {
                _investmentStatusMessage = T("investment.messages.submitError", _detail.DisplaySymbol);
                ShowInvestmentPopup("Investimento não concluído", "Não foi possível registrar seu investimento agora. Tente novamente em instantes.");
            }
        }
        catch (Exception ex)
        {
            _investmentStatusMessage = GetBetPopupExceptionMessage(ex);
            ShowInvestmentPopup("Investimento não concluído", GetBetPopupExceptionMessage(ex));
        }
        finally
        {
            _isSendingBet = false;
            _pendingBetTeamId = 0;
            _pendingBetTeamName = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<InvestmentPreparationResult> PrepareInvestmentDiagnosticsAsync(MatchDto match, int teamId, string teamName, decimal amountSol)
    {
        var blockchainMode = Config["CriptoVersusBlockchain:Mode"] ?? "HybridContractCustody";

        _bettingModule ??= await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "./js/solanaInvestDiagnostics.js?v=20260505-rpc-config");

        var programId = string.Equals(blockchainMode, "FullOnChain", StringComparison.OrdinalIgnoreCase)
            ? Config["CriptoVersusBlockchain:FutureFullOnChainProgramId"]
            : Config["CriptoVersusBlockchain:CurrentHybridProgramId"] ?? Config["OnChainBetting:ProgramId"];

        if (!string.Equals(blockchainMode, "OffChainCustody", StringComparison.OrdinalIgnoreCase)
            && string.IsNullOrWhiteSpace(programId))
            throw new InvalidOperationException("CriptoVersusBlockchain program id nao configurado para o modo atual.");

        return await _bettingModule.InvokeAsync<InvestmentPreparationResult>(
            "prepareInvestment",
            new
            {
                programId,
                cluster = Config["CriptoVersusBlockchain:Cluster"] ?? Config["OnChainBetting:Cluster"] ?? "devnet",
                rpcUrl = Config["CriptoVersusBlockchain:RpcUrl"],
                matchId = match.MatchId,
                teamId,
                teamName,
                teamAId = match.TeamAId,
                teamBId = match.TeamBId,
                bettingCloseUnix = PublicInvestmentRules.GetOnChainBettingCloseUnix(match),
                amountSol,
                mode = blockchainMode,
                custodyWalletPublicKey = Config["CriptoVersusBlockchain:CustodyWalletPublicKey"],
                supportsLegacyPositionInvestments = Config.GetValue<bool>("OnChainBetting:EnableLegacyPositionInvestments")
            });
    }

    private void ShowInvestmentPopup(string title, string message)
    {
        _simplePopupTitle = title;
        _simplePopupMessage = message;
        _showSimplePopup = true;
    }

    private void CloseSimplePopup()
    {
        _showSimplePopup = false;
    }

    private string GetBetPopupExceptionMessage(Exception ex)
    {
        if (ex.ToString().Contains("ONCHAIN_MATCH_NOT_INITIALIZED", StringComparison.OrdinalIgnoreCase))
            return InvestmentT("theMatchHasNotBeenCreatedOnChainOnDevnetYetPleaseTryAgainShortly");

        if (ex.ToString().Contains("TeamId invalido para posicao on-chain.", StringComparison.OrdinalIgnoreCase))
            return InvestmentT("itWasNotPossibleToPrepareThisCoinSOnChainPositionRightNowPleaseTryAgainShortly");

        return InvestmentT("itWasNotPossibleToCompleteTheInvestmentRightNowPleaseTryAgainShortly");
    }

    private static string FmtSolAmount(decimal value)
        => $"{value:0.########} SOL";

    private string FormatMomentum(string? momentum)
        => string.IsNullOrWhiteSpace(momentum) ? T("momentum.volatile") : T($"momentum.{momentum.Trim().ToLowerInvariant()}");

    private string FormatStatus(string? status)
        => string.IsNullOrWhiteSpace(status)
            ? T("states.noData")
            : status.Trim().ToLowerInvariant() switch
            {
                "completed" => T("status.completed"),
                "ongoing" => T("status.ongoing"),
                "pending" => T("status.pending"),
                "cancelled" => T("status.cancelled"),
                _ => status
            };

    private string GetStatusBadgeClass(string? status)
    {
        var suffix = status?.Trim().ToLowerInvariant() switch
        {
            "completed" => "is-finished",
            "ongoing" => "is-live",
            "pending" => "is-pending",
            "cancelled" => "is-cancelled",
            _ => "is-neutral"
        };

        return $"team-detail-status-badge {suffix}";
    }

    private static string CleanAssetSymbol(string? symbol)
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return "-";

        var normalized = new string(symbol.Trim().ToUpperInvariant().Where(char.IsLetterOrDigit).ToArray());
        foreach (var suffix in VisualSuffixes)
        {
            if (normalized.Length > suffix.Length + 1 && normalized.EndsWith(suffix, StringComparison.Ordinal))
                return normalized[..^suffix.Length];
        }

        return normalized;
    }

    private static string BuildAssetSlug(string? symbol)
        => new string((symbol ?? string.Empty).Trim().ToLowerInvariant().Where(char.IsLetterOrDigit).ToArray());

    private static string GetAssetMonogram(string? symbol)
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return "?";

        var normalized = symbol.Trim().ToUpperInvariant();
        return normalized.Length >= 2 ? normalized[..2] : normalized;
    }

    private static string DisplayNumber(int value) => value.ToString("N0", CultureInfo.InvariantCulture);
    private static string FormatPercent(decimal value) => $"{value:0.##}%";
    private static string FormatDecimal(decimal value) => value.ToString("0.##", CultureInfo.InvariantCulture);
    private static string DisplayDate(DateTime? value) => value.HasValue ? EnsureUtc(value.Value).ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) : "-";
    private static string DisplayDateTime(DateTime? value) => value.HasValue ? EnsureUtc(value.Value).ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture) : "-";
    private string BuildAbsolute(string path) => new Uri(new Uri(Nav.BaseUri), path).AbsoluteUri;
    private string T(string key, params object?[] args) => L.T($"statsTeamDetail.{key}", CurrentCulture, args);
    private string InvestmentT(string key, params object?[] args) => L.T($"matchDetail.{key}", CurrentCulture, args);
    private static DateTime EnsureUtc(DateTime value) => value.Kind switch { DateTimeKind.Utc => value, DateTimeKind.Local => value.ToUniversalTime(), _ => DateTime.SpecifyKind(value, DateTimeKind.Utc) };
    private static readonly string[] VisualSuffixes = ["USDT", "USDC", "BUSD", "FDUSD", "BTC", "ETH"];

    private sealed class InvestmentPreparationResult
    {
        public string? Signature { get; set; }
        public string? Instruction { get; set; }
        public string? Result { get; set; }
        public string? ProgramId { get; set; }
        public string? UserAccountPda { get; set; }
        public string? ConfigPda { get; set; }
        public string? VaultPda { get; set; }
        public string? PositionPda { get; set; }
        public bool UserAccountExists { get; set; }
        public bool PositionExists { get; set; }
        public string AmountLamports { get; set; } = "";
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("criptoVersusStatsCharts.dispose", ActivityChartId);
        }
        catch
        {
        }
    }
}

