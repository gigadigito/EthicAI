    private string FormatStreak(string? streak)

    {

        if (string.IsNullOrWhiteSpace(streak) || streak!.Length < 2)

            return T("states.noData");



        var type = streak[..1].ToUpperInvariant();

        var count = streak[1..];



        return type switch

        {

            "W" => T("hero.streakWinValue", count),

            "L" => T("hero.streakLossValue", count),

            "D" => T("hero.streakDrawValue", count),

            _ => streak

        };

    }



    private string FormatStatus(string? status)

        => string.IsNullOrWhiteSpace(status)

            ? T("states.noData")

            : status.Trim().ToLowerInvariant() switch

            {

                "completed" => T("status.completed"),

                "ongoing" => T("status.ongoing"),

                "pending" => T("status.pending"),

                "cancelled" => T("status.cancelled"),

                _ => status

            };



