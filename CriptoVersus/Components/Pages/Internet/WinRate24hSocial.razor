@layout BlankLayout
@page "/social/win-rate-24h"
@page "/{Culture}/social/win-rate-24h"
@using System.Globalization
@using System.Text.Json
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersusApiClient Api
@inject AppCultureService AppCulture
@inject LocalizationService L
@inject RouteLocalizationService RouteLocalization
@inject IHttpContextAccessor HttpContextAccessor
@inject IConfiguration Config
@inject ILogger<WinRate24hSocial> Logger
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))
@implements IAsyncDisposable

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <meta name="robots" content="noindex,nofollow,noarchive" />
    <meta name="description" content="@SeoDescription" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="en-US" href="@EnglishUrl" />
    <link rel="alternate" hreflang="pt-BR" href="@PortugueseUrl" />
    <link rel="alternate" hreflang="zh-CN" href="@ChineseUrl" />
    <link rel="alternate" hreflang="x-default" href="@EnglishUrl" />
    <meta property="og:title" content="@PageTitleText" />
    <meta property="og:description" content="@SeoDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="@AppCulture.ToOgLocale(ResolvedCulture)" />
    <meta property="og:locale:alternate" content="@AppCulture.GetAlternateOgLocale(ResolvedCulture)" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@PageTitleText" />
    <meta name="twitter:description" content="@SeoDescription" />
    <script type="application/ld+json">@((MarkupString)StructuredDataMarkup)</script>
</HeadContent>

<main id="win-rate-24h-social-card"
      class="win-rate-24h-social"
      data-generated-at-utc="@GeneratedAtUtcAttr"
      data-can-post="@CanPostAttr"
      data-asset-count="@AssetCountAttr"
      data-social-ready="@SocialReadyAttr">
    <div class="win-rate-24h-social__backdrop" aria-hidden="true"></div>

    <section class="win-rate-24h-social__card" aria-label="@PageTitleText">
        <header class="win-rate-24h-social__header">
            <div class="win-rate-24h-social__brand">
                <span class="win-rate-24h-social__brand-mark">CriptoVersus</span>
                <span class="win-rate-24h-social__period">@T("hero.period")</span>
            </div>

            <div class="win-rate-24h-social__title-block">
                <h1>@PageTitleText</h1>
                <p>@SeoDescription</p>
            </div>

            <div class="win-rate-24h-social__meta">
                <span>@GeneratedAtLabel</span>
                <span>@T("hero.utcNote")</span>
            </div>
        </header>

        @if (_loading)
        {
            <section class="win-rate-24h-social__state" aria-live="polite">
                <strong>@T("states.loadingTitle")</strong>
                <p>@T("states.loadingBody")</p>
            </section>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <section class="win-rate-24h-social__state win-rate-24h-social__state--error" role="alert">
                <strong>@T("states.errorTitle")</strong>
                <p>@_error</p>
            </section>
        }
        else if (_response is null || _response.Assets.Count == 0)
        {
            <section class="win-rate-24h-social__state win-rate-24h-social__state--empty">
                <strong>@T("states.emptyTitle")</strong>
                <p>@(string.IsNullOrWhiteSpace(_response?.SkipReason) ? T("states.emptyBody") : _response!.SkipReason)</p>
            </section>
        }
        else
        {
            <section class="win-rate-24h-social__chart-card" aria-label="@T("chart.ariaLabel")">
                <div class="win-rate-24h-social__scale" aria-hidden="true">
                    <div></div>
                    <div></div>
                    <div class="win-rate-24h-social__scale-track">
                        <span>0%</span>
                        <span>20%</span>
                        <span>40%</span>
                        <span>60%</span>
                        <span>80%</span>
                        <span>100%</span>
                    </div>
                    <div></div>
                </div>

                <div class="win-rate-24h-social__rows">
                    @foreach (var item in _response.Assets)
                    {
                        <article class="win-rate-24h-social__row">
                            <div class="win-rate-24h-social__rank">@item.Rank</div>
                            <div class="win-rate-24h-social__symbol">
                                <strong>@item.DisplaySymbol</strong>
                                <span>@T("chart.decisions", item.Decisions)</span>
                            </div>
                            <div class="win-rate-24h-social__bar-track" aria-hidden="true">
                                <div class="win-rate-24h-social__bar-fill"
                                     style="@GetBarStyle(item.WinRate)"></div>
                            </div>
                            <div class="win-rate-24h-social__metric">
                                <strong>@FormatPercent(item.WinRate)</strong>
                                <span>@T("chart.matches", item.TotalMatches)</span>
                            </div>
                        </article>
                    }
                </div>
            </section>

            <footer class="win-rate-24h-social__footer">
                <span>@T("footer.disclaimer")</span>
                <span>@T("footer.generatedAt", GeneratedAtFooterValue)</span>
            </footer>
        }
    </section>
</main>
<style>
    .win-rate-24h-social {
        --brand-crypto: #ff9100;
        --brand-versus: #18d8d2;
        --brand-crypto-rgb: 255, 145, 0;
        --brand-versus-rgb: 24, 216, 210;
        --bg-0: #03060c;
        --bg-1: #07101a;
        --panel: rgba(8, 13, 20, 0.96);
        --panel-strong: rgba(11, 17, 27, 0.99);
        --line: rgba(255, 255, 255, 0.08);
        --line-soft: rgba(255, 255, 255, 0.045);
        --text-main: #f5fbff;
        --text-muted: #b1c0d1;
        --text-soft: #7f93a8;
        position: relative;
        min-height: 100vh;
        overflow: hidden;
        display: grid;
        place-items: center;
        padding: clamp(12px, 2vw, 28px);
        color: var(--text-main);
        background: radial-gradient(circle at 10% 10%, rgba(var(--brand-crypto-rgb), 0.18), transparent 24%), radial-gradient(circle at 90% 12%, rgba(var(--brand-versus-rgb), 0.18), transparent 26%), radial-gradient(circle at 50% 112%, rgba(255, 255, 255, 0.05), transparent 30%), linear-gradient(180deg, var(--bg-0) 0%, var(--bg-1) 54%, #020409 100%);
    }

    .win-rate-24h-social__backdrop {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
        background-size: 34px 34px;
        mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.55), transparent 88%);
    }

    .win-rate-24h-social__card {
        position: relative;
        z-index: 1;
        width: min(100%, 1200px);
        aspect-ratio: 1200 / 675;
        display: grid;
        grid-template-rows: auto minmax(0, 1fr) auto;
        gap: clamp(14px, 1.4vw, 18px);
        padding: clamp(18px, 2vw, 28px);
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.09);
        border-radius: 30px;
        background: radial-gradient(circle at top left, rgba(var(--brand-crypto-rgb), 0.11), transparent 20%), radial-gradient(circle at top right, rgba(var(--brand-versus-rgb), 0.11), transparent 20%), linear-gradient(180deg, rgba(8, 12, 18, 0.98), rgba(5, 8, 13, 0.99));
        box-shadow: 0 36px 96px rgba(0, 0, 0, 0.52), inset 0 1px 0 rgba(255, 255, 255, 0.04);
    }

        .win-rate-24h-social__card::after {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            border-radius: inherit;
            background: linear-gradient(115deg, rgba(255, 255, 255, 0.025), transparent 25%, transparent 75%, rgba(255, 255, 255, 0.015));
        }

    .win-rate-24h-social__header {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: auto minmax(0, 1fr) auto;
        gap: 20px;
        align-items: center;
        min-width: 0;
    }

    .win-rate-24h-social__brand {
        display: grid;
        gap: 8px;
        align-content: center;
    }

    .win-rate-24h-social__brand-mark {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: fit-content;
        padding: 8px 13px;
        border-radius: 999px;
        border: 1px solid rgba(var(--brand-versus-rgb), 0.36);
        background: rgba(6, 24, 28, 0.88);
        color: var(--brand-versus);
        font-size: 11px;
        font-weight: 900;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        box-shadow: inset 0 0 18px rgba(var(--brand-versus-rgb), 0.05);
    }

    .win-rate-24h-social__period {
        color: var(--text-muted);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    .win-rate-24h-social__title-block {
        min-width: 0;
        display: grid;
        gap: 6px;
        text-align: center;
        justify-items: center;
    }

        .win-rate-24h-social__title-block h1 {
            margin: 0;
            max-width: 100%;
            overflow: hidden;
            color: var(--text-main);
            font-size: clamp(32px, 4vw, 54px);
            font-weight: 500;
            line-height: 0.98;
            letter-spacing: -0.055em;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .win-rate-24h-social__title-block p {
            margin: 0;
            color: var(--text-muted);
            font-size: 15px;
            line-height: 1.4;
        }

    .win-rate-24h-social__meta {
        display: grid;
        justify-items: end;
        align-content: center;
        gap: 4px;
        color: #e7eef8;
        font-size: 12px;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-align: right;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .win-rate-24h-social__state,
    .win-rate-24h-social__chart-card {
        position: relative;
        z-index: 1;
        min-width: 0;
    }

    .win-rate-24h-social__state {
        display: grid;
        align-content: center;
        justify-items: center;
        gap: 10px;
        padding: clamp(22px, 3vw, 34px);
        border: 1px solid var(--line);
        border-radius: 24px;
        background: rgba(6, 10, 16, 0.84);
        text-align: center;
    }

        .win-rate-24h-social__state strong {
            font-size: 20px;
            font-weight: 900;
            letter-spacing: 0.04em;
        }

        .win-rate-24h-social__state p {
            margin: 0;
            max-width: 46rem;
            color: var(--text-muted);
            line-height: 1.55;
        }

    .win-rate-24h-social__state--error {
        border-color: rgba(255, 145, 0, 0.22);
    }

    .win-rate-24h-social__state--empty {
        border-color: rgba(24, 216, 210, 0.18);
    }

    .win-rate-24h-social__chart-card {
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
        gap: 14px;
        min-height: 0;
    }

    .win-rate-24h-social__scale {
        display: grid;
        grid-template-columns: 54px minmax(160px, 220px) minmax(0, 1fr) 120px;
        align-items: center;
        gap: 14px;
        color: var(--text-soft);
        font-size: 11px;
        font-weight: 900;
        letter-spacing: 0.14em;
        text-transform: uppercase;
    }

    .win-rate-24h-social__scale-track {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        min-width: 0;
    }

    .win-rate-24h-social__rows {
        min-height: 0;
        display: grid;
        grid-template-rows: repeat(10, minmax(0, 1fr));
        gap: 10px;
    }

    .win-rate-24h-social__row {
        position: relative;
        display: grid;
        grid-template-columns: 54px minmax(160px, 220px) minmax(0, 1fr) 120px;
        align-items: center;
        gap: 14px;
        min-width: 0;
        min-height: 0;
        padding: 10px 14px;
        overflow: hidden;
        border: 1px solid var(--line-soft);
        border-radius: 18px;
        background: linear-gradient(90deg, rgba(var(--brand-crypto-rgb), 0.055), transparent 38%, transparent 62%, rgba(var(--brand-versus-rgb), 0.055)), rgba(8, 12, 18, 0.88);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.025);
    }

        .win-rate-24h-social__row::before {
            content: "";
            position: absolute;
            inset: 0 auto 0 0;
            width: 3px;
            opacity: 0.72;
            background: linear-gradient(180deg, var(--brand-crypto), var(--brand-versus));
        }

    .win-rate-24h-social__rank {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        margin-inline: auto;
        border: 1px solid rgba(255, 255, 255, 0.09);
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.035);
        color: var(--text-main);
        font-weight: 900;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.03);
    }

    .win-rate-24h-social__symbol,
    .win-rate-24h-social__metric {
        min-width: 0;
        display: grid;
        gap: 4px;
    }

    .win-rate-24h-social__symbol {
        justify-items: start;
    }

    .win-rate-24h-social__metric {
        justify-items: end;
        text-align: right;
    }

        .win-rate-24h-social__symbol strong,
        .win-rate-24h-social__metric strong {
            min-width: 0;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

    .win-rate-24h-social__symbol strong {
        color: var(--brand-crypto);
        font-size: clamp(17px, 1.5vw, 22px);
        font-weight: 900;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .win-rate-24h-social__symbol span,
    .win-rate-24h-social__metric span {
        color: var(--text-soft);
        font-size: 10px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .win-rate-24h-social__metric strong {
        color: var(--text-main);
        font-size: clamp(18px, 1.6vw, 24px);
        font-weight: 900;
        letter-spacing: 0.04em;
    }

    .win-rate-24h-social__bar-track {
        position: relative;
        height: 14px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.05);
    }

    .win-rate-24h-social__bar-fill {
        width: var(--win-rate, 0%);
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, var(--brand-crypto) 0%, #ffbf73 18%, var(--brand-versus) 100%);
        box-shadow: 0 0 18px rgba(var(--brand-versus-rgb), 0.16);
    }

    .win-rate-24h-social__footer {
        position: relative;
        z-index: 1;
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 18px;
        color: var(--text-muted);
        font-size: 12px;
        line-height: 1.45;
    }

        .win-rate-24h-social__footer span:last-child {
            text-align: right;
            white-space: nowrap;
        }

    @@media (max-width: 980px) {
        .win-rate-24h-social__card

    {
        aspect-ratio: auto;
        min-height: min(calc(100vh - 24px), 675px);
    }

    .win-rate-24h-social__header {
        grid-template-columns: 150px minmax(0, 1fr);
    }

    .win-rate-24h-social__meta {
        grid-column: 1 / -1;
        justify-items: start;
        text-align: left;
    }

    .win-rate-24h-social__scale,
    .win-rate-24h-social__row {
        grid-template-columns: 48px minmax(140px, 190px) minmax(0, 1fr) 108px;
    }

    }

    @@media (max-width: 680px) {
        .win-rate-24h-social

    {
        padding: 8px;
    }

    .win-rate-24h-social__card {
        padding: 16px;
        border-radius: 22px;
    }

    .win-rate-24h-social__header {
        grid-template-columns: 1fr;
        text-align: left;
    }

    .win-rate-24h-social__title-block {
        justify-items: start;
        text-align: left;
    }

        .win-rate-24h-social__title-block h1 {
            white-space: normal;
        }

    .win-rate-24h-social__meta {
        justify-items: start;
    }

    .win-rate-24h-social__scale,
    .win-rate-24h-social__row {
        grid-template-columns: 34px minmax(0, 1fr) 94px;
        gap: 10px;
    }

    .win-rate-24h-social__scale {
        display: none;
    }

    .win-rate-24h-social__symbol {
        grid-column: 2 / 3;
    }

    .win-rate-24h-social__metric {
        grid-column: 3 / 4;
    }

    .win-rate-24h-social__bar-track {
        grid-column: 1 / -1;
        order: 4;
    }

    .win-rate-24h-social__footer {
        flex-direction: column;
        align-items: flex-start;
    }

        .win-rate-24h-social__footer span:last-child {
            white-space: normal;
            text-align: left;
        }

    }

    @@media (prefers-reduced-motion: reduce) {
        .win-rate-24h-social__bar-fill

    {
        transition: none !important;
    }

    }
</style>
@code {
    [Parameter] public string? Culture { get; set; }

    private CancellationTokenSource? _loadCts;
    private bool _loading = true;
    private string? _error;
    private string _loadKey = string.Empty;
    private string _resolvedCulture = AppCultureService.DefaultRouteCulture;
    private SocialWinRate24hDto? _response;

    private string ResolvedCulture => _resolvedCulture;
    private string PageTitleText => T("seo.title");
    private string SeoDescription => T("seo.description");
    private string CanonicalUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildWinRate24hSocialPath(ResolvedCulture));
    private string EnglishUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildWinRate24hSocialPath(AppCultureService.DefaultRouteCulture));
    private string PortugueseUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildWinRate24hSocialPath(AppCultureService.SecondaryRouteCulture));
    private string ChineseUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildWinRate24hSocialPath(AppCultureService.TertiaryRouteCulture));
    private string StructuredDataMarkup => JsonSerializer.Serialize(new Dictionary<string, object?>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "WebPage",
        ["name"] = PageTitleText,
        ["description"] = SeoDescription,
        ["url"] = CanonicalUrl,
        ["inLanguage"] = AppCulture.ToHrefLang(ResolvedCulture)
    });
    private string GeneratedAtLabel => _response is null
        ? T("hero.generatedAtPending")
        : T("hero.generatedAt", _response.GeneratedAtUtc.ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture));
    private string GeneratedAtFooterValue => _response is null
        ? string.Empty
        : _response.GeneratedAtUtc.ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture);
    private string? GeneratedAtUtcAttr => _response is null ? null : _response.GeneratedAtUtc.ToString("o", CultureInfo.InvariantCulture);
    private string? SocialReadyAttr => IsSocialReady ? "true" : null;
    private string? CanPostAttr => _response is null ? null : _response.CanPost.ToString().ToLowerInvariant();
    private string? AssetCountAttr => _response is null ? null : _response.Assets.Count.ToString(CultureInfo.InvariantCulture);
    private bool IsSocialReady => !_loading && _error is null && _response is not null && _response.CanPost && _response.Assets.Count > 0;

    protected override async Task OnParametersSetAsync()
    {
        _resolvedCulture = !string.IsNullOrWhiteSpace(Culture)
            ? AppCulture.NormalizeRouteCulture(Culture)
            : AppCulture.DetectPreferredRouteCulture(HttpContextAccessor.HttpContext);

        var nextLoadKey = _resolvedCulture;
        if (string.Equals(nextLoadKey, _loadKey, StringComparison.Ordinal))
            return;

        _loadKey = nextLoadKey;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        _response = null;

        _loadCts?.Cancel();
        _loadCts?.Dispose();
        _loadCts = new CancellationTokenSource();

        try
        {
            _loadCts.CancelAfter(TimeSpan.FromSeconds(20));
            _response = await Api.GetSocialWinRate24hAsync(_loadCts.Token);

            if (_response is null)
                throw new InvalidOperationException(T("states.errorBody"));
        }
        catch (OperationCanceledException) when (_loadCts.IsCancellationRequested)
        {
            _error = T("states.errorBody");
        }
        catch (Exception ex)
        {
            _error = T("states.errorBody");
            Logger.LogWarning(ex, "Win-rate 24h social page failed to load. Culture={Culture}", _resolvedCulture);
        }
        finally
        {
            _loading = false;
        }
    }

    private static string FormatPercent(decimal value)
        => $"{value.ToString("0.0", CultureInfo.CurrentCulture)}%";

    private string GetBarStyle(decimal winRate)
    {
        var clamped = Math.Clamp(winRate, 0m, 100m).ToString("0.0", CultureInfo.InvariantCulture);
        return $"--win-rate:{clamped}%";
    }

    private string T(string key, params object?[] args)
        => L.T($"social.winRate24h.{key}", ResolvedCulture, args);

    public async ValueTask DisposeAsync()
    {
        if (_loadCts is not null)
        {
            await _loadCts.CancelAsync();
            _loadCts.Dispose();
            _loadCts = null;
        }
    }
}


