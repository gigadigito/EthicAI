@page "/tv/match/{MatchId:int}/{Slug}"
@page "/{Culture}/tv/match/{MatchId:int}/{Slug}"
@using System.Diagnostics
@using System.Text.Json
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersusApiClient Api
@inject HotMatchService HotMatches
@inject AppCultureService AppCulture
@inject IConfiguration Config
@inject IHttpContextAccessor HttpContextAccessor
@inject IJSRuntime JS
@inject LocalizationService L
@inject NavigationManager Nav
@inject RouteLocalizationService RouteLocalization
@inject MatchSlugHelper MatchSlugHelper
@inject ILogger<TvMatchPage> Logger
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <meta name="description" content="@MetaDescription" />
    <meta name="keywords" content="@MetaKeywords" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="en-US" href="@EnglishUrl" />
    <link rel="alternate" hreflang="pt-BR" href="@PortugueseUrl" />
    <link rel="alternate" hreflang="x-default" href="@EnglishUrl" />
    <meta property="og:title" content="@PageTitleText" />
    <meta property="og:description" content="@MetaDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="@SocialImageUrl" />
    <meta property="og:image:alt" content="@PageTitleText" />
    <meta property="og:locale" content="@AppCulture.ToOgLocale(_culture)" />
    <meta property="og:locale:alternate" content="@AppCulture.GetAlternateOgLocale(_culture)" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@PageTitleText" />
    <meta name="twitter:description" content="@MetaDescription" />
    <meta name="twitter:image" content="@SocialImageUrl" />
    <meta name="twitter:image:alt" content="@PageTitleText" />
    <script type="application/ld+json">@StructuredDataMarkup</script>
</HeadContent>

@if (_loadState == TvMatchPageLoadState.Loading)
{
    <section class="tv-match-page-state-shell" aria-live="polite" aria-busy="true">
        <div class="tv-match-page-state-card">
            <div class="tv-match-page-state-card__eyebrow">TV MATCH</div>
            <div class="tv-match-page-state-card__spinner" aria-hidden="true"></div>
            <h2>@LocalizedTvMatchText("loading")</h2>
            <p>@LocalizedTvMatchText("loadingBody")</p>
        </div>
    </section>
}
else if (_loadState != TvMatchPageLoadState.Loaded)
{
    <section class="tv-match-page-state-shell" aria-live="polite">
        <div class="tv-match-page-state-card tv-match-page-state-card--error">
            <div class="tv-match-page-state-card__eyebrow">TV MATCH</div>
            <h2>@LoadStateTitle</h2>
            <p>@LoadStateBody</p>
            <button type="button"
                    class="tv-match-page-state-card__retry"
                    @onclick="RetryLoadAsync"
                    disabled="@(_loadState == TvMatchPageLoadState.Loading)">
                @LocalizedTvMatchText("retry")
            </button>
        </div>
    </section>
}
else if (_match is not null)
{
    <TvStage Culture="@_culture"
             IsBroadcastMode="false"
             HotMatch="@_hotMatch"
             Match="@_match"
             Stats="@_stats"
             Snapshot="@_snapshot"
             TopCoinsLoading="@_topCoinsLoading"
             TopCoinsError="@_topCoinsError"
             LatestBattlesLoading="@_latestBattlesLoading"
             LatestBattlesError="@_latestBattlesError"
             MarketPulseLoading="@_marketPulseLoading"
             MarketPulseError="@_marketPulseError" />
}
else
{
    <section class="tv-match-page-state-shell" aria-live="polite">
        <div class="tv-match-page-state-card tv-match-page-state-card--error">
            <div class="tv-match-page-state-card__eyebrow">TV MATCH</div>
            <h2>@LocalizedTvMatchText("error")</h2>
            <p>@LocalizedTvMatchText("errorBody")</p>
            <button type="button"
                    class="tv-match-page-state-card__retry"
                    @onclick="RetryLoadAsync">
                @LocalizedTvMatchText("retry")
            </button>
        </div>
    </section>
}

<style>
    .tv-match-page-state-shell {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 2rem;
        background:
            radial-gradient(circle at top left, rgba(83, 200, 255, 0.12), transparent 24%),
            radial-gradient(circle at top right, rgba(76, 243, 141, 0.14), transparent 22%),
            linear-gradient(180deg, #02060f, #050914 52%, #040812);
    }

    .tv-match-page-state-card {
        width: min(100%, 520px);
        padding: 1.5rem;
        border-radius: 28px;
        border: 1px solid rgba(127, 246, 223, 0.18);
        background:
            radial-gradient(circle at top left, rgba(76, 243, 141, 0.12), transparent 28%),
            radial-gradient(circle at top right, rgba(96, 165, 250, 0.10), transparent 26%),
            linear-gradient(180deg, rgba(10, 13, 21, 0.98), rgba(7, 9, 15, 0.99));
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.42);
        color: #eef5ff;
        text-align: center;
    }

    .tv-match-page-state-card--error {
        border-color: rgba(255, 118, 160, 0.22);
    }

    .tv-match-page-state-card__eyebrow {
        display: block;
        margin-bottom: 0.75rem;
        color: #7ff6df;
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }

    .tv-match-page-state-card h2 {
        margin: 0 0 0.55rem;
        font-size: clamp(1.4rem, 2vw, 2rem);
        line-height: 1.1;
    }

    .tv-match-page-state-card p {
        margin: 0;
        color: #b9c7da;
        line-height: 1.6;
    }

    .tv-match-page-state-card__spinner {
        width: 52px;
        height: 52px;
        margin: 0 auto 1rem;
        border-radius: 999px;
        border: 3px solid rgba(255, 255, 255, 0.12);
        border-top-color: #7ff6df;
        animation: tvMatchPageSpin 0.9s linear infinite;
    }

    .tv-match-page-state-card__retry {
        margin-top: 1.15rem;
        min-height: 2.9rem;
        padding: 0.78rem 1.1rem;
        border-radius: 16px;
        border: 1px solid rgba(127, 246, 223, 0.35);
        background: linear-gradient(90deg, #4cf38d, #7ff6df);
        color: #03150f;
        font-weight: 800;
        letter-spacing: 0.03em;
    }

    .tv-match-page-state-card__retry:disabled {
        opacity: 0.7;
        cursor: wait;
    }

    @@keyframes tvMatchPageSpin {
        to {
            transform: rotate(360deg);
        }
    }

    @@media (max-width: 640px) {
        .tv-match-page-state-shell {
            padding: 1rem;
        }

        .tv-match-page-state-card {
            padding: 1.2rem;
            border-radius: 22px;
        }

        .tv-match-page-state-card__retry {
            width: 100%;
        }
    }
</style>

@code {
    private const int RefreshIntervalSeconds = 15;
    private static readonly TimeSpan InitialLoadTimeout = TimeSpan.FromSeconds(5);

    [Parameter] public string? Culture { get; set; }
    [Parameter] public int MatchId { get; set; }
    [Parameter] public string? Slug { get; set; }

    private string _culture = AppCultureService.DefaultRouteCulture;
    private MatchDto? _match;
    private TvHotMatchDto? _hotMatch;
    private StatsOverviewDto? _stats;
    private DashboardSnapshotDto? _snapshot;
    private IJSObjectReference? _tvModule;
    private CancellationTokenSource? _refreshCts;
    private Task? _refreshLoopTask;
    private int _refreshInProgress;
    private TvMatchPageLoadState _loadState = TvMatchPageLoadState.Loading;
    private bool _topCoinsLoading = true;
    private bool _latestBattlesLoading = true;
    private bool _marketPulseLoading = true;
    private string? _topCoinsError;
    private string? _latestBattlesError;
    private string? _marketPulseError;
    private string LoadStateTitle => _loadState switch
    {
        TvMatchPageLoadState.NotFound => LocalizedTvMatchText("notFound"),
        TvMatchPageLoadState.Unavailable => LocalizedTvMatchText("unavailable"),
        TvMatchPageLoadState.Error => LocalizedTvMatchText("error"),
        _ => LocalizedTvMatchText("loading")
    };
    private string LoadStateBody => _loadState switch
    {
        TvMatchPageLoadState.NotFound => LocalizedTvMatchText("notFoundBody"),
        TvMatchPageLoadState.Unavailable => LocalizedTvMatchText("unavailableBody"),
        TvMatchPageLoadState.Error => LocalizedTvMatchText("errorBody"),
        _ => LocalizedTvMatchText("loadingBody")
    };
    private string PageTitleText
        => _match is null
            ? L.T("tv.seo.title", _culture)
            : L.T("tv.seo.matchTitle", _culture, _match.TeamA, _match.TeamB);
    private string MetaDescription
        => _match is null
            ? L.T("tv.seo.matchDescriptionFallback", _culture)
            : L.T("tv.seo.matchDescription", _culture, _match.TeamA, _match.TeamB);
    private string CanonicalUrl => BuildAbsolute(RouteLocalization.BuildTvMatchPath(_culture, MatchId, ResolvedSlug));
    private string EnglishUrl => BuildAbsolute(RouteLocalization.BuildTvMatchPath(AppCultureService.DefaultRouteCulture, MatchId, ResolvedSlug));
    private string PortugueseUrl => BuildAbsolute(RouteLocalization.BuildTvMatchPath(AppCultureService.SecondaryRouteCulture, MatchId, ResolvedSlug));
    private string MetaKeywords => _match is null
        ? $"{SeoDefaults.GlobalKeywords}, CriptoVersus TV match, #CriptoVersus TV, crypto battle stream"
        : $"{SeoDefaults.GlobalKeywords}, CriptoVersus TV match, #CriptoVersus TV, {_match.TeamA} vs {_match.TeamB}, crypto match stream";
    private string SocialImageUrl => SeoDefaults.BuildAbsoluteUrl(Config, Nav, SeoDefaults.DefaultSocialImagePath);
    private string StructuredDataMarkup
        => JsonSerializer.Serialize(new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "WebPage",
            ["name"] = PageTitleText,
            ["description"] = MetaDescription,
            ["url"] = CanonicalUrl,
            ["image"] = SocialImageUrl,
            ["keywords"] = MetaKeywords,
            ["inLanguage"] = _culture
        });
    private string ResolvedSlug => !string.IsNullOrWhiteSpace(_match?.TeamA) && !string.IsNullOrWhiteSpace(_match?.TeamB)
        ? MatchSlugHelper.BuildSlug(_match.TeamA, _match.TeamB)
        : Slug?.Trim().ToLowerInvariant() ?? "match";

    protected override void OnParametersSet()
    {
        _culture = !string.IsNullOrWhiteSpace(Culture)
            ? AppCulture.NormalizeRouteCulture(Culture)
            : AppCulture.DetectPreferredRouteCulture(HttpContextAccessor.HttpContext);
    }

    protected override async Task OnInitializedAsync()
    {
        var sw = Stopwatch.StartNew();
        Logger.LogInformation("[TV_MATCH_LOAD] Start matchId={MatchId} slug={Slug} culture={Culture}", MatchId, Slug, Culture);
        try
        {
            using var initialLoadCts = new CancellationTokenSource(InitialLoadTimeout);
            await RefreshAsync(initialLoadCts.Token);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "TvMatchPage initial load timed out or failed during prerender. Rendering fallback state. MatchId={MatchId}", MatchId);
        }
        finally
        {
            Logger.LogInformation("[TV_MATCH_LOAD] OnInitializedAsync matchId={MatchId} elapsedMs={ElapsedMs}", MatchId, sw.ElapsedMilliseconds);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var sw = Stopwatch.StartNew();
        try
        {
            _tvModule = await JS.InvokeAsync<IJSObjectReference>("import", "/js/tvMode.js?v=20260606-direct-audio-1");
            Logger.LogInformation("[TV_MATCH_LOAD] JS import tvMode matchId={MatchId} elapsedMs={ElapsedMs}", MatchId, sw.ElapsedMilliseconds);
            await LogAsync("loaded");
        }
        catch (Exception ex) when (ex is JSException or InvalidOperationException)
        {
            Logger.LogWarning(ex, "TvMatchPage JS module import failed. Match data load remains available without TV JS bootstrap. MatchId={MatchId}", MatchId);
        }

        _refreshCts = new CancellationTokenSource();
        _refreshLoopTask = RunRefreshLoopAsync(_refreshCts.Token);
        Logger.LogInformation("TvMatchPage refresh loop started. MatchId={MatchId} IntervalSeconds={IntervalSeconds}", MatchId, RefreshIntervalSeconds);
    }

    private async Task RunRefreshLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(RefreshIntervalSeconds));

        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                await RefreshMatchOnlyAsync(ct);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }
    private async Task RefreshMatchOnlyAsync(CancellationToken ct)
    {
        if (_match is null)
            return;

        var sw = Stopwatch.StartNew();

        try
        {
            Logger.LogInformation(
                "[TV_MATCH_REFRESH] Match refresh start matchId={MatchId}",
                MatchId);

            var updatedMatch = await MeasureLoadCallAsync(
                $"Api.GetMatchByIdAsync refresh matchId={MatchId}",
                () => Api.GetMatchByIdAsync(MatchId, includeParticipants: false, ct));

            if (updatedMatch is null)
            {
                Logger.LogWarning(
                    "[TV_MATCH_REFRESH] Match became null matchId={MatchId}",
                    MatchId);

                return;
            }

            _match = updatedMatch;

            await InvokeAsync(StateHasChanged);

            Logger.LogInformation(
                "[TV_MATCH_REFRESH] Match refresh completed matchId={MatchId} elapsedMs={ElapsedMs}",
                MatchId,
                sw.ElapsedMilliseconds);
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            Logger.LogWarning(
                ex,
                "[TV_MATCH_REFRESH] Match refresh failed matchId={MatchId}",
                MatchId);
        }
    }
    private async Task RefreshAsync(CancellationToken ct)
    {
        if (Interlocked.Exchange(ref _refreshInProgress, 1) == 1)
        {
            Logger.LogInformation("TvMatchPage refresh skipped because another refresh is already running. MatchId={MatchId}", MatchId);
            return;
        }

        var startedAtUtc = DateTime.UtcNow;
        var totalSw = Stopwatch.StartNew();
        var isInitialLoad = _match is null && _loadState != TvMatchPageLoadState.Loaded;

        try
        {
            Logger.LogInformation("[TV_MATCH_LOAD] RefreshAsync start matchId={MatchId} slug={Slug} initial={Initial}", MatchId, Slug, isInitialLoad);

            if (isInitialLoad)
            {
                _loadState = TvMatchPageLoadState.Loading;
                _hotMatch = null;
                await InvokeAsync(StateHasChanged);
            }

            if (MatchId <= 0)
            {
                _loadState = TvMatchPageLoadState.NotFound;
                await InvokeAsync(StateHasChanged);
                return;
            }

            var match = await MeasureLoadCallAsync(
                $"Api.GetMatchByIdAsync matchId={MatchId} includeParticipants=false",
                () => Api.GetMatchByIdAsync(MatchId, includeParticipants: false, ct));

            if (match is null)
            {
                _loadState = TvMatchPageLoadState.NotFound;
                await InvokeAsync(StateHasChanged);
                return;
            }

            if (IsUnavailableForTv(match))
            {
                _loadState = TvMatchPageLoadState.Unavailable;
                await InvokeAsync(StateHasChanged);
                return;
            }

            var expectedPath = RouteLocalization.BuildTvMatchPath(_culture, match.MatchId, MatchSlugHelper.BuildSlug(match.TeamA, match.TeamB));
            var currentPath = "/" + Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].Trim('/');
            if (!currentPath.Equals(expectedPath, StringComparison.OrdinalIgnoreCase))
            {
                Nav.NavigateTo(expectedPath, replace: true);
                return;
            }

            _match = match;
            _loadState = TvMatchPageLoadState.Loaded;

            await InvokeAsync(StateHasChanged);

            Logger.LogInformation(
                "[TV_MATCH_LOAD] FirstRenderReady matchId={MatchId} initial={Initial} elapsedMs={ElapsedMs}",
                MatchId,
                isInitialLoad,
                totalSw.ElapsedMilliseconds);

            if (isInitialLoad)
            {
                StartSecondaryDataLoad();
            }

            Logger.LogInformation(
                "TvMatchPage refresh completed. Mode={Mode} MatchId={MatchId} HasHotMatch={HasHotMatch} AvailableMatches={AvailableMatches} DurationMs={DurationMs}",
                "fixed-match-fast-path",
                MatchId,
                _hotMatch is not null,
                _stats?.LatestMatches?.Count ?? 0,
                (DateTime.UtcNow - startedAtUtc).TotalMilliseconds);
        }
        catch (OperationCanceledException)
        {
            if (isInitialLoad)
            {
                _loadState = TvMatchPageLoadState.Error;
                _topCoinsLoading = false;
                _latestBattlesLoading = false;
                _marketPulseLoading = false;
                _topCoinsError ??= LocalizedTvMatchText("error");
                _latestBattlesError ??= LocalizedTvMatchText("error");
                _marketPulseError ??= LocalizedTvMatchText("error");
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            if (isInitialLoad)
            {
                _loadState = TvMatchPageLoadState.Error;
                _topCoinsLoading = false;
                _latestBattlesLoading = false;
                _marketPulseLoading = false;
                _topCoinsError ??= LocalizedTvMatchText("error");
                _latestBattlesError ??= LocalizedTvMatchText("error");
                _marketPulseError ??= LocalizedTvMatchText("error");
            }

            Logger.LogWarning(ex, "TvMatchPage refresh failed. MatchId={MatchId}", MatchId);
            await LogAsync("refresh error", ex.Message);
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            Logger.LogInformation("[TV_MATCH_LOAD] Total matchId={MatchId} elapsedMs={ElapsedMs}", MatchId, totalSw.ElapsedMilliseconds);
            Interlocked.Exchange(ref _refreshInProgress, 0);
        }
    }
    
    private void StartSecondaryDataLoad()
    {
        var token = _refreshCts?.Token ?? CancellationToken.None;

        _ = Task.Run(async () =>
        {
            try
            {
                await LoadSecondaryDataAsync(token);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "[TV_MATCH_LOAD] SecondaryData background task crashed. MatchId={MatchId}", MatchId);
            }
        }, token);
    }
    private async Task LoadSecondaryDataAsync(CancellationToken ct)
    {
        var sw = Stopwatch.StartNew();

        try
        {
            Logger.LogInformation("[TV_MATCH_LOAD] SecondaryData start matchId={MatchId}", MatchId);

            var hotTask = MeasureLoadCallAsync(
                "HotMatchService.GetHotMatchesAsync",
                () => HotMatches.GetHotMatchesAsync(ct));

            var statsTask = MeasureLoadCallAsync(
                "Api.GetStatsOverviewAsync",
                () => Api.GetStatsOverviewAsync(ct));

            var snapshotTask = MeasureLoadCallAsync(
                "Api.GetDashboardSnapshotAsync",
                () => Api.GetDashboardSnapshotAsync(ct));

            await Task.WhenAll(hotTask, statsTask, snapshotTask);

            _stats = statsTask.Result;
            _snapshot = snapshotTask.Result;

            var hotMatch = hotTask.Result?.FirstOrDefault(x => x.MatchId == MatchId);

            _hotMatch = hotMatch is not null
                ? HotMatches.ToTvHotMatch(hotMatch, _culture, RouteLocalization)
                : null;

            _topCoinsLoading = false;
            _latestBattlesLoading = false;
            _marketPulseLoading = false;
            _topCoinsError = null;
            _latestBattlesError = null;
            _marketPulseError = null;

            if (hotMatch is not null)
            {
                await LogAsync("[HOT_MATCH] refreshed", new { hotMatch.MatchId, hotMatch.HotScore, hotMatch.PriorityScore });
            }

            await InvokeAsync(StateHasChanged);

            Logger.LogInformation(
                "[TV_MATCH_LOAD] SecondaryData loaded matchId={MatchId} hasHotMatch={HasHotMatch} elapsedMs={ElapsedMs}",
                MatchId,
                _hotMatch is not null,
                sw.ElapsedMilliseconds);
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            _topCoinsLoading = false;
            _latestBattlesLoading = false;
            _marketPulseLoading = false;
            _topCoinsError ??= LocalizedTvMatchText("error");
            _latestBattlesError ??= LocalizedTvMatchText("error");
            _marketPulseError ??= LocalizedTvMatchText("error");

            Logger.LogWarning(ex, "[TV_MATCH_LOAD] SecondaryData failed. MatchId={MatchId}", MatchId);
            await InvokeAsync(StateHasChanged);
        }
    }
    private async Task<T> MeasureLoadCallAsync<T>(string name, Func<Task<T>?> action)
    {
        var sw = Stopwatch.StartNew();
        try
        {
            var task = action() ?? throw new InvalidOperationException($"TV match load call returned null task: {name}");
            var result = await task;
            Logger.LogInformation("[TV_MATCH_LOAD] {Call} elapsedMs={ElapsedMs}", name, sw.ElapsedMilliseconds);
            return result;
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "[TV_MATCH_LOAD] {Call} failed elapsedMs={ElapsedMs}", name, sw.ElapsedMilliseconds);
            throw;
        }
    }

    private async Task RetryLoadAsync()
    {
        await RefreshAsync(CancellationToken.None);
    }

    private string BuildAbsolute(string path)
        => $"{new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority)}{path}";

    private async Task LogAsync(string message, object? payload = null)
    {
        if (_tvModule is null)
            return;

        await _tvModule.InvokeVoidAsync("log", "TV_MODE", message, payload);
    }

    private string LocalizedTvMatchText(string key)
    {
        var isPortuguese = string.Equals(_culture, AppCultureService.SecondaryRouteCulture, StringComparison.OrdinalIgnoreCase);
        return key switch
        {
            "loading" => isPortuguese ? "Carregando partida..." : "Loading match...",
            "loadingBody" => isPortuguese ? "A arena esta preparando o confronto ao vivo." : "The arena is preparing the live matchup.",
            "notFound" => isPortuguese ? "Partida não encontrada." : "Match not found.",
            "notFoundBody" => isPortuguese ? "Não foi possível localizar a partida solicitada." : "We couldn't locate the requested match.",
            "unavailable" => isPortuguese ? "Esta partida já terminou ou não está mais disponível." : "This match has already ended or is no longer available.",
            "unavailableBody" => isPortuguese ? "A arena fixa só pode ser aberta enquanto a partida estiver disponível para transmissão." : "The fixed arena can only open while the match is still available for broadcast.",
            "error" => isPortuguese ? "Não foi possível carregar a arena no momento." : "Unable to load the arena right now.",
            "errorBody" => isPortuguese ? "Tente novamente em instantes. Se o problema continuar, a transmissão pode estar se atualizando." : "Please try again in a moment. If the problem persists, the broadcast may still be refreshing.",
            "retry" => isPortuguese ? "Tentar novamente" : "Try again",
            _ => key
        };
    }

    private static bool IsUnavailableForTv(MatchDto match)
    {
        if (match.IsFinished)
            return true;

        return match.Status?.Trim().ToUpperInvariant() switch
        {
            "COMPLETED" => true,
            "CANCELLED" => true,
            "CANCELED" => true,
            "CLOSED" => true,
            "SETTLED" => true,
            "FINISHED" => true,
            "EXPIRED" => true,
            "ABORTED" => true,
            _ => false
        };
    }

    private enum TvMatchPageLoadState
    {
        Loading,
        Loaded,
        NotFound,
        Unavailable,
        Error
    }

    public async ValueTask DisposeAsync()
    {
        if (_refreshCts is not null)
        {
            _refreshCts.Cancel();
            _refreshCts.Dispose();
        }

        if (_refreshLoopTask is not null)
        {
            try
            {
                await _refreshLoopTask;
            }
            catch
            {
            }
        }

        Logger.LogInformation("TvMatchPage refresh loop disposed. MatchId={MatchId}", MatchId);

        if (_tvModule is not null)
            await _tvModule.DisposeAsync();
    }
}
