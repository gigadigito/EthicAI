@page "/tv/match/{MatchId:int}/{Slug}"
@page "/{Culture}/tv/match/{MatchId:int}/{Slug}"
@using System.Text.Json
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersusApiClient Api
@inject HotMatchService HotMatches
@inject AppCultureService AppCulture
@inject IConfiguration Config
@inject IHttpContextAccessor HttpContextAccessor
@inject IJSRuntime JS
@inject LocalizationService L
@inject NavigationManager Nav
@inject RouteLocalizationService RouteLocalization
@inject MatchSlugHelper MatchSlugHelper
@inject ILogger<TvMatchPage> Logger
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <meta name="description" content="@MetaDescription" />
    <meta name="keywords" content="@MetaKeywords" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="en-US" href="@EnglishUrl" />
    <link rel="alternate" hreflang="pt-BR" href="@PortugueseUrl" />
    <link rel="alternate" hreflang="x-default" href="@EnglishUrl" />
    <meta property="og:title" content="@PageTitleText" />
    <meta property="og:description" content="@MetaDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="@SocialImageUrl" />
    <meta property="og:image:alt" content="@PageTitleText" />
    <meta property="og:locale" content="@AppCulture.ToOgLocale(_culture)" />
    <meta property="og:locale:alternate" content="@AppCulture.GetAlternateOgLocale(_culture)" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@PageTitleText" />
    <meta name="twitter:description" content="@MetaDescription" />
    <meta name="twitter:image" content="@SocialImageUrl" />
    <meta name="twitter:image:alt" content="@PageTitleText" />
    <script type="application/ld+json">@StructuredDataMarkup</script>
</HeadContent>

@if (!string.IsNullOrWhiteSpace(_error))
{
    <section class="container py-4">
        <div class="alert alert-warning" role="alert">@_error</div>
    </section>
}

@if (_match is not null)
{
    <TvStage Culture="@_culture"
             HotMatch="@_hotMatch"
             Match="@_match" />
}
else
{
    <TvStage Culture="@_culture" />
}

@code {
    private const int RefreshIntervalSeconds = 15;

    [Parameter] public string? Culture { get; set; }
    [Parameter] public int MatchId { get; set; }
    [Parameter] public string? Slug { get; set; }

    private string _culture = AppCultureService.DefaultRouteCulture;
    private MatchDto? _match;
    private TvHotMatchDto? _hotMatch;
    private IJSObjectReference? _tvModule;
    private CancellationTokenSource? _refreshCts;
    private Task? _refreshLoopTask;
    private string? _error;
    private int _refreshInProgress;
    private string PageTitleText
        => _match is null
            ? L.T("tv.seo.title", _culture)
            : L.T("tv.seo.matchTitle", _culture, _match.TeamA, _match.TeamB);
    private string MetaDescription
        => _match is null
            ? L.T("tv.seo.matchDescriptionFallback", _culture)
            : L.T("tv.seo.matchDescription", _culture, _match.TeamA, _match.TeamB);
    private string CanonicalUrl => BuildAbsolute(RouteLocalization.BuildTvMatchPath(_culture, MatchId, ResolvedSlug));
    private string EnglishUrl => BuildAbsolute(RouteLocalization.BuildTvMatchPath(AppCultureService.DefaultRouteCulture, MatchId, ResolvedSlug));
    private string PortugueseUrl => BuildAbsolute(RouteLocalization.BuildTvMatchPath(AppCultureService.SecondaryRouteCulture, MatchId, ResolvedSlug));
    private string MetaKeywords => _match is null
        ? $"{SeoDefaults.GlobalKeywords}, CriptoVersus TV match, #CriptoVersus TV, crypto battle stream"
        : $"{SeoDefaults.GlobalKeywords}, CriptoVersus TV match, #CriptoVersus TV, {_match.TeamA} vs {_match.TeamB}, crypto match stream";
    private string SocialImageUrl => SeoDefaults.BuildAbsoluteUrl(Config, Nav, SeoDefaults.DefaultSocialImagePath);
    private string StructuredDataMarkup
        => JsonSerializer.Serialize(new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "WebPage",
            ["name"] = PageTitleText,
            ["description"] = MetaDescription,
            ["url"] = CanonicalUrl,
            ["image"] = SocialImageUrl,
            ["keywords"] = MetaKeywords,
            ["inLanguage"] = _culture
        });
    private string ResolvedSlug => !string.IsNullOrWhiteSpace(_match?.TeamA) && !string.IsNullOrWhiteSpace(_match?.TeamB)
        ? MatchSlugHelper.BuildSlug(_match.TeamA, _match.TeamB)
        : Slug?.Trim().ToLowerInvariant() ?? "match";

    protected override void OnParametersSet()
    {
        _culture = !string.IsNullOrWhiteSpace(Culture)
            ? AppCulture.NormalizeRouteCulture(Culture)
            : AppCulture.DetectPreferredRouteCulture(HttpContextAccessor.HttpContext);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _tvModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/tvMode.js?v=20260602-battle-crossover-1");
        await LogAsync("loaded");
        await RefreshAsync(CancellationToken.None);

        _refreshCts = new CancellationTokenSource();
        _refreshLoopTask = RunRefreshLoopAsync(_refreshCts.Token);
        Logger.LogInformation("TvMatchPage refresh loop started. MatchId={MatchId} IntervalSeconds={IntervalSeconds}", MatchId, RefreshIntervalSeconds);
    }

    private async Task RunRefreshLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(RefreshIntervalSeconds));

        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                await RefreshAsync(ct);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task RefreshAsync(CancellationToken ct)
    {
        if (Interlocked.Exchange(ref _refreshInProgress, 1) == 1)
        {
            Logger.LogInformation("TvMatchPage refresh skipped because another refresh is already running. MatchId={MatchId}", MatchId);
            return;
        }

        var startedAtUtc = DateTime.UtcNow;
        try
        {
            Logger.LogInformation("TvMatchPage refresh started. MatchId={MatchId}", MatchId);
            _error = null;
            var matchTask = Api.GetMatchByIdAsync(MatchId, includeParticipants: false, ct);
            var hotTask = HotMatches.GetHotMatchesAsync(ct);
            await Task.WhenAll(matchTask, hotTask);

            _match = matchTask.Result;
            if (_match is null)
            {
                _error = L.T("tv.matchNotFound", _culture);
                await InvokeAsync(StateHasChanged);
                return;
            }

            var expectedPath = RouteLocalization.BuildTvMatchPath(_culture, _match.MatchId, MatchSlugHelper.BuildSlug(_match.TeamA, _match.TeamB));
            var currentPath = "/" + Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].Trim('/');
            if (!currentPath.Equals(expectedPath, StringComparison.OrdinalIgnoreCase))
            {
                Nav.NavigateTo(expectedPath, replace: true);
                return;
            }

            var hotMatch = hotTask.Result?.FirstOrDefault(x => x.MatchId == MatchId);

            if (hotMatch is not null)
            {
                _hotMatch = HotMatches.ToTvHotMatch(hotMatch, _culture, RouteLocalization);
                await LogAsync("[HOT_MATCH] refreshed", new { hotMatch.MatchId, hotMatch.HotScore, hotMatch.PriorityScore });
            }
            else
            {
                _hotMatch = null;
            }

            await InvokeAsync(StateHasChanged);
            Logger.LogInformation(
                "TvMatchPage refresh completed. MatchId={MatchId} HasHotMatch={HasHotMatch} DurationMs={DurationMs}",
                MatchId,
                _hotMatch is not null,
                (DateTime.UtcNow - startedAtUtc).TotalMilliseconds);
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Logger.LogWarning(ex, "TvMatchPage refresh failed. MatchId={MatchId}", MatchId);
            await LogAsync("refresh error", ex.Message);
        }
        finally
        {
            Interlocked.Exchange(ref _refreshInProgress, 0);
        }
    }

    private string BuildAbsolute(string path)
        => $"{new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority)}{path}";

    private async Task LogAsync(string message, object? payload = null)
    {
        if (_tvModule is null)
            return;

        await _tvModule.InvokeVoidAsync("log", "TV_MODE", message, payload);
    }

    public async ValueTask DisposeAsync()
    {
        if (_refreshCts is not null)
        {
            _refreshCts.Cancel();
            _refreshCts.Dispose();
        }

        if (_refreshLoopTask is not null)
        {
            try
            {
                await _refreshLoopTask;
            }
            catch
            {
            }
        }

        Logger.LogInformation("TvMatchPage refresh loop disposed. MatchId={MatchId}", MatchId);

        if (_tvModule is not null)
            await _tvModule.DisposeAsync();
    }
}
