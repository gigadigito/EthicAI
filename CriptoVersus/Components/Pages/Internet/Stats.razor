@page "/stats"
@page "/en/stats"
@page "/pt/estatisticas"
@using System.Globalization
@using System.Text.Json
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersusApiClient Api
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpContextAccessor
@inject AppCultureService AppCulture
@inject LocalizationService L
@inject RouteLocalizationService RouteLocalization
@inject MatchSlugHelper MatchSlugHelper
@inject IConfiguration Config
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <meta name="description" content="@MetaDescription" />
    <meta name="keywords" content="@MetaKeywords" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="en-US" href="@EnglishUrl" />
    <link rel="alternate" hreflang="pt-BR" href="@PortugueseUrl" />
    <link rel="alternate" hreflang="x-default" href="@CanonicalUrl" />
    <meta property="og:title" content="@PageTitleText" />
    <meta property="og:description" content="@MetaDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="@SocialImageUrl" />
    <meta property="og:image:alt" content="@PageTitleText" />
    <meta property="og:locale" content="@AppCulture.ToOgLocale(CurrentCulture)" />
    <meta property="og:locale:alternate" content="@AppCulture.GetAlternateOgLocale(CurrentCulture)" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@PageTitleText" />
    <meta name="twitter:description" content="@MetaDescription" />
    <meta name="twitter:image" content="@SocialImageUrl" />
    <meta name="twitter:image:alt" content="@PageTitleText" />
    <script type="application/ld+json">@StructuredDataMarkup</script>
</HeadContent>

<section class="stats-page">
    <header class="stats-hero">
        <div class="stats-hero__copy">
            <span class="stats-hero__eyebrow">@T("hero.eyebrow")</span>
            <h1>@T("hero.title")</h1>
            <p class="stats-hero__lead">@T("hero.subtitle")</p>
            <p class="stats-hero__seo-copy">@T("hero.seoCopy")</p>
            <p class="stats-hero__live-note">@T("hero.liveNote")</p>
            <div class="stats-hero__actions">
                <a class="stats-pill-link" href="@RouteLocalization.BuildHomePath(CurrentCulture)" aria-label="@T("hero.backToArenaAria")">@T("hero.backToArena")</a>
                <a class="stats-pill-link stats-pill-link--accent" href="@RouteLocalization.BuildHowItWorksPath(CurrentCulture)" aria-label="@T("hero.howScoringWorksAria")">@T("hero.howScoringWorks")</a>
            </div>
        </div>
        <div class="stats-hero__panel">
            <article>
                <span>@T("hero.coverage")</span>
                <strong>@DisplayNumber(_stats.TotalMatches)</strong>
                <small>@T("hero.coverageHint")</small>
            </article>
            <article>
                <span>@T("hero.finishedBattles")</span>
                <strong>@DisplayNumber(_stats.FinishedMatches)</strong>
                <small>@T("hero.finishedBattlesHint")</small>
            </article>
            <article>
                <span>@T("hero.lastUpdate")</span>
                <strong>@DisplayDateTime(_stats.LastUpdatedUtc)</strong>
                <small>UTC</small>
            </article>
        </div>
    </header>

    <section class="stats-search-shell" aria-labelledby="stats-search-heading">
        <div class="stats-section-head">
            <div>
                <span>@T("search.eyebrow")</span>
                <h2 id="stats-search-heading">@T("search.title")</h2>
            </div>
            <p>@T("search.description")</p>
        </div>
        <label class="stats-search-label" for="stats-search-input">@T("search.label")</label>
        <div class="stats-search-row">
            <input id="stats-search-input"
                   class="stats-search-input"
                   type="search"
                   placeholder="@T("search.placeholder")"
                   aria-label="@T("search.ariaLabel")"
                   value="@_searchInput"
                   @oninput="OnSearchInputChanged" />
            @if (!string.IsNullOrWhiteSpace(_searchInput))
            {
                <button type="button" class="stats-search-clear" @onclick="ClearSearchAsync">@T("search.clear")</button>
            }
        </div>
    </section>

    @if (_loading)
    {
        <section class="stats-feedback">
            <div class="stats-spinner" aria-hidden="true"></div>
            <div>
                <strong>@T("states.loadingTitle")</strong>
                <p>@T("states.loadingBody")</p>
            </div>
        </section>
    }
    else
    {
        if (!string.IsNullOrWhiteSpace(_error))
        {
            <section class="stats-feedback stats-feedback--error" role="alert">
                <div>
                    <strong>@T("states.errorTitle")</strong>
                    <p>@_error</p>
                </div>
            </section>
        }

        if (IsEmptyState)
        {
            <section class="stats-feedback stats-feedback--empty">
                <div>
                    <strong>@T("states.emptyTitle")</strong>
                    <p>@T("states.emptyBody")</p>
                </div>
            </section>
        }

        if (HasNoSearchResults)
        {
            <section class="stats-feedback stats-feedback--inline">
                <div>
                    <strong>@T("search.noResultsTitle")</strong>
                    <p>@T("search.noResultsBody")</p>
                </div>
            </section>
        }

        <section class="stats-summary-grid" aria-label="@T("summary.ariaLabel")">
            @foreach (var card in SummaryCards)
            {
                <article class="stats-card">
                    <span>@card.Label</span>
                    <strong>@card.Value</strong>
                    <small>@card.Hint</small>
                </article>
            }
        </section>

        <section class="stats-trending-section" aria-labelledby="stats-trending-heading">
            <div class="stats-section-head">
                <div>
                    <span>@T("trending.eyebrow")</span>
                    <h2 id="stats-trending-heading">@T("trending.title")</h2>
                </div>
                <p>@T("trending.description")</p>
            </div>
            <div class="stats-trending-grid">
                @if (TrendingAssets.Count == 0)
                {
                    <div class="stats-feedback stats-feedback--inline">
                        <div>
                            <strong>@T("trending.emptyTitle")</strong>
                            <p>@T("trending.emptyBody")</p>
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var asset in TrendingAssets)
                    {
                        @if (asset.IsLinkEnabled)
                        {
                            <a class="stats-trending-pill" href="@asset.TeamUrl" aria-label="@T("trending.assetAria", asset.DisplaySymbol)" title="@asset.FullSymbol">
                                <img src="@GetIconUrl(asset.FullSymbol)" alt="" loading="lazy" width="20" height="20" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                <span class="stats-asset-fallback" aria-hidden="true">@GetAssetMonogram(asset.DisplaySymbol)</span>
                                <strong>@asset.DisplaySymbol</strong>
                                <small>@T("trending.matchesHint", asset.Matches)</small>
                            </a>
                        }
                        else
                        {
                            <article class="stats-trending-pill is-static" title="@asset.FullSymbol">
                                <img src="@GetIconUrl(asset.FullSymbol)" alt="" loading="lazy" width="20" height="20" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                <span class="stats-asset-fallback" aria-hidden="true">@GetAssetMonogram(asset.DisplaySymbol)</span>
                                <strong>@asset.DisplaySymbol</strong>
                                <small>@T("trending.matchesHint", asset.Matches)</small>
                            </article>
                        }
                    }
                }
            </div>
        </section>

        <section class="stats-chart-grid">
            <article class="stats-chart-card">
                <div class="stats-section-head">
                    <div>
                        <span>@T("charts.winRate.eyebrow")</span>
                        <h2>@T("charts.winRate.title")</h2>
                    </div>
                    <p>@T("charts.winRate.description")</p>
                </div>
                <div class="stats-chart-shell" id="@WinRateChartId" role="img" aria-label="@T("charts.winRate.ariaLabel")"></div>
            </article>

            <article class="stats-chart-card">
                <div class="stats-section-head">
                    <div>
                        <span>@T("charts.activity.eyebrow")</span>
                        <h2>@T("charts.activity.title")</h2>
                    </div>
                    <p>@T("charts.activity.description")</p>
                </div>
                <div class="stats-chart-shell" id="@ActivityChartId" role="img" aria-label="@T("charts.activity.ariaLabel")"></div>
            </article>
        </section>

        <section class="stats-table-section">
            <div class="stats-section-head">
                <div>
                    <span>@T("ranking.eyebrow")</span>
                    <h2>@T("ranking.title")</h2>
                </div>
                <p>@T("ranking.description")</p>
            </div>
            <div class="stats-table-wrap">
                <table class="stats-table">
                    <thead>
                        <tr>
                            <th>@T("ranking.columns.rank")</th>
                            <th>@T("ranking.columns.asset")</th>
                            <th>@T("ranking.columns.matches")</th>
                            <th>@T("ranking.columns.wins")</th>
                            <th>@T("ranking.columns.losses")</th>
                            <th>@T("ranking.columns.winRate")</th>
                            <th>@T("ranking.columns.averageScore")</th>
                            <th>@T("ranking.columns.totalScore")</th>
                            <th>@T("ranking.columns.lastMatch")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_stats.TopTeams.Count == 0)
                        {
                            <tr>
                                <td colspan="9" class="stats-table__empty">@T("ranking.empty")</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var team in _stats.TopTeams)
                            {
                                var assetView = BuildAssetView(team.Symbol, team.DisplayName, team.Matches);
                                <tr>
                                    <td>@team.Rank</td>
                                    <td>
                                        @if (assetView.IsLinkEnabled)
                                        {
                                            <a class="stats-asset-link" href="@assetView.TeamUrl" aria-label="@T("ranking.assetAria", assetView.DisplaySymbol)" title="@assetView.FullSymbol">
                                                <img src="@GetIconUrl(assetView.FullSymbol)" alt="" loading="lazy" width="18" height="18" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                                <span class="stats-asset-fallback" aria-hidden="true">@GetAssetMonogram(assetView.DisplaySymbol)</span>
                                                <strong>@assetView.DisplaySymbol</strong>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="stats-asset-link is-static" title="@assetView.FullSymbol">
                                                <img src="@GetIconUrl(assetView.FullSymbol)" alt="" loading="lazy" width="18" height="18" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                                <span class="stats-asset-fallback" aria-hidden="true">@GetAssetMonogram(assetView.DisplaySymbol)</span>
                                                <strong>@assetView.DisplaySymbol</strong>
                                            </span>
                                        }
                                        @if (!string.Equals(assetView.DisplayName, assetView.DisplaySymbol, StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="stats-table__muted" title="@team.DisplayName">@assetView.DisplayName</span>
                                        }
                                    </td>
                                    <td>@DisplayNumber(team.Matches)</td>
                                    <td>@DisplayNumber(team.Wins)</td>
                                    <td>@DisplayNumber(team.Losses)</td>
                                    <td>@FormatPercent(team.WinRate)</td>
                                    <td>@FormatDecimal(team.AverageScore)</td>
                                    <td>@DisplayNumber(team.TotalScore)</td>
                                    <td>@DisplayDate(team.LastMatchUtc)</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="stats-table-section">
            <div class="stats-section-head">
                <div>
                    <span>@T("latest.eyebrow")</span>
                    <h2>@T("latest.title")</h2>
                </div>
                <p>@T("latest.description")</p>
            </div>
            <div class="stats-table-wrap">
                <table class="stats-table">
                    <thead>
                        <tr>
                            <th>@T("latest.columns.match")</th>
                            <th>@T("latest.columns.score")</th>
                            <th>@T("latest.columns.status")</th>
                            <th>@T("latest.columns.startedAt")</th>
                            <th>@T("latest.columns.finishedAt")</th>
                            <th>@T("latest.columns.publicPage")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_stats.LatestMatches.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="stats-table__empty">@T("latest.empty")</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var match in _stats.LatestMatches)
                            {
                                var matchUrl = GetMatchUrl(match);
                                var homeAsset = BuildAssetView(match.HomeSymbol, match.HomeSymbol, 0);
                                var awayAsset = BuildAssetView(match.AwaySymbol, match.AwaySymbol, 0);
                                <tr>
                                    <td>
                                        <div class="stats-matchup">
                                            @if (homeAsset.IsLinkEnabled)
                                            {
                                                <a class="stats-asset-link" href="@homeAsset.TeamUrl" aria-label="@T("latest.homeAssetAria", homeAsset.DisplaySymbol)" title="@homeAsset.FullSymbol">
                                                    <img src="@GetIconUrl(homeAsset.FullSymbol)" alt="" loading="lazy" width="18" height="18" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                                    <span class="stats-asset-fallback" aria-hidden="true">@GetAssetMonogram(homeAsset.DisplaySymbol)</span>
                                                    <strong>@homeAsset.DisplaySymbol</strong>
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="stats-asset-link is-static" title="@homeAsset.FullSymbol">
                                                    <img src="@GetIconUrl(homeAsset.FullSymbol)" alt="" loading="lazy" width="18" height="18" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                                    <span class="stats-asset-fallback" aria-hidden="true">@GetAssetMonogram(homeAsset.DisplaySymbol)</span>
                                                    <strong>@homeAsset.DisplaySymbol</strong>
                                                </span>
                                            }
                                            <span class="stats-matchup__vs">@T("latest.vs")</span>
                                            @if (awayAsset.IsLinkEnabled)
                                            {
                                                <a class="stats-asset-link" href="@awayAsset.TeamUrl" aria-label="@T("latest.awayAssetAria", awayAsset.DisplaySymbol)" title="@awayAsset.FullSymbol">
                                                    <img src="@GetIconUrl(awayAsset.FullSymbol)" alt="" loading="lazy" width="18" height="18" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                                    <span class="stats-asset-fallback" aria-hidden="true">@GetAssetMonogram(awayAsset.DisplaySymbol)</span>
                                                    <strong>@awayAsset.DisplaySymbol</strong>
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="stats-asset-link is-static" title="@awayAsset.FullSymbol">
                                                    <img src="@GetIconUrl(awayAsset.FullSymbol)" alt="" loading="lazy" width="18" height="18" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                                    <span class="stats-asset-fallback" aria-hidden="true">@GetAssetMonogram(awayAsset.DisplaySymbol)</span>
                                                    <strong>@awayAsset.DisplaySymbol</strong>
                                                </span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="stats-scoreline">
                                            <strong>@match.HomeScore</strong>
                                            <span>x</span>
                                            <strong>@match.AwayScore</strong>
                                        </div>
                                    </td>
                                    <td><span class="@GetStatusBadgeClass(match.Status)">@FormatStatus(match.Status)</span></td>
                                    <td>@DisplayDateTime(match.StartedAtUtc)</td>
                                    <td>@DisplayDateTime(match.FinishedAtUtc)</td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(matchUrl))
                                        {
                                            <a class="stats-cta-link" href="@matchUrl" aria-label="@T("latest.openMatchAria", homeAsset.DisplaySymbol, awayAsset.DisplaySymbol)">@T("latest.openMatch")</a>
                                        }
                                        else
                                        {
                                            <span class="stats-table__muted">@T("latest.unavailable")</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="stats-internal-links">
            <div class="stats-section-head">
                <div>
                    <span>@T("future.eyebrow")</span>
                    <h2>@T("future.title")</h2>
                </div>
                <p>@T("future.description")</p>
            </div>
            <div class="stats-link-grid">
                @foreach (var futureLink in FutureLinks)
                {
                    if (futureLink.IsEnabled)
                    {
                        <a class="stats-link-card stats-link-card--active" href="@futureLink.Path" aria-label="@T("future.openAria", futureLink.Title)">
                            <span>@T("future.availableNow")</span>
                            <strong>@futureLink.Title</strong>
                            <p>@futureLink.Description</p>
                            <code>@futureLink.Path</code>
                        </a>
                    }
                    else
                    {
                        <article class="stats-link-card is-disabled" aria-disabled="true">
                            <span>@T("future.comingSoon")</span>
                            <strong>@futureLink.Title</strong>
                            <p>@futureLink.Description</p>
                            <code>@futureLink.Path</code>
                        </article>
                    }
                }
            </div>
        </section>

        <section class="stats-seo-footnote" aria-labelledby="stats-seo-footnote-heading">
            <h2 id="stats-seo-footnote-heading">@T("footnote.title")</h2>
            <p>@T("footnote.body")</p>
        </section>
    }
</section>

@code {
    [Parameter] public string? Culture { get; set; }

    private const string WinRateChartId = "stats-win-rate-chart";
    private const string ActivityChartId = "stats-activity-chart";

    private readonly StatsOverviewDto _stats = new();
    private bool _loading = true;
    private bool _chartsPendingRender;
    private string? _error;
    private string _searchInput = string.Empty;
    private string _appliedSearch = string.Empty;
    private CancellationTokenSource? _searchDebounceCts;

    private string CurrentCulture => !string.IsNullOrWhiteSpace(Culture)
        ? AppCulture.NormalizeRouteCulture(Culture)
        : AppCulture.DetectPreferredRouteCulture(HttpContextAccessor.HttpContext);
    private bool IsEmptyState => _stats.TotalMatches == 0 && _stats.TopTeams.Count == 0 && _stats.LatestMatches.Count == 0;
    private bool HasNoSearchResults => !string.IsNullOrWhiteSpace(_appliedSearch) && _stats.TopTeams.Count == 0;
    private string PageTitleText => T("seo.title");
    private string MetaDescription => T("seo.description");
    private string MetaKeywords => $"{SeoDefaults.GlobalKeywords}, CriptoVersus stats, #CriptoVersus stats, crypto market stats";
    private string CanonicalUrl => BuildAbsolute("/stats");
    private string EnglishUrl => BuildAbsolute("/stats");
    private string PortugueseUrl => BuildAbsolute("/pt/estatisticas");
    private string SocialImageUrl => BuildAbsolute(SeoDefaults.DefaultSocialImagePath);
    private string StructuredDataMarkup => BuildStructuredDataMarkup();
    private HashSet<string> LinkableTeamSlugs => _stats.TopTeams
        .Select(team => BuildAssetSlug(CleanAssetSymbol(team.Symbol)))
        .Where(slug => !string.IsNullOrWhiteSpace(slug))
        .ToHashSet(StringComparer.OrdinalIgnoreCase);

    private IReadOnlyList<SummaryCardViewModel> SummaryCards =>
    [
        new SummaryCardViewModel(T("summary.totalMatches.label"), DisplayNumber(_stats.TotalMatches), T("summary.totalMatches.hint")),
        new SummaryCardViewModel(T("summary.finishedMatches.label"), DisplayNumber(_stats.FinishedMatches), T("summary.finishedMatches.hint")),
        new SummaryCardViewModel(T("summary.activeAssets.label"), DisplayNumber(_stats.ActiveAssets), T("summary.activeAssets.hint")),
        new SummaryCardViewModel(T("summary.averageScore.label"), FormatDecimal(_stats.AverageScore), T("summary.averageScore.hint")),
        new SummaryCardViewModel(T("summary.highestScore.label"), DisplayNumber(_stats.HighestScore), T("summary.highestScore.hint")),
        new SummaryCardViewModel(T("summary.lastUpdated.label"), DisplayDateTime(_stats.LastUpdatedUtc), T("summary.lastUpdated.hint"))
    ];

    private IReadOnlyList<FutureLinkViewModel> FutureLinks =>
    [
        new FutureLinkViewModel(T("future.links.teams.title"), RouteLocalization.BuildStatsTeamsPath(CurrentCulture), T("future.links.teams.description"), isEnabled: true),
        new FutureLinkViewModel(T("future.links.matches.title"), RouteLocalization.BuildStatsMatchesPath(CurrentCulture), T("future.links.matches.description"), isEnabled: true),
        new FutureLinkViewModel(T("future.links.rankings.title"), RouteLocalization.BuildStatsRankingsPath(CurrentCulture), T("future.links.rankings.description"), isEnabled: true),
        new FutureLinkViewModel(T("future.links.records.title"), RouteLocalization.BuildStatsRecordsPath(CurrentCulture), T("future.links.records.description"), isEnabled: true)
    ];

    private IReadOnlyList<TrendingAssetViewModel> TrendingAssets =>
        _stats.TopTeams
            .OrderByDescending(team => team.Matches)
            .ThenByDescending(team => team.WinRate)
            .ThenBy(team => team.Symbol, StringComparer.OrdinalIgnoreCase)
            .Take(5)
            .Select(team => BuildAssetView(team.Symbol, team.DisplayName, team.Matches))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        _appliedSearch = GetSearchFromUri();
        _searchInput = _appliedSearch;
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_chartsPendingRender || _loading)
            return;

        _chartsPendingRender = false;

        await JS.InvokeVoidAsync("criptoVersusStatsCharts.renderWinRateChart", WinRateChartId, _stats.TopTeams.Take(10).ToList());
        await JS.InvokeVoidAsync("criptoVersusStatsCharts.renderMatchActivityChart", ActivityChartId, _stats.MatchActivity);
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            var response = await Api.GetStatsOverviewAsync(_appliedSearch);
            if (response is not null)
            {
                _stats.TotalMatches = response.TotalMatches;
                _stats.FinishedMatches = response.FinishedMatches;
                _stats.ActiveAssets = response.ActiveAssets;
                _stats.AverageScore = response.AverageScore;
                _stats.HighestScore = response.HighestScore;
                _stats.LastUpdatedUtc = response.LastUpdatedUtc;

                _stats.TopTeams.Clear();
                _stats.TopTeams.AddRange(response.TopTeams ?? []);

                _stats.MatchActivity.Clear();
                _stats.MatchActivity.AddRange(response.MatchActivity ?? []);

                _stats.LatestMatches.Clear();
                _stats.LatestMatches.AddRange(response.LatestMatches ?? []);
            }
        }
        catch (Exception ex)
        {
            _error = T("states.errorBody");

            Console.WriteLine($"Stats page load error: {ex.Message}");
        }
        finally
        {
            _loading = false;
            _chartsPendingRender = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnSearchInputChanged(ChangeEventArgs args)
    {
        _searchInput = args.Value?.ToString() ?? string.Empty;
        await DebounceSearchAsync();
    }

    private async Task ClearSearchAsync()
    {
        _searchInput = string.Empty;
        await ApplySearchAsync(string.Empty);
    }

    private async Task DebounceSearchAsync()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        _searchDebounceCts = new CancellationTokenSource();

        try
        {
            await Task.Delay(300, _searchDebounceCts.Token);
            await ApplySearchAsync(_searchInput);
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task ApplySearchAsync(string? value)
    {
        var normalized = value?.Trim() ?? string.Empty;
        if (string.Equals(normalized, _appliedSearch, StringComparison.Ordinal))
            return;

        _appliedSearch = normalized;
        var nextUri = Nav.GetUriWithQueryParameter("search", string.IsNullOrWhiteSpace(normalized) ? null : normalized);
        Nav.NavigateTo(nextUri, replace: true);
        await LoadAsync();
    }

    private string GetSearchFromUri()
    {
        var uri = new Uri(Nav.Uri);
        var query = uri.Query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries);
        foreach (var part in query)
        {
            var pieces = part.Split('=', 2);
            if (pieces.Length > 0 && string.Equals(Uri.UnescapeDataString(pieces[0]), "search", StringComparison.OrdinalIgnoreCase))
                return pieces.Length == 2 ? Uri.UnescapeDataString(pieces[1]).Replace('+', ' ') : string.Empty;
        }

        return string.Empty;
    }

    private string BuildStructuredDataMarkup()
    {
        var title = T("hero.title");
        var description = T("hero.subtitle");

        var graph = new object[]
        {
            new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "WebPage",
                ["name"] = title,
                ["description"] = description,
                ["url"] = CanonicalUrl
            },
            new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "Dataset",
                ["name"] = title,
                ["description"] = description,
                ["url"] = CanonicalUrl,
                ["keywords"] = new[]
                {
                    "CriptoVersus statistics",
                    "crypto battle rankings",
                    "public match history",
                    "arena performance"
                }
            },
            new Dictionary<string, object?>
            {
                ["@context"] = "https://schema.org",
                ["@type"] = "BreadcrumbList",
                ["itemListElement"] = new object[]
                {
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "ListItem",
                        ["position"] = 1,
                        ["name"] = "CriptoVersus",
                        ["item"] = BuildAbsolute(RouteLocalization.BuildHomePath(CurrentCulture))
                    },
                    new Dictionary<string, object?>
                    {
                        ["@type"] = "ListItem",
                        ["position"] = 2,
                        ["name"] = T("structuredData.breadcrumbStats"),
                        ["item"] = CanonicalUrl
                    }
                }
            }
        };

        return JsonSerializer.Serialize(graph);
    }

    private string GetMatchUrl(StatsLatestMatchDto match)
    {
        var slug = MatchSlugHelper.BuildSlug(match.HomeSymbol, match.AwaySymbol);
        if (!string.IsNullOrWhiteSpace(slug))
            return RouteLocalization.BuildBestPath(CurrentCulture, match.MatchId, slug);

        return match.PublicUrl ?? string.Empty;
    }

    private string FormatStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status))
            return T("states.noData");

        return status.Trim().ToLowerInvariant() switch
        {
            "completed" => T("status.completed"),
            "ongoing" => T("status.ongoing"),
            "pending" => T("status.pending"),
            "cancelled" => T("status.cancelled"),
            _ => status
        };
    }

    private string GetStatusBadgeClass(string? status)
    {
        var suffix = status?.Trim().ToLowerInvariant() switch
        {
            "completed" => "is-finished",
            "ongoing" => "is-live",
            "pending" => "is-pending",
            "cancelled" => "is-cancelled",
            _ => "is-neutral"
        };

        return $"stats-status-badge {suffix}";
    }

    private TrendingAssetViewModel BuildAssetView(string? symbol, string? displayName, int matches)
    {
        var fullSymbol = string.IsNullOrWhiteSpace(symbol) ? (displayName ?? string.Empty) : symbol.Trim();
        var cleanSymbol = CleanAssetSymbol(fullSymbol);
        var effectiveDisplayName = !string.IsNullOrWhiteSpace(displayName) ? displayName.Trim() : cleanSymbol;
        if (string.Equals(effectiveDisplayName, fullSymbol, StringComparison.OrdinalIgnoreCase))
            effectiveDisplayName = cleanSymbol;

        var slug = BuildAssetSlug(cleanSymbol);

        return new TrendingAssetViewModel(
            fullSymbol,
            cleanSymbol,
            effectiveDisplayName,
            matches,
            RouteLocalization.BuildStatsTeamDetailPath(CurrentCulture, slug),
            isLinkEnabled: LinkableTeamSlugs.Contains(slug));
    }

    private static string CleanAssetSymbol(string? symbol)
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return "-";

        var normalized = symbol.Trim().ToUpperInvariant();
        foreach (var suffix in AssetSuffixes)
        {
            if (normalized.Length > suffix.Length + 1 && normalized.EndsWith(suffix, StringComparison.Ordinal))
                return normalized[..^suffix.Length];
        }

        return normalized;
    }

    private static string BuildAssetSlug(string symbol)
    {
        var buffer = new List<char>(symbol.Length);
        foreach (var ch in symbol.ToLowerInvariant())
        {
            if (char.IsLetterOrDigit(ch))
                buffer.Add(ch);
            else if (buffer.Count > 0 && buffer[^1] != '-')
                buffer.Add('-');
        }

        return new string(buffer.ToArray()).Trim('-');
    }

    private string GetIconUrl(string? symbol)
    {
        var baseSymbol = CleanAssetSymbol(symbol);
        return EnvironmentIsolationGuard.BuildBinanceIconUrl(baseSymbol);
    }

    private static string GetAssetMonogram(string? symbol)
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return "?";

        var text = symbol.Trim().ToUpperInvariant();
        return text.Length >= 2 ? text[..2] : text;
    }

    private static string DisplayNumber(int value)
        => value.ToString("N0", CultureInfo.InvariantCulture);

    private static string FormatPercent(decimal value)
        => $"{value:0.##}%";

    private static string FormatDecimal(decimal value)
        => value.ToString("0.##", CultureInfo.InvariantCulture);

    private static string DisplayDate(DateTime? value)
        => value.HasValue
            ? EnsureUtc(value.Value).ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)
            : "-";

    private static string DisplayDateTime(DateTime? value)
        => value.HasValue
            ? EnsureUtc(value.Value).ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture)
            : "-";

    private string BuildAbsolute(string path)
        => new Uri(new Uri(Nav.BaseUri), path).AbsoluteUri;

    private string T(string key, params object?[] args)
        => L.T($"stats.{key}", CurrentCulture, args);

    private static DateTime EnsureUtc(DateTime value)
        => value.Kind switch
        {
            DateTimeKind.Utc => value,
            DateTimeKind.Local => value.ToUniversalTime(),
            _ => DateTime.SpecifyKind(value, DateTimeKind.Utc)
        };

    private static readonly string[] AssetSuffixes = ["USDT", "USDC", "BUSD", "FDUSD", "BTC", "ETH"];

    public async ValueTask DisposeAsync()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();

        try
        {
            await JS.InvokeVoidAsync("criptoVersusStatsCharts.dispose", WinRateChartId);
            await JS.InvokeVoidAsync("criptoVersusStatsCharts.dispose", ActivityChartId);
        }
        catch
        {
        }
    }

    private sealed class SummaryCardViewModel
    {
        public SummaryCardViewModel(string label, string value, string hint)
        {
            Label = label;
            Value = value;
            Hint = hint;
        }

        public string Label { get; }
        public string Value { get; }
        public string Hint { get; }
    }

    private sealed class FutureLinkViewModel
    {
        public FutureLinkViewModel(string title, string path, string description, bool isEnabled = false)
        {
            Title = title;
            Path = path;
            Description = description;
            IsEnabled = isEnabled;
        }

        public string Title { get; }
        public string Path { get; }
        public string Description { get; }
        public bool IsEnabled { get; }
    }

    private sealed class TrendingAssetViewModel
    {
        public TrendingAssetViewModel(string fullSymbol, string displaySymbol, string displayName, int matches, string teamUrl, bool isLinkEnabled)
        {
            FullSymbol = fullSymbol;
            DisplaySymbol = displaySymbol;
            DisplayName = displayName;
            Matches = matches;
            TeamUrl = teamUrl;
            IsLinkEnabled = isLinkEnabled;
        }

        public string FullSymbol { get; }
        public string DisplaySymbol { get; }
        public string DisplayName { get; }
        public int Matches { get; }
        public string TeamUrl { get; }
        public bool IsLinkEnabled { get; }
    }
}

