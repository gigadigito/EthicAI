@using DTOs
@namespace CriptoVersus.Components.Pages.Internet

<section class="tv-stage-telemetry-stack tv-stage-telemetry-stack--@Variant">
    <section class="tv-stage-telemetry-stack__panel tv-stage-telemetry-stack__panel--compare">
        <TvMatchPriceBattleChart Culture="@Model.Culture"
                                 LeftSymbol="@Model.LeftTickerLabel"
                                 LeftDisplayName="@Model.LeftName"
                                 LeftLogoUrl="@Model.LeftLogoUrl"
                                 LeftCurrentPrice="@Model.LeftCurrentPrice"
                                 LeftChangePercent="@Model.LeftChangePercent"
                                 LeftColor="@Model.LeftPriceBattleColor"
                                 LeftPoints="@Model.LeftPriceBattlePoints"
                                 LeftHasPriceHistory="@Model.LeftPriceBattleHasHistory"
                                 RightSymbol="@Model.RightTickerLabel"
                                 RightDisplayName="@Model.RightName"
                                 RightLogoUrl="@Model.RightLogoUrl"
                                 RightCurrentPrice="@Model.RightCurrentPrice"
                                 RightChangePercent="@Model.RightChangePercent"
                                 RightColor="@Model.RightPriceBattleColor"
                                 RightPoints="@Model.RightPriceBattlePoints"
                                 RightHasPriceHistory="@Model.RightPriceBattleHasHistory"
                                 Competitiveness="@Model.Competitiveness"
                                 BroadcastFocusLabel="@Model.BroadcastFocusLabel"
                                 BroadcastRotationRemaining="@Model.BroadcastRotationRemaining"
                                 BroadcastRotationProgress="@Model.BroadcastRotationProgress"
                                 BroadcastFocusProgress="@Model.BroadcastFocusProgress"
                                 BroadcastFocusColor="@Model.BroadcastFocusColor"
                                 IsSignalStable="@Model.IsSignalStable" />
    </section>

    <section class="tv-stage-telemetry-stack__panel tv-stage-telemetry-stack__panel--split">
        <TvCandleBattle LeftTickerLabel="@Model.LeftTickerLabel"
                        RightTickerLabel="@Model.RightTickerLabel"
                        LeftHeroLabel="@Model.LeftHeroLabel"
                        RightHeroLabel="@Model.RightHeroLabel"
                        LeftLogoUrl="@Model.LeftLogoUrl"
                        RightLogoUrl="@Model.RightLogoUrl"
                        LeftChangePercent="@Model.LeftChangePercent"
                        RightChangePercent="@Model.RightChangePercent"
                        LeftPoints="@Model.LeftPriceBattlePoints"
                        RightPoints="@Model.RightPriceBattlePoints"
                        ShowTacticalPanel="@ShowTacticalPanel"
                        AriaLabel="@($"{Model.LeftTickerLabel} vs {Model.RightTickerLabel} candle battle arena")" />
    </section>

    <section class="tv-stage-telemetry-stack__panel tv-stage-telemetry-stack__panel--goals">
        <header class="tv-stage-telemetry-stack__header">
            <span>@Model.GoalLogTitle</span>
            <div class="tv-stage-telemetry-stack__headline">
                <strong>@Model.ScoreContext</strong>
                <em>@Model.GoalLogLeaderSymbol</em>
            </div>
            <small>@Model.GoalLogHeadline</small>
        </header>

        <div class="tv-goal-log">
            <TvGoalEventFeed FeedId="@FeedId"
                             Culture="@Model.Culture"
                             Items="@Model.RecentScoreEvents"
                             FormatTime="FormatTime"
                             DescribeFallback="DescribeFallback"
                             ResolveTeamLogoUrl="ResolveTeamLogoUrl"
                             EmptyTitle="@Model.GoalLogTitle"
                             EmptySubtitle="@Model.GoalLogEmptyState" />
        </div>
    </section>

    <section class="tv-stage-telemetry-stack__panel tv-stage-telemetry-stack__panel--sentiment">
        <TvArenaPressureGauge LeftSymbol="@Model.LeftHeroLabel"
                              Culture="@Model.Culture"
                              LeftDisplayName="@Model.LeftSymbol"
                              LeftLogoUrl="@Model.LeftLogoUrl"
                              LeftPressurePercent="@Model.ArenaPressureLeftPercent"
                              LeftMomentumLabel="@Model.ArenaPressureLeftMomentumLabel"
                              LeftColor="#ffd76e"
                              RightSymbol="@Model.RightHeroLabel"
                              RightDisplayName="@Model.RightSymbol"
                              RightLogoUrl="@Model.RightLogoUrl"
                              RightPressurePercent="@Model.ArenaPressureRightPercent"
                              RightMomentumLabel="@Model.ArenaPressureRightMomentumLabel"
                              RightColor="#53c8ff"
                              CurrentPressurePercent="@Model.ArenaCurrentPressurePercent"
                              StatusLabel="@Model.ArenaPressureStatusLabel"
                              Description="@Model.ArenaPressureDescription"
                              IsCompact="@Model.UseCompactArenaGauge" />
    </section>
</section>

<style>
    .tv-stage-telemetry-stack {
        display: grid;
        gap: 14px;
        min-width: 0;
        width: 100%;
    }

    .tv-stage-telemetry-stack__panel {
        min-width: 0;
    }

    .tv-stage-telemetry-stack__header {
        display: grid;
        gap: 6px;
        margin-bottom: 12px;
    }

    .tv-stage-telemetry-stack__headline {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
    }

    .tv-stage-telemetry-stack--mobile .tv-stage-telemetry-stack__panel--compare {
        min-height: 420px;
    }

    .tv-stage-telemetry-stack--mobile .tv-stage-telemetry-stack__panel--split {
        min-height: 360px;
    }

    .tv-stage-telemetry-stack--mobile .tv-stage-telemetry-stack__panel--goals {
        min-height: 300px;
    }

    .tv-stage-telemetry-stack--mobile .tv-stage-telemetry-stack__panel--sentiment {
        min-height: 300px;
    }

    .tv-stage-telemetry-stack--tablet {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .tv-stage-telemetry-stack--tablet .tv-stage-telemetry-stack__panel--compare {
        min-height: 360px;
    }

    .tv-stage-telemetry-stack--tablet .tv-stage-telemetry-stack__panel--split {
        min-height: 320px;
    }

    .tv-stage-telemetry-stack--tablet .tv-stage-telemetry-stack__panel--goals {
        min-height: 280px;
    }

    .tv-stage-telemetry-stack--tablet .tv-stage-telemetry-stack__panel--sentiment {
        min-height: 280px;
    }

    .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--compare {
        min-height: 300px;
    }

    .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--split {
        min-height: 280px;
    }

    .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals {
        min-height: 260px;
    }

    .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--sentiment {
        min-height: 260px;
    }

    .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel,
    .tv-stage-telemetry-stack--tablet .tv-stage-telemetry-stack__panel,
    .tv-stage-telemetry-stack--mobile .tv-stage-telemetry-stack__panel {
        overflow: hidden;
    }

    @@media (max-width: 720px) {
        .tv-stage-telemetry-stack--tablet {
            grid-template-columns: minmax(0, 1fr);
        }
    }


    /* Goal Log compact event cards. Prevent event cards from stretching to the
       full carousel/tbarena height. */
    .tv-stage-telemetry-stack .tv-event-card,
    .tv-stage-telemetry-stack .tv-goal-event-feed__card,
    .tv-stage-telemetry-stack .tv-goal-event-feed__item {
        max-height: 130px !important;
        min-height: 56px;
        overflow: hidden;
    }

    .tv-stage-telemetry-stack .tv-goal-log,
    .tv-stage-telemetry-stack .tv-goal-event-feed,
    .tv-stage-telemetry-stack .tv-goal-event-feed__list {
        min-height: 0;
        overflow-y: auto;
    }

    /* Let non-compare telemetry panels use the available carousel/tbarena height
       without forcing Market Battle Flow into absolute positioning. */
    .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--split,
    .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals,
    .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--sentiment {
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
        min-height: 0;
        height: 100%;
    }

    .tv-stage-telemetry-stack--desktop .tv-candle-battle,
    .tv-stage-telemetry-stack--desktop .tv-arena-pressure-gauge {
        min-height: 0;
        height: 100%;
    }

</style>

@code {
    [Parameter, EditorRequired] public TvStageRenderModel Model { get; set; } = default!;
    [Parameter] public string Variant { get; set; } = "desktop";
    [Parameter] public string FeedId { get; set; } = "tv-goal-event-feed";
    [Parameter] public bool ShowTacticalPanel { get; set; }
    [Parameter] public Func<MatchScoreEventDto, string>? FormatGoalLogTime { get; set; }
    [Parameter] public Func<MatchScoreEventDto, string>? DescribeGoalLog { get; set; }
    [Parameter] public Func<MatchScoreEventDto, string>? ResolveGoalLogTeamLogoUrl { get; set; }

    private string FormatTime(MatchScoreEventDto item) => FormatGoalLogTime?.Invoke(item) ?? string.Empty;
    private string DescribeFallback(MatchScoreEventDto item) => DescribeGoalLog?.Invoke(item) ?? string.Empty;
    private string ResolveTeamLogoUrl(MatchScoreEventDto item) => ResolveGoalLogTeamLogoUrl?.Invoke(item) ?? string.Empty;
}
