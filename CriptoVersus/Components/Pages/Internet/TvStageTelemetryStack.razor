@using DTOs
@using CriptoVersus.Components.Shared
@namespace CriptoVersus.Components.Pages.Internet
@implements IAsyncDisposable

@if (IsDesktop)
{
    <section class="tv-stage-telemetry-stack tv-stage-telemetry-stack--desktop">
        <div id="@CarouselId"
             class="carousel slide tv-stage-telemetry-carousel"
             data-tv-stage-carousel="true"
             aria-roledescription="carousel"
             data-left-points="@Model.LeftPriceBattlePoints.Count"
             data-right-points="@Model.RightPriceBattlePoints.Count"
             data-goal-events="@Model.RecentScoreEvents.Count"
             data-arena-left="@Model.ArenaPressureLeftPercent"
             data-arena-right="@Model.ArenaPressureRightPercent"
             aria-label="@($"{SlideTitle(_activeSlide)} telemetry carousel")">
            <div class="tv-stage-telemetry-carousel__caption" aria-hidden="true">
                @SlideTitle(_activeSlide)
            </div>

            <div class="carousel-indicators tv-stage-telemetry-carousel__indicators">
                @for (var i = 0; i < SlideCount; i++)
                {
                    var slideIndex = i;
                    <button type="button"
                            class="@(slideIndex == _activeSlide ? "active" : string.Empty)"
                            aria-current="@(slideIndex == _activeSlide ? "true" : null)"
                            aria-label="@SlideTitle(slideIndex)"
                            @onclick="() => GoToSlideAsync(slideIndex)"></button>
                }
            </div>

            <div class="carousel-inner tv-stage-telemetry-carousel__inner">
                @if (_activeSlide == 0)
                {
                    <section class="carousel-item tv-stage-telemetry-carousel__item active">
                        <div class="tv-stage-telemetry-stack__panel tv-stage-telemetry-stack__panel--compare">
                            @PriceBattleContent
                        </div>
                    </section>
                }
                else if (_activeSlide == 1)
                {
                    <section class="carousel-item tv-stage-telemetry-carousel__item active">
                        <div class="tv-stage-telemetry-stack__panel tv-stage-telemetry-stack__panel--split">
                            @CandleBattleContent
                        </div>
                    </section>
                }
                else if (_activeSlide == 2)
                {
                    <section class="carousel-item tv-stage-telemetry-carousel__item active">
                        <div class="tv-stage-telemetry-stack__panel tv-stage-telemetry-stack__panel--goals">
                            @GoalLogContent
                        </div>
                    </section>
                }
                else
                {
                    <section class="carousel-item tv-stage-telemetry-carousel__item active">
                        <div class="tv-stage-telemetry-stack__panel tv-stage-telemetry-stack__panel--sentiment">
                            @ArenaPressureContent
                        </div>
                    </section>
                }
            </div>

            <button class="carousel-control-prev tv-stage-telemetry-carousel__control tv-stage-telemetry-carousel__control--prev"
                    type="button"
                    aria-label="Previous"
                    @onclick="PreviousSlideAsync">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Previous</span>
            </button>

            <button class="carousel-control-next tv-stage-telemetry-carousel__control tv-stage-telemetry-carousel__control--next"
                    type="button"
                    aria-label="Next"
                    @onclick="NextSlideAsync">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Next</span>
            </button>
        </div>
    </section>
}
else
{
    <section class="tv-stage-telemetry-stack tv-stage-telemetry-stack--@Variant">
        <section class="tv-stage-telemetry-stack__panel tv-stage-telemetry-stack__panel--compare">
            @PriceBattleContent
        </section>

        <section class="tv-stage-telemetry-stack__panel tv-stage-telemetry-stack__panel--split">
            @CandleBattleContent
        </section>

        <section class="tv-stage-telemetry-stack__panel tv-stage-telemetry-stack__panel--goals">
            @GoalLogContent
        </section>

        <section class="tv-stage-telemetry-stack__panel tv-stage-telemetry-stack__panel--sentiment">
            @ArenaPressureContent
        </section>
    </section>
}

<style>
    .tv-stage-telemetry-stack {
        display: grid;
        gap: 14px;
        min-width: 0;
        width: 100%;
    }

    .tv-stage-telemetry-stack__panel {
        min-width: 0;
        overflow: visible;
    }

    .tv-stage-telemetry-stack__header {
        display: grid;
        gap: 6px;
        margin-bottom: 12px;
    }

    .tv-stage-telemetry-stack__headline {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
    }

    .tv-stage-telemetry-stack--mobile .tv-stage-telemetry-stack__panel--compare {
        min-height: 420px;
    }

    .tv-stage-telemetry-stack--mobile .tv-stage-telemetry-stack__panel--split {
        min-height: 360px;
    }

    .tv-stage-telemetry-stack--mobile .tv-stage-telemetry-stack__panel--goals {
        min-height: 300px;
    }

    .tv-stage-telemetry-stack--mobile .tv-stage-telemetry-stack__panel--sentiment {
        min-height: 300px;
    }

    .tv-stage-telemetry-stack--tablet {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

