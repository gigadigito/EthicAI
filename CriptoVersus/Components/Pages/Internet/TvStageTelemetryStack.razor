        width: 100%;
        height: auto;
        min-height: 280px;
    }

    /* Desktop carousel viewport fill: keep every active telemetry slide using the available arena height. */
    .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--split,
    .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--sentiment {
        display: grid;
        grid-template-rows: minmax(0, 1fr);
        height: 100%;
        min-height: 0;
        overflow: hidden;
    }

        .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--split > :not(style):not(script):not(link):not(template),
        .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--sentiment > :not(style):not(script):not(link):not(template) {
            height: 100%;
            min-height: 0;
            max-height: none;
        }

    .tv-stage-telemetry-stack--desktop :is(.tv-candle-battle, .tv-candle-battle__surface, .tv-candle-battle__chart, .tv-candle-battle__body),
    .tv-stage-telemetry-stack--desktop :is(.tv-arena-pressure, .tv-arena-pressure-gauge, .tv-arena-pressure-gauge__panel, .tv-arena-pressure-gauge__body, .tv-arena-pressure-gauge__center, .tv-arena-pressure-gauge__gauge-shell) {
        height: 100%;
        min-height: 0;
        max-height: none;
    }

    .tv-stage-telemetry-stack--desktop .tv-arena-pressure-gauge__svg {
        min-height: clamp(300px, 58svh, 620px);
        max-height: none;
    }


    /* Desktop Goal Log compact mode: each event can breathe, but never becomes a giant full-height card. */
    .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals {
        display: grid;
        grid-template-rows: auto minmax(0, 1fr);
        height: 100%;
        min-height: 0;
        overflow: hidden;
    }

