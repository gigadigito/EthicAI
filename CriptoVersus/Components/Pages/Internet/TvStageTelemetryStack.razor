        min-height: 540px;
        width: 100%;
        overflow: hidden;
    }

    .tv-stage-telemetry-stack--desktop .tv-price-battle,
    .tv-stage-telemetry-stack--desktop .tv-candle-battle,
    .tv-stage-telemetry-stack--desktop .tv-goal-log,
    .tv-stage-telemetry-stack--desktop .tv-goal-event-feed,
    .tv-stage-telemetry-stack--desktop .tv-goal-event-feed__list,
    .tv-stage-telemetry-stack--desktop .tv-arena-pressure,
    .tv-stage-telemetry-stack--desktop .tv-arena-pressure-gauge,
    .tv-stage-telemetry-stack--desktop .tv-arena-pressure-gauge__panel,
