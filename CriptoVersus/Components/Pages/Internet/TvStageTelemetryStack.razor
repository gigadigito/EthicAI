        .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals .tv-goal-event-feed {
            height: 100%;
            min-height: 0;
            overflow: hidden;
        }

        .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals .tv-goal-event-feed__list,
        .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals .tv-goal-event-feed__items {
            height: 100%;
            min-height: 0;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
            padding-right: 6px;
        }

            .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals :is(.tv-event-card, .tv-goal-event-feed__card, .tv-goal-event-feed__item),
            .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals .tv-goal-event-feed__items > *,
            .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals .tv-goal-event-feed__list > * {
                min-height: 74px !important;
                max-height: 130px !important;
                height: auto !important;
                overflow: hidden !important;
                padding-top: 10px !important;
                padding-bottom: 10px !important;
                align-items: center !important;
                flex: 0 0 auto !important;
            }

                .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals :is(.tv-event-card, .tv-goal-event-feed__card, .tv-goal-event-feed__item) img,
                .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals .tv-goal-event-feed__items > * img,
                .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals .tv-goal-event-feed__list > * img,
                .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals :is(.tv-event-card, .tv-goal-event-feed__card, .tv-goal-event-feed__item) svg,
                .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals .tv-goal-event-feed__items > * svg,
                .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals .tv-goal-event-feed__list > * svg {
                    width: 44px !important;
                    height: 44px !important;
                    min-width: 44px !important;
                    max-height: 44px !important;
                }

                .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals :is(.tv-event-card, .tv-goal-event-feed__card, .tv-goal-event-feed__item) :is(p, small),
                .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals .tv-goal-event-feed__items > * :is(p, small),
                .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals .tv-goal-event-feed__list > * :is(p, small) {
                    display: -webkit-box;
                    -webkit-line-clamp: 2;
                    -webkit-box-orient: vertical;
                    overflow: hidden;
                    text-overflow: ellipsis;
                    margin: 0 !important;
                }

                .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals :is(.tv-event-card, .tv-goal-event-feed__card, .tv-goal-event-feed__item) :is(h3, h4, strong),
                .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals .tv-goal-event-feed__items > * :is(h3, h4, strong),
                .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--goals .tv-goal-event-feed__list > * :is(h3, h4, strong) {
                    white-space: nowrap;
                    overflow: hidden;
                    text-overflow: ellipsis;
                    margin: 0 !important;
                }



    /* Desktop Market Battle Flow fill: make the active price chart consume the whole carousel viewport. */
    .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--compare {
        display: grid;
        grid-template-rows: minmax(0, 1fr);
        height: 100%;
        min-height: 0;
        overflow: hidden;
    }

        .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--compare > :not(style):not(script):not(link):not(template) {
            display: grid;
            grid-template-rows: minmax(0, 1fr);
            height: 100%;
            min-height: 0;
            max-height: none;
            overflow: hidden;
        }

        .tv-stage-telemetry-stack--desktop .tv-stage-telemetry-stack__panel--compare :is( .tv-price-battle, .tv-price-battle-chart, .tv-match-price-battle, .tv-match-price-battle-chart ) {
            display: grid !important;
