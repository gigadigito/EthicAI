@rendermode InteractiveServer
@page "/tokenomics"
@using DTOs
@inject CriptoVersus.Web.Services.CriptoVersusApiClient Api
@inject IJSRuntime JS

<section class="tokenomics-page">
    <div class="tokenomics-hero">
        <img class="tokenomics-hero__banner" src="/img/tokenomics-hero-banner.png" alt="CriptoVersus Arena Financeira. Estrategia. Vitoria." />
    </div>

    @if (_loading)
    {
        <p>Carregando regras do protocolo...</p>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="rule-alert">@_error</div>
    }
    else if (_data is not null)
    {
        <div class="metrics-band">
            <article>
                <span>Capital ativo</span>
                <strong>@FmtSol(_data.ActiveCapital)</strong>
                <small>@_data.ActivePositions posicoes ativas</small>
            </article>
            <article>
                <span>Total alocado</span>
                <strong>@FmtSol(_data.PrincipalAllocated)</strong>
                <small>@_data.Users usuarios indexados</small>
            </article>
            <article>
                <span>Ciclos em andamento</span>
                <strong>@_data.OngoingMatches</strong>
                <small>@_data.PendingMatches pendentes</small>
            </article>
            <article>
                <span>Em partidas abertas</span>
                <strong>@FmtSol(_data.OpenEntryAmount)</strong>
                <small>@_data.OpenEntries entradas abertas</small>
            </article>
        </div>

        <section class="topic-callout">
            <div>
                <span>Topico especial</span>
                <h3>Regras das partidas e formacao do placar</h3>
                <p>
                    Veja em detalhe como funcionam cruzamentos, thresholds, volume por janela, volume por cruzamento e o log
                    auditavel que reconstrui cada ponto da partida.
                </p>
            </div>
            <a class="topic-link" href="/tokenomics/regras-das-partidas">Abrir topico completo</a>
        </section>

        <div class="rule-grid">
            <section class="rule-panel lead-panel" id="como-funciona">
                <span>01</span>
                <h3>Como funciona</h3>
                <p>
                    Escolha um ativo, deposite SOL e mantenha sua posicao ativa para participar automaticamente de novos
                    ciclos sempre que esse ativo retornar. Assim, voce nao precisa repetir a entrada manual a cada rodada e
                    seu capital continua pronto para seguir no jogo.
                </p>
                <div class="flow-line">
                    <strong>Depositar SOL</strong>
                    <strong>Entrar na posicao</strong>
                    <strong>Liquidar quando desejar</strong>
                    <strong>Continuar automaticamente</strong>
                </div>
            </section>

            <section class="rule-panel" id="posicoes">
                <span>02</span>
                <h3>Posicoes</h3>
                <p>
                    Cada posicao pertence a uma carteira e a um ativo especifico. O capital atual pode crescer com ciclos
                    vencedores, sofrer erosao controlada em ciclos perdedores ou entrar em processo de saida quando o usuario
                    solicitar encerramento da posicao.
                </p>
                <dl>
                    <div><dt>Ativas</dt><dd>@_data.ActivePositions</dd></div>
                    <div><dt>Saida solicitada</dt><dd>@_data.ClosingPositions</dd></div>
                    <div><dt>Fechadas</dt><dd>@_data.ClosedPositions</dd></div>
                </dl>
            </section>

            <section class="rule-panel" id="pontuacao">
                <span>03</span>
                <h3>Sistema de Pontuacao</h3>
                <p>
                    A pontuacao compara a performance relativa dos ativos dentro do ciclo. A cada @_data.PercentPerGoal.ToString("0.##")%
                    de vantagem, o ativo pode converter essa diferenca em gols, sempre respeitando o teto maximo de pontuacao
                    por lado definido na configuracao operacional.
                </p>
                <dl>
                    <div><dt>% por gol</dt><dd>@_data.PercentPerGoal.ToString("0.##")%</dd></div>
                    <div><dt>Limite por time</dt><dd>@_data.MaxGoalsPerTeam</dd></div>
                </dl>
            </section>

            <section class="rule-panel" id="ciclos">
                <span>04</span>
                <h3>Ciclos</h3>
                <p>
                    Cada partida representa um ciclo de mercado com janela de entrada, periodo de acompanhamento e liquidacao.
                    Se a reentrada automatica estiver habilitada, posicoes recorrentes voltam ao jogo quando o ativo reaparece,
                    desde que a posicao siga ativa e acima do capital minimo operacional.
                </p>
                <dl>
                    <div><dt>Duracao alvo</dt><dd>@_data.MatchDurationMinutes min</dd></div>
                    <div><dt>Reentrada automatica</dt><dd>@(_data.AutoReenterEnabled ? "Ativa" : "Pausada")</dd></div>
                </dl>
            </section>

            <section class="rule-panel settlement-panel" id="liquidacao">
                <span>05</span>
                <h3>Liquidacao</h3>
                <p>
                    O lado vencedor recebe ganho proporcional da parcela distribuivel originada no lado perdedor. O lado
                    perdedor preserva a maior parte do capital, reduzindo a eliminacao rapida e reforcando uma dinamica mais
                    parecida com pool rotativa do que com aposta classica de rodada unica.
                </p>
                <div class="settlement-chart" aria-label="Distribuicao da liquidacao">
                    <div class="settlement-chart__pie" @ref="_settlementPieRef"></div>
                    <div class="settlement-chart__summary">
                        <article class="settlement-chart__target settlement-chart__target--refund">
                            <small>Retorno ao perdedor</small>
                            <strong>@FmtPct(_data.LoserRefundRate)</strong>
                        </article>
                        <article class="settlement-chart__target settlement-chart__target--winners">
                            <small>Pool dos vencedores</small>
                            <strong>@FmtPct(_data.WinnerPoolRate)</strong>
                        </article>
                        <article class="settlement-chart__target settlement-chart__target--house">
                            <small>Taxa da casa</small>
                            <strong>@FmtPct(_data.HouseFeeRate)</strong>
                        </article>
                    </div>
                </div>
                <div class="allocation-bar">
                    <i style="width:@PctCss(_data.LoserRefundRate)"></i>
                    <b style="width:@PctCss(_data.WinnerPoolRate)"></b>
                    <em style="width:@PctCss(_data.HouseFeeRate)"></em>
                </div>
                <div class="legend">
                    <span>Perdedor recupera @FmtPct(_data.LoserRefundRate)</span>
                    <span>Vencedores recebem @FmtPct(_data.WinnerPoolRate)</span>
                    <span>Casa @FmtPct(_data.HouseFeeRate)</span>
                </div>
            </section>

            <section class="rule-panel" id="taxas">
                <span>06</span>
                <h3>Taxas</h3>
                <p>
                    A taxa da casa e mantida em nivel reduzido para sustentar a operacao, a indexacao e a infraestrutura
                    operacional, sem consumir uma parcela agressiva do capital dos participantes a cada ciclo.
                </p>
                <dl>
                    <div><dt>Taxa da casa</dt><dd>@FmtPct(_data.HouseFeeRate)</dd></div>
                    <div><dt>Capital minimo</dt><dd>@FmtSol(_data.MinPositionCapital)</dd></div>
                </dl>
            </section>

            <section class="rule-panel" id="retirada">
                <span>07</span>
                <h3>Retirada</h3>
                <p>
                    O usuario pode solicitar saida da posicao a qualquer momento. Se houver ciclo ativo, a posicao aguarda a
                    liquidacao daquele ciclo; depois disso, o capital remanescente pode seguir para encerramento e retirada
                    conforme o fluxo operacional habilitado no sistema.
                </p>
            </section>

            <section class="rule-panel" id="riscos">
                <span>08</span>
                <h3>Riscos</h3>
                <p>
                    O protocolo opera com ativos volateis, regras automatizadas e contratos em rede Solana. Pequenas perdas por
                    ciclo podem se acumular ao longo do tempo, parametros podem ser ajustados pela operacao e ambiente de devnet
                    nao deve ser interpretado como garantia de retorno, liquidez ou desempenho futuro.
                </p>
            </section>

            <section class="rule-panel contract-panel" id="contrato">
                <span>09</span>
                @if (IsOffChainCustodyMode)
                {
                    <h3>Carteira de custodia</h3>
                    <p>
                        No modo Off-chain Custody, os fundos operacionais sao conciliados fora do contrato. A wallet Solana
                        continua sendo a identidade do usuario, enquanto as transferencias para a carteira de custodia na rede
                        @_data.Cluster precisam ser reconhecidas pelo sistema para virar saldo interno de apostas.
                    </p>
                    <dl>
                        <div><dt>Carteira</dt><dd title="@_data.CustodyWalletPublicKey">@ShortAddress(_data.CustodyWalletPublicKey)</dd></div>
                        <div><dt>Label</dt><dd>@DisplayCustodyWalletLabel</dd></div>
                        <div><dt>Rede</dt><dd>@_data.Cluster</dd></div>
                    </dl>
                }
                else
                {
                    <h3>Contrato on-chain</h3>
                    <p>
                        Depositos e posicoes usam o programa configurado na rede @_data.Cluster. O backend atua como indexador e
                        camada de orquestracao, enquanto a posicao on-chain preserva a rastreabilidade do capital, dos enderecos
                        vinculados e da logica operacional publicada no contrato.
                    </p>
                    <dl>
                        <div><dt>Program ID</dt><dd title="@_data.ProgramId">@ShortAddress(_data.ProgramId)</dd></div>
                        <div><dt>Authority</dt><dd title="@_data.AuthorityWallet">@ShortAddress(_data.AuthorityWallet)</dd></div>
                        <div><dt>Rede</dt><dd>@_data.Cluster</dd></div>
                    </dl>
                }
            </section>
        </div>

        @if (_data.TopPositions.Count > 0)
        {
            <section class="positions-band">
                <div class="positions-band__header">
                    <span>Ativos com mais capital</span>
                    <h3>Distribuicao atual das posicoes</h3>
                    <p>Leitura rapida das posicoes com maior capital ativo neste momento.</p>
                </div>
                <div class="position-list">
                    @{
                        var rank = 1;
                    }
                    @foreach (var position in _data.TopPositions)
                    {
                        <article>
                            <div class="position-list__rank">@rank.ToString("00")</div>
                            <div class="position-list__body">
                                <strong class="@GetPositionTitleClass(position.Symbol)">
                                    <span>@GetBaseSymbol(position.Symbol)</span>
                                    <span class="position-list__quote" title="@GetBaseSymbol(position.Symbol)">
                                        <img src="@GetCoinIconUrl(GetBaseSymbol(position.Symbol))"
                                             alt="@GetBaseSymbol(position.Symbol)"
                                             loading="lazy"
                                             onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                        <span class="position-list__quote-fallback d-none">@GetBaseSymbol(position.Symbol)</span>
                                    </span>
                                </strong>
                                <span>@FmtSol(position.CurrentCapital)</span>
                                <small>Capital em jogo</small>
                            </div>
                        </article>
                        rank++;
                    }
                </div>
            </section>
        }
    }
</section>

@code {
    private TokenomicsDto? _data;
    private bool _loading = true;
    private string? _error;
    private ElementReference _settlementPieRef;
    private bool _settlementChartRendered;

    private bool IsOffChainCustodyMode
        => string.Equals(_data?.BlockchainMode, "OffChainCustody", StringComparison.OrdinalIgnoreCase);

    private string DisplayCustodyWalletLabel
        => string.IsNullOrWhiteSpace(_data?.CustodyWalletLabel)
            ? "Carteira de custodia"
            : _data!.CustodyWalletLabel;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _data = await Api.GetTokenomicsAsync();
        }
        catch (Exception ex)
        {
            _error = $"Nao foi possivel carregar as regras dinamicas: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_data is null || _settlementChartRendered)
            return;

        _settlementChartRendered = true;

        await JS.InvokeVoidAsync(
            "tokenomicsCharts.renderSettlementPie",
            _settlementPieRef,
            new
            {
                loserRefundRate = decimal.ToDouble(_data.LoserRefundRate),
                winnerPoolRate = decimal.ToDouble(_data.WinnerPoolRate),
                houseFeeRate = decimal.ToDouble(_data.HouseFeeRate)
            });
    }

    private static string FmtSol(decimal value)
        => $"{value:0.########} SOL";

    private static string FmtPct(decimal value)
        => $"{value * 100m:0.##}%";

    private static string PctCss(decimal value)
        => $"{Math.Max(0m, Math.Min(1m, value)) * 100m:0.##}%";

    private static string GetBaseSymbol(string pair)
    {
        if (string.IsNullOrWhiteSpace(pair))
            return "";

        var normalized = pair.Trim().ToUpperInvariant();
        var quotes = new[] { "USDT", "USDC", "BUSD", "BRL", "EUR", "BTC", "ETH" };

        foreach (var quote in quotes)
        {
            if (normalized.EndsWith(quote, StringComparison.OrdinalIgnoreCase) && normalized.Length > quote.Length)
                return normalized[..^quote.Length];
        }

        return normalized;
    }

    private static string GetCoinIconUrl(string symbol)
        => $"https://criptoversus-api.duckdns.org/api/icons/binance/{symbol.Trim().ToUpperInvariant()}";

    private static string GetPositionTitleClass(string pair)
    {
        var length = GetBaseSymbol(pair).Length;

        if (length >= 10)
            return "position-list__title position-list__title--xs";

        if (length >= 8)
            return "position-list__title position-list__title--sm";

        if (length >= 6)
            return "position-list__title position-list__title--md";

        return "position-list__title";
    }

    private static string ShortAddress(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "-";

        const int start = 7;
        const int end = 6;

        return value.Length <= start + end + 3
            ? value
            : $"{value[..start]}...{value[^end..]}";
    }
}

<style>
    .tokenomics-page {
        --tk-bg: #07090d;
        --tk-panel: rgba(10, 13, 21, 0.96);
        --tk-panel-soft: rgba(12, 16, 26, 0.92);
        --tk-border: rgba(118, 131, 164, 0.18);
        --tk-text: #eef4ff;
        --tk-muted: #aab7cb;
        --tk-purple: #9f5cff;
        --tk-green: #4cf38d;
        --tk-cyan: #53c8ff;
        --tk-gold: #f4c247;
        display: grid;
        gap: 1.35rem;
        position: relative;
        width: min(1680px, 100%);
        color: var(--tk-text);
    }

    .tokenomics-page::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
            radial-gradient(circle at 8% 12%, rgba(159, 92, 255, 0.14), transparent 20%),
            radial-gradient(circle at 92% 16%, rgba(76, 243, 141, 0.1), transparent 24%);
    }

    .tokenomics-hero {
        min-height: 0;
        border: 1px solid var(--tk-border);
        border-radius: 28px;
        overflow: hidden;
        box-shadow:
            0 30px 80px rgba(0, 0, 0, 0.42),
            inset 0 1px 0 rgba(255,255,255,0.05);
    }

    .tokenomics-hero__banner {
        display: block;
        width: 100%;
        height: auto;
        aspect-ratio: 923 / 321;
        object-fit: cover;
        background: #030507;
    }

    .rule-panel span,
    .metrics-band span,
    .positions-band span {
        color: #7ff6df;
        font-weight: 900;
        letter-spacing: .12em;
        text-transform: uppercase;
    }

    .metrics-band,
    .rule-panel,
    .positions-band,
    .rule-alert {
        position: relative;
        border: 1px solid var(--tk-border);
        border-radius: 24px;
        background:
            linear-gradient(180deg, rgba(10, 13, 21, 0.98), rgba(7, 9, 15, 0.99));
        box-shadow:
            0 24px 70px rgba(0,0,0,0.34),
            inset 0 1px 0 rgba(255,255,255,0.03);
        overflow: hidden;
    }

    .metrics-band::before,
    .rule-panel::before,
    .positions-band::before,
    .rule-alert::before,
    .topic-callout::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
            linear-gradient(135deg, rgba(126, 34, 206, 0.08), transparent 22%, transparent 72%, rgba(34, 197, 94, 0.07)),
            linear-gradient(90deg, rgba(255,255,255,0.02), transparent 18%, transparent 82%, rgba(255,255,255,0.02));
    }

    .metrics-band {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 1px;
        overflow: hidden;
        background: rgba(86, 100, 126, 0.16);
    }

    .metrics-band article {
        position: relative;
        padding: 1.15rem 1.2rem;
        background:
            linear-gradient(180deg, rgba(8, 11, 18, 0.98), rgba(8, 10, 16, 0.98));
        display: grid;
        gap: .42rem;
    }

    .metrics-band strong {
        color: #f8fbff;
        font-size: clamp(1.7rem, 2vw, 2.2rem);
        letter-spacing: -.04em;
    }

    .metrics-band small {
        color: var(--tk-muted);
    }

    .topic-callout {
        align-items: center;
        background:
            radial-gradient(circle at top left, rgba(159, 92, 255, .16), transparent 34%),
            radial-gradient(circle at bottom right, rgba(76, 243, 141, .12), transparent 32%),
            linear-gradient(135deg, rgba(11, 18, 26, .96), rgba(14, 21, 31, .94));
        border: 1px solid rgba(116, 131, 164, .2);
        border-radius: 24px;
        display: grid;
        gap: 1.2rem;
        grid-template-columns: minmax(0, 1fr) auto;
        padding: 1.2rem 1.35rem;
        position: relative;
        overflow: hidden;
    }

    .topic-callout h3 {
        color: #f8fbff;
        margin: .42rem 0 .5rem;
        font-size: clamp(1.35rem, 2vw, 1.8rem);
        letter-spacing: -.03em;
    }

    .topic-callout p {
        color: #ced8e6;
        line-height: 1.65;
        margin: 0;
        max-width: 780px;
    }

    .topic-link {
        align-items: center;
        background: linear-gradient(90deg, rgba(159, 92, 255, 0.94), rgba(76, 243, 141, 0.94));
        border-radius: 999px;
        color: #041018;
        display: inline-flex;
        font-weight: 900;
        min-height: 3rem;
        padding: 0 1.15rem;
        text-decoration: none;
        white-space: nowrap;
        box-shadow: 0 10px 24px rgba(24, 255, 112, 0.14);
    }

    .topic-link:hover {
        color: #041018;
        filter: brightness(1.05);
    }

    .rule-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 1rem;
    }

    .rule-panel {
        grid-column: span 4;
        padding: 1.15rem 1.15rem 1.2rem;
        display: grid;
        gap: .82rem;
        align-content: start;
    }

    .lead-panel,
    .contract-panel,
    .settlement-panel {
        grid-column: span 8;
    }

    .rule-panel h3,
    .positions-band h3 {
        color: #f8fbff;
        margin: 0;
        font-size: 1.45rem;
        letter-spacing: -.03em;
    }

    .rule-panel p {
        color: #d5e1ee;
        margin: 0;
        line-height: 1.65;
    }

    .flow-line {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: .65rem;
    }

    .flow-line strong,
    .legend span {
        border: 1px solid rgba(118, 131, 164, 0.18);
        border-radius: 14px;
        color: #f8fbff;
        padding: .8rem .7rem;
        text-align: center;
        background: rgba(9, 12, 19, 0.74);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
    }

    .rule-panel dl {
        display: grid;
        gap: .55rem;
        margin: 0;
    }

    .rule-panel dl div {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        border-top: 1px solid rgba(118, 131, 164, 0.14);
        padding-top: .68rem;
    }

    .rule-panel dt {
        color: #9fb0c7;
        font-weight: 900;
    }

    .rule-panel dd {
        color: #f8fbff;
        margin: 0;
        font-weight: 900;
        overflow-wrap: anywhere;
        text-align: right;
    }

    .allocation-bar {
        height: 14px;
        display: flex;
        overflow: hidden;
        border-radius: 999px;
        background: #0b1118;
        border: 1px solid rgba(118, 131, 164, 0.18);
    }

    .settlement-chart {
        display: grid;
        grid-template-columns: minmax(280px, 1.15fr) minmax(240px, .9fr);
        gap: 1rem;
        align-items: center;
        padding: 1rem;
        border: 1px solid rgba(118, 131, 164, 0.18);
        border-radius: 18px;
        background:
            radial-gradient(circle at left center, rgba(159, 92, 255, 0.09), transparent 30%),
            radial-gradient(circle at right center, rgba(76, 243, 141, 0.08), transparent 34%),
            #101720;
    }

    .settlement-chart__pie {
        width: 100%;
        min-height: 260px;
    }

    .settlement-chart__summary {
        display: grid;
        gap: .7rem;
    }

    .settlement-chart__target {
        display: grid;
        gap: .35rem;
        padding: .85rem .95rem;
        border-radius: 12px;
        border: 1px solid rgba(118, 131, 164, 0.18);
        background: rgba(11, 17, 24, 0.88);
    }

    .settlement-chart__target small {
        color: #94a3b8;
        font-size: .76rem;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .settlement-chart__target strong {
        color: #f8fafc;
        font-size: 1.1rem;
    }

    .settlement-chart__target--refund {
        border-color: rgba(94, 234, 212, 0.32);
        box-shadow: inset 3px 0 0 #5eead4;
    }

    .settlement-chart__target--winners {
        border-color: rgba(147, 197, 253, 0.28);
        box-shadow: inset 3px 0 0 #93c5fd;
    }

    .settlement-chart__target--house {
        border-color: rgba(248, 250, 252, 0.22);
        box-shadow: inset 3px 0 0 #f8fafc;
    }

    .allocation-bar i,
    .allocation-bar b,
    .allocation-bar em {
        display: block;
        min-width: 2px;
    }

    .allocation-bar i {
        background: #5eead4;
    }

    .allocation-bar b {
        background: #93c5fd;
    }

    .allocation-bar em {
        background: #f8fafc;
    }

    .legend {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: .5rem;
    }

    .positions-band {
        padding: 1.35rem 1.35rem 1.45rem;
        display: grid;
        gap: 1.15rem;
        background:
            radial-gradient(circle at left top, rgba(159, 92, 255, 0.08), transparent 26%),
            radial-gradient(circle at right center, rgba(76, 243, 141, 0.08), transparent 30%),
            linear-gradient(180deg, rgba(9, 13, 20, 0.98), rgba(7, 10, 16, 0.99));
    }

    .positions-band__header {
        display: grid;
        gap: .3rem;
        max-width: 42rem;
    }

    .positions-band__header p {
        margin: 0;
        color: #98a8bf;
        line-height: 1.6;
    }

    .position-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1rem;
    }

