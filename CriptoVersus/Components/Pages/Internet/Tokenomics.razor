@rendermode InteractiveServer
@page "/tokenomics"
@page "/en/how-it-works"
@page "/pt/como-funciona"
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersus.Web.Services.CriptoVersusApiClient Api
@inject IJSRuntime JS
@inject IConfiguration Config
@inject NavigationManager Nav
@inject AppCultureService AppCulture
@inject LocalizationService L
@inject RouteLocalizationService RouteLocalization
@using System.Text.Json

<PageTitle>@L.T("howItWorks.seo.title", CurrentCulture)</PageTitle>
<HeadContent>
    <meta name="description" content="@L.T("howItWorks.seo.description", CurrentCulture)" />
    <meta name="keywords" content="@MetaKeywords" />
    <link rel="canonical" href="@BuildAbsolute(RouteLocalization.BuildHowItWorksPath(CurrentCulture))" />
    <link rel="alternate" hreflang="en-US" href="@BuildAbsolute(RouteLocalization.BuildHowItWorksPath("en"))" />
    <link rel="alternate" hreflang="pt-BR" href="@BuildAbsolute(RouteLocalization.BuildHowItWorksPath("pt"))" />
    <link rel="alternate" hreflang="x-default" href="@BuildAbsolute(RouteLocalization.BuildHowItWorksPath("en"))" />
    <meta property="og:title" content="@L.T("howItWorks.seo.title", CurrentCulture)" />
    <meta property="og:description" content="@L.T("howItWorks.seo.description", CurrentCulture)" />
    <meta property="og:url" content="@BuildAbsolute(RouteLocalization.BuildHowItWorksPath(CurrentCulture))" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="@SocialImageUrl" />
    <meta property="og:image:alt" content="@L.T("howItWorks.seo.title", CurrentCulture)" />
    <meta property="og:locale" content="@(AppCulture.ToOgLocale(CurrentCulture))" />
    <meta property="og:locale:alternate" content="@(AppCulture.GetAlternateOgLocale(CurrentCulture))" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@L.T("howItWorks.seo.title", CurrentCulture)" />
    <meta name="twitter:description" content="@L.T("howItWorks.seo.description", CurrentCulture)" />
    <meta name="twitter:image" content="@SocialImageUrl" />
    <meta name="twitter:image:alt" content="@L.T("howItWorks.seo.title", CurrentCulture)" />
    <script type="application/ld+json">@StructuredDataMarkup</script>
</HeadContent>

<section class="tokenomics-page">
    <div class="tokenomics-hero">
        @if (IsEnglish)
        {
            <img class="tokenomics-hero__banner" src="/img/tokenomics-hero-banner-en.png" alt="@L.T("howItWorks.seo.title", CurrentCulture)" />
        }
        else
        {
            <img class="tokenomics-hero__banner" src="/img/tokenomics-hero-banner.png" alt="@L.T("howItWorks.seo.title", CurrentCulture)" />
        }
    </div>

    @if (_loading)
    {
        <p>@(CurrentCulture == "en" ? "Loading protocol rules..." : "Carregando regras do protocolo...")</p>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="rule-alert">@_error</div>
    }
    else if (_data is not null)
    {
        <div class="metrics-band">
            <article>
                <span>@(IsEnglish ? "Active capital" : "Capital ativo")</span>
                <strong>@FmtSol(_data.ActiveCapital)</strong>
                <small>@(IsEnglish ? $"{_data.ActivePositions} active positions" : $"{_data.ActivePositions} posicoes ativas")</small>
            </article>
            <article>
                <span>@(IsEnglish ? "Total allocated" : "Total alocado")</span>
                <strong>@FmtSol(_data.PrincipalAllocated)</strong>
                <small>@(IsEnglish ? $"{_data.Users} indexed users" : $"{_data.Users} usuarios indexados")</small>
            </article>
            <article>
                <span>@(IsEnglish ? "Cycles in progress" : "Ciclos em andamento")</span>
                <strong>@_data.OngoingMatches</strong>
                <small>@(IsEnglish ? $"{_data.PendingMatches} pending" : $"{_data.PendingMatches} pendentes")</small>
            </article>
            <article>
                <span>@(IsEnglish ? "In open matches" : "Em partidas abertas")</span>
                <strong>@FmtSol(_data.OpenEntryAmount)</strong>
                <small>@(IsEnglish ? $"{_data.OpenEntries} open entries" : $"{_data.OpenEntries} entradas abertas")</small>
            </article>
        </div>

        <section class="semantic-band">
            <article>
                <span>@(IsEnglish ? "Open positions" : "Posicoes abertas")</span>
                <p>
                    @(IsEnglish
                        ? "CriptoVersus is not only a scoreboard. Users open positions on one side of a live crypto arena and keep competitive staking-style exposure across cyclical battle pools."
                        : "O CriptoVersus nao e apenas um placar. Usuarios abrem posicoes em um lado da arena cripto ao vivo e mantem exposicao em estilo staking competitivo ao longo de pools ciclicos de batalha.")
                </p>
            </article>
            <article>
                <span>@(IsEnglish ? "Cyclical pools" : "Pools ciclicos")</span>
                <p>
                    @(IsEnglish
                        ? "Each arena cycle groups side selection, market performance, pool competition and recurring participation, so assets return to the battleground as new cycles open."
                        : "Cada ciclo da arena agrupa selecao de lado, performance de mercado, competicao entre pools e participacao recorrente, para que os ativos retornem ao campo quando novos ciclos se abrem.")
                </p>
            </article>
            <article>
                <span>@(IsEnglish ? "Reward redistribution" : "Redistribuicao de recompensas")</span>
                <p>
                    @(IsEnglish
                        ? "Rewards are redistributed according to real market performance, side-based pool mechanics and settlement rules, reinforcing a competitive crypto arena instead of a simple list of prices."
                        : "As recompensas sao redistribuidas de acordo com a performance real de mercado, com as mecanicas de pools por lado e com as regras de liquidacao, reforcando uma arena competitiva cripto em vez de uma simples lista de precos.")
                </p>
            </article>
        </section>

        <section class="topic-callout">
            <div>
                <span>@(IsEnglish ? "Special topic" : "Topico especial")</span>
                <h3>@(IsEnglish ? "Match rules and score formation" : "Regras das partidas e formacao do placar")</h3>
                <p>
                    @(IsEnglish
                        ? "See in detail how crossovers, thresholds, volume windows, crossover volume and the auditable event log rebuild every point in the match."
                        : "Veja em detalhe como funcionam cruzamentos, thresholds, volume por janela, volume por cruzamento e o log auditavel que reconstrui cada ponto da partida.")
                </p>
            </div>
            <a class="topic-link" href="@($"{RouteLocalization.BuildHowItWorksPath(CurrentCulture)}#pontuacao")">@(IsEnglish ? "Open full topic" : "Abrir topico completo")</a>
        </section>

        <div class="rule-grid">
            <section class="rule-panel lead-panel" id="como-funciona">
                <span>01</span>
                <h3>@(IsEnglish ? "How it works" : "Como funciona")</h3>
                <p>
                    @(IsEnglish
                        ? "Choose an asset, select a side through that asset, deposit SOL and keep your position active to automatically participate in new cycles whenever that asset returns. This way, you do not need to repeat the manual entry every round and your capital stays ready for the next competitive arena cycle."
                        : "Escolha um ativo, selecione um lado por meio desse ativo, deposite SOL e mantenha sua posicao ativa para participar automaticamente de novos ciclos sempre que esse ativo retornar. Assim, voce nao precisa repetir a entrada manual a cada rodada e seu capital continua pronto para o proximo ciclo competitivo da arena.")
                </p>
                <div class="flow-line">
                    <strong>@(IsEnglish ? "Deposit SOL" : "Depositar SOL")</strong>
                    <strong>@(IsEnglish ? "Enter position" : "Entrar na posicao")</strong>
                    <strong>@(IsEnglish ? "Settle when you want" : "Liquidar quando desejar")</strong>
                    <strong>@(IsEnglish ? "Continue automatically" : "Continuar automaticamente")</strong>
                </div>
            </section>

            <section class="rule-panel" id="posicoes">
                <span>02</span>
                <h3>@(IsEnglish ? "Positions" : "Posicoes")</h3>
                <p>
                    @(IsEnglish
                        ? "Each position belongs to a wallet and a specific asset. Current capital can grow after winning cycles, suffer controlled erosion in losing cycles or move into an exit process when the user requests to close the position, while still behaving like part of a larger cyclical arena pool."
                        : "Cada posicao pertence a uma carteira e a um ativo especifico. O capital atual pode crescer com ciclos vencedores, sofrer erosao controlada em ciclos perdedores ou entrar em processo de saida quando o usuario solicitar encerramento da posicao, enquanto continua se comportando como parte de um pool ciclico maior da arena.")
                </p>
                <dl>
                    <div><dt>@(IsEnglish ? "Active" : "Ativas")</dt><dd>@_data.ActivePositions</dd></div>
                    <div><dt>@(IsEnglish ? "Exit requested" : "Saida solicitada")</dt><dd>@_data.ClosingPositions</dd></div>
                    <div><dt>@(IsEnglish ? "Closed" : "Fechadas")</dt><dd>@_data.ClosedPositions</dd></div>
                </dl>
            </section>

            <section class="rule-panel" id="pontuacao">
                <span>03</span>
                <h3>@(IsEnglish ? "Scoring system" : "Sistema de Pontuacao")</h3>
                <p>
                    @(IsEnglish
                        ? $"Scoring compares the relative performance of assets inside the cycle. Every {_data.PercentPerGoal:0.##}% of advantage can be converted into goals, while respecting the maximum scoring cap per side defined in the operational configuration."
                        : $"A pontuacao compara a performance relativa dos ativos dentro do ciclo. A cada {_data.PercentPerGoal:0.##}% de vantagem, o ativo pode converter essa diferenca em gols, sempre respeitando o teto maximo de pontuacao por lado definido na configuracao operacional.")
                </p>
                <dl>
                    <div><dt>@(IsEnglish ? "% per goal" : "% por gol")</dt><dd>@_data.PercentPerGoal.ToString("0.##")%</dd></div>
                    <div><dt>@(IsEnglish ? "Cap per team" : "Limite por time")</dt><dd>@_data.MaxGoalsPerTeam</dd></div>
                </dl>
            </section>

            <section class="rule-panel" id="ciclos">
                <span>04</span>
                <h3>@(IsEnglish ? "Cycles" : "Ciclos")</h3>
                <p>
                    @(IsEnglish
                        ? "Each match represents a market cycle with an entry window, a tracking period and settlement. If automatic re-entry is enabled, recurring positions return to the game when the asset appears again, as long as the position remains active and above the minimum operational capital, creating cyclical participation instead of a one-off entry."
                        : "Cada partida representa um ciclo de mercado com janela de entrada, periodo de acompanhamento e liquidacao. Se a reentrada automatica estiver habilitada, posicoes recorrentes voltam ao jogo quando o ativo reaparece, desde que a posicao siga ativa e acima do capital minimo operacional, criando participacao ciclica em vez de uma entrada unica.")
                </p>
                <dl>
                    <div><dt>@(IsEnglish ? "Target duration" : "Duracao alvo")</dt><dd>@_data.MatchDurationMinutes min</dd></div>
                    <div><dt>@(IsEnglish ? "Auto re-entry" : "Reentrada automatica")</dt><dd>@(_data.AutoReenterEnabled ? (IsEnglish ? "Enabled" : "Ativa") : (IsEnglish ? "Paused" : "Pausada"))</dd></div>
                </dl>
            </section>

            <section class="rule-panel settlement-panel" id="liquidacao">
                <span>05</span>
                <h3>@(IsEnglish ? "Settlement" : "Liquidacao")</h3>
                <p>
                    @(IsEnglish
                        ? "The winning side receives a proportional gain from the distributable share generated by the losing side. The losing side preserves most of its capital, reducing fast elimination and reinforcing a dynamic closer to a rotating pool with reward redistribution than a classic single-round bet."
                        : "O lado vencedor recebe ganho proporcional da parcela distribuivel originada no lado perdedor. O lado perdedor preserva a maior parte do capital, reduzindo a eliminacao rapida e reforcando uma dinamica mais parecida com pool rotativa com redistribuicao de recompensas do que com aposta classica de rodada unica.")
                </p>
                <div class="settlement-chart" aria-label="@(IsEnglish ? "Settlement distribution" : "Distribuicao da liquidacao")">
                    <div class="settlement-chart__pie" @ref="_settlementPieRef"></div>
                    <div class="settlement-chart__summary">
                        <article class="settlement-chart__target settlement-chart__target--refund">
                            <small>@(IsEnglish ? "Loser refund" : "Retorno ao perdedor")</small>
                            <strong>@FmtPct(_data.LoserRefundRate)</strong>
                        </article>
                        <article class="settlement-chart__target settlement-chart__target--winners">
                            <small>@(IsEnglish ? "Winners pool" : "Pool dos vencedores")</small>
                            <strong>@FmtPct(_data.WinnerPoolRate)</strong>
                        </article>
                        <article class="settlement-chart__target settlement-chart__target--house">
                            <small>@(IsEnglish ? "House fee" : "Taxa da casa")</small>
                            <strong>@FmtPct(_data.HouseFeeRate)</strong>
                        </article>
                    </div>
                </div>
                <div class="allocation-bar">
                    <i style="width:@PctCss(_data.LoserRefundRate)"></i>
                    <b style="width:@PctCss(_data.WinnerPoolRate)"></b>
                    <em style="width:@PctCss(_data.HouseFeeRate)"></em>
                </div>
                <div class="legend">
                    <span>@(IsEnglish ? $"Loser recovers {FmtPct(_data.LoserRefundRate)}" : $"Perdedor recupera {FmtPct(_data.LoserRefundRate)}")</span>
                    <span>@(IsEnglish ? $"Winners receive {FmtPct(_data.WinnerPoolRate)}" : $"Vencedores recebem {FmtPct(_data.WinnerPoolRate)}")</span>
                    <span>@(IsEnglish ? $"House {FmtPct(_data.HouseFeeRate)}" : $"Casa {FmtPct(_data.HouseFeeRate)}")</span>
                </div>
            </section>

            <section class="rule-panel" id="taxas">
                <span>06</span>
                <h3>@(IsEnglish ? "Fees" : "Taxas")</h3>
                <p>
                    @(IsEnglish
                        ? "The house fee is kept at a reduced level to support operations, indexing and operational infrastructure without consuming an aggressive share of participant capital in each cycle."
                        : "A taxa da casa e mantida em nivel reduzido para sustentar a operacao, a indexacao e a infraestrutura operacional, sem consumir uma parcela agressiva do capital dos participantes a cada ciclo.")
                </p>
                <dl>
                    <div><dt>@(IsEnglish ? "House fee" : "Taxa da casa")</dt><dd>@FmtPct(_data.HouseFeeRate)</dd></div>
                    <div><dt>@(IsEnglish ? "Minimum capital" : "Capital minimo")</dt><dd>@FmtSol(_data.MinPositionCapital)</dd></div>
                </dl>
            </section>

            <section class="rule-panel" id="retirada">
                <span>07</span>
                <h3>@(IsEnglish ? "Withdrawal" : "Retirada")</h3>
                <p>
                    @(IsEnglish
                        ? "The user can request to exit the position at any time. If there is an active cycle, the position waits for that cycle settlement; after that, the remaining capital can proceed to closing and withdrawal according to the operational flow enabled in the system."
                        : "O usuario pode solicitar saida da posicao a qualquer momento. Se houver ciclo ativo, a posicao aguarda a liquidacao daquele ciclo; depois disso, o capital remanescente pode seguir para encerramento e retirada conforme o fluxo operacional habilitado no sistema.")
                </p>
            </section>

            <section class="rule-panel" id="riscos">
                <span>08</span>
                <h3>@(IsEnglish ? "Risks" : "Riscos")</h3>
                <p>
                    @(IsEnglish
                        ? "The protocol operates with volatile assets, automated rules and contracts on the Solana network. Small losses per cycle can accumulate over time, parameters may be adjusted by operations and a devnet environment must not be interpreted as a guarantee of returns, liquidity or future performance."
                        : "O protocolo opera com ativos volateis, regras automatizadas e contratos em rede Solana. Pequenas perdas por ciclo podem se acumular ao longo do tempo, parametros podem ser ajustados pela operacao e ambiente de devnet nao deve ser interpretado como garantia de retorno, liquidez ou desempenho futuro.")
                </p>
            </section>

            <section class="rule-panel contract-panel" id="contrato">
                <span>09</span>
                @if (IsOffChainCustodyMode)
                {
                    <h3>@(IsEnglish ? "Custody wallet" : "Carteira de custodia")</h3>
                    <p>
                        @(IsEnglish
                            ? $"In Off-chain Custody mode, operational funds are reconciled outside the contract. The Solana wallet remains the user identity, while transfers to the custody wallet on the {_data.Cluster} network must be recognized by the system before becoming internal betting balance."
                            : $"No modo Off-chain Custody, os fundos operacionais sao conciliados fora do contrato. A wallet Solana continua sendo a identidade do usuario, enquanto as transferencias para a carteira de custodia na rede {_data.Cluster} precisam ser reconhecidas pelo sistema para virar saldo interno de apostas.")
                    </p>
                    <dl>
                        <div><dt>@(IsEnglish ? "Wallet" : "Carteira")</dt><dd title="@_data.CustodyWalletPublicKey">@ShortAddress(_data.CustodyWalletPublicKey)</dd></div>
                        <div><dt>Label</dt><dd>@DisplayCustodyWalletLabel</dd></div>
                        <div><dt>@(IsEnglish ? "Network" : "Rede")</dt><dd>@_data.Cluster</dd></div>
                    </dl>
                }
                else
                {
                    <h3>@(IsEnglish ? "On-chain contract" : "Contrato on-chain")</h3>
                    <p>
                        @(IsEnglish
                            ? $"Deposits and positions use the configured program on the {_data.Cluster} network. The backend acts as an indexer and orchestration layer, while the on-chain position preserves traceability for capital, linked addresses and the operational logic published in the contract."
                            : $"Depositos e posicoes usam o programa configurado na rede {_data.Cluster}. O backend atua como indexador e camada de orquestracao, enquanto a posicao on-chain preserva a rastreabilidade do capital, dos enderecos vinculados e da logica operacional publicada no contrato.")
                    </p>
                    <dl>
                        <div><dt>Program ID</dt><dd title="@_data.ProgramId">@ShortAddress(_data.ProgramId)</dd></div>
                        <div><dt>Authority</dt><dd title="@_data.AuthorityWallet">@ShortAddress(_data.AuthorityWallet)</dd></div>
                        <div><dt>@(IsEnglish ? "Network" : "Rede")</dt><dd>@_data.Cluster</dd></div>
                    </dl>
                }
            </section>
        </div>

        @if (_data.TopPositions.Count > 0)
        {
            <section class="positions-band">
                <div class="positions-band__header">
                    <span>@(IsEnglish ? "Assets with more capital" : "Ativos com mais capital")</span>
                    <h3>@(IsEnglish ? "Current position distribution" : "Distribuicao atual das posicoes")</h3>
                    <p>@(IsEnglish ? "Quick read of the positions with the highest active capital right now." : "Leitura rapida das posicoes com maior capital ativo neste momento.")</p>
                </div>
                <div class="position-list">
                    @{
                        var rank = 1;
                    }
                    @foreach (var position in _data.TopPositions)
                    {
                        <article>
                            <div class="position-list__rank">@rank.ToString("00")</div>
                            <div class="position-list__body">
                                <strong class="@GetPositionTitleClass(position.Symbol)">
                                    <span>@GetBaseSymbol(position.Symbol)</span>
                                    <span class="position-list__quote" title="@GetBaseSymbol(position.Symbol)">
                                        <img src="@GetCoinIconUrl(GetBaseSymbol(position.Symbol))"
                                             alt="@GetBaseSymbol(position.Symbol)"
                                             loading="lazy"
                                             onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                        <span class="position-list__quote-fallback d-none">@GetBaseSymbol(position.Symbol)</span>
                                    </span>
                                </strong>
                                <span>@FmtSol(position.CurrentCapital)</span>
                                <small>@(IsEnglish ? "Capital in play" : "Capital em jogo")</small>
                            </div>
                        </article>
                        rank++;
                    }
                </div>
            </section>
        }
    }
</section>

@code {
    private TokenomicsDto? _data;
    private bool _loading = true;
    private string? _error;
    private ElementReference _settlementPieRef;
    private bool _settlementChartRendered;

    private bool IsOffChainCustodyMode
        => string.Equals(_data?.BlockchainMode, "OffChainCustody", StringComparison.OrdinalIgnoreCase);

    private string CurrentCulture => AppCulture.GetCurrentRouteCulture(Nav);
    private bool IsEnglish => CurrentCulture == "en";
    private string MetaKeywords => $"{SeoDefaults.GlobalKeywords}, CriptoVersus how it works, #CriptoVersus rules, crypto scoring rules";
    private string SocialImageUrl => BuildAbsolute(IsEnglish ? "/img/tokenomics-hero-banner-en.png" : "/img/tokenomics-hero-banner.png");
    private MarkupString StructuredDataMarkup => new(BuildStructuredDataJson());

    private string BuildAbsolute(string relativePath)
    {
        var baseUrl = Config["CriptoVersus:PublicBaseUrl"]?.TrimEnd('/') ?? Nav.BaseUri.TrimEnd('/');
        return $"{baseUrl}{relativePath}";
    }

    private string DisplayCustodyWalletLabel
        => string.IsNullOrWhiteSpace(_data?.CustodyWalletLabel)
            ? (IsEnglish ? "Custody wallet" : "Carteira de custodia")
            : _data!.CustodyWalletLabel;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _data = await Api.GetTokenomicsAsync();
        }
        catch (Exception ex)
        {
            _error = IsEnglish
                ? $"Unable to load dynamic rules: {ex.Message}"
                : $"Nao foi possivel carregar as regras dinamicas: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_data is null || _settlementChartRendered)
            return;

        _settlementChartRendered = true;

        await JS.InvokeVoidAsync(
            "tokenomicsCharts.renderSettlementPie",
            _settlementPieRef,
            new
            {
                loserRefundRate = decimal.ToDouble(_data.LoserRefundRate),
                winnerPoolRate = decimal.ToDouble(_data.WinnerPoolRate),
                houseFeeRate = decimal.ToDouble(_data.HouseFeeRate)
            });
    }

    private static string FmtSol(decimal value)
        => $"{value:0.########} SOL";

    private static string FmtPct(decimal value)
        => $"{value * 100m:0.##}%";

    private static string PctCss(decimal value)
        => $"{Math.Max(0m, Math.Min(1m, value)) * 100m:0.##}%";

    private static string GetBaseSymbol(string pair)
    {
        if (string.IsNullOrWhiteSpace(pair))
            return "";

        var normalized = pair.Trim().ToUpperInvariant();
        var quotes = new[] { "USDT", "USDC", "BUSD", "BRL", "EUR", "BTC", "ETH" };

        foreach (var quote in quotes)
        {
            if (normalized.EndsWith(quote, StringComparison.OrdinalIgnoreCase) && normalized.Length > quote.Length)
                return normalized[..^quote.Length];
        }

        return normalized;
    }

    private string GetCoinIconUrl(string symbol)
        => CriptoVersus.Web.Services.EnvironmentIsolationGuard.BuildBinanceIconUrl(symbol.Trim().ToUpperInvariant());

    private static string GetPositionTitleClass(string pair)
    {
        var length = GetBaseSymbol(pair).Length;

        if (length >= 10)
            return "position-list__title position-list__title--xs";

        if (length >= 8)
            return "position-list__title position-list__title--sm";

        if (length >= 6)
            return "position-list__title position-list__title--md";

        return "position-list__title";
    }

    private static string ShortAddress(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "-";

        const int start = 7;
        const int end = 6;

        return value.Length <= start + end + 3
            ? value
            : $"{value[..start]}...{value[^end..]}";
    }

    private string BuildStructuredDataJson()
    {
        var pageUrl = BuildAbsolute(RouteLocalization.BuildHowItWorksPath(CurrentCulture));
        var description = L.T("howItWorks.seo.description", CurrentCulture);
        var about = IsEnglish
            ? new[]
            {
                "open positions",
                "cyclical pools",
                "reward redistribution",
                "side selection",
                "competitive staking",
                "market performance"
            }
            : new[]
            {
                "abertura de posicoes",
                "pools ciclicos",
                "redistribuicao de recompensas",
                "selecao de lado",
                "staking competitivo",
                "performance de mercado"
            };

        return JsonSerializer.Serialize(new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@graph"] = new object[]
            {
                new Dictionary<string, object?>
                {
                    ["@type"] = "WebPage",
                    ["name"] = L.T("howItWorks.seo.title", CurrentCulture),
                    ["url"] = pageUrl,
                    ["description"] = description,
                    ["abstract"] = IsEnglish
                        ? "How CriptoVersus handles positions, cyclical pools, side selection, reward redistribution and competitive staking across live crypto arena cycles."
                        : "Como o CriptoVersus trata posicoes, pools ciclicos, selecao de lado, redistribuicao de recompensas e staking competitivo ao longo de ciclos da arena cripto ao vivo.",
                    ["about"] = about,
                    ["keywords"] = about,
                    ["inLanguage"] = AppCulture.ToHrefLang(CurrentCulture)
                },
                new Dictionary<string, object?>
                {
                    ["@type"] = "BreadcrumbList",
