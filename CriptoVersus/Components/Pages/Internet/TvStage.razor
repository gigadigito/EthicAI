    private async Task LogClockDebugAsync()
    {
        if (!Environment.IsDevelopment() || _tvModule is null)
            return;

        var payload = new
        {
            HotMatchRemainingSeconds = HotMatch?.RemainingSeconds,
            HotMatchRemainingTimeLabel = HotMatch?.RemainingTimeLabel,
            MatchRemainingMinutes = Match?.RemainingMinutes,
            SeedMilliseconds = ResolveRemainingMillisecondsSeed(),
            DisplayRemainingTime = DisplayRemainingTime(),
            DisplayClockPrimary = DisplayClockPrimary()
        };

        var signature = string.Join("|",
            payload.HotMatchRemainingSeconds?.ToString(CultureInfo.InvariantCulture) ?? "null",
            payload.HotMatchRemainingTimeLabel ?? "null",
            payload.MatchRemainingMinutes?.ToString(CultureInfo.InvariantCulture) ?? "null",
            payload.SeedMilliseconds.ToString("0", CultureInfo.InvariantCulture),
            payload.DisplayRemainingTime,
            payload.DisplayClockPrimary);

        if (signature == _clockDebugSignature)
            return;

        _clockDebugSignature = signature;
        await LogAsync("TV_CLOCK_DEBUG", "state", payload);
    }

    private static int ParseRemainingSeconds(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return 0;

        var cleaned = value.Trim();
        var start = cleaned.IndexOfAny("0123456789".ToCharArray());
        if (start > 0)
            cleaned = cleaned[start..];

        var parts = cleaned.Split(':', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 2
            && int.TryParse(parts[0], NumberStyles.Integer, CultureInfo.InvariantCulture, out var minutes)
            && int.TryParse(parts[1], NumberStyles.Integer, CultureInfo.InvariantCulture, out var seconds)
            && minutes >= 0
            && seconds >= 0
            && seconds < 60)
        {
            return (minutes * 60) + seconds;
        }

        return 0;
    }

    private string FormatChangePercent(decimal? value)
        => value.HasValue
            ? value.Value > 0m
                ? $"+{value.Value:0.00}%"
                : $"{value.Value:0.00}%"
            : "--";

    private string GetChangeClass(decimal? value)
        => value switch
        {
            > 0m => "tv-change tv-change--positive",
            < 0m => "tv-change tv-change--negative",
            0m => "tv-change tv-change--neutral",
            _ => "tv-change tv-change--missing"
        };

    private string FormatPercent(decimal value)
        => $"{value:0.#}%";

    private string FormatSignedPercent(decimal value)
        => value >= 0m ? $"+{value:0.##}%" : $"{value:0.##}%";

    private string FormatStatus(string? status)
        => string.Equals(status, "Ongoing", StringComparison.OrdinalIgnoreCase)
            ? T("labels.liveArena")
            : string.Equals(status, "Completed", StringComparison.OrdinalIgnoreCase)
                ? T("labels.completed")
                : T("labels.nextBattle");

    private async Task LogAsync(string prefix, string eventName, object? payload = null)
    {
        if (_isDisposed || _tvModule is null)
            return;

        try
        {
            await _tvModule.InvokeVoidAsync("log", prefix, eventName, payload);
        }
        catch (ObjectDisposedException)
        {
        }
    }

