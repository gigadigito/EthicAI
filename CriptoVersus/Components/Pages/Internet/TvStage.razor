    private string BuildRemainingTimeFallback()
    {
        var remaining = Match?.RemainingMinutes ?? 0;
        return $"{Math.Max(0, remaining):00}:00";
    }

    private static string FormatClock(int totalSeconds)
    {
        if (totalSeconds < 0)
            return "--:--";

        var minutes = totalSeconds / 60;
        var seconds = totalSeconds % 60;
        return $"{minutes:00}:{seconds:00}";
    }

    private static string FormatPreciseClock(TimeSpan remaining)
    {
        var safe = remaining < TimeSpan.Zero ? TimeSpan.Zero : remaining;
        var totalMinutes = (int)Math.Floor(safe.TotalMinutes);
        return $"{totalMinutes:00}:{safe.Seconds:00}";
    }

    private void SyncClockAnchor()
    {
        _clockAnchorRemainingMilliseconds = ResolveRemainingMillisecondsSeed();
        _clockAnchorUtc = DateTime.UtcNow;
    }

    private double ResolveRemainingMillisecondsSeed()
    {
        if (HotMatch?.RemainingSeconds is int explicitRemainingSeconds)
            return Math.Max(0, explicitRemainingSeconds) * 1000d;

        var parsed = ParseRemainingSeconds(DisplayRemainingTime());
        if (parsed > 0)
            return parsed * 1000d;

        return Math.Max(0, (Match?.RemainingMinutes ?? 0) * 60) * 1000d;
    }

    private TimeSpan? ResolvePreciseRemainingTime()
    {
        if (_clockAnchorRemainingMilliseconds <= 0d)
            return null;

        var elapsedMs = Math.Max(0d, (DateTime.UtcNow - _clockAnchorUtc).TotalMilliseconds);
        var remainingMs = Math.Max(0d, _clockAnchorRemainingMilliseconds - elapsedMs);
        return TimeSpan.FromMilliseconds(remainingMs);
    }

    private TvClockState ResolveClockState()
    {
        var startUtc = ResolveMatchStartUtc();
        if (startUtc is null)
            return BuildFallbackClockState();

        var elapsedSeconds = Math.Max(0, (int)Math.Floor((DateTime.UtcNow - startUtc.Value).TotalSeconds));
        const int firstHalfSeconds = 45 * 60;
        const int halfTimeEndSeconds = 60 * 60;
        const int secondHalfEndSeconds = 105 * 60;

        if (elapsedSeconds < firstHalfSeconds)
            return new TvClockState(TvClockPhase.FirstHalf, elapsedSeconds);

        if (elapsedSeconds < halfTimeEndSeconds)
            return new TvClockState(TvClockPhase.HalfTime, firstHalfSeconds);

        if (elapsedSeconds < secondHalfEndSeconds)
            return new TvClockState(TvClockPhase.SecondHalf, elapsedSeconds - (15 * 60));

        return new TvClockState(TvClockPhase.Final, 90 * 60);
    }

    private DateTime? ResolveMatchStartUtc()
        => HotMatch?.MatchStartTimeUtc ?? Match?.StartTime;

    private TvClockState BuildFallbackClockState()
    {
        var fallbackRemainingSeconds = HotMatch?.RemainingSeconds ?? ParseRemainingSeconds(DisplayRemainingTime());
        if (fallbackRemainingSeconds > 0)
        {
            var elapsed = Math.Max(0, (90 * 60) - fallbackRemainingSeconds);
            return elapsed < 45 * 60
                ? new TvClockState(TvClockPhase.FirstHalf, elapsed)
                : new TvClockState(TvClockPhase.SecondHalf, Math.Min(90 * 60, elapsed));
        }

        return new TvClockState(TvClockPhase.FirstHalf, 0);
    }

    private string BuildVolumeFallback()
    {
        var totalPool = (Match?.TotalAmountTeamA ?? 0m) + (Match?.TotalAmountTeamB ?? 0m);
        return $"{totalPool:0.##} SOL";
    }

    private string BuildMomentumFallback()
    {
        if (Match is null)
            return T("labels.momentum");

        var leader = (Match.PctA ?? 0m) >= (Match.PctB ?? 0m) ? Match.TeamA : Match.TeamB;
        return string.Format(CultureInfo.InvariantCulture, T("labels.pressureRising"), leader);
    }

    private string BuildReasonFallback()
    {
        if (Match is null)
            return T("states.noHotMatchRightNow");

        if (Math.Abs(Match.ScoreA - Match.ScoreB) <= 1)
            return T("fallback.closeMatchReason");

        return T("fallback.liveArenaReason");
    }

    private string ResolvePressureSymbolFallback()
    {
        if (Match is null)
            return DisplayLeaderSymbol();

        var poolA = Match.TotalAmountTeamA;
        var poolB = Match.TotalAmountTeamB;
        if (poolA == poolB)
            return ResolveMomentumLeader();

        return poolA > poolB ? DisplayLeftSymbol() : DisplayRightSymbol();
    }

    private string BuildPoolStatusFallback()
    {
        if (Match is null)
            return T("labels.poolStatusIdle");

        if (Match.TotalPool > 0m && Math.Abs(DisplayLeftScore() - DisplayRightScore()) <= 1)
            return T("labels.poolStatusBalanced");

        if (Match.TotalPool > 0m)
            return T("labels.poolStatusOpen");

        return T("labels.poolStatusIdle");
    }

