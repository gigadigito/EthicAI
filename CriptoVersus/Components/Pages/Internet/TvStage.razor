            return T("refreshing");

        if (HasArenaCommentaryFeed)
            return IsPortugueseCulture
                ? $"{_arenaCommentaryFeed.Count} eventos ao vivo"
                : $"{_arenaCommentaryFeed.Count} live events";

        if (_lastAiNarrationAtUtc.HasValue)
            return T("labels.commentaryMetaTimestamp", T("commentary.source.aiDisabled"), _lastAiNarrationAtUtc.Value.ToString("HH:mm:ss", CultureInfo.InvariantCulture));

