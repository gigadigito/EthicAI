    private async Task MaybeRefreshAiNarrationAsync(string eventType, bool forceRefresh = false)
    {
        var matchId = HotMatch?.MatchId ?? Match?.MatchId ?? 0;
        if (matchId <= 0 || _isAiNarrationLoading)
            return;

        var signature = string.Join("|",
            matchId,
            eventType,
            DisplayLeftScore(),
            DisplayRightScore(),
            DisplayLeaderSymbol(),
            DisplayPressureSymbol(),
            DisplayHotScore(),
            DisplayRemainingTime());

        if (!forceRefresh && string.Equals(signature, _lastAiNarrationRequestSignature, StringComparison.Ordinal))
            return;

        _isAiNarrationLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var response = ArenaCommentary.Generate(BuildCommentaryContext(eventType));

            if (!string.IsNullOrWhiteSpace(response.Text))
            {
                _currentAiNarration = response.Text;
                _aiNarrationSource = response.Source;
                _lastAiNarrationAtUtc = response.GeneratedAtUtc;
                _commentaryHistory = response.History.ToList();
                _lastAiNarrationRequestSignature = signature;
            }
        }
        catch (Exception ex)
        {
            await LogAsync("TV_ARENA_COMMENTARY", "refresh error", ex.Message);
        }
        finally
        {
            _isAiNarrationLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private TvArenaCommentaryContext BuildCommentaryContext(string eventType)
    {
        var teamA = DisplayLeftSymbol();
        var teamB = DisplayRightSymbol();
        var leader = DisplayLeaderSymbol();
        var remainingSeconds = ParseRemainingSeconds(DisplayRemainingTime());
        var remainingTime = TimeSpan.FromSeconds(Math.Max(0, remainingSeconds));
        var totalPool = Match?.TotalPoolAmount > 0m
            ? Match.TotalPoolAmount
            : Match?.TotalPool > 0m
                ? Match.TotalPool
                : 0m;
        var competitiveness = Math.Clamp(100 - (Math.Abs(DisplayLeftScore() - DisplayRightScore()) * 18) - (int)(Math.Abs((DisplayLeftChangePercent() ?? 0m) - (DisplayRightChangePercent() ?? 0m)) * 10m), 30, 98);

        return new TvArenaCommentaryContext(
            MatchId: HotMatch?.MatchId ?? Match?.MatchId ?? 0,
            Culture: Culture,
            TeamA: teamA,
            TeamB: teamB,
            ScoreA: DisplayLeftScore(),
            ScoreB: DisplayRightScore(),
            PercentA: DisplayLeftChangePercent() ?? 0m,
            PercentB: DisplayRightChangePercent() ?? 0m,
            Momentum: DisplayMomentum(),
            Leader: leader,
            RemainingTime: remainingTime,
            HotScore: HotMatch?.HotScore ?? competitiveness,
            PoolVolume: totalPool,
            Competitiveness: competitiveness,
            EventType: eventType,
            IsFinished: string.Equals(Match?.Status, "Completed", StringComparison.OrdinalIgnoreCase) || Match?.IsFinished == true);
    }

