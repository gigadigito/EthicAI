    private object CreateDevReplayEvent(string eventType)
    {
        var leftSymbol = DisplayLeftSymbol();
        var rightSymbol = DisplayRightSymbol();
        var leaderSymbol = ResolveLeaderSymbol();
        var attackerIsLeft = !string.Equals(leaderSymbol, rightSymbol, StringComparison.OrdinalIgnoreCase);

        var attackerSymbol = attackerIsLeft ? leftSymbol : rightSymbol;
        var opponentSymbol = attackerIsLeft ? rightSymbol : leftSymbol;

        var leftChange = DisplayLeftChangePercent();
        var rightChange = DisplayRightChangePercent();
        var difference = leftChange.HasValue && rightChange.HasValue
            ? Math.Abs(leftChange.Value - rightChange.Value)
            : (decimal?)null;

        var minute = DisplayClockPrimary();
        if (string.IsNullOrWhiteSpace(minute) || minute == "--:--")
            minute = "43:27";

        var leftScore = DisplayLeftScore();
        var rightScore = DisplayRightScore();
        var scoreAfterAttack = attackerIsLeft
            ? $"{leftScore + 1} vs {rightScore}"
            : $"{leftScore} vs {rightScore + 1}";

        var preset = ReplayDebugPresets.FirstOrDefault(x => string.Equals(x.EventType, eventType, StringComparison.OrdinalIgnoreCase))
            ?? ReplayDebugPresets[0];

        return new
        {
            eventType = preset.EventType,
            team = attackerSymbol,
            opponent = opponentSymbol,
            animation = preset.Animation,
            reason = preset.Reason,
            value = difference.HasValue && difference.Value > 0m ? (double)difference.Value : 8.24,
            minute,
            teamLogo = GetLogoUrl(attackerIsLeft ? DisplayLeftLogoUrl() : DisplayRightLogoUrl()),
            opponentLogo = GetLogoUrl(attackerIsLeft ? DisplayRightLogoUrl() : DisplayLeftLogoUrl()),
            teamColor = GetAccentColor(attackerSymbol),
            opponentColor = GetAccentColor(opponentSymbol),
            intensity = 0.8,
            scoreLine = scoreAfterAttack
        };
    }

    private object CreateScoreReplayEvent(BroadcastSnapshot current, MatchScoreEventDto scoreEvent)
    {
        var eventType = NormalizeReplayEventType(scoreEvent);
        var animation = ResolveReplayAnimation(eventType, scoreEvent.RuleType);
        var scorerIsLeft = string.Equals(scoreEvent.TeamSymbol, current.LeftSymbol, StringComparison.OrdinalIgnoreCase);
        var teamSymbol = scorerIsLeft ? current.LeftSymbol : current.RightSymbol;
        var opponentSymbol = scorerIsLeft ? current.RightSymbol : current.LeftSymbol;
        var displayTeamSymbol = GetBaseSymbol(teamSymbol);
        var displayOpponentSymbol = GetBaseSymbol(opponentSymbol);
        var leftScore = current.LeftScore;
        var rightScore = current.RightScore;

        return new
        {
            eventType,
            team = displayTeamSymbol,
            opponent = displayOpponentSymbol,
            animation,
            reason = BuildReplayReason(scoreEvent),
            value = ResolveReplayValue(scoreEvent),
            minute = DisplayClockPrimary(),
            teamLogo = GetLogoUrl(scorerIsLeft ? DisplayLeftLogoUrl() : DisplayRightLogoUrl()),
            opponentLogo = GetLogoUrl(scorerIsLeft ? DisplayRightLogoUrl() : DisplayLeftLogoUrl()),
            teamColor = GetAccentColor(displayTeamSymbol),
            opponentColor = GetAccentColor(displayOpponentSymbol),
            intensity = ResolveReplayIntensity(scoreEvent),
            scoreLine = $"{leftScore} vs {rightScore}"
        };
    }

    private static string NormalizeReplayEventType(MatchScoreEventDto scoreEvent)
    {
        var candidates = new[]
        {
            scoreEvent.EventType,
            scoreEvent.RuleType,
            scoreEvent.ReasonCode
        };

        foreach (var candidate in candidates)
        {
            if (string.IsNullOrWhiteSpace(candidate))
                continue;

            var normalized = candidate.Trim().ToUpperInvariant();
            if (normalized.Contains("PENAL"))
                return "PENALTY_KICK";
            if (normalized.Contains("CROSS"))
                return "CROSSOVER_UP";
            if (normalized.Contains("VOLUME") && normalized.Contains("SPIKE"))
                return "VOLUME_SPIKE";
            if (normalized.Contains("FEAR"))
                return "FEAR_DOMINANCE";
            if (normalized.Contains("THRESHOLD") && normalized.Contains("16"))
                return "THRESHOLD_16";
            if (normalized.Contains("THRESHOLD") && normalized.Contains("8"))
                return "THRESHOLD_8";
            if (normalized.Contains("THRESHOLD") && normalized.Contains("2"))
                return "THRESHOLD_2";
            if (normalized.Contains("VOLUME") && normalized.Contains("WINDOW"))
                return "VOLUME_SPIKE";
            if (normalized.Contains("HEADER"))
                return "VOLUME_SPIKE";
            if (normalized.Contains("CORNER"))
                return "FEAR_DOMINANCE";
        }

        return "THRESHOLD_8";
    }

    private static string ResolveReplayAnimation(string eventType, string? ruleType)
    {
        var normalizedEventType = (eventType ?? string.Empty).Trim().ToUpperInvariant();
        var normalizedRuleType = (ruleType ?? string.Empty).Trim().ToUpperInvariant();

        if (normalizedEventType.Contains("PENAL"))
            return "PENALTY_KICK";
        if (normalizedEventType.Contains("CROSS"))
            return "BICYCLE_KICK";
        if (normalizedEventType.Contains("VOLUME") && normalizedEventType.Contains("SPIKE"))
            return "HEADER_GOAL";
        if (normalizedEventType.Contains("FEAR"))
            return "CORNER_GOAL";
        if (normalizedEventType.Contains("THRESHOLD") && normalizedEventType.Contains("16"))
            return "CINEMATIC_SUPER_GOAL";
        if (normalizedEventType.Contains("THRESHOLD") && normalizedEventType.Contains("8"))
            return "POWER_SHOT";
        if (normalizedEventType.Contains("THRESHOLD") && normalizedEventType.Contains("2"))
            return "SIMPLE_SHOT";

        if (normalizedRuleType.Contains("PERCENTAGECROSSOVER"))
            return "BICYCLE_KICK";
        if (normalizedRuleType.Contains("VOLUMEWINDOW") || normalizedRuleType.Contains("VOLUMECROSSOVER"))
            return "HEADER_GOAL";
        if (normalizedRuleType.Contains("ARENAPRESSURE"))
            return "CORNER_GOAL";
        if (normalizedRuleType.Contains("PERCENTTHRESHOLD"))
            return "POWER_SHOT";

        return "POWER_SHOT";
    }

    private static string BuildReplayReason(MatchScoreEventDto scoreEvent)
        => !string.IsNullOrWhiteSpace(scoreEvent.Description)
            ? scoreEvent.Description
            : !string.IsNullOrWhiteSpace(scoreEvent.ReasonCode)
                ? scoreEvent.ReasonCode!
                : scoreEvent.RuleType switch
                {
                    "PercentThreshold" => "Superou o limiar percentual",
                    "PercentageCrossover" => "Cruzou a linha com impulso",
                    "VolumeWindow" => "Dominou a janela de volume",
                    "VolumeCrossover" => "Virou o volume a favor",
                    "ArenaPressure" => "Pressao de arena convertida",
                    _ => "Evento de pontuacao detectado"
                };

    private bool ShouldRenderScoreEventInCompareChart(MatchScoreEventDto scoreEvent)
    {
        var ruleType = scoreEvent.RuleType ?? string.Empty;
        if (string.IsNullOrWhiteSpace(ruleType))
            return false;

        // Market Battle Flow plots the physical battle between the two percentage lines,
        // so only upward percentage crossovers belong to this layer.
        return IsPercentageCrossoverRule(ruleType);
    }

    private static bool IsPercentageCrossoverRule(string ruleType)
        => ruleType.Equals("PercentageCrossover", StringComparison.OrdinalIgnoreCase);

    private static double ResolveReplayValue(MatchScoreEventDto scoreEvent)
    {
        var candidates = new decimal?[]
        {
            scoreEvent.TeamPercentageChange,
            scoreEvent.MetricDelta
        };

        foreach (var candidate in candidates)
        {
            if (candidate.HasValue)
                return (double)candidate.Value;
        }

        return scoreEvent.Points > 0 ? scoreEvent.Points : 8.24;
    }

    private static double ResolveReplayIntensity(MatchScoreEventDto scoreEvent)
    {
        var value = Math.Abs(scoreEvent.TeamPercentageChange ?? scoreEvent.MetricDelta ?? 8.24m);
        var normalized = Math.Clamp((double)(value / 16m), 0.35, 1.0);
        if (string.Equals(scoreEvent.RuleType, "ArenaPressure", StringComparison.OrdinalIgnoreCase))
            normalized = Math.Min(1.0, normalized + 0.15);
        if (string.Equals(scoreEvent.RuleType, "PercentageCrossover", StringComparison.OrdinalIgnoreCase))
            normalized = Math.Min(1.0, normalized + 0.10);
        return normalized;
    }

    private async Task PulseScoreAsync(bool pulseLeft, bool pulseRight, bool pulseHotScore)
    {
        _pulseCts?.Cancel();
        _pulseCts?.Dispose();
        _pulseCts = new CancellationTokenSource();
        var ct = _pulseCts.Token;

        _pulseLeftScore = pulseLeft;
        _pulseRightScore = pulseRight;
        _pulseScoreboard = pulseLeft || pulseRight;
        _pulseHotScore = pulseHotScore;
        if (_pulseScoreboard || _pulseHotScore)
        {
            await LogAsync("TV_MOTION", "score pulse", new
            {
                pulseLeft,
                pulseRight,
                pulseHotScore
            });
        }

        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(TimeSpan.FromSeconds(2.2), ct);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        _pulseLeftScore = false;
        _pulseRightScore = false;
        _pulseScoreboard = false;
        _pulseHotScore = false;
        await InvokeAsync(StateHasChanged);
    }

