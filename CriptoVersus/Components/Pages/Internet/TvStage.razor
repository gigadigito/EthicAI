    }











































    private async Task SyncTelemetryChartsAsync()
    {
        if (_isDisposed || _tvModule is null)
            return;

        var latestId = _metricSnapshots.Count == 0 ? 0 : _metricSnapshots.Max(x => x.MatchMetricSnapshotId);
        var currentLeftLiveValue = DisplayLeftChangePercent();
        var currentRightLiveValue = DisplayRightChangePercent();
        if (latestId == _telemetryCubeLastSnapshotId
            && _metricSnapshots.Count == _telemetryCubeLastSnapshotCount
            && Nullable.Equals(currentLeftLiveValue, _telemetryCubeLastLeftLiveValue)
            && Nullable.Equals(currentRightLiveValue, _telemetryCubeLastRightLiveValue)
            && (latestId != 0 || _metricSnapshots.Count == 0))
            return;

        _telemetryCubeLastSnapshotId = latestId;
        _telemetryCubeLastSnapshotCount = _metricSnapshots.Count;
        _telemetryCubeLastLeftLiveValue = currentLeftLiveValue;
        _telemetryCubeLastRightLiveValue = currentRightLiveValue;

        static long ToUnixSeconds(DateTime capturedAtUtc)
            => new DateTimeOffset(DateTime.SpecifyKind(capturedAtUtc, DateTimeKind.Utc)).ToUnixTimeSeconds();

        static bool ShouldAppendLivePoint((long Time, double Value)? lastPoint, decimal liveValue, long nowUnixSeconds)
        {
            if (!lastPoint.HasValue)
                return true;

            if (Math.Abs(lastPoint.Value.Value - (double)liveValue) > 0.0001d)
                return true;

            return nowUnixSeconds - lastPoint.Value.Time >= 12;
        }

        object[] BuildPoints(IEnumerable<MatchMetricSnapshotDto> snapshots, decimal? liveValue, bool includeLivePoint = true)
        {
            var points = snapshots
                .OrderBy(x => x.CapturedAtUtc)
                .Select(x => (
                    Time: ToUnixSeconds(x.CapturedAtUtc),
                    Value: (double)x.PercentageChange))
                .ToList();

            if (includeLivePoint && liveValue.HasValue)
            {
                var nowUnixSeconds = DateTimeOffset.UtcNow.ToUnixTimeSeconds();
                var lastPoint = points.Count == 0 ? ((long Time, double Value)?)null : points[^1];

                if (ShouldAppendLivePoint(lastPoint, liveValue.Value, nowUnixSeconds))
                {
                    points.Add((nowUnixSeconds, (double)liveValue.Value));
                }
            }

            return points
                .Select(x => new { time = x.Time, value = x.Value })
                .Cast<object>()
                .ToArray();
        }

        if (_metricSnapshots.Count == 0)
        {
            var nowMissingTick = System.Environment.TickCount64;
            if (nowMissingTick - _telemetryCubeLastMissingLogTick >= 6000)
            {
                _telemetryCubeLastMissingLogTick = nowMissingTick;
                await LogAsync("TV_CHART", "missing snapshots");
            }
            try
            {
                var filteredScoreEvents = _allScoreEvents.Where(ShouldRenderScoreEventInCompareChart).ToList();
                await _tvModule.InvokeVoidAsync("updateTelemetryCharts", new
                {
                    left = BuildPoints([], currentLeftLiveValue),
                    right = BuildPoints([], currentRightLiveValue),
                    leftMarkerPoints = BuildPoints([], null, includeLivePoint: false),
                    rightMarkerPoints = BuildPoints([], null, includeLivePoint: false),
                    scoreEvents = filteredScoreEvents,
                    leftTeamId = Match?.TeamAId ?? 0,
                    rightTeamId = Match?.TeamBId ?? 0,
                    matchStartTimeUtc = Match?.StartTime,
                    leftMeta = new
                    {
                        symbol = DisplayLeftSymbol(),
                        logoUrl = GetLogoUrl(DisplayLeftLogoUrl()),
                        accentColor = GetAccentColor(DisplayLeftSymbol())
                    },
                    rightMeta = new
                    {
                        symbol = DisplayRightSymbol(),
                        logoUrl = GetLogoUrl(DisplayRightLogoUrl()),
                        accentColor = GetAccentColor(DisplayRightSymbol())
                    }
                });
            }
            catch (ObjectDisposedException)
            {
                return;
            }
            return;
        }

        var nowTick = System.Environment.TickCount64;
        if (nowTick - _telemetryCubeLastRawLogTick >= 8000)
        {
            _telemetryCubeLastRawLogTick = nowTick;
            await LogAsync("TV_CHART_RAW", "snapshot-sample", new
            {
                count = _metricSnapshots.Count,
                first = _metricSnapshots
                    .OrderByDescending(x => x.CapturedAtUtc)
                    .Take(5)
                    .Select(x => new
                    {
                        x.MatchMetricSnapshotId,
                        x.MatchId,
                        x.TeamId,
                        x.TeamSymbol,
                        x.CapturedAtUtc,
                        x.PercentageChange,
                        x.QuoteVolume,
                        x.TradeCount
                    })
                    .ToArray()
            });
        }

        var matchTeamAId = Match?.TeamAId ?? 0;
        var matchTeamBId = Match?.TeamBId ?? 0;

        List<MatchMetricSnapshotDto> leftSnapshots = matchTeamAId > 0
            ? _metricSnapshots.Where(x => x.TeamId == matchTeamAId).OrderBy(x => x.CapturedAtUtc).ToList()
            : [];

        List<MatchMetricSnapshotDto> rightSnapshots = matchTeamBId > 0
            ? _metricSnapshots.Where(x => x.TeamId == matchTeamBId).OrderBy(x => x.CapturedAtUtc).ToList()
            : [];

        var leftPoints = BuildPoints(leftSnapshots, currentLeftLiveValue);
        var rightPoints = BuildPoints(rightSnapshots, currentRightLiveValue);
        var leftMarkerPoints = BuildPoints(leftSnapshots, null, includeLivePoint: false);
        var rightMarkerPoints = BuildPoints(rightSnapshots, null, includeLivePoint: false);
        var chartScoreEvents = _allScoreEvents
            .Where(x => (x.TeamId == matchTeamAId || x.TeamId == matchTeamBId) && ShouldRenderScoreEventInCompareChart(x))
            .OrderBy(x => x.EventSequence)
            .ThenBy(x => x.EventTimeUtc)
            .ToList();

        await LogAsync("TV_CHART_PAYLOAD", "final", new
        {
            mappingStrategy = "match-team-ids",
            matchLeftTeamId = matchTeamAId,
            matchRightTeamId = matchTeamBId,
            leftPoints = leftPoints.Length,
            rightPoints = rightPoints.Length,
            leftTeamIds = leftSnapshots.Select(x => x.TeamId).Distinct().ToArray(),
            rightTeamIds = rightSnapshots.Select(x => x.TeamId).Distinct().ToArray(),
            leftSymbols = leftSnapshots.Select(x => x.TeamSymbol).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct().ToArray(),
            rightSymbols = rightSnapshots.Select(x => x.TeamSymbol).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct().ToArray(),
            scoreEventCount = chartScoreEvents.Count,
            scoreEventTeamIds = chartScoreEvents.Select(x => x.TeamId).Distinct().ToArray(),
            scoreEventRuleTypes = chartScoreEvents.Select(x => x.RuleType).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct().ToArray(),
            leftPreview = leftPoints.Take(3).ToArray(),
            rightPreview = rightPoints.Take(3).ToArray()
        });

        try
        {
                await _tvModule.InvokeVoidAsync("updateTelemetryCharts", new
            {
                left = leftPoints,
                right = rightPoints,
                leftMarkerPoints = leftMarkerPoints,
                rightMarkerPoints = rightMarkerPoints,
                scoreEvents = chartScoreEvents,
                leftTeamId = matchTeamAId,
                rightTeamId = matchTeamBId,
                matchStartTimeUtc = Match?.StartTime,
                leftMeta = new
                {
                    symbol = Match?.TeamA ?? DisplayLeftSymbol(),
                    logoUrl = GetLogoUrl(DisplayLeftLogoUrl()),
                    accentColor = GetAccentColor(Match?.TeamA ?? DisplayLeftSymbol())
                },
                rightMeta = new
                {
                    symbol = Match?.TeamB ?? DisplayRightSymbol(),
                    logoUrl = GetLogoUrl(DisplayRightLogoUrl()),
                    accentColor = GetAccentColor(Match?.TeamB ?? DisplayRightSymbol())
                }
            });
        }
        catch (ObjectDisposedException)
        {
        }
    }





























