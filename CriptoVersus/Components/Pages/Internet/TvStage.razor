    .tv-telemetry-cube-shell {
        grid-column: 1 / -1;
        position: relative;
        height: clamp(520px, 56vh, 720px);
        min-height: 0;
        perspective: 1600px;
        perspective-origin: 50% 44%;
        isolation: isolate;
    }

    .tv-telemetry-cube-shell.is-paused::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 26px;
        box-shadow: 0 0 0 1px rgba(127, 246, 223, 0.14), 0 0 30px rgba(127, 246, 223, 0.08);
        pointer-events: none;
        opacity: .9;
    }

    .tv-telemetry-cube {
        position: absolute;
        inset: 0;
        transform-style: preserve-3d;
        transition: transform 1.1s cubic-bezier(.22,.82,.28,1);
        will-change: transform;
        --tv-cube-depth: 280px;
    }

    .tv-telemetry-cube.is-face-0 { transform: rotateY(0deg); }
    .tv-telemetry-cube.is-face-1 { transform: rotateY(-90deg); }
    .tv-telemetry-cube.is-face-2 { transform: rotateY(-180deg); }
    .tv-telemetry-cube.is-face-3 { transform: rotateY(-270deg); }
    .tv-telemetry-cube.is-face-4 { transform: rotateY(-180deg); }
    .tv-telemetry-cube.is-face-5 { transform: rotateY(-180deg); }
    .tv-telemetry-cube.is-face-6 { transform: rotateY(-180deg); }

    .tv-telemetry-cube__face {
        position: absolute;
        inset: 0;
        backface-visibility: hidden;
        border-radius: 26px;
        border: 1px solid rgba(255,255,255,0.06);
        background:
            radial-gradient(circle at 10% 10%, rgba(127, 246, 223, 0.10), transparent 58%),
            linear-gradient(180deg, rgba(10, 16, 28, 0.90), rgba(6, 10, 18, 0.92));
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.03), 0 22px 55px rgba(0,0,0,0.28);
        overflow: hidden;
    }

    .tv-telemetry-cube__face::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 50% -10%, rgba(83, 200, 255, 0.16), transparent 62%);
        opacity: .9;
        pointer-events: none;
    }

    .tv-telemetry-cube__face--front { transform: rotateY(0deg) translateZ(var(--tv-cube-depth)); }
    .tv-telemetry-cube__face--right { transform: rotateY(90deg) translateZ(var(--tv-cube-depth)); }
    .tv-telemetry-cube__face--back { transform: rotateY(180deg) translateZ(var(--tv-cube-depth)); }
    .tv-telemetry-cube__face--left { transform: rotateY(-90deg) translateZ(var(--tv-cube-depth)); }

    /* Virtual 5th face: reuse the back face, but swap content (compare vs split) */
    .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--compare,
    .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--split,
    .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--goals,
    .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--sentiment {
        height: 100%;
    }

    .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--split,
    .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--goals,
    .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--sentiment {
        display: none;
    }

    .tv-telemetry-cube.is-face-4 .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--compare {
        display: none;
    }

    .tv-telemetry-cube.is-face-4 .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--split {
        display: grid;
    }

    .tv-telemetry-cube.is-face-5 .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--compare,
    .tv-telemetry-cube.is-face-5 .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--split {
        display: none;
    }

    .tv-telemetry-cube.is-face-5 .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--goals {
        display: grid;
    }

    .tv-telemetry-cube.is-face-6 .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--compare,
    .tv-telemetry-cube.is-face-6 .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--split,
    .tv-telemetry-cube.is-face-6 .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--goals {
        display: none;
    }

    .tv-telemetry-cube.is-face-6 .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--sentiment {
        display: grid;
    }

    .tv-telemetry-cube__inner {
        position: relative;
        height: 100%;
        min-height: 0;
        padding: 14px;
        display: grid;
        grid-template-rows: auto minmax(0, 1fr) auto;
        gap: 12px;
    }

    .tv-telemetry-cube__inner--compare,
    .tv-telemetry-cube__inner--split,
    .tv-telemetry-cube__inner--goals,
    .tv-telemetry-cube__inner--sentiment {
        align-self: stretch;
    }

    .tv-telemetry-cube__telemetry-grid {
        height: 100%;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
        align-content: start;
    }

    .tv-telemetry-cube__face--front .tv-telemetry__match-link,
    .tv-telemetry-cube__face--front article {
        animation: none;
    }

    .tv-telemetry-face-header {
        position: relative;
        display: grid;
        gap: 8px;
        padding: 14px 16px;
        border-radius: 22px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.025);
    }

    .tv-telemetry-face-header__kicker {
        color: var(--tv-green);
        text-transform: uppercase;
        letter-spacing: .14em;
        font-size: .72rem;
        font-weight: 900;
    }

    .tv-telemetry-face-header__row {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
    }

    .tv-telemetry-face-header__row strong {
        font-size: clamp(1.2rem, 1.4vw, 1.6rem);
        letter-spacing: -.02em;
    }

    .tv-telemetry-face-header__row em {
        font-style: normal;
        font-weight: 900;
        letter-spacing: .04em;
    }

    .tv-telemetry-face-header__vs {
        opacity: .7;
        font-weight: 900;
        margin: 0 10px;
    }

    .tv-telemetry-face-header__muted {
        color: rgba(219, 232, 247, 0.72);
        font-style: normal;
        font-weight: 900;
        letter-spacing: .04em;
    }

    .tv-telemetry-chart-shell {
        position: relative;
        min-height: 0;
        height: 100%;
        border-radius: 22px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.02);
        overflow: hidden;
    }

    .tv-telemetry-split {
        display: grid;
        height: 100%;
        grid-template-rows: minmax(0, 1fr) minmax(0, 1fr);
        gap: 12px;
        min-height: 0;
    }

    .tv-telemetry-split__panel {
        display: grid;
        grid-template-rows: auto 1fr;
        gap: 10px;
        min-height: 0;
    }

    .tv-telemetry-split__meta {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.05);
        background: rgba(255,255,255,0.02);
    }

    .tv-goal-log {
        min-height: 0;
        height: 100%;
        padding: 4px 2px 0;
    }

    .tv-goal-log__list {
        min-height: 100%;
        display: grid;
        grid-auto-rows: minmax(0, 1fr);
        gap: 10px;
        align-content: stretch;
    }

    .tv-goal-log__item,
    .tv-goal-log__empty {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.06);
        background: linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.02));
    }

    .tv-goal-log__item strong,
    .tv-goal-log__empty strong {
        font-size: 1rem;
        letter-spacing: .03em;
    }

    .tv-goal-log__item div,
    .tv-goal-log__empty {
        display: grid;
        gap: 4px;
    }

    .tv-goal-log__item span {
        color: var(--tv-green);
        font-size: .74rem;
        font-weight: 900;
        letter-spacing: .12em;
        text-transform: uppercase;
    }

    .tv-goal-log__item small,
    .tv-goal-log__empty small {
        color: var(--tv-muted);
        line-height: 1.45;
    }

    .tv-goal-log__item em {
        font-style: normal;
        font-weight: 900;
        color: #7ff6df;
        letter-spacing: .04em;
    }

    .tv-goal-log__empty {
        grid-template-columns: 1fr;
        min-height: 220px;
        place-content: center;
        text-align: center;
    }

    .tv-telemetry-split__meta strong {
        font-size: .98rem;
        letter-spacing: .04em;
    }

    .tv-telemetry-split__meta em {
        font-style: normal;
        font-weight: 900;
    }

    .tv-telemetry-chart-shell--split {
        min-height: 0;
    }

    .tv-telemetry-face-footer {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 12px;
        padding: 12px 14px;
        border-radius: 20px;
        border: 1px solid rgba(255,255,255,0.05);
        background: rgba(255,255,255,0.02);
    }

    @@media (prefers-reduced-motion: reduce) {
        .tv-telemetry-cube-shell {
            perspective: none;
            height: auto;
        }

        .tv-telemetry-cube {
            position: static;
            transform: none !important;
            transition: none;
        }

        .tv-telemetry-cube__face {
            position: static;
            transform: none !important;
            margin-bottom: 10px;
        }
    }

    @@media (max-width: 1080px) {
        .tv-telemetry-cube-shell {
            perspective: none;
            height: auto;
        }

        .tv-telemetry-cube {
            position: static;
            transform: none !important;
            display: grid;
            gap: 10px;
        }

        .tv-telemetry-cube__face {
            position: static;
            transform: none !important;
            display: block;
            min-height: 0;
        }

        .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--compare {
            display: grid;
        }

        .tv-telemetry-cube__face--back .tv-telemetry-cube__inner--split {
            display: none;
        }
    }

    .tv-event-strip {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .tv-event-strip--football {
        gap: 12px;
    }

    .tv-event-strip__card {
        padding: 18px;
        display: grid;
        gap: 10px;
        position: relative;
        overflow: hidden;
    }

    .tv-event-strip__card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.035), transparent);
        transform: translateX(-100%);
        animation: tvSweep 12s ease-in-out infinite;
    }

    .tv-event-strip__card--accent {
        border-color: rgba(255, 215, 110, 0.16);
        background:
            radial-gradient(circle at top right, rgba(255, 215, 110, 0.1), transparent 28%),
            linear-gradient(180deg, rgba(11, 15, 27, 0.98), rgba(7, 10, 18, 0.98));
    }

    .tv-waiting-hero {
        display: grid;
        gap: 14px;
        justify-items: start;
    }

    .tv-waiting-hero__lead {
        margin: 0;
        font-size: clamp(1.2rem, 2vw, 1.8rem);
        color: #f5fbff;
        font-weight: 700;
    }

    .tv-waiting-hero__sublead {
        margin: 0;
        color: var(--tv-muted);
        font-size: 1rem;
    }

    .tv-waiting-hero__sublead--alt {
        color: rgba(207, 228, 239, 0.62);
    }

    .tv-procedural-log {
        display: grid;
        gap: 10px;
        width: min(100%, 620px);
        padding: 14px 16px;
        border-radius: 22px;
        border: 1px solid rgba(83, 200, 255, 0.14);
        background:
            linear-gradient(180deg, rgba(5, 10, 18, 0.96), rgba(4, 8, 16, 0.98)),
            radial-gradient(circle at top left, rgba(153, 76, 255, 0.08), transparent 32%);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.03), 0 20px 44px rgba(0,0,0,0.18);
    }

    .tv-procedural-log__line {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #c7f9e0;
        font-size: .88rem;
        letter-spacing: .04em;
        opacity: .34;
        transform: translateX(-8px);
        animation: tvProceduralLogPulse 2.8s ease-in-out infinite;
        animation-delay: var(--tv-log-delay, 0s);
    }

    .tv-procedural-log__dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: linear-gradient(180deg, #7ff6df, #7dff63);
        box-shadow: 0 0 14px rgba(127, 246, 223, 0.34);
        flex: 0 0 auto;
    }

    .tv-waiting-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
    }

    .tv-community-callout {
        display: grid;
        gap: 18px;
        margin-top: 16px;
        padding: 20px 22px;
        border: 1px solid rgba(127, 246, 223, 0.16);
        border-radius: 28px;
        background:
            radial-gradient(circle at top right, rgba(127, 246, 223, 0.08), transparent 22%),
            radial-gradient(circle at top left, rgba(167, 139, 250, 0.08), transparent 24%),
            linear-gradient(180deg, rgba(8, 12, 21, 0.96), rgba(5, 9, 18, 0.98));
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.03), 0 24px 60px rgba(0,0,0,0.24);
    }

    .tv-community-callout__copy {
        display: grid;
        gap: 8px;
    }

    .tv-community-callout__copy span {
        color: #7ff6df;
        font-size: .76rem;
        font-weight: 900;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .tv-community-callout__copy h2,
    .tv-panel--community h2 {
        margin: 0;
        font-size: clamp(1.2rem, 2vw, 1.7rem);
        letter-spacing: -.03em;
    }

    .tv-community-callout__copy p,
    .tv-community-callout__description {
        margin: 0;
        color: var(--tv-muted);
        line-height: 1.6;
    }

    .tv-community-callout :deep(.community-links--tv),
    .tv-panel--community :deep(.community-links--tv) {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .tv-panel {
        display: grid;
        gap: 14px;
    }

    .tv-panel__head {
        display: grid;
        gap: 6px;
    }

    .tv-panel__head h2 {
        margin: 0;
        font-size: 1.25rem;
        letter-spacing: -.03em;
    }

    .tv-ranking-list,
    .tv-latest-list,
    .tv-gainers-list {
        display: grid;
        gap: 10px;
    }

    .tv-panel__status {
        display: grid;
        place-items: center;
        min-height: 112px;
        padding: 18px 16px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.03);
        color: #dceaf4;
        text-align: center;
        line-height: 1.5;
    }

    .tv-panel__status--loading {
        border-color: rgba(83, 200, 255, 0.16);
        color: #cde8ff;
    }

    .tv-panel__status--error {
        border-color: rgba(255, 168, 111, 0.18);
        color: #ffd2b0;
    }

    .tv-panel__status--empty {
        border-color: rgba(127, 246, 223, 0.12);
        color: rgba(220, 234, 244, 0.74);
    }

    .tv-ranking-row,
    .tv-latest-row,
    .tv-gainer-row {
        display: flex;
        justify-content: space-between;
        gap: 14px;
        align-items: center;
        padding: 12px 14px;
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.06);
        background: rgba(255,255,255,0.025);
    }

    .tv-ranking-row strong,
    .tv-latest-row strong,
    .tv-gainer-row strong {
        font-size: 1rem;
    }

    .tv-ranking-row div,
    .tv-latest-row div {
        display: grid;
        gap: 4px;
        flex: 1;
    }

    .tv-ranking-row em,
    .tv-latest-row em,
    .tv-gainer-row strong {
        color: var(--tv-yellow);
        font-style: normal;
        font-weight: 900;
        letter-spacing: -.02em;
    }

.pirate-signal-backdrop {
    position: absolute;
    inset: 0;
    z-index: 14;
    display: grid;
    place-items: start center;
    overflow: hidden;
    padding: clamp(16px, 3vw, 36px);
    background:
        radial-gradient(circle at 50% 50%, rgba(14, 22, 38, 0.14), rgba(2, 6, 14, 0.76)),
        linear-gradient(180deg, rgba(2, 10, 24, 0.08), rgba(2, 10, 24, 0.5));
    pointer-events: none;
    animation: pirateFadeIn .45s ease-out both;
}

.pirate-signal-backdrop.is-market-warning {
    background:
        radial-gradient(circle at 50% 50%, rgba(90, 18, 18, 0.22), rgba(16, 4, 10, 0.82)),
        linear-gradient(180deg, rgba(78, 18, 28, 0.12), rgba(16, 8, 20, 0.64));
}

.pirate-signal-backdrop.is-villain-message {
    background:
        radial-gradient(circle at 50% 50%, rgba(60, 16, 90, 0.22), rgba(8, 4, 18, 0.84)),
        linear-gradient(180deg, rgba(52, 18, 84, 0.12), rgba(10, 8, 22, 0.64));
}

.pirate-signal-backdrop.is-special-event {
    background:
        radial-gradient(circle at 50% 50%, rgba(96, 72, 20, 0.18), rgba(16, 12, 4, 0.82)),
        linear-gradient(180deg, rgba(84, 66, 20, 0.12), rgba(8, 10, 22, 0.62));
}

.pirate-signal-panel {
    position: relative;
    width: min(84vw, 1100px);
    min-height: min(70vh, 720px);
    margin-top: clamp(12px, 4vh, 42px);
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 18px;
    padding: clamp(18px, 3vw, 34px);
    color: #dffcff;
    border-radius: 28px;
    overflow: hidden;
    border: 1px solid rgba(102, 228, 255, 0.72);
    background: linear-gradient(135deg, rgba(4, 18, 34, 0.94), rgba(3, 10, 24, 0.9));
    box-shadow:
        0 0 0 1px rgba(120, 244, 255, 0.12) inset,
        0 28px 80px rgba(0, 0, 0, 0.46),
        0 0 42px rgba(34, 214, 255, 0.22);
    animation:
        pirateGlitch .22s steps(2, end) 2,
        pirateVhsBurst 1.05s ease-out 1,
        pirateFloat 5.8s ease-in-out infinite,
        neonPulse 2.8s ease-in-out infinite;
}

.pirate-signal-panel.is-market-warning {
    border-color: rgba(255, 131, 102, 0.74);
    background: linear-gradient(135deg, rgba(34, 12, 14, 0.96), rgba(18, 8, 20, 0.92));
}

.pirate-signal-panel.is-villain-message {
    border-color: rgba(198, 132, 255, 0.7);
    background: linear-gradient(135deg, rgba(20, 10, 38, 0.96), rgba(12, 8, 24, 0.92));
}

.pirate-signal-panel.is-special-event {
    border-color: rgba(255, 226, 124, 0.76);
    background: linear-gradient(135deg, rgba(30, 22, 8, 0.96), rgba(10, 12, 24, 0.92));
}

.pirate-signal-panel.is-transition-emergency-alert {
    animation:
        pirateGlitch .22s steps(2, end) 2,
        pirateVhsBurst 1.05s ease-out 1,
        pirateAlertPulse 1.2s ease-in-out infinite;
}

.pirate-signal-panel.is-transition-arena-takeover {
    animation:
        pirateGlitch .22s steps(2, end) 2,
        pirateVhsBurst 1.05s ease-out 1,
        pirateTakeoverShake 2.4s ease-in-out infinite,
        neonPulse 2.8s ease-in-out infinite;
}

.pirate-signal-panel::before,
.pirate-signal-panel::after {
    content: "";
    position: absolute;
    inset: 10px;
    border: 2px solid rgba(28, 200, 255, 0.68);
    clip-path: polygon(6% 0, 24% 0, 27% 3%, 92% 3%, 100% 14%, 100% 100%, 45% 100%, 41% 96%, 3% 96%, 0 92%, 0 11%);
    pointer-events: none;
}

.pirate-signal-panel::after {
    inset: 20px;
    border-color: rgba(111, 250, 255, 0.18);
    opacity: .8;
}

.pirate-signal-panel__scanlines,
.pirate-signal-panel__noise {
    position: absolute;
    inset: 0;
    pointer-events: none;
}

.pirate-vhs-glitch {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 1;
    animation: pirateVhsContainer 1.5s linear infinite;
}

.pirate-vhs-glitch::before,
.pirate-vhs-glitch::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    pointer-events: none;
}

.pirate-vhs-glitch::before {
    top: 0;
    height: 22%;
    background: linear-gradient(180deg, rgba(160, 248, 255, 0.52), rgba(160, 248, 255, 0));
    opacity: 0;
    animation: pirateVhsTracking 1.15s linear infinite;
}

.pirate-vhs-glitch::after {
    inset: 0;
    background:
        linear-gradient(90deg, rgba(255, 0, 84, 0.12), transparent 22%, transparent 78%, rgba(0, 229, 255, 0.12)),
        linear-gradient(180deg, rgba(255, 255, 255, 0.07), transparent 30%, transparent 70%, rgba(255, 255, 255, 0.05));
    opacity: 0;
    animation: pirateVhsFlash 2.4s steps(2, end) infinite;
}

.pirate-vhs-glitch__line {
    position: absolute;
    display: block;
    left: 0;
    right: 0;
    top: calc(-8% + (var(--line-index) * 2.85%));
    height: clamp(2px, .34vw, 6px);
    opacity: 0;
    background:
        linear-gradient(90deg,
            rgba(115, 245, 255, 0) 0%,
            rgba(115, 245, 255, 0.3) 18%,
            rgba(255, 255, 255, 0.88) 46%,
            rgba(80, 210, 255, 0.42) 78%,
            rgba(115, 245, 255, 0) 100%);
    box-shadow:
        0 0 14px rgba(120, 246, 255, 0.42),
        0 0 30px rgba(120, 246, 255, 0.18);
    transform: translateX(0) scaleX(1);
    animation: pirateVhsLine 1.18s calc(var(--line-index) * 0.035s) infinite;
}

.pirate-signal-panel__scanlines {
    background: repeating-linear-gradient(
        to bottom,
        rgba(146, 255, 255, 0.09) 0 2px,
        rgba(2, 8, 14, 0) 2px 6px);
    mix-blend-mode: screen;
    opacity: .26;
    animation: scanlines 8s linear infinite;
}

.pirate-signal-panel__noise {
    background:
        linear-gradient(90deg, transparent 0%, rgba(0, 255, 255, 0.08) 50%, transparent 100%),
        radial-gradient(circle at 20% 20%, rgba(83, 200, 255, 0.18), transparent 32%),
        radial-gradient(circle at 78% 12%, rgba(0, 255, 198, 0.14), transparent 28%);
    opacity: .34;
    animation: pirateNoise 3.8s steps(3, end) infinite;
}

.pirate-signal-header {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(104, 227, 255, 0.24);
    text-transform: uppercase;
    letter-spacing: .22em;
    font-size: .74rem;
}

.pirate-signal-header__left {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
}

.signal-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: #57ebff;
    box-shadow: 0 0 14px rgba(87, 235, 255, 0.95);
    animation: signalDotPulse 1.2s ease-in-out infinite;
    flex: 0 0 auto;
}

.signal-status {
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid rgba(127, 245, 255, 0.34);
    background: rgba(8, 24, 42, 0.8);
    color: #8ff9ff;
    box-shadow: 0 0 18px rgba(55, 220, 255, 0.14);
}

.pirate-signal-body {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(280px, 1.05fr) minmax(300px, .95fr);
    gap: clamp(18px, 3vw, 34px);
    align-items: stretch;
    min-height: 0;
}

.pirate-character-frame {
    position: relative;
    min-height: clamp(280px, 48vw, 540px);
    border-radius: 24px;
    overflow: hidden;
    background:
        radial-gradient(circle at 50% 28%, rgba(52, 223, 255, 0.22), transparent 34%),
        linear-gradient(180deg, rgba(3, 12, 28, 0.85), rgba(3, 8, 20, 0.98));
    border: 1px solid rgba(117, 242, 255, 0.35);
    box-shadow:
        inset 0 0 0 1px rgba(255,255,255,0.03),
        0 0 26px rgba(44, 208, 255, 0.18);
    display: grid;
    align-items: end;
}

.pirate-character-frame__hud {
    position: absolute;
    inset: 0;
    background:
        linear-gradient(90deg, rgba(50, 200, 255, 0.1), transparent 14%, transparent 86%, rgba(50, 200, 255, 0.1)),
        linear-gradient(180deg, rgba(50, 200, 255, 0.08), transparent 16%, transparent 84%, rgba(50, 200, 255, 0.08));
    pointer-events: none;
}

.pirate-character-frame__portrait {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.02) contrast(1.08);
}

.pirate-character-frame__video {
    background: #020814;
}

.pirate-character-frame__fallback {
    position: absolute;
    inset: 0;
    display: none;
    place-items: center;
    background:
        radial-gradient(circle at 50% 40%, rgba(57, 229, 255, 0.3), transparent 25%),
        linear-gradient(180deg, rgba(11, 23, 41, 0.15), rgba(3, 8, 20, 0.9));
    color: rgba(152, 248, 255, 0.92);
    font-size: clamp(3.8rem, 10vw, 7rem);
    font-weight: 800;
    letter-spacing: .2em;
    text-shadow: 0 0 24px rgba(73, 223, 255, 0.32);
}

.pirate-character-frame.is-placeholder .pirate-character-frame__fallback {
    display: grid;
}

.pirate-character-frame__label {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 4px;
    padding: 18px 18px 16px;
    background: linear-gradient(180deg, rgba(5, 13, 28, 0), rgba(5, 13, 28, 0.86));
    text-transform: uppercase;
    letter-spacing: .14em;
}

.pirate-character-frame__label small {
    color: rgba(152, 245, 255, 0.72);
    font-size: .68rem;
}

.pirate-character-frame__label strong {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: #f2ffff;
}

.pirate-signal-copy {
    display: grid;
    align-content: end;
    gap: 16px;
    min-height: 0;
}

.pirate-signal-copy__eyebrow {
    text-transform: uppercase;
    letter-spacing: .22em;
    font-size: .72rem;
    color: rgba(123, 242, 255, 0.84);
}

.pirate-message {
    position: relative;
    padding: clamp(18px, 2.4vw, 28px);
    border-radius: 24px;
    background:
        linear-gradient(180deg, rgba(6, 18, 36, 0.88), rgba(3, 10, 22, 0.96));
    border: 1px solid rgba(112, 236, 255, 0.28);
    box-shadow:
        inset 0 0 0 1px rgba(255,255,255,0.02),
        0 0 24px rgba(40, 207, 255, 0.12);
    font-size: clamp(1rem, 1.9vw, 1.45rem);
    line-height: 1.55;
    color: #f4ffff;
}

.pirate-message::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(90deg, rgba(48, 229, 255, 0.1), transparent 26%, transparent 74%, rgba(48, 229, 255, 0.1));
    pointer-events: none;
}

.pirate-signal-copy__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px 16px;
    justify-content: space-between;
    text-transform: uppercase;
    letter-spacing: .16em;
    font-size: .68rem;
    color: rgba(135, 239, 255, 0.76);
}

.tv-event-overlay {
    position: fixed;
    inset: 0;
    z-index: 999999;
    display: grid;
    place-items: center;
    pointer-events: none;
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    transition:
        opacity .35s ease,
        visibility .35s ease;
}

.tv-event-overlay.is-visible {
    opacity: 1;
    visibility: visible;
}

.tv-event-overlay::before {
    content: "";
    position: absolute;
    inset: -20%;
    background:
        radial-gradient(circle at center,
            rgba(83,200,255,.22) 0%,
            rgba(83,200,255,.12) 18%,
            rgba(127,246,223,.08) 28%,
            transparent 60%);
    filter: blur(60px);
    animation: tvOverlayPulse 2.8s ease-in-out infinite;
}

.tv-event-overlay__card {
    --event-accent: #53c8ff;

    position: relative;

    width: min(92vw, 1400px);
    max-width: 1400px;

    padding:
        clamp(24px, 3vw, 42px)
        clamp(28px, 5vw, 70px);

    border-radius: 38px;

    display: grid;
    gap: 14px;

    text-align: center;

    border:
        1px solid color-mix(
            in srgb,
            var(--event-accent) 44%,
            rgba(255,255,255,.12)
        );

    background:
        linear-gradient(
            180deg,
            rgba(4,7,16,.72),
            rgba(3,5,12,.84)
        );

    backdrop-filter:
        blur(28px)
        saturate(160%);

    overflow: hidden;

    box-shadow:
        0 0 140px rgba(0,0,0,.82),
        0 0 80px color-mix(
            in srgb,
            var(--event-accent) 26%,
            transparent
        ),
        inset 0 0 0 1px rgba(255,255,255,.04);

    animation:
        tvOverlayEntrance .65s cubic-bezier(.22,1,.36,1),
        tvOverlayGlow 3.5s ease-in-out infinite;
}

.tv-event-overlay__card::before {
    content: "";
    position: absolute;
    inset: 0;

    background:
        linear-gradient(
            115deg,
            transparent 0%,
            rgba(255,255,255,.06) 32%,
            transparent 58%
        );

    transform: translateX(-140%);
    animation: tvOverlaySweep 4.5s linear infinite;
}

.tv-event-overlay__card::after {
    content: "";
    position: absolute;
    inset: -2px;

    border-radius: inherit;

    background:
        linear-gradient(
            135deg,
            color-mix(in srgb, var(--event-accent) 65%, white),
            transparent 24%,
            transparent 76%,
            color-mix(in srgb, var(--event-accent) 45%, white)
        );

    opacity: .35;

    mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);

    -webkit-mask:
        linear-gradient(#fff 0 0) content-box,
        linear-gradient(#fff 0 0);

    padding: 1px;

    mask-composite: exclude;
    -webkit-mask-composite: xor;

    pointer-events: none;
}

.tv-event-overlay__card span {
    position: relative;

    color:
        color-mix(
            in srgb,
            var(--event-accent) 82%,
            white
        );

    text-transform: uppercase;

    letter-spacing: .38em;

    font-size:
        clamp(.8rem, 1vw, 1.2rem);

    font-weight: 900;

    text-shadow:
        0 0 18px color-mix(
            in srgb,
            var(--event-accent) 50%,
            transparent
        );
}

.tv-event-overlay__card strong {
    position: relative;

    font-size:
        clamp(4rem, 10vw, 12rem);

    line-height: .9;

    font-weight: 1000;

    letter-spacing: -.08em;

    text-transform: uppercase;

    color: #ffffff;

    text-shadow:
        0 0 12px rgba(255,255,255,.18),
        0 0 34px color-mix(
            in srgb,
            var(--event-accent) 55%,
            transparent
        ),
        0 0 90px color-mix(
            in srgb,
            var(--event-accent) 24%,
            transparent
        );

    filter:
        drop-shadow(0 10px 24px rgba(0,0,0,.55));
}

.tv-event-overlay__card small {
    position: relative;

    color: rgba(230,240,255,.82);

    font-size:
        clamp(1rem, 2vw, 2.4rem);

    line-height: 1.4;

    font-weight: 700;

    letter-spacing: .02em;

    text-shadow:
        0 0 16px rgba(255,255,255,.08);
}

@@keyframes tvOverlayEntrance {
    0% {
        opacity: 0;
        transform:
            scale(.78)
            translateY(80px);
        filter:
            blur(26px);
    }

    60% {
        opacity: 1;
        transform:
            scale(1.04)
            translateY(-6px);
        filter:
            blur(0);
    }

    100% {
        opacity: 1;
        transform:
            scale(1)
            translateY(0);
        filter:
            blur(0);
    }
}

@@keyframes tvOverlayGlow {
    0%,100% {
        transform: scale(1);
    }

    50% {
        transform: scale(1.015);
    }
}

@@keyframes tvOverlayPulse {
    0%,100% {
        transform: scale(1);
        opacity: .7;
    }

    50% {
        transform: scale(1.08);
        opacity: 1;
    }
}

@@keyframes tvOverlaySweep {
    0% {
        transform: translateX(-140%);
    }

    100% {
        transform: translateX(140%);
    }
}


