@using System.Globalization
@using System.Text
@using DTOs
@using CriptoVersus.Web.Services
@inject LocalizationService L
@inject IConfiguration Config
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (HasLiveMatch)
{
    <section class="tv-stage tv-stage--live">
        <div class="tv-stage__backdrop"></div>
        <div class="tv-stage__aurora"></div>
        <div class="tv-stage__fog"></div>
        <div class="tv-stage__gridlines"></div>
        <div class="tv-stage__particles"></div>

        @if (_isEventVisible && _activeEvent is not null)
        {
            <div class="tv-event-overlay is-visible" aria-live="polite" aria-atomic="true">
                <div class="tv-event-overlay__card" style="@GetEventAccentStyle(_activeEvent.AccentHex)">
                    <span>@_activeEvent.Kicker</span>
                    <strong>@_activeEvent.Title</strong>
                    <small>@_activeEvent.Body</small>
                </div>
            </div>
        }

        <header class="tv-stage__topbar">
            <div>
                <span class="tv-stage__eyebrow">@T("hero.eyebrow")</span>
                <h1>@T("hero.title")</h1>
            </div>

            <div class="tv-stage__badges">
                <span class="tv-pill tv-pill--live">
                    <span class="tv-pill__dot"></span>
                    @T("labels.liveArena")
                </span>
                <span class="tv-pill">@T("labels.automaticBroadcast")</span>
                <span class="tv-pill tv-pill--signal">@T("labels.signalStable")</span>
                <span class="tv-pill tv-pill--score @(_pulseHotScore ? "is-pulsing" : string.Empty)">@T("labels.hotScore") @DisplayHotScore()</span>
            </div>
        </header>

        <div class="tv-stage__grid">
            <article class="tv-match-card">
                <div class="tv-match-card__meta">
                    <span>@T("labels.hotMatch")</span>
                    <strong>@DisplayRemainingTime()</strong>
                </div>

                <div class="tv-match-card__arena">
                    <div class="tv-team tv-team--left" style="@GetTeamStyle(DisplayLeftSymbol(), true)">
                        <div class="tv-team__halo"></div>
                        <div class="tv-team__logo-shell">
                            <img src="@GetLogoUrl(DisplayLeftLogoUrl())" alt="" />
                        </div>
                        <span class="tv-team__symbol">@DisplayLeftSymbol()</span>
                        <strong>@DisplayLeftName()</strong>
                    </div>

                    <div class="tv-scoreboard @(_pulseScoreboard ? "is-pulsing" : string.Empty)">
                        <span class="tv-scoreboard__status">@T("labels.matchArena")</span>
                        <div class="tv-scoreboard__score">
                            <strong class="@(_pulseLeftScore ? "tv-score-value tv-score-value--pulse" : "tv-score-value")">@DisplayLeftScore()</strong>
                            <span class="tv-scoreboard__versus">VS</span>
                            <strong class="@(_pulseRightScore ? "tv-score-value tv-score-value--pulse" : "tv-score-value")">@DisplayRightScore()</strong>
                        </div>
                        <small>@DisplayScoreContext()</small>
                    </div>

                    <div class="tv-team tv-team--right" style="@GetTeamStyle(DisplayRightSymbol(), false)">
                        <div class="tv-team__halo"></div>
                        <div class="tv-team__logo-shell">
                            <img src="@GetLogoUrl(DisplayRightLogoUrl())" alt="" />
                        </div>
                        <span class="tv-team__symbol">@DisplayRightSymbol()</span>
                        <strong>@DisplayRightName()</strong>
                    </div>
                </div>
            </article>

            <aside class="tv-telemetry">
                <article>
                    <span>@T("labels.volume")</span>
                    <strong>@DisplayVolume()</strong>
                    <small>@T("labels.competitivePool")</small>
                </article>
                <article>
                    <span>@T("labels.momentum")</span>
                    <strong>@DisplayMomentum()</strong>
                    <small>@DisplayMomentumSupportLine()</small>
                </article>
                <article>
                    <span>@T("labels.remainingTime")</span>
                    <strong>@DisplayRemainingTime()</strong>
                    <small>@T("labels.arenaCycle")</small>
                </article>
                <article>
                    <span>@T("labels.reason")</span>
                    <strong>@T("labels.liveRewardDynamics")</strong>
                    <small>@DisplayReason()</small>
                </article>
            </aside>
        </div>

        <section class="tv-event-strip">
            <article class="tv-event-strip__card">
                <span>@T("labels.eventZone")</span>
                <strong>@DisplayEventHeadline()</strong>
                <p>@DisplayReason()</p>
            </article>
            <article class="tv-event-strip__card tv-event-strip__card--accent">
                <span>@T("labels.marketDrivenArena")</span>
                <strong>@DisplayPressureHeadline()</strong>
                <p>@DisplayPressureBody()</p>
            </article>
        </section>

        @if (_tickerItems.Count > 0)
        {
            <section class="tv-ticker" aria-label="@T("labels.broadcastTicker")">
                <div class="tv-ticker__track">
                    @for (var repetition = 0; repetition < 2; repetition++)
                    {
                        <div class="tv-ticker__lane">
                            @foreach (var item in _tickerItems)
                            {
                                <span class="tv-ticker__item">@item</span>
                            }
                        </div>
                    }
                </div>
            </section>
        }
    </section>
}
else
{
    <section class="tv-stage tv-stage--waiting">
        <div class="tv-stage__backdrop"></div>
        <div class="tv-stage__aurora"></div>
        <div class="tv-stage__fog"></div>
        <div class="tv-stage__gridlines"></div>
        <div class="tv-stage__particles"></div>

        <header class="tv-waiting-hero">
            <span class="tv-stage__eyebrow">@T("hero.eyebrow")</span>
            <h1>@T("hero.title")</h1>
            <p class="tv-waiting-hero__lead">@T("states.waitingForNextHotBattle")</p>
            <p class="tv-waiting-hero__sublead">@GetAlternateLanguageLine()</p>
            <div class="tv-stage__badges">
                <span class="tv-pill">@T("labels.automaticBroadcast")</span>
                <span class="tv-pill tv-pill--signal">@T("states.noHotMatchRightNow")</span>
            </div>
        </header>

        <div class="tv-waiting-grid">
            <article class="tv-panel">
                <div class="tv-panel__head">
                    <span>@T("waiting.topCoinsEyebrow")</span>
                    <h2>@T("waiting.topCoins")</h2>
                </div>
                <div class="tv-ranking-list">
                    @foreach (var team in TopTeams)
                    {
                        <div class="tv-ranking-row">
                            <strong>#{team.Rank}</strong>
                            <div>
                                <span>@team.Symbol</span>
                                <small>@team.DisplayName</small>
                            </div>
                            <em>@FormatPercent(team.WinRate)</em>
                        </div>
                    }
                </div>
            </article>

            <article class="tv-panel">
                <div class="tv-panel__head">
                    <span>@T("waiting.statsEyebrow")</span>
                    <h2>@T("waiting.latestBattles")</h2>
                </div>
                <div class="tv-latest-list">
                    @foreach (var match in LatestMatches)
                    {
                        <div class="tv-latest-row">
                            <div>
                                <strong>@match.HomeSymbol vs @match.AwaySymbol</strong>
                                <small>@FormatStatus(match.Status)</small>
                            </div>
                            <em>@match.HomeScore:@match.AwayScore</em>
                        </div>
                    }
                </div>
            </article>

            <article class="tv-panel">
                <div class="tv-panel__head">
                    <span>@T("waiting.gainersEyebrow")</span>
                    <h2>@T("waiting.marketPulse")</h2>
                </div>
                <div class="tv-gainers-list">
                    @foreach (var asset in TopGainers)
                    {
                        <div class="tv-gainer-row">
                            <span>@asset.Symbol</span>
                            <strong>@FormatSignedPercent(asset.PercentageChange)</strong>
                        </div>
                    }
                </div>
            </article>
        </div>

        @if (_tickerItems.Count > 0)
        {
            <section class="tv-ticker" aria-label="@T("labels.broadcastTicker")">
                <div class="tv-ticker__track">
                    @for (var repetition = 0; repetition < 2; repetition++)
                    {
                        <div class="tv-ticker__lane">
                            @foreach (var item in _tickerItems)
                            {
                                <span class="tv-ticker__item">@item</span>
                            }
                        </div>
                    }
                </div>
            </section>
        }
    </section>
}

@code {
    [Parameter] public string Culture { get; set; } = AppCultureService.DefaultRouteCulture;
    [Parameter] public TvHotMatchDto? HotMatch { get; set; }
    [Parameter] public MatchDto? Match { get; set; }
    [Parameter] public StatsOverviewDto? Stats { get; set; }
    [Parameter] public DashboardSnapshotDto? Snapshot { get; set; }

    private IJSObjectReference? _tvModule;
    private BroadcastSnapshot? _previousSnapshot;
    private CancellationTokenSource? _eventCts;
    private CancellationTokenSource? _pulseCts;
    private TvOverlayEvent? _activeEvent;
    private bool _isEventVisible;
    private bool _pulseLeftScore;
    private bool _pulseRightScore;
    private bool _pulseScoreboard;
    private bool _pulseHotScore;
    private string _tickerSignature = string.Empty;
    private IReadOnlyList<string> _tickerItems = [];

    private bool HasLiveMatch => HotMatch?.HasMatch == true || Match is not null;
    private IReadOnlyList<StatsAssetPerformanceDto> TopTeams => Stats?.TopTeams?.Take(6).ToList() ?? [];
    private IReadOnlyList<StatsLatestMatchDto> LatestMatches => Stats?.LatestMatches?.Take(4).ToList() ?? [];
    private IReadOnlyList<CurrencyDto> TopGainers => Snapshot?.TopGainers?.Take(6).ToList() ?? [];

    protected override void OnParametersSet()
    {
        BuildTickerItems();
        ProcessBroadcastState();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _tvModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/tvMode.js");
        await LogAsync("TV_MOTION", "motion system ready");
        if (_tickerItems.Count > 0)
            await LogAsync("TV_TICKER", "updated", _tickerItems);
    }

    private void ProcessBroadcastState()
    {
        var current = CaptureSnapshot();
        if (current is null)
        {
            _previousSnapshot = null;
            return;
        }

        if (_previousSnapshot is null)
        {
            _ = TriggerEventAsync(CreateEvent("hotMatchDetected"));
            _previousSnapshot = current;
            return;
        }

        var hasScoreChange = current.LeftScore != _previousSnapshot.LeftScore || current.RightScore != _previousSnapshot.RightScore;
        var scoreLeaderChanged = current.LeaderSymbol != _previousSnapshot.LeaderSymbol && !string.IsNullOrWhiteSpace(_previousSnapshot.LeaderSymbol);
        var hotScoreSpike = current.HotScore >= _previousSnapshot.HotScore + 8;
        var reversalDetected = current.HasRecentReversal && !_previousSnapshot.HasRecentReversal;
        var fearSpike = current.HasFearSignal && !_previousSnapshot.HasFearSignal;
        var finalMoments = current.RemainingSeconds <= 300 && _previousSnapshot.RemainingSeconds > 300;

        if (hasScoreChange)
        {
            _ = PulseScoreAsync(current.LeftScore > _previousSnapshot.LeftScore, current.RightScore > _previousSnapshot.RightScore, hotScoreSpike);
            _ = TriggerEventAsync(CreateGoalEvent(current));
        }
        else if (scoreLeaderChanged)
        {
            _ = TriggerEventAsync(CreateLeaderEvent(current));
        }
        else if (reversalDetected)
        {
            _ = TriggerEventAsync(CreateEvent("momentumReversal"));
        }
        else if (fearSpike)
        {
            _ = TriggerEventAsync(CreateEvent("fearSurge"));
        }
        else if (hotScoreSpike)
        {
            _ = PulseScoreAsync(false, false, true);
            _ = TriggerEventAsync(CreateEvent("hotScoreSpike"));
        }
        else if (finalMoments)
        {
            _ = TriggerEventAsync(CreateEvent("finalMoments"));
        }

        _previousSnapshot = current;
    }

    private BroadcastSnapshot? CaptureSnapshot()
    {
        if (!HasLiveMatch)
            return null;

        return new BroadcastSnapshot(
            DisplayLeftScore(),
            DisplayRightScore(),
            DisplayLeftSymbol(),
            DisplayRightSymbol(),
            ResolveLeaderSymbol(),
            HotMatch?.HotScore ?? 0,
            ParseRemainingSeconds(DisplayRemainingTime()),
            HotMatch?.HasRecentReversal == true,
            HasFearSignal());
    }

    private async Task TriggerEventAsync(TvOverlayEvent? overlayEvent)
    {
        if (overlayEvent is null)
            return;

        _eventCts?.Cancel();
        _eventCts?.Dispose();
        _eventCts = new CancellationTokenSource();
        var ct = _eventCts.Token;

        _activeEvent = overlayEvent;
        _isEventVisible = true;
        await LogAsync("TV_EVENT", overlayEvent.Key);
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(TimeSpan.FromSeconds(5), ct);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        _isEventVisible = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task PulseScoreAsync(bool pulseLeft, bool pulseRight, bool pulseHotScore)
    {
        _pulseCts?.Cancel();
        _pulseCts?.Dispose();
        _pulseCts = new CancellationTokenSource();
        var ct = _pulseCts.Token;

        _pulseLeftScore = pulseLeft;
        _pulseRightScore = pulseRight;
        _pulseScoreboard = pulseLeft || pulseRight;
        _pulseHotScore = pulseHotScore;
        if (_pulseScoreboard || _pulseHotScore)
        {
            await LogAsync("TV_MOTION", "score pulse", new
            {
                pulseLeft,
                pulseRight,
                pulseHotScore
            });
        }

        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(TimeSpan.FromSeconds(2.2), ct);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        _pulseLeftScore = false;
        _pulseRightScore = false;
        _pulseScoreboard = false;
        _pulseHotScore = false;
        await InvokeAsync(StateHasChanged);
    }

    private void BuildTickerItems()
    {
        var items = new List<string>();

        if (HasLiveMatch)
        {
            items.Add(T("ticker.hotMatchDetected"));
            items.Add(T("ticker.liveCryptoBattle"));
            items.Add(T("ticker.arenaPressureRising"));
            items.Add(T("ticker.marketVolatilityIncreasing"));

            if (HotMatch?.HasRecentReversal == true)
                items.Add(T("ticker.momentumShift"));

            if (HasFearSignal())
                items.Add(T("ticker.fearSurge"));

            var leader = ResolveLeaderSymbol();
            var trailer = leader == DisplayLeftSymbol() ? DisplayRightSymbol() : DisplayLeftSymbol();
            items.Add(T("ticker.dominating", leader));
            items.Add(T("ticker.recovering", trailer));

            if (ParseRemainingSeconds(DisplayRemainingTime()) <= 600)
                items.Add(T("ticker.finalMinutes"));

            if ((HotMatch?.HotScore ?? 0) >= 90)
                items.Add(T("ticker.crowdEnergySpike"));
        }
        else
        {
            items.Add(T("states.waitingForNextHotBattle"));
            items.Add(T("labels.automaticBroadcast"));

            var topCoin = TopTeams.FirstOrDefault()?.Symbol;
            if (!string.IsNullOrWhiteSpace(topCoin))
                items.Add(T("ticker.nextBattleAround", topCoin));

            var topMover = TopGainers.FirstOrDefault()?.Symbol;
            if (!string.IsNullOrWhiteSpace(topMover))
                items.Add(T("ticker.marketPulseAround", topMover));
        }

        _tickerItems = items.Where(x => !string.IsNullOrWhiteSpace(x)).Distinct().ToList();
        var signature = string.Join("||", _tickerItems);
        if (signature != _tickerSignature)
        {
            _tickerSignature = signature;
            _ = LogAsync("TV_TICKER", "updated", _tickerItems);
        }
    }

    private TvOverlayEvent CreateGoalEvent(BroadcastSnapshot current)
    {
        var scorer = current.LeftScore > _previousSnapshot!.LeftScore ? current.LeftSymbol : current.RightSymbol;
        return new TvOverlayEvent("goal", T("events.goalKicker"), T("events.goalTitle", scorer), DisplayScoreContext(), GetAccentColor(scorer));
    }

    private TvOverlayEvent CreateLeaderEvent(BroadcastSnapshot current)
        => new("leaderChange", T("events.leaderChangeKicker"), T("events.leaderChangeTitle", current.LeaderSymbol), T("events.leaderChangeBody"), GetAccentColor(current.LeaderSymbol));

    private TvOverlayEvent? CreateEvent(string key)
        => key switch
        {
            "hotMatchDetected" => new TvOverlayEvent("hotMatchDetected", T("events.hotMatchKicker"), T("events.hotMatchTitle"), T("events.hotMatchBody"), GetAccentColor(ResolveLeaderSymbol())),
            "momentumReversal" => new TvOverlayEvent("momentumReversal", T("events.momentumReversalKicker"), T("events.momentumReversalTitle"), T("events.momentumReversalBody"), "#7ff6df"),
            "fearSurge" => new TvOverlayEvent("fearSurge", T("events.fearSurgeKicker"), T("events.fearSurgeTitle"), T("events.fearSurgeBody"), "#ffd76e"),
            "hotScoreSpike" => new TvOverlayEvent("hotScoreSpike", T("events.hotScoreSpikeKicker"), T("events.hotScoreSpikeTitle"), T("events.hotScoreSpikeBody"), "#53c8ff"),
            "finalMoments" => new TvOverlayEvent("finalMoments", T("events.finalMomentsKicker"), T("events.finalMomentsTitle"), T("events.finalMomentsBody"), "#ff8e8e"),
            _ => null
        };

    private string T(string key, params object?[] args)
        => L.T($"tv.{key}", Culture, args);

    private string DisplayLeftSymbol() => HotMatch?.LeftSymbol ?? Match?.TeamA ?? "-";
    private string DisplayRightSymbol() => HotMatch?.RightSymbol ?? Match?.TeamB ?? "-";
    private string DisplayLeftName() => HotMatch?.LeftName ?? Match?.TeamA ?? "-";
    private string DisplayRightName() => HotMatch?.RightName ?? Match?.TeamB ?? "-";
    private int DisplayLeftScore() => HotMatch?.LeftScore ?? Match?.ScoreA ?? 0;
    private int DisplayRightScore() => HotMatch?.RightScore ?? Match?.ScoreB ?? 0;

    private string DisplayLeftLogoUrl()

     => HotMatch?.LeftLogoUrl

        ?? $"/api/icons/binance/{GetBaseSymbol(DisplayLeftSymbol())}";



    private string DisplayRightLogoUrl()

        => HotMatch?.RightLogoUrl

           ?? $"/api/icons/binance/{GetBaseSymbol(DisplayRightSymbol())}";

    private string DisplayRemainingTime() => HotMatch?.RemainingTimeLabel ?? BuildRemainingTimeFallback();
    private string DisplayVolume() => HotMatch?.VolumeLabel ?? BuildVolumeFallback();
    private string DisplayMomentum() => HotMatch?.MomentumLabel ?? BuildMomentumFallback();
    private string DisplayReason() => HotMatch?.Reason ?? BuildReasonFallback();
    private string DisplayHotScore() => (HotMatch?.HotScore ?? 0).ToString(CultureInfo.InvariantCulture);

    private string DisplayScoreContext()
    {
        var diff = Math.Abs(DisplayLeftScore() - DisplayRightScore());
        return diff switch
        {
            0 => T("labels.tiePressure"),
            1 => T("labels.onePointBattle"),
            _ => T("labels.liveRewardDynamics")
        };
    }

    private string DisplayMomentumSupportLine()
        => HotMatch?.HasRecentReversal == true
            ? T("labels.reversalDetected")
            : T("labels.sideCompetition");

    private string DisplayEventHeadline()
        => _activeEvent?.Title
            ?? (HotMatch?.HasRecentReversal == true
                ? T("labels.reversalDetected")
                : T("labels.nextBattle"));

    private string DisplayPressureHeadline()
        => $"{DisplayLeftSymbol()} vs {DisplayRightSymbol()}";

    private string DisplayPressureBody()
        => $"{T("labels.competitivePool")} • {DisplayVolume()} • {DisplayRemainingTime()}";

    private string BuildRemainingTimeFallback()
    {
        var remaining = Match?.RemainingMinutes ?? 0;
        return $"{Math.Max(0, remaining):00}:00";
    }

    private string BuildVolumeFallback()
    {
        var totalPool = (Match?.TotalAmountTeamA ?? 0m) + (Match?.TotalAmountTeamB ?? 0m);
        return $"{totalPool:0.##} SOL";
    }

    private string BuildMomentumFallback()
    {
        if (Match is null)
            return T("labels.momentum");

        var leader = (Match.PctA ?? 0m) >= (Match.PctB ?? 0m) ? Match.TeamA : Match.TeamB;
        return string.Format(CultureInfo.InvariantCulture, T("labels.pressureRising"), leader);
    }

    private string BuildReasonFallback()
    {
        if (Match is null)
            return T("states.noHotMatchRightNow");

        if (Math.Abs(Match.ScoreA - Match.ScoreB) <= 1)
            return T("fallback.closeMatchReason");

        return T("fallback.liveArenaReason");
    }

    private string GetAlternateLanguageLine()
        => Culture == AppCultureService.SecondaryRouteCulture
            ? L.T("tv.states.waitingForNextHotBattle", AppCultureService.DefaultRouteCulture)
            : L.T("tv.states.waitingForNextHotBattle", AppCultureService.SecondaryRouteCulture);

    private string GetLogoUrl(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        if (Uri.TryCreate(value, UriKind.Absolute, out var absoluteUri))
        {
            var sanitizedAbsolute = NormalizeAbsoluteIconUrl(absoluteUri);
            return sanitizedAbsolute ?? value;
        }

        var sanitized = NormalizeIconRoute(value);
        return EnvironmentIsolationGuard.BuildApiUrl(Config, sanitized);
    }

    private string? NormalizeAbsoluteIconUrl(Uri value)
    {
        var sanitizedPath = NormalizeIconRoute(value.AbsolutePath);
        if (string.Equals(sanitizedPath, value.AbsolutePath, StringComparison.Ordinal))
            return value.ToString();

        return EnvironmentIsolationGuard.BuildApiUrl(Config, sanitizedPath);
    }

    private static string NormalizeIconRoute(string value)
    {
        const string prefix = "/api/icons/binance/";
        if (!value.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
            return value;

        var symbol = value[prefix.Length..];
        var normalized = GetBaseSymbol(Uri.UnescapeDataString(symbol));
        return $"{prefix}{Uri.EscapeDataString(normalized)}";
    }

    private string GetTeamStyle(string symbol, bool isLeft)
    {
        var accent = GetAccentColor(symbol);
        var shadow = isLeft ? "rgba(83, 200, 255, 0.28)" : "rgba(127, 246, 223, 0.24)";
        return $"--team-accent:{accent}; --team-shadow:{shadow};";
    }

    private string GetEventAccentStyle(string accentHex)
        => $"--event-accent:{accentHex};";

    private string GetAccentColor(string? symbol)
    {
        var normalized = symbol?.Trim().ToUpperInvariant() ?? string.Empty;
        return normalized switch
        {
            "BTC" => "#f5b942",
            "ETH" => "#7f8df6",
            "SOL" => "#55f5bf",
            "BNB" => "#f2d56b",
            "XRP" => "#71d1ff",
            "ADA" => "#5dd8ff",
            "DOGE" => "#efc166",
            _ => HashAccent(normalized)
        };
    }

    private static string HashAccent(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "#53c8ff";

        var seed = value.Sum(ch => ch);
        var hue = seed % 360;
        return $"hsl({hue} 78% 64%)";
    }

    private string ResolveLeaderSymbol()
    {
        if (DisplayLeftScore() == DisplayRightScore())
            return HotMatch?.HasRecentReversal == true
                ? ResolveMomentumLeader()
                : DisplayLeftSymbol();

        return DisplayLeftScore() > DisplayRightScore() ? DisplayLeftSymbol() : DisplayRightSymbol();
    }

    private string ResolveMomentumLeader()
    {
        var momentum = DisplayMomentum();
        if (momentum.Contains(DisplayLeftSymbol(), StringComparison.OrdinalIgnoreCase))
            return DisplayLeftSymbol();

        if (momentum.Contains(DisplayRightSymbol(), StringComparison.OrdinalIgnoreCase))
            return DisplayRightSymbol();

        return DisplayLeftSymbol();
    }

    private static string GetBaseSymbol(string? symbol)

    {

        if (string.IsNullOrWhiteSpace(symbol))

            return string.Empty;



        var upper = symbol.Trim().ToUpperInvariant();



        string[] quoteAssets =

        [

            "USDT",
    "USDC",
    "BUSD",
    "FDUSD",
    "BTC",
    "ETH"

        ];



        foreach (var quote in quoteAssets)

        {

            if (upper.EndsWith(quote, StringComparison.OrdinalIgnoreCase)

                && upper.Length > quote.Length)

            {

                return upper[..^quote.Length];

            }

        }



        return upper;

    }

    private bool HasFearSignal()
    {
        var text = $"{DisplayMomentum()} {DisplayReason()}";
        return text.Contains("fear", StringComparison.OrdinalIgnoreCase)
            || text.Contains("medo", StringComparison.OrdinalIgnoreCase)
            || text.Contains("surge", StringComparison.OrdinalIgnoreCase);
    }

    private static int ParseRemainingSeconds(string value)
    {
        if (TimeSpan.TryParseExact(value, @"mm\:ss", CultureInfo.InvariantCulture, out var mmss))
            return (int)mmss.TotalSeconds;

        return 0;
    }

    private string FormatPercent(decimal value)
        => $"{value:0.#}%";

    private string FormatSignedPercent(decimal value)
        => value >= 0m ? $"+{value:0.##}%" : $"{value:0.##}%";

    private string FormatStatus(string? status)
        => string.Equals(status, "Ongoing", StringComparison.OrdinalIgnoreCase)
            ? T("labels.liveArena")
            : string.Equals(status, "Completed", StringComparison.OrdinalIgnoreCase)
                ? T("labels.completed")
                : T("labels.nextBattle");

    private async Task LogAsync(string prefix, string eventName, object? payload = null)
    {
        if (_tvModule is null)
            return;

        await _tvModule.InvokeVoidAsync("log", prefix, eventName, payload);
    }

    public async ValueTask DisposeAsync()
    {
        _eventCts?.Cancel();
        _eventCts?.Dispose();
        _pulseCts?.Cancel();
        _pulseCts?.Dispose();

        if (_tvModule is not null)
            await _tvModule.DisposeAsync();
    }

    private sealed record BroadcastSnapshot(
        int LeftScore,
        int RightScore,
        string LeftSymbol,
        string RightSymbol,
        string LeaderSymbol,
        int HotScore,
        int RemainingSeconds,
        bool HasRecentReversal,
        bool HasFearSignal);

    private sealed record TvOverlayEvent(
        string Key,
        string Kicker,
        string Title,
        string Body,
        string AccentHex);
}

