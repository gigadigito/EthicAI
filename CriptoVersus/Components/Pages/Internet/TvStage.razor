@using System.Globalization
@using System.Text
@using CriptoVersus.Components.Shared
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersusApiClient Api
@inject LocalizationService L
@inject IConfiguration Config
@inject IJSRuntime JS
@inject IWebHostEnvironment Environment
@inject MatchSlugHelper MatchSlugHelper
@inject RouteLocalizationService RouteLocalization
@inject TvArenaCommentaryService ArenaCommentary
@implements IAsyncDisposable

@if (HasLiveMatch)
{
    <section class="tv-stage tv-stage--live @(IsBroadcastMode ? "tv-stage--broadcast" : string.Empty)">
        <div class="tv-stage__backdrop"></div>
        <div class="tv-stage__aurora"></div>
        <div class="tv-stage__fog"></div>
        <div class="tv-stage__gridlines"></div>
        <div class="tv-stage__particles"></div>
        <TvNarrationOverlay @ref="_narrationOverlay" />

        @if (_isEventVisible && _activeEvent is not null)
        {
            <div class="tv-event-overlay is-visible" aria-live="polite" aria-atomic="true">
                <div class="tv-event-overlay__card" style="@GetEventAccentStyle(_activeEvent.AccentHex)">
                    <span>@_activeEvent.Kicker</span>
                    <strong>@_activeEvent.Title</strong>
                    <small>@_activeEvent.Body</small>
                </div>
            </div>
        }

        @if (IsBroadcastSwitchNoticeVisible)
        {
            <div class="tv-broadcast-notice" aria-live="polite" aria-atomic="true">
                <strong>@T("broadcast.switchingArena")</strong>
                <span>@T("broadcast.nextHotArena")</span>
            </div>
        }

        <header class="tv-stage__topbar">
            <div>
                <span class="tv-stage__eyebrow">@T("hero.eyebrow")</span>
                <h1>@T("hero.title")</h1>
            </div>

            <div class="tv-stage__badges">
                <span class="tv-pill tv-pill--live">
                    <span class="tv-pill__dot"></span>
                    @T("labels.liveArena")
                </span>
                <span class="tv-pill">@T("labels.automaticBroadcast")</span>
                <span class="tv-pill tv-pill--signal">@T("labels.signalStable")</span>
                <span class="tv-pill tv-pill--score @(_pulseHotScore ? "is-pulsing" : string.Empty)">@T("labels.hotScore") @DisplayHotScore()</span>
                @if (ShouldRenderCrowdAudio)
                {
                    <button type="button" class="tv-pill tv-pill--audio" @onclick="ToggleCrowdAudioAsync">@DisplayCrowdAudioLabel()</button>
                }
            </div>
        </header>

        <div class="tv-stage__grid">
            <article class="tv-match-card">
                <div class="tv-match-card__meta">
                    <span>@T("labels.hotMatch")</span>
                    <strong>@DisplayRemainingTime()</strong>
                </div>

                <div class="tv-match-card__arena">
                    <div class="tv-team tv-team--left" style="@GetTeamStyle(DisplayLeftSymbol(), true)">
                        <div class="tv-team__halo"></div>
                        <div class="tv-team__logo-shell">
                            <img src="@GetLogoUrl(DisplayLeftLogoUrl())" alt="" />
                        </div>
                        <span class="tv-team__symbol">@DisplayLeftSymbol()</span>
                        <strong>@DisplayLeftName()</strong>
                        <span class="@GetChangeClass(DisplayLeftChangePercent())">@FormatChangePercent(DisplayLeftChangePercent())</span>
                    </div>

                    <div class="tv-center-hud">
                        <div class="tv-broadcast-clock">
                            <div class="tv-broadcast-clock__header">
                                <span>@T("labels.matchClock")</span>
                                @if (IsClockLive())
                                {
                                    <span class="tv-broadcast-clock__live">@T("labels.live")</span>
                                }
                            </div>
                            <strong>@DisplayClockPrimary()</strong>
                            <small>@DisplayClockPhaseLabel()</small>
                        </div>

                        <div class="tv-scoreboard @(_pulseScoreboard ? "is-pulsing" : string.Empty)">
                            <span class="tv-scoreboard__status">@T("labels.matchArena")</span>
                            <div class="tv-scoreboard__score">
                                <strong class="@(_pulseLeftScore ? "tv-score-value tv-score-value--pulse" : "tv-score-value")">@DisplayLeftScore()</strong>
                                <span class="tv-scoreboard__versus">@T("vs")</span>
                                <strong class="@(_pulseRightScore ? "tv-score-value tv-score-value--pulse" : "tv-score-value")">@DisplayRightScore()</strong>
                            </div>
                            <small>@DisplayScoreContext()</small>
                        </div>
                    </div>

                    <div class="tv-team tv-team--right" style="@GetTeamStyle(DisplayRightSymbol(), false)">
                        <div class="tv-team__halo"></div>
                        <div class="tv-team__logo-shell">
                            <img src="@GetLogoUrl(DisplayRightLogoUrl())" alt="" />
                        </div>
                        <span class="tv-team__symbol">@DisplayRightSymbol()</span>
                        <strong>@DisplayRightName()</strong>
                        <span class="@GetChangeClass(DisplayRightChangePercent())">@FormatChangePercent(DisplayRightChangePercent())</span>
                    </div>
                </div>

                <section class="tv-ai-commentary">
                    <div class="tv-ai-commentary__header">
                        <span>@T("commentary.title")</span>
                        <small>@DisplayCommentaryMeta()</small>
                    </div>

                    <div class="tv-ai-commentary__text">
                        @DisplayCommentaryText()
                    </div>
                </section>

                @if (!string.IsNullOrWhiteSpace(CurrentMatchUrl))
                {
                    <div class="tv-match-card__footer">
                        <a class="tv-watch-link" href="@CurrentMatchUrl">@T("watchMatch")</a>
                    </div>
                }
            </article>

            <aside class="tv-telemetry">
                <article>
                    <span>@T("labels.volume")</span>
                    <strong>@DisplayVolume()</strong>
                    <small>@T("labels.competitivePool")</small>
                </article>
                <article>
                    <span>@T("labels.momentum")</span>
                    <strong>@DisplayMomentum()</strong>
                    <small>@DisplayMomentumSupportLine()</small>
                </article>
                <article>
                    <span>@T("labels.remainingTime")</span>
                    <strong>@DisplayRemainingTime()</strong>
                    <small>@T("labels.arenaCycle")</small>
                </article>
                <article>
                    <span>@T("labels.reason")</span>
                    <strong>@T("labels.liveRewardDynamics")</strong>
                    <small>@DisplayReason()</small>
                </article>
                <article>
                    <span>@T("labels.leader")</span>
                    <strong>@DisplayLeaderSymbol()</strong>
                    <small>@T("labels.assetPerformance")</small>
                </article>
                <article>
                    <span>@T("labels.pressure")</span>
                    <strong>@DisplayPressureSymbol()</strong>
                    <small>@DisplayPoolStatus()</small>
                </article>
                <article>
                    <span>@T("labels.leftAssetChange")</span>
                    <strong class="@GetChangeClass(DisplayLeftChangePercent())">@FormatChangePercent(DisplayLeftChangePercent())</strong>
                    <small>@DisplayLeftSymbol()</small>
                </article>
                <article>
                    <span>@T("labels.rightAssetChange")</span>
                    <strong class="@GetChangeClass(DisplayRightChangePercent())">@FormatChangePercent(DisplayRightChangePercent())</strong>
                    <small>@DisplayRightSymbol()</small>
                </article>
                <article>
                    <span>@T("labels.competitiveness")</span>
                    <strong>@DisplayHotScore()</strong>
                    <small>@DisplayScoreContext()</small>
                </article>
                <article>
                    <span>@T("labels.poolStatus")</span>
                    <strong>@DisplayPoolStatus()</strong>
                    <small>@DisplayVolume()</small>
                </article>
            </aside>
        </div>

        <section class="tv-event-strip">
            <article class="tv-event-strip__card">
                <span>@T("labels.eventZone")</span>
                <strong>@DisplayEventHeadline()</strong>
                <p>@DisplayReason()</p>
            </article>
            <article class="tv-event-strip__card tv-event-strip__card--accent">
                <span>@T("labels.marketDrivenArena")</span>
                <strong>@DisplayPressureHeadline()</strong>
                <p>@DisplayPressureBody()</p>
            </article>
        </section>

        @if (_tickerItems.Count > 0)
        {
            <section class="tv-ticker" aria-label="@T("labels.broadcastTicker")">
                <div class="tv-ticker__track">
                    @for (var repetition = 0; repetition < 2; repetition++)
                    {
                        <div class="tv-ticker__lane">
                            @foreach (var item in _tickerItems)
                            {
                                <span class="tv-ticker__item">@item</span>
                            }
                        </div>
                    }
                </div>
            </section>
        }
    </section>
}
else
{
    <section class="tv-stage tv-stage--waiting @(IsBroadcastMode ? "tv-stage--broadcast" : string.Empty)">
        <div class="tv-stage__backdrop"></div>
        <div class="tv-stage__aurora"></div>
        <div class="tv-stage__fog"></div>
        <div class="tv-stage__gridlines"></div>
        <div class="tv-stage__particles"></div>
        <TvNarrationOverlay @ref="_narrationOverlay" />

        <header class="tv-waiting-hero">
            <span class="tv-stage__eyebrow">@T("hero.eyebrow")</span>
            <h1>@T("hero.title")</h1>
            <p class="tv-waiting-hero__lead">@T("states.waitingForNextHotBattle")</p>
            <p class="tv-waiting-hero__sublead">@GetAlternateLanguageLine()</p>
            <div class="tv-stage__badges">
                <span class="tv-pill">@T("labels.automaticBroadcast")</span>
                <span class="tv-pill tv-pill--signal">@T("states.noHotMatchRightNow")</span>
                @if (ShouldRenderCrowdAudio)
                {
                    <button type="button" class="tv-pill tv-pill--audio" @onclick="ToggleCrowdAudioAsync">@DisplayCrowdAudioLabel()</button>
                }
            </div>
        </header>

        <div class="tv-waiting-grid">
            <article class="tv-panel">
                <div class="tv-panel__head">
                    <span>@T("waiting.topCoinsEyebrow")</span>
                    <h2>@T("waiting.topCoins")</h2>
                </div>
                <div class="tv-ranking-list">
                    @foreach (var team in TopTeams)
                    {
                        <div class="tv-ranking-row">
                            <strong>#{team.Rank}</strong>
                            <div>
                                <span>@team.Symbol</span>
                                <small>@team.DisplayName</small>
                            </div>
                            <em>@FormatPercent(team.WinRate)</em>
                        </div>
                    }
                </div>
            </article>

            <article class="tv-panel">
                <div class="tv-panel__head">
                    <span>@T("waiting.statsEyebrow")</span>
                    <h2>@T("waiting.latestBattles")</h2>
                </div>
                <div class="tv-latest-list">
                    @foreach (var match in LatestMatches)
                    {
                        <div class="tv-latest-row">
                            <div>
                                <strong>@match.HomeSymbol @T("vs") @match.AwaySymbol</strong>
                                <small>@FormatStatus(match.Status)</small>
                            </div>
                            <div class="tv-latest-row__meta">
                                <em>@match.HomeScore:@match.AwayScore</em>
                                @if (!string.IsNullOrWhiteSpace(BuildMatchUrl(match)))
                                {
                                    <a class="tv-inline-link" href="@BuildMatchUrl(match)">@T("watchMatch")</a>
                                }
                            </div>
                        </div>
                    }
                </div>
            </article>

            <article class="tv-panel">
                <div class="tv-panel__head">
                    <span>@T("waiting.gainersEyebrow")</span>
                    <h2>@T("waiting.marketPulse")</h2>
                </div>
                <div class="tv-gainers-list">
                    @foreach (var asset in TopGainers)
                    {
                        <div class="tv-gainer-row">
                            <span>@asset.Symbol</span>
                            <strong>@FormatSignedPercent(asset.PercentageChange)</strong>
                        </div>
                    }
                </div>
            </article>
        </div>

        @if (_tickerItems.Count > 0)
        {
            <section class="tv-ticker" aria-label="@T("labels.broadcastTicker")">
                <div class="tv-ticker__track">
                    @for (var repetition = 0; repetition < 2; repetition++)
                    {
                        <div class="tv-ticker__lane">
                            @foreach (var item in _tickerItems)
                            {
                                <span class="tv-ticker__item">@item</span>
                            }
                        </div>
                    }
                </div>
            </section>
        }
    </section>
}

@if (ShouldRenderCrowdAudio)
{
    <audio id="tv-broadcast-crowd" class="tv-crowd-audio" src="/audio/tv/stadium-crowd-loop.mp3" preload="auto" loop></audio>
}

@if (Environment.IsDevelopment())
{
    <aside class="tv-dev-narration-panel">
        @foreach (var animation in NarrationDebugAnimations)
        {
            <button type="button" @onclick="() => TriggerDevNarrationAsync(animation)">@animation</button>
        }
        <button type="button" @onclick="TriggerDevAiNarrationAsync">test commentary</button>
    </aside>
}

@code {
    [Parameter] public string Culture { get; set; } = AppCultureService.DefaultRouteCulture;
    [Parameter] public bool IsBroadcastMode { get; set; }
    [Parameter] public TvHotMatchDto? HotMatch { get; set; }
    [Parameter] public MatchDto? Match { get; set; }
    [Parameter] public StatsOverviewDto? Stats { get; set; }
    [Parameter] public DashboardSnapshotDto? Snapshot { get; set; }

    // Temporary debug demo to validate the cinematic narration overlay visually.
    private const bool EnableNarrationDebugDemo = true;
    private static readonly string[] NarrationDebugAnimations =
    [
        "grow",
        "zoom-burst",
        "glitch",
        "neon-flash",
        "shockwave",
        "screen-impact",
        "diagonal-swipe",
        "split-reveal",
        "hologram-reveal",
        "pulse"
    ];

    private IJSObjectReference? _tvModule;
    private BroadcastSnapshot? _previousSnapshot;
    private CancellationTokenSource? _eventCts;
    private CancellationTokenSource? _pulseCts;
    private CancellationTokenSource? _clockCts;
    private Task? _clockLoopTask;
    private TvOverlayEvent? _activeEvent;
    private TvNarrationOverlay? _narrationOverlay;
    private bool _isEventVisible;
    private bool _pulseLeftScore;
    private bool _pulseRightScore;
    private bool _pulseScoreboard;
    private bool _pulseHotScore;
    private bool _narrationDebugDemoStarted;
    private bool _isAiNarrationLoading;
    private DateTime? _lastAiNarrationAtUtc;
    private int? _lastAiNarrationMatchId;
    private string _currentAiNarration = string.Empty;
    private string _aiNarrationSource = "template";
    private string _lastAiNarrationRequestSignature = string.Empty;
    private List<string> _commentaryHistory = [];
    private string _clockDebugSignature = string.Empty;
    private string _tickerSignature = string.Empty;
    private IReadOnlyList<string> _tickerItems = [];
    private DateTime _clockAnchorUtc = DateTime.UtcNow;
    private double _clockAnchorRemainingMilliseconds;
    private DateTime _broadcastNoticeUntilUtc = DateTime.MinValue;
    private bool _isCrowdAudioMuted;
    private bool _broadcastAudioInitialized;
    private bool HasLiveMatch => HotMatch?.HasMatch == true || Match is not null;
    private bool IsBroadcastSwitchNoticeVisible => IsBroadcastMode && DateTime.UtcNow <= _broadcastNoticeUntilUtc;
    private bool ShouldRenderCrowdAudio => IsBroadcastMode && Config.GetValue<bool?>("CriptoVersusTV:EnableBroadcastCrowdAudio") != false;
    private IReadOnlyList<StatsAssetPerformanceDto> TopTeams => Stats?.TopTeams?.Take(6).ToList() ?? [];
    private IReadOnlyList<StatsLatestMatchDto> LatestMatches => Stats?.LatestMatches?.Take(4).ToList() ?? [];
    private IReadOnlyList<CurrencyDto> TopGainers => Snapshot?.TopGainers?.Take(6).ToList() ?? [];
    private string CurrentMatchUrl => BuildMatchUrl(Match?.MatchId ?? HotMatch?.MatchId ?? 0, MatchSlugOrHotSlug());

    protected override void OnParametersSet()
    {
        if (!ShouldRenderCrowdAudio)
            _broadcastAudioInitialized = false;

        SyncClockAnchor();
        ProcessBroadcastState();
        BuildTickerItems();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _tvModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/tvMode.js");
            await LogAsync("TV_MOTION", "motion system ready");
            if (_tickerItems.Count > 0)
                await LogAsync("TV_TICKER", "updated", _tickerItems);

            _clockCts = new CancellationTokenSource();
            _clockLoopTask = RunClockLoopAsync(_clockCts.Token);

            if (EnableNarrationDebugDemo && !_narrationDebugDemoStarted && _narrationOverlay is not null)
            {
                _narrationDebugDemoStarted = true;
                _ = RunNarrationDebugDemoAsync();
            }

            await LogClockDebugAsync();
        }

        if (ShouldRenderCrowdAudio && !_broadcastAudioInitialized)
            await EnsureBroadcastAudioAsync();
    }

    private async Task RunClockLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromMilliseconds(75));

        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void ProcessBroadcastState()
    {
        var current = CaptureSnapshot();
        if (current is null)
        {
            _previousSnapshot = null;
            _lastAiNarrationMatchId = null;
            _currentAiNarration = string.Empty;
            _commentaryHistory = [];
            return;
        }

        if (_lastAiNarrationMatchId != current.MatchId)
        {
            if (IsBroadcastMode && _lastAiNarrationMatchId.HasValue)
                _broadcastNoticeUntilUtc = DateTime.UtcNow.AddSeconds(4);

            _lastAiNarrationMatchId = current.MatchId;
            _lastAiNarrationRequestSignature = string.Empty;
            _currentAiNarration = string.Empty;
            _commentaryHistory = [];
        }

        if (_previousSnapshot is null)
        {
            _ = TriggerEventAsync(CreateEvent("hotMatchDetected"));
            _ = QueueNarrationAsync(CreateNarrationEvent("hotMatchDetected", current));
            _ = MaybeRefreshAiNarrationAsync("initial");
            _previousSnapshot = current;
            return;
        }

        var hasScoreChange = current.LeftScore != _previousSnapshot.LeftScore || current.RightScore != _previousSnapshot.RightScore;
        var scoreLeaderChanged = current.LeaderSymbol != _previousSnapshot.LeaderSymbol && !string.IsNullOrWhiteSpace(_previousSnapshot.LeaderSymbol);
        var hotScoreSpike = current.HotScore >= _previousSnapshot.HotScore + 8;
        var reversalDetected = current.HasRecentReversal && !_previousSnapshot.HasRecentReversal;
        var fearSpike = current.HasFearSignal && !_previousSnapshot.HasFearSignal;
        var finalMoments = current.RemainingSeconds <= 300 && _previousSnapshot.RemainingSeconds > 300;

        if (hasScoreChange)
        {
            _ = PulseScoreAsync(current.LeftScore > _previousSnapshot.LeftScore, current.RightScore > _previousSnapshot.RightScore, hotScoreSpike);
            _ = TriggerEventAsync(CreateGoalEvent(current));
            _ = QueueNarrationAsync(CreateGoalNarration(current));
            _ = MaybeRefreshAiNarrationAsync("goal");
        }
        else if (scoreLeaderChanged)
        {
            _ = TriggerEventAsync(CreateLeaderEvent(current));
            _ = QueueNarrationAsync(CreateLeaderNarration(current));
            _ = MaybeRefreshAiNarrationAsync("leader-change");
        }
        else if (reversalDetected)
        {
            _ = TriggerEventAsync(CreateEvent("momentumReversal"));
            _ = QueueNarrationAsync(CreateNarrationEvent("momentumReversal", current));
            _ = MaybeRefreshAiNarrationAsync("momentum-shift");
        }
        else if (fearSpike)
        {
            _ = TriggerEventAsync(CreateEvent("fearSurge"));
            _ = QueueNarrationAsync(CreateNarrationEvent("fearSurge", current));
            _ = MaybeRefreshAiNarrationAsync("fear-spike");
        }
        else if (hotScoreSpike)
        {
            _ = PulseScoreAsync(false, false, true);
            _ = TriggerEventAsync(CreateEvent("hotScoreSpike"));
            _ = QueueNarrationAsync(CreateNarrationEvent("hotScoreSpike", current));
            _ = MaybeRefreshAiNarrationAsync("massive-breakout");
        }
        else if (finalMoments)
        {
            _ = TriggerEventAsync(CreateEvent("finalMoments"));
            _ = QueueNarrationAsync(CreateNarrationEvent("finalMoments", current));
            _ = MaybeRefreshAiNarrationAsync("final-minutes");
        }

        _previousSnapshot = current;
    }

    private BroadcastSnapshot? CaptureSnapshot()
    {
        if (!HasLiveMatch)
            return null;

        return new BroadcastSnapshot(
            HotMatch?.MatchId ?? Match?.MatchId ?? 0,
            DisplayLeftScore(),
            DisplayRightScore(),
            DisplayLeftSymbol(),
            DisplayRightSymbol(),
            ResolveLeaderSymbol(),
            HotMatch?.HotScore ?? 0,
            ParseRemainingSeconds(DisplayRemainingTime()),
            HotMatch?.HasRecentReversal == true,
            HasFearSignal());
    }

    private async Task TriggerEventAsync(TvOverlayEvent? overlayEvent)
    {
        if (overlayEvent is null)
            return;

        _eventCts?.Cancel();
        _eventCts?.Dispose();
        _eventCts = new CancellationTokenSource();
        var ct = _eventCts.Token;

        _activeEvent = overlayEvent;
        _isEventVisible = true;
        await LogAsync("TV_EVENT", overlayEvent.Key);
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(TimeSpan.FromSeconds(5), ct);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        _isEventVisible = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task QueueNarrationAsync(TvNarrationEvent? narrationEvent)
    {
        if (narrationEvent is null || _narrationOverlay is null)
            return;

        if (IsImpactSeverity(narrationEvent.Severity))
            _ = TriggerStageImpactAsync(narrationEvent.DurationMs);

        await LogAsync("TV_NARRATION", narrationEvent.Type, new
        {
            narrationEvent.Severity,
            narrationEvent.Text,
            narrationEvent.Asset,
            narrationEvent.Side,
            narrationEvent.Animation
        });

        await _narrationOverlay.EnqueueAsync(narrationEvent);
    }

    private async Task TriggerStageImpactAsync(int durationMs)
    {
        try
        {
            await JS.InvokeVoidAsync("criptoVersusTvNarration.impact");
        }
        catch
        {
        }
    }

    private async Task RunNarrationDebugDemoAsync()
    {
        await LogAsync("TV_NARRATION", "debug-demo-started");

        await Task.Delay(TimeSpan.FromSeconds(2));
        await QueueNarrationAsync(new TvNarrationEvent
        {
            Type = "debug-goal-kite",
            Severity = "extreme",
            Text = T("narration.devZoomBurstText"),
            Subtitle = T("narration.devZoomBurstSubtitle"),
            Animation = "zoom-burst",
            DurationMs = 4000,
            CooldownMs = 250,
            Side = "center"
        });
        await MaybeRefreshAiNarrationAsync("goal", true);

        await Task.Delay(TimeSpan.FromSeconds(4));
        await QueueNarrationAsync(new TvNarrationEvent
        {
            Type = "debug-momentum-shift",
            Severity = "high",
            Text = T("narration.devGlitchText"),
            Subtitle = T("narration.devGlitchSubtitle"),
            Animation = "glitch",
            DurationMs = 3500,
            CooldownMs = 250,
            Side = "center"
        });
        await MaybeRefreshAiNarrationAsync("momentum-shift", true);

        await Task.Delay(TimeSpan.FromSeconds(4));
        await QueueNarrationAsync(new TvNarrationEvent
        {
            Type = "debug-massive-breakout",
            Severity = "extreme",
            Text = T("narration.devScreenImpactText"),
            Subtitle = T("narration.devMassiveBreakoutSubtitle"),
            Animation = "screen-impact",
            DurationMs = 3600,
            CooldownMs = 250,
            Side = "center"
        });
        await MaybeRefreshAiNarrationAsync("massive-breakout", true);
    }

    private Task TriggerDevNarrationAsync(string animation)
        => QueueNarrationAsync(CreateDevNarrationEvent(animation));

    private Task TriggerDevAiNarrationAsync()
        => MaybeRefreshAiNarrationAsync("manual-test", true);

    private async Task PulseScoreAsync(bool pulseLeft, bool pulseRight, bool pulseHotScore)
    {
        _pulseCts?.Cancel();
        _pulseCts?.Dispose();
        _pulseCts = new CancellationTokenSource();
        var ct = _pulseCts.Token;

        _pulseLeftScore = pulseLeft;
        _pulseRightScore = pulseRight;
        _pulseScoreboard = pulseLeft || pulseRight;
        _pulseHotScore = pulseHotScore;
        if (_pulseScoreboard || _pulseHotScore)
        {
            await LogAsync("TV_MOTION", "score pulse", new
            {
                pulseLeft,
                pulseRight,
                pulseHotScore
            });
        }

        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(TimeSpan.FromSeconds(2.2), ct);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        _pulseLeftScore = false;
        _pulseRightScore = false;
        _pulseScoreboard = false;
        _pulseHotScore = false;
        await InvokeAsync(StateHasChanged);
    }

    private void BuildTickerItems()
    {
        var items = new List<string>();

        if (HasLiveMatch)
        {
            items.Add("https://criptoversus.com");
            items.Add(T("ticker.visitSite"));
            items.Add(T("ticker.liveBattles"));
            items.Add(T("ticker.matchMarkets"));
            items.Add(T("ticker.rankings"));
            items.Add(T("ticker.hotMatchDetected"));
            items.Add(T("ticker.liveCryptoBattle"));
            items.Add(T("ticker.arenaPressureRising"));
            items.Add(T("ticker.marketVolatilityIncreasing"));

            if (HotMatch?.HasRecentReversal == true)
                items.Add(T("ticker.momentumShift"));

            if (HasFearSignal())
                items.Add(T("ticker.fearSurge"));

            var leader = ResolveLeaderSymbol();
            var trailer = leader == DisplayLeftSymbol() ? DisplayRightSymbol() : DisplayLeftSymbol();
            items.Add(T("ticker.dominating", leader));
            items.Add(T("ticker.recovering", trailer));

            if (ParseRemainingSeconds(DisplayRemainingTime()) <= 600)
                items.Add(T("ticker.finalMinutes"));

            if ((HotMatch?.HotScore ?? 0) >= 90)
                items.Add(T("ticker.crowdEnergySpike"));

            foreach (var commentary in _commentaryHistory.TakeLast(4))
                items.Add(commentary);
        }
        else
        {
            items.Add(T("states.waitingForNextHotBattle"));
            items.Add(T("labels.automaticBroadcast"));
            items.Add("https://criptoversus.com");
            items.Add(T("ticker.visitSite"));
            items.Add(T("ticker.liveBattles"));

            var topCoin = TopTeams.FirstOrDefault()?.Symbol;
            if (!string.IsNullOrWhiteSpace(topCoin))
                items.Add(T("ticker.nextBattleAround", topCoin));

            var topMover = TopGainers.FirstOrDefault()?.Symbol;
            if (!string.IsNullOrWhiteSpace(topMover))
                items.Add(T("ticker.marketPulseAround", topMover));
        }

        _tickerItems = items.Where(x => !string.IsNullOrWhiteSpace(x)).Distinct().ToList();
        var signature = string.Join("||", _tickerItems);
        if (signature != _tickerSignature)
        {
            _tickerSignature = signature;
            _ = LogAsync("TV_TICKER", "updated", _tickerItems);
        }
    }

