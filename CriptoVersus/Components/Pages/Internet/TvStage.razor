    private string GetLogoUrl(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        if (Uri.TryCreate(value, UriKind.Absolute, out var absoluteUri))
        {
            var sanitizedAbsolute = NormalizeAbsoluteIconUrl(absoluteUri);
            return sanitizedAbsolute ?? value;
        }

        var sanitized = NormalizeIconRoute(value);
        return EnvironmentIsolationGuard.BuildApiUrl(Config, sanitized);
    }

    private string? NormalizeAbsoluteIconUrl(Uri value)
    {
        var sanitizedPath = NormalizeIconRoute(value.AbsolutePath);
        if (string.Equals(sanitizedPath, value.AbsolutePath, StringComparison.Ordinal))
            return value.ToString();

        return EnvironmentIsolationGuard.BuildApiUrl(Config, sanitizedPath);
    }

    private static string NormalizeIconRoute(string value)
    {
        const string prefix = "/api/icons/binance/";
        if (!value.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
            return value;

        var symbol = value[prefix.Length..];
        var normalized = GetBaseSymbol(Uri.UnescapeDataString(symbol));
        return $"{prefix}{Uri.EscapeDataString(normalized)}";
    }

    private string GetTeamStyle(string symbol, bool isLeft)
    {
        var accent = GetAccentColor(symbol);
        var shadow = isLeft ? "rgba(83, 200, 255, 0.28)" : "rgba(127, 246, 223, 0.24)";
        return $"--team-accent:{accent}; --team-shadow:{shadow};";
    }

    private string GetEventAccentStyle(string accentHex)
        => $"--event-accent:{accentHex};";

    private string GetAccentColor(string? symbol)
    {
        var normalized = symbol?.Trim().ToUpperInvariant() ?? string.Empty;
        return normalized switch
        {
            "BTC" => "#f5b942",
            "ETH" => "#7f8df6",
            "SOL" => "#55f5bf",
            "BNB" => "#f2d56b",
            "XRP" => "#71d1ff",
            "ADA" => "#5dd8ff",
            "DOGE" => "#efc166",
            _ => HashAccent(normalized)
        };
    }

    private static string HashAccent(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "#53c8ff";

        var seed = value.Sum(ch => ch);
        var hue = seed % 360;
        return $"hsl({hue} 78% 64%)";
    }

    private string ResolveLeaderSymbol()
    {
        if (DisplayLeftScore() == DisplayRightScore())
            return HotMatch?.HasRecentReversal == true
                ? ResolveMomentumLeader()
                : DisplayLeftSymbol();

        return DisplayLeftScore() > DisplayRightScore() ? DisplayLeftSymbol() : DisplayRightSymbol();
    }

    private string ResolveMomentumLeader()
    {
        var momentum = DisplayMomentum();
        if (momentum.Contains(DisplayLeftSymbol(), StringComparison.OrdinalIgnoreCase))
            return DisplayLeftSymbol();

        if (momentum.Contains(DisplayRightSymbol(), StringComparison.OrdinalIgnoreCase))
            return DisplayRightSymbol();

        return DisplayLeftSymbol();
    }

    private static string GetBaseSymbol(string? symbol)

    {

        if (string.IsNullOrWhiteSpace(symbol))

            return string.Empty;



        var upper = symbol.Trim().ToUpperInvariant();



        string[] quoteAssets =

        [

            "USDT",
    "USDC",
    "BUSD",
    "FDUSD",
    "BTC",
    "ETH"

        ];



        foreach (var quote in quoteAssets)

        {

            if (upper.EndsWith(quote, StringComparison.OrdinalIgnoreCase)

                && upper.Length > quote.Length)

            {

                return upper[..^quote.Length];

            }

        }



        return upper;

    }

    private bool HasFearSignal()
    {
        var text = $"{DisplayMomentum()} {DisplayReason()}";
        return text.Contains("fear", StringComparison.OrdinalIgnoreCase)
            || text.Contains("medo", StringComparison.OrdinalIgnoreCase)
            || text.Contains("surge", StringComparison.OrdinalIgnoreCase);
    }

    private async Task LogClockDebugAsync()
    {
        if (!Environment.IsDevelopment() || _tvModule is null)
            return;

        var payload = new
        {
            HotMatchRemainingSeconds = HotMatch?.RemainingSeconds,
            HotMatchRemainingTimeLabel = HotMatch?.RemainingTimeLabel,
            MatchRemainingMinutes = Match?.RemainingMinutes,
            SeedMilliseconds = ResolveRemainingMillisecondsSeed(),
            DisplayRemainingTime = DisplayRemainingTime(),
            DisplayClockPrimary = DisplayClockPrimary()
        };

        var signature = string.Join("|",
            payload.HotMatchRemainingSeconds?.ToString(CultureInfo.InvariantCulture) ?? "null",
            payload.HotMatchRemainingTimeLabel ?? "null",
            payload.MatchRemainingMinutes?.ToString(CultureInfo.InvariantCulture) ?? "null",
            payload.SeedMilliseconds.ToString("0", CultureInfo.InvariantCulture),
            payload.DisplayRemainingTime,
            payload.DisplayClockPrimary);

        if (signature == _clockDebugSignature)
            return;

        _clockDebugSignature = signature;
        await LogAsync("TV_CLOCK_DEBUG", "state", payload);
    }

    private static int ParseRemainingSeconds(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return 0;

        var cleaned = value.Trim();
        var start = cleaned.IndexOfAny("0123456789".ToCharArray());
        if (start > 0)
            cleaned = cleaned[start..];

        var parts = cleaned.Split(':', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 2
            && int.TryParse(parts[0], NumberStyles.Integer, CultureInfo.InvariantCulture, out var minutes)
            && int.TryParse(parts[1], NumberStyles.Integer, CultureInfo.InvariantCulture, out var seconds)
            && minutes >= 0
            && seconds >= 0
            && seconds < 60)
        {
            return (minutes * 60) + seconds;
        }

        return 0;
    }

    private string FormatChangePercent(decimal? value)
        => value.HasValue
            ? value.Value > 0m
                ? $"+{value.Value:0.00}%"
                : $"{value.Value:0.00}%"
            : "--";

    private string GetChangeClass(decimal? value)
        => value switch
        {
            > 0m => "tv-change tv-change--positive",
            < 0m => "tv-change tv-change--negative",
            0m => "tv-change tv-change--neutral",
            _ => "tv-change tv-change--missing"
        };

    private string FormatPercent(decimal value)
        => $"{value:0.#}%";

    private string FormatSignedPercent(decimal value)
        => value >= 0m ? $"+{value:0.##}%" : $"{value:0.##}%";

    private string FormatStatus(string? status)
        => string.Equals(status, "Ongoing", StringComparison.OrdinalIgnoreCase)
            ? T("labels.liveArena")
            : string.Equals(status, "Completed", StringComparison.OrdinalIgnoreCase)
                ? T("labels.completed")
                : T("labels.nextBattle");

    private async Task LogAsync(string prefix, string eventName, object? payload = null)
    {
        if (_tvModule is null)
            return;

        await _tvModule.InvokeVoidAsync("log", prefix, eventName, payload);
    }

    public async ValueTask DisposeAsync()
    {
        if (_clockCts is not null)
        {
            _clockCts.Cancel();
            _clockCts.Dispose();
        }

        if (_clockLoopTask is not null)
        {
            try
            {
                await _clockLoopTask;
            }
            catch
            {
            }
        }

        _eventCts?.Cancel();
        _eventCts?.Dispose();
        _pulseCts?.Cancel();
        _pulseCts?.Dispose();

        if (_narrationOverlay is not null)
            await _narrationOverlay.DisposeAsync();

        if (_tvModule is not null)
            await _tvModule.DisposeAsync();
    }

    private sealed record BroadcastSnapshot(
        int MatchId,
        int LeftScore,
        int RightScore,
        string LeftSymbol,
        string RightSymbol,
        string LeaderSymbol,
        int HotScore,
        int RemainingSeconds,
        bool HasRecentReversal,
        bool HasFearSignal);

    private sealed record TvClockState(TvClockPhase Phase, int DisplaySeconds);

    private enum TvClockPhase
    {
        FirstHalf,
        HalfTime,
        SecondHalf,
        Final
    }

    private sealed record TvOverlayEvent(
        string Key,
        string Kicker,
        string Title,
        string Body,
        string AccentHex);
}

