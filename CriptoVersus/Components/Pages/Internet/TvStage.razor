    private async Task TriggerBroadcastFlipAsync()
    {
        _broadcastFlipCts?.Cancel();
        _broadcastFlipCts?.Dispose();
        _broadcastFlipCts = new CancellationTokenSource();
        var ct = _broadcastFlipCts.Token;

        _isBroadcastFlipActive = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(1350, ct);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        _isBroadcastFlipActive = false;
        await InvokeAsync(StateHasChanged);
    }

    private static string FormatPrimaryAssetName(string? value)
    {
        var normalized = (value ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(normalized))
            return "-";

        return TrySplitUsdtPair(normalized, out var baseAsset)
            ? baseAsset
            : normalized;
    }

    private static string FormatTickerLabel(string? value)
    {
        var normalized = (value ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(normalized))
            return "-";

        return TrySplitUsdtPair(normalized, out var baseAsset)
            ? $"{baseAsset} - USDT"
            : normalized;
    }

    private static bool TrySplitUsdtPair(string value, out string baseAsset)
    {
        const string quote = "USDT";

        var normalized = value.Trim();
        if (normalized.EndsWith($"-{quote}", StringComparison.OrdinalIgnoreCase))
        {
            baseAsset = normalized[..^($@"-{quote}".Length)].Trim();
            return !string.IsNullOrWhiteSpace(baseAsset);
        }

        if (normalized.EndsWith($"/{quote}", StringComparison.OrdinalIgnoreCase))
        {
            baseAsset = normalized[..^($@"/{quote}".Length)].Trim();
            return !string.IsNullOrWhiteSpace(baseAsset);
        }

        if (normalized.EndsWith($" {quote}", StringComparison.OrdinalIgnoreCase))
        {
            baseAsset = normalized[..^($" {quote}".Length)].Trim();
            return !string.IsNullOrWhiteSpace(baseAsset);
        }

        if (normalized.EndsWith(quote, StringComparison.OrdinalIgnoreCase) && normalized.Length > quote.Length)
        {
            baseAsset = normalized[..^quote.Length].Trim('-', '/', ' ');
            return !string.IsNullOrWhiteSpace(baseAsset);
        }

        baseAsset = string.Empty;
        return false;
    }

    private async Task MaybeEmitArenaNarrativeAsync(BroadcastSnapshot current, TvFieldStateDto? fieldState, NarrativeEventKind? forcedKind, string reason)
    {
        if (!HasActiveOngoingMatch || fieldState is null || current.MatchId <= 0)
            return;

        var candidate = BuildArenaNarrativeCandidate(current, fieldState, forcedKind, reason);
        if (candidate is null)
            return;

        candidate = await ResolveArenaNarrativeAudioAsync(candidate);

        var now = DateTime.UtcNow;
        var visualBlockedReason = ResolveArenaNarrativeVisualCommentBlockReason();
        var tickerBlockedReason = ResolveArenaNarrativeTickerBlockReason();

        if (_arenaNarrativeCooldownsUtc.TryGetValue(candidate.TypeKey, out var cooldownUntilUtc) && cooldownUntilUtc > now)
        {
            await LogAsync("TV_ARENA_COMMENTARY", "cooldown-applied", new
            {
                candidate.MatchId,
                candidate.TypeKey,
                candidate.Reason,
                candidate.HighlightSymbol,
                cooldownUntilUtc
            });
            return;
        }

        if (string.Equals(candidate.Signature, _lastArenaNarrativeSignature, StringComparison.Ordinal))
        {
            await LogAsync("TV_ARENA_COMMENTARY", "duplicate-ignored", new
            {
                candidate.MatchId,
                candidate.TypeKey,
                candidate.Reason,
                candidate.HighlightSymbol
            });
            return;
        }

        _arenaNarrativeCooldownsUtc[candidate.TypeKey] = now.Add(candidate.Cooldown);
        _arenaNarrativeLastTextByType[candidate.TypeKey] = candidate.Text;
        _lastArenaNarrativeSignature = candidate.Signature;
        _lastArenaNarrativeAtUtc = now;
        _didNarrativeOpening |= candidate.Type == NarrativeEventKind.MatchOpening;

        if (!string.IsNullOrWhiteSpace(visualBlockedReason))
        {
            await LogAsync("TV_ARENA_COMMENTARY", "visual-comment-blocked", new
            {
                candidate.MatchId,
                candidate.TypeKey,
                candidate.Reason,
                candidate.HighlightSymbol,
                visualBlockedReason
            });
        }
        else
        {
            var entry = new TvArenaCommentaryEntry(
                Guid.NewGuid().ToString("N"),
                candidate.MatchId,
                candidate.TypeKey,
                DescribeNarrativeEventType(candidate.Type),
                candidate.MinuteLabel,
                candidate.Text,
                candidate.HighlightSymbol,
                candidate.AccentHex,
                candidate.Priority,
                candidate.AudioKey,
                candidate.AudioUrl,
                candidate.AudioAssetId,
                candidate.AudioQueued,
                candidate.AudioQueueStatus,
                candidate.AudioQueueReason,
                candidate.AudioRequest,
                candidate.Silent,
                DateTime.UtcNow,
                false);

            AppendArenaCommentary(entry);
            await LogAsync("TV_ARENA_COMMENTARY", "event-created", new
            {
                candidate.MatchId,
                candidate.TypeKey,
                candidate.Reason,
                candidate.HighlightSymbol,
                candidate.MinuteLabel,
                candidate.AudioKey,
                candidate.AudioUrl,
                candidate.AudioAssetId,
                candidate.AudioQueued,
                candidate.AudioQueueStatus,
                candidate.AudioQueueReason,
                candidate.Silent,
                candidate.Text
            });
        }

        if (!string.IsNullOrWhiteSpace(tickerBlockedReason))
        {
            await LogAsync("TV_ARENA_COMMENTARY", "ticker-blocked", new
            {
                candidate.MatchId,
                candidate.TypeKey,
                candidate.Reason,
                candidate.HighlightSymbol,
                tickerBlockedReason
            });
        }

        var audioBlockedReason = ResolveArenaNarrativeAudioBlockReason(candidate);
        if (string.Equals(visualBlockedReason, "broadcast-overlay-active", StringComparison.Ordinal)
            && string.IsNullOrWhiteSpace(audioBlockedReason))
        {
            await LogAsync("TV_ARENA_COMMENTARY", "broadcast-overlay-active-but-audio-allowed", new
            {
                candidate.MatchId,
                candidate.TypeKey,
                candidate.Reason,
                candidate.HighlightSymbol
            });
        }

        if (!string.IsNullOrWhiteSpace(audioBlockedReason))
        {
            await LogAsync("TV_ARENA_COMMENTARY", "procedural-audio-blocked", new
            {
                candidate.MatchId,
                candidate.TypeKey,
                candidate.Reason,
                candidate.HighlightSymbol,
                audioBlockedReason
            });
            return;
        }

        await TryPlayArenaNarrativeAudioAsync(candidate);
    }

    private TvArenaNarrativeCandidate? BuildArenaNarrativeCandidate(BroadcastSnapshot current, TvFieldStateDto fieldState, NarrativeEventKind? forcedKind, string reason)
    {
        var ownerSymbol = ResolveNarrativeOwnerSymbol(fieldState);
        if (string.IsNullOrWhiteSpace(ownerSymbol))
            return null;

        var highlightSymbol = GetBaseSymbol(ownerSymbol);
        if (string.IsNullOrWhiteSpace(highlightSymbol))
            highlightSymbol = GetBaseSymbol(current.LeaderSymbol);

        var ownerPossession = ResolveNarrativePossession(fieldState, ownerSymbol);
        var ownerPressure = ResolveNarrativePressure(fieldState, ownerSymbol);
        var opponentPressure = ResolveNarrativePressure(fieldState, ResolveOpposingNarrativeSymbol(fieldState, ownerSymbol));
        var ballZone = ResolveNarrativeBallZone(fieldState, ownerSymbol);
        var netPossession = Math.Abs(fieldState.PossessionA - fieldState.PossessionB);
        var elapsedMinute = ResolveArenaCommentaryMinute(current);
        var tensionHigh = current.RemainingSeconds <= 900 || (current.HotScore >= 84 && Math.Abs(current.LeftScore - current.RightScore) <= 1);
        var offensivePressure = ownerPressure >= 1.35d || ownerPossession >= 58 || string.Equals(fieldState.MomentumOwner, ownerSymbol, StringComparison.OrdinalIgnoreCase);
        var defensiveCaution = ballZone == NarrativeBallZone.Defensive && ownerPossession <= 56 && ownerPressure <= 1.1d;
        var dominance = netPossession >= 14 || (ownerPressure - opponentPressure) >= 1.05d || (string.Equals(fieldState.Leader, ownerSymbol, StringComparison.OrdinalIgnoreCase) && Math.Abs(current.LeftScore - current.RightScore) >= 2);
        var transition = ballZone == NarrativeBallZone.Middle && netPossession <= 8 && Math.Abs(ownerPressure - opponentPressure) <= 0.5d;
        var recoveredPossession = !string.IsNullOrWhiteSpace(_lastArenaNarrativeOwner)
            && !string.Equals(_lastArenaNarrativeOwner, ownerSymbol, StringComparison.OrdinalIgnoreCase)
            && ballZone != NarrativeBallZone.Offensive;

        if (offensivePressure && ballZone == NarrativeBallZone.Offensive)
        {
            _arenaAttackSequenceCount = string.Equals(_lastArenaNarrativeOwner, ownerSymbol, StringComparison.OrdinalIgnoreCase)
                ? Math.Min(5, _arenaAttackSequenceCount + 1)
                : 1;
        }
        else if (!string.Equals(_lastArenaNarrativeOwner, ownerSymbol, StringComparison.OrdinalIgnoreCase))
        {
            _arenaAttackSequenceCount = 0;
        }

        _lastArenaNarrativeOwner = ownerSymbol;

        var narrativeType = forcedKind
            ?? (!_didNarrativeOpening && elapsedMinute <= 2 ? NarrativeEventKind.MatchOpening
                : recoveredPossession ? NarrativeEventKind.PossessionRecovery
                : ballZone == NarrativeBallZone.Offensive && _arenaAttackSequenceCount >= 2 ? NarrativeEventKind.PressureGrowth
                : ballZone == NarrativeBallZone.Offensive ? NarrativeEventKind.OffensivePossession
                : defensiveCaution ? NarrativeEventKind.DefensivePossession
                : dominance ? NarrativeEventKind.Dominance
                : transition ? NarrativeEventKind.Transition
                : tensionHigh ? NarrativeEventKind.Tension
                : null);

        if (narrativeType is null)
            return null;

        var minuteLabel = FormatArenaNarrativeMinuteLabel(elapsedMinute);
        var typeKey = narrativeType.Value.ToString();
        var accentHex = GetAccentColor(highlightSymbol);
        var text = BuildArenaNarrativeText(narrativeType.Value, highlightSymbol, current.MatchId, elapsedMinute, current.HotScore);
        if (string.IsNullOrWhiteSpace(text))
            return null;

        var signature = string.Join("|",
            current.MatchId,
            typeKey,
            highlightSymbol,
            minuteLabel,
            ballZone,
            Math.Max(0, current.RemainingSeconds / 20),
            _arenaAttackSequenceCount);

        return new TvArenaNarrativeCandidate(
            current.MatchId,
            narrativeType.Value,
            typeKey,
            text,
            minuteLabel,
            highlightSymbol,
            accentHex,
            ResolveArenaNarrativePriority(narrativeType.Value, current),
            ResolveArenaNarrativeAudioKey(narrativeType.Value),
            new AudioResolveRequest
            {
                EventType = ResolveArenaNarrativeEventType(narrativeType.Value),
                Language = IsPortugueseCulture ? "pt-BR" : "en-US",
                RawSymbol = ownerSymbol,
                NormalizedSymbol = highlightSymbol,
                TeamSymbol = highlightSymbol,
                TeamName = highlightSymbol,
                TextPrompt = text,
                ContextKey = ResolveArenaNarrativeContextKey(narrativeType.Value),
                Intensity = ResolveArenaNarrativeIntensity(narrativeType.Value),
                QueueIfMissing = true
            },
            null,
            null,
            false,
            null,
            null,
            ResolveArenaNarrativeCooldown(narrativeType.Value),
            ResolveArenaNarrativeShouldBeSilent(narrativeType.Value, tensionHigh, current.HotScore),
            signature,
            $"{reason}|owner={highlightSymbol}|zone={ballZone}|pressure={ownerPressure:0.##}|possession={ownerPossession}");
    }

    private void AppendArenaCommentary(TvArenaCommentaryEntry entry)
    {
        if (_arenaCommentaryFeed.Count >= MaxArenaCommentaryFeedItems)
        {
            var removable = _arenaCommentaryFeed
                .Select((item, index) => new { item, index })
                .FirstOrDefault(x => x.item.Priority < entry.Priority)
                ?? _arenaCommentaryFeed.Select((item, index) => new { item, index }).First();

            _arenaCommentaryFeed.RemoveAt(removable.index);
        }

        _arenaCommentaryFeed.Add(entry);
        _arenaCommentaryArchive.Enqueue(entry);
        while (_arenaCommentaryArchive.Count > MaxArenaCommentaryHistoryItems)
            _arenaCommentaryArchive.Dequeue();

        _commentaryHistory = _arenaCommentaryArchive.Select(item => item.Text).ToList();
        _currentAiNarration = entry.Text;
        _aiNarrationSource = "arena-live";
        _lastAiNarrationAtUtc = entry.CreatedAtUtc;
    }

    private async Task<TvArenaNarrativeCandidate> ResolveArenaNarrativeAudioAsync(TvArenaNarrativeCandidate candidate, bool forceQueue = false)
    {
        if (candidate.Silent || candidate.AudioRequest is null)
            return candidate;

        try
        {
            var response = await Api.ResolveAudioAsync(new AudioResolveRequest
            {
                EventType = candidate.AudioRequest.EventType,
                Language = candidate.AudioRequest.Language,
                RawSymbol = candidate.AudioRequest.RawSymbol,
                NormalizedSymbol = candidate.AudioRequest.NormalizedSymbol,
                TeamSymbol = candidate.AudioRequest.TeamSymbol,
                TeamName = candidate.AudioRequest.TeamName,
                TextPrompt = candidate.AudioRequest.TextPrompt,
                ContextKey = candidate.AudioRequest.ContextKey,
                Intensity = candidate.AudioRequest.Intensity,
                VoiceKey = candidate.AudioRequest.VoiceKey,
                QueueIfMissing = candidate.AudioRequest.QueueIfMissing,
                ForceQueue = forceQueue || candidate.AudioRequest.ForceQueue
            });

            await LogAsync("TV_ARENA_COMMENTARY", "audio-resolution", new
            {
                candidate.MatchId,
                candidate.TypeKey,
                candidate.Reason,
                candidate.HighlightSymbol,
                requestedEventType = candidate.AudioRequest.EventType,
                candidate.AudioRequest.ContextKey,
                candidate.AudioRequest.Intensity,
                found = response?.Found ?? false,
                response?.AudioUrl,
                response?.AssetId,
                queued = response?.Queued ?? false,
                response?.QueueStatus,
                response?.QueueReason
            });

            if (response is null)
                return candidate;

            return candidate with
            {
                AudioUrl = response.AudioUrl,
                AudioAssetId = response.AssetId,
                AudioQueued = response.Queued,
                AudioQueueStatus = response.QueueStatus,
                AudioQueueReason = response.QueueReason
            };
        }
        catch (Exception ex)
        {
            await LogAsync("TV_ARENA_COMMENTARY", "audio-resolution-failed", new
            {
                candidate.MatchId,
                candidate.TypeKey,
                candidate.Reason,
                candidate.HighlightSymbol,
                requestedEventType = candidate.AudioRequest.EventType,
                candidate.AudioRequest.ContextKey,
                candidate.AudioRequest.Intensity,
                error = ex.Message
            });

            return candidate;
        }
    }

    private async Task TryPlayArenaNarrativeAudioAsync(TvArenaNarrativeCandidate candidate)
    {
        if (candidate.Silent || (string.IsNullOrWhiteSpace(candidate.AudioUrl) && string.IsNullOrWhiteSpace(candidate.AudioKey)))
        {
            await LogAsync("TV_ARENA_COMMENTARY", "comment-sent-to-ui", new
            {
                candidate.MatchId,
                candidate.TypeKey,
                candidate.Reason,
                candidate.HighlightSymbol,
                candidate.Silent,
                audio = candidate.Silent ? "silent" : "missing"
            });
            return;
        }

        try
        {
            var playback = new
            {
                priority = Math.Max(26, candidate.Priority),
                cooldownMs = (int)candidate.Cooldown.TotalMilliseconds,
                volume = (double)Math.Clamp(ResolveCrowdAudioVolume() * 0.96m, 0.18m, 0.76m),
                muted = _isCrowdAudioMuted,
                eventType = candidate.AudioRequest?.EventType ?? candidate.TypeKey,
                contextKey = candidate.AudioRequest?.ContextKey,
                intensity = candidate.AudioRequest?.Intensity,
                teamSymbol = candidate.HighlightSymbol,
                assetId = candidate.AudioAssetId
            };

            var played = !string.IsNullOrWhiteSpace(candidate.AudioUrl)
                ? (_tvModule is not null
                    ? await _tvModule.InvokeAsync<bool>("playProceduralAudioUrl", candidate.AudioUrl, playback)
                    : await JS.InvokeAsync<bool>("playProceduralAudioUrl", candidate.AudioUrl, playback))
                : (_tvModule is not null
                    ? await _tvModule.InvokeAsync<bool>("playTvAudioCue", candidate.AudioKey, playback)
                    : await JS.InvokeAsync<bool>("playTvAudioCue", candidate.AudioKey, playback));

            await LogAsync("TV_ARENA_COMMENTARY", played ? "audio-chosen" : "audio-ignored", new
            {
                candidate.MatchId,
                candidate.TypeKey,
                candidate.Reason,
                candidate.HighlightSymbol,
                candidate.AudioKey,
                candidate.AudioUrl,
                candidate.AudioAssetId,
                played
            });
        }
        catch (Exception ex) when (ex is JSException or ObjectDisposedException)
        {
            await LogAsync("TV_ARENA_COMMENTARY", "audio-failed", new
            {
                candidate.MatchId,
                candidate.TypeKey,
                candidate.Reason,
                candidate.HighlightSymbol,
                candidate.AudioKey,
                candidate.AudioUrl,
                candidate.AudioAssetId,
                error = ex.Message
            });
        }
        finally
        {
            await LogAsync("TV_ARENA_COMMENTARY", "comment-sent-to-ui", new
            {
                candidate.MatchId,
                candidate.TypeKey,
                candidate.Reason,
                candidate.HighlightSymbol,
                candidate.Text
            });
        }
    }

    private async Task HandleArenaCommentaryClickAsync(TvArenaCommentaryEntry commentary)
    {
        await LogAsync("TV_ARENA_COMMENTARY", "event-clicked", new
        {
            commentary.MatchId,
            commentary.TypeKey,
            commentary.HighlightSymbol,
            commentary.AudioKey,
            commentary.AudioUrl,
            commentary.AudioAssetId,
            commentary.Silent
        });

        if (commentary.Silent)
        {
            await LogAsync("TV_ARENA_COMMENTARY", "audio-ignored", new
            {
                commentary.MatchId,
                commentary.TypeKey,
                commentary.HighlightSymbol,
                reason = "silent-event-click"
            });
            return;
        }

        try
        {
            var resolvedCommentary = commentary;
            if (string.IsNullOrWhiteSpace(resolvedCommentary.AudioUrl) && resolvedCommentary.AudioRequest is not null)
            {
                var refreshedCandidate = await ResolveArenaNarrativeAudioAsync(new TvArenaNarrativeCandidate(
                    resolvedCommentary.MatchId,
                    ResolveNarrativeEventKind(resolvedCommentary.TypeKey),
                    resolvedCommentary.TypeKey,
                    resolvedCommentary.Text,
                    resolvedCommentary.MinuteLabel,
                    resolvedCommentary.HighlightSymbol,
                    resolvedCommentary.AccentHex,
                    resolvedCommentary.Priority,
                    resolvedCommentary.AudioKey,
                    resolvedCommentary.AudioRequest,
                    resolvedCommentary.AudioUrl,
                    resolvedCommentary.AudioAssetId,
                    resolvedCommentary.AudioQueued,
                    resolvedCommentary.AudioQueueStatus,
                    resolvedCommentary.AudioQueueReason,
                    TimeSpan.FromMilliseconds(150),
                    resolvedCommentary.Silent,
                    resolvedCommentary.Id,
                    "entry-click"), forceQueue: true);

                resolvedCommentary = UpdateArenaCommentaryAudioState(
                    resolvedCommentary.Id,
                    refreshedCandidate.AudioUrl,
                    refreshedCandidate.AudioAssetId,
                    refreshedCandidate.AudioQueued,
                    refreshedCandidate.AudioQueueStatus,
                    refreshedCandidate.AudioQueueReason);
            }

            if (string.IsNullOrWhiteSpace(resolvedCommentary.AudioUrl) && string.IsNullOrWhiteSpace(resolvedCommentary.AudioKey))
            {
                await LogAsync("TV_ARENA_COMMENTARY", "audio-ignored", new
                {
                    resolvedCommentary.MatchId,
                    resolvedCommentary.TypeKey,
                    resolvedCommentary.HighlightSymbol,
                    resolvedCommentary.AudioQueueStatus,
                    resolvedCommentary.AudioQueueReason,
                    reason = "missing-audio-after-resolve-click"
                });
                return;
            }

            var playback = new
            {
                priority = Math.Max(28, resolvedCommentary.Priority),
                cooldownMs = 150,
                volume = (double)Math.Clamp(Math.Max(ResolveCrowdAudioVolume(), 0.48m), 0.24m, 0.82m),
                muted = false,
                eventType = resolvedCommentary.AudioRequest?.EventType ?? resolvedCommentary.TypeKey,
                contextKey = resolvedCommentary.AudioRequest?.ContextKey,
                intensity = resolvedCommentary.AudioRequest?.Intensity,
                teamSymbol = resolvedCommentary.HighlightSymbol,
                assetId = resolvedCommentary.AudioAssetId
            };

            var played = !string.IsNullOrWhiteSpace(resolvedCommentary.AudioUrl)
                ? (_tvModule is not null
                    ? await _tvModule.InvokeAsync<bool>("playProceduralAudioUrl", resolvedCommentary.AudioUrl, playback)
                    : await JS.InvokeAsync<bool>("playProceduralAudioUrl", resolvedCommentary.AudioUrl, playback))
                : (_tvModule is not null
                    ? await _tvModule.InvokeAsync<bool>("playTvAudioCue", resolvedCommentary.AudioKey, playback)
                    : await JS.InvokeAsync<bool>("playTvAudioCue", resolvedCommentary.AudioKey, playback));

            await LogAsync("TV_ARENA_COMMENTARY", played ? "audio-chosen" : "audio-ignored", new
            {
                resolvedCommentary.MatchId,
                resolvedCommentary.TypeKey,
                resolvedCommentary.HighlightSymbol,
                resolvedCommentary.AudioKey,
                resolvedCommentary.AudioUrl,
                resolvedCommentary.AudioAssetId,
                source = "entry-click",
                played
            });
        }
        catch (Exception ex) when (ex is JSException or ObjectDisposedException)
        {
            await LogAsync("TV_ARENA_COMMENTARY", "audio-failed", new
            {
                commentary.MatchId,
                commentary.TypeKey,
                commentary.HighlightSymbol,
                commentary.AudioKey,
                commentary.AudioUrl,
                commentary.AudioAssetId,
                source = "entry-click",
                error = ex.Message
            });
        }
    }

