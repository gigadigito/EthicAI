                AudioAssetId = audioAssetId,
                AudioQueued = audioQueued,
                AudioQueueStatus = audioQueueStatus,
                AudioQueueReason = audioQueueReason
            };

            _arenaCommentaryFeed[i] = updated;
            return updated;
        }

        return new TvArenaCommentaryEntry(
            entryId,
            0,
            string.Empty,
            string.Empty,
            string.Empty,
            string.Empty,
            string.Empty,
            "#53c8ff",
            0,
            null,
            audioUrl,
            audioAssetId,
            audioQueued,
            audioQueueStatus,
            audioQueueReason,
            null,
            true,
