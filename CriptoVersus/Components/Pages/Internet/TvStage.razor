    private static string SanitizeBroadcastVideoCssToken(string? value)
        => string.IsNullOrWhiteSpace(value)
            ? "default"
            : NormalizeBroadcastToken(value).Replace('_', '-');

    private static string NormalizeBroadcastToken(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        return value.Trim().ToLowerInvariant()
            .Replace(' ', '-')
            .Replace('_', '-');
    }

    private bool IsKickoffWindow(BroadcastSnapshot current)
        => current.LeftScore == 0
            && current.RightScore == 0
            && current.RemainingSeconds >= (90 * 60) - 120;

    private static bool IsHalftimeWindow(BroadcastSnapshot current)
        => current.RemainingSeconds is <= (46 * 60) and >= (44 * 60);

    private static bool IsVictoryWindow(BroadcastSnapshot current)
        => current.RemainingSeconds <= 90
            && Math.Abs(current.LeftScore - current.RightScore) >= 2;

    private bool IsBitcoinDominanceArena(BroadcastSnapshot current)
    {
        var symbols = new[]
        {
            current.LeftSymbol,
            current.RightSymbol,
            current.LeaderSymbol
        };

        return symbols.Any(symbol => !string.IsNullOrWhiteSpace(symbol)
            && (symbol.Contains("BTC", StringComparison.OrdinalIgnoreCase)
                || symbol.Contains("BITCOIN", StringComparison.OrdinalIgnoreCase)));
    }

    private bool IsMemeCoinArena(BroadcastSnapshot current)
    {
        var symbols = new[]
        {
            current.LeftSymbol,
            current.RightSymbol,
            current.LeaderSymbol
        };

        string[] memeTokens = ["DOGE", "PEPE", "SHIB", "FLOKI", "BONK", "WIF", "BRETT"];
        return symbols.Any(symbol => memeTokens.Any(token => symbol?.Contains(token, StringComparison.OrdinalIgnoreCase) == true));
    }

