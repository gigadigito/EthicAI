    public async ValueTask DisposeAsync()
    {
        _isDisposed = true;
        Logger.LogInformation("TvStage disposing timers and JS interop resources. BroadcastMode={BroadcastMode} MatchId={MatchId}", IsBroadcastMode, Match?.MatchId ?? HotMatch?.MatchId ?? 0);
        CancelPirateOverlayTimer();

        if (_clockCts is not null)
        {
            _clockCts.Cancel();
            _clockCts.Dispose();
        }

        if (_metricSnapshotCts is not null)
        {
            _metricSnapshotCts.Cancel();
            _metricSnapshotCts.Dispose();
        }

        if (_clockLoopTask is not null)
        {
            try
            {
                await _clockLoopTask;
            }
            catch
            {
            }
        }

        if (_metricSnapshotLoopTask is not null)
        {
            try
            {
                await _metricSnapshotLoopTask;
            }
            catch
            {
            }
        }

        _eventCts?.Cancel();
        _eventCts?.Dispose();
        _pulseCts?.Cancel();
        _pulseCts?.Dispose();
        _broadcastFlipCts?.Cancel();
        _broadcastFlipCts?.Dispose();

        if (_narrationOverlay is not null)
            await _narrationOverlay.DisposeAsync();

        try
        {
            await JS.InvokeVoidAsync("destroyBroadcastAudio", "tv-broadcast-crowd");
        }
        catch (ObjectDisposedException)
        {
        }
        catch
        {
        }

        try
        {
            await JS.InvokeVoidAsync("criptoVersusReplay.dispose");
        }
        catch (ObjectDisposedException)
        {
        }
        catch
        {
        }

        if (_tvModule is not null)
        {
            try
            {
                await _tvModule.InvokeVoidAsync("destroyFieldSway", "tv-crypto-field");
            }
            catch (ObjectDisposedException)
            {
            }
            catch
            {
            }

            await _tvModule.DisposeAsync();
            _tvModule = null;
        }

        if (_tvCameraModule is not null)
        {
            try
            {
                await _tvCameraModule.InvokeVoidAsync("destroyTvCamera", "tv-crypto-field");
            }
            catch (ObjectDisposedException)
            {
            }
            catch
            {
            }

            await _tvCameraModule.DisposeAsync();
            _tvCameraModule = null;
        }

        if (_tvEventFeedModule is not null)
        {
            try
            {
                await _tvEventFeedModule.InvokeVoidAsync("disposeTvEventFeed", GoalEventFeedId);
            }
            catch (ObjectDisposedException)
            {
            }
            catch
            {
            }

            await _tvEventFeedModule.DisposeAsync();
            _tvEventFeedModule = null;
        }
    }

