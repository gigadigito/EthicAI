            _ => "normal"
        };

    private static bool ResolveArenaNarrativeShouldBeSilent(NarrativeEventKind type, bool tensionHigh, int hotScore)
        => type == NarrativeEventKind.Transition || (type == NarrativeEventKind.Tension && (tensionHigh || hotScore >= 88));

    private static int ResolveArenaNarrativePriority(NarrativeEventKind type, BroadcastSnapshot current)
        => type switch
        {
            NarrativeEventKind.MatchOpening => 44,
            NarrativeEventKind.PressureGrowth => 38,
            NarrativeEventKind.Tension => current.RemainingSeconds <= 600 ? 36 : 32,
            NarrativeEventKind.Dominance => 34,
            NarrativeEventKind.PossessionRecovery => 31,
            NarrativeEventKind.OffensivePossession => 30,
            NarrativeEventKind.DefensivePossession => 28,
            NarrativeEventKind.Transition => 26,
            _ => 25
        };

    private string ResolveNarrativeOwnerSymbol(TvFieldStateDto fieldState)
    {
        var liveCarrier = fieldState.PlayerPositions.FirstOrDefault(player => player.HasBall)?.TeamSymbol;
        if (!string.IsNullOrWhiteSpace(liveCarrier))
            return liveCarrier;

        if (!string.IsNullOrWhiteSpace(fieldState.MomentumOwner))
            return fieldState.MomentumOwner;

        if (!string.IsNullOrWhiteSpace(fieldState.Leader))
            return fieldState.Leader;

        return fieldState.PossessionA >= fieldState.PossessionB ? fieldState.TeamA : fieldState.TeamB;
    }

    private static string ResolveOpposingNarrativeSymbol(TvFieldStateDto fieldState, string ownerSymbol)
        => string.Equals(ownerSymbol, fieldState.TeamA, StringComparison.OrdinalIgnoreCase)
            ? fieldState.TeamB
            : fieldState.TeamA;

    private static int ResolveNarrativePossession(TvFieldStateDto fieldState, string ownerSymbol)
        => string.Equals(ownerSymbol, fieldState.TeamA, StringComparison.OrdinalIgnoreCase)
            ? fieldState.PossessionA
            : fieldState.PossessionB;

    private static double ResolveNarrativePressure(TvFieldStateDto fieldState, string ownerSymbol)
        => string.Equals(ownerSymbol, fieldState.TeamA, StringComparison.OrdinalIgnoreCase)
            ? fieldState.TeamPressureA
            : fieldState.TeamPressureB;

    private static NarrativeBallZone ResolveNarrativeBallZone(TvFieldStateDto fieldState, string ownerSymbol)
    {
        var carrier = fieldState.PlayerPositions
            .Where(player => player.HasBall && string.Equals(player.TeamSymbol, ownerSymbol, StringComparison.OrdinalIgnoreCase))
            .OrderBy(player => player.PlayerIndex)
            .FirstOrDefault();

        var xPercent = carrier?.XPercent;
        if (!xPercent.HasValue)
            return NarrativeBallZone.Middle;

        var attacksLeftToRight = string.Equals(ownerSymbol, fieldState.TeamA, StringComparison.OrdinalIgnoreCase);
        if (attacksLeftToRight)
        {
            if (xPercent.Value >= 62d)
                return NarrativeBallZone.Offensive;
            if (xPercent.Value <= 38d)
                return NarrativeBallZone.Defensive;
            return NarrativeBallZone.Middle;
        }

        if (xPercent.Value <= 38d)
            return NarrativeBallZone.Offensive;
        if (xPercent.Value >= 62d)
            return NarrativeBallZone.Defensive;
        return NarrativeBallZone.Middle;
    }

