    private async Task MaybeTriggerBroadcastPromoAsync(BroadcastSnapshot current)
    {
        if (_isDisposed
            || !IsBroadcastMode
            || _scheduledBroadcastPromoMatchId != current.MatchId
            || _lastBroadcastPromoMatchId == current.MatchId
            || DateTime.UtcNow < _scheduledBroadcastPromoAtUtc)
        {
            return;
        }

        _lastBroadcastPromoMatchId = current.MatchId;
        _scheduledBroadcastPromoMatchId = null;
        _scheduledBroadcastPromoAtUtc = DateTime.MaxValue;

        await LogAsync("TV_PROMO", "triggered", new
        {
            current.MatchId,
            current.LeftSymbol,
            current.RightSymbol
        });

        foreach (var promoEvent in CreateBroadcastPromoNarrationSequence())
            await QueueNarrationAsync(promoEvent);
    }

    private BroadcastFocusState ResolveBroadcastFocusState(BroadcastSnapshot current, TvFieldStateDto? fieldState)
    {
        var replayReady = _autoReplayRemainingPlays > 0
            && current.LeftScore + current.RightScore > 0
            && _pendingAutoReplayQueue.Count > 0
            && DateTime.UtcNow >= _nextAutoReplayAtUtc;
        if (replayReady)
        {
            var replaySide = _pendingAutoReplayQueue.Peek().Side;
            return new BroadcastFocusState("replay", "Last goal replay", GetAccentColor(replaySide), 4800);
        }

        if (fieldState is not null)
        {
            if (fieldState.TeamPressureA >= 2.1 || fieldState.TeamPressureB >= 2.1 || current.HotScore >= 74)
            {
                var pressureSide = fieldState.TeamPressureA >= fieldState.TeamPressureB ? fieldState.TeamA : fieldState.TeamB;
                return new BroadcastFocusState("pressure", "Big pressure", GetAccentColor(pressureSide), 4200);
            }

            if (fieldState.PossessionA >= 62 || fieldState.PossessionB >= 62)
            {
                var owningSide = fieldState.PossessionA >= fieldState.PossessionB ? fieldState.TeamA : fieldState.TeamB;
                return new BroadcastFocusState(owningSide == current.LeftSymbol ? "left" : "right", $"{owningSide} focus", GetAccentColor(owningSide), 4200);
            }
        }

        var cycle = new[]
        {
            new BroadcastFocusState("wide", "Wide camera", "#53c8ff", 3800),
            new BroadcastFocusState("left", $"{current.LeftSymbol} focus", GetAccentColor(current.LeftSymbol), 3600),
            new BroadcastFocusState("overview", "Overview", "#8bc8ff", 3600),
            new BroadcastFocusState("right", $"{current.RightSymbol} focus", GetAccentColor(current.RightSymbol), 3600)
        };

        var index = Math.Abs(_broadcastRotationIndex++) % cycle.Length;
        return cycle[index];
    }

    private async Task<bool> TryPlayAutoReplayAsync(BroadcastSnapshot current, BroadcastFocusState focusState)
    {
        if (_isDisposed)
            return false;

        if (_autoReplayRemainingPlays <= 0)
            return false;

        if (DateTime.UtcNow < _nextAutoReplayAtUtc)
            return false;

        if (current.LeftScore + current.RightScore <= 0)
            return false;

        if (_pendingAutoReplayQueue.Count == 0)
            return false;

        var pendingReplay = _pendingAutoReplayQueue.Peek();
        if (DateTime.UtcNow < pendingReplay.ReadyAtUtc)
            return false;

        var replaySide = pendingReplay.Side;
        var scoreEvent = pendingReplay.ScoreEvent ?? ResolveAutoReplayScoreEvent(current, replaySide);
        if (scoreEvent is null)
            return false;

        _pendingAutoReplayQueue.Dequeue();
        _lastAutoReplaySide = replaySide;
        _autoReplayRemainingPlays = Math.Max(0, _autoReplayRemainingPlays - 1);
        _nextAutoReplayAtUtc = _pendingAutoReplayQueue.Count > 0
            ? _pendingAutoReplayQueue.Peek().ReadyAtUtc
            : DateTime.MaxValue;

        await SetBroadcastFocusAsync(focusState.Key, focusState.Label, focusState.Color, focusState.DurationMs);
        await EnsureReplayEngineAsync();

        await LogAsync("TV_REPLAY", "auto-trigger", new
        {
            side = replaySide,
            scoreLine = $"{current.LeftScore} vs {current.RightScore}",
            eventType = scoreEvent.EventType,
            ruleType = scoreEvent.RuleType
        });

        await PlayReplayAsync(CreateScoreReplayEvent(current, scoreEvent));
        return true;
    }

    private MatchScoreEventDto? ResolveAutoReplayScoreEvent(BroadcastSnapshot current, string replaySide)
    {
        var matchingEvent = _recentScoreEvents
            .FirstOrDefault(x => string.Equals(x.TeamSymbol, replaySide, StringComparison.OrdinalIgnoreCase));

        if (matchingEvent is not null)
            return matchingEvent;

        var latestEvent = _recentScoreEvents.FirstOrDefault();
        if (latestEvent is not null)
            return latestEvent;

        return new MatchScoreEventDto
        {
            MatchId = current.MatchId,
            TeamSymbol = replaySide,
            RuleType = "THRESHOLD_8",
            EventType = "THRESHOLD_8",
            Points = 1,
            Description = "Auto replay fallback",
            EventTimeUtc = DateTime.UtcNow
        };
    }

    private void ArmAutoReplay(BroadcastSnapshot current, BroadcastSnapshot? previousSnapshot = null, IEnumerable<MatchScoreEventDto>? scoreEvents = null)
    {
        var previousLeftScore = previousSnapshot?.LeftScore ?? Math.Max(0, current.LeftScore - 1);
        var previousRightScore = previousSnapshot?.RightScore ?? Math.Max(0, current.RightScore - 1);
        var latestBySide = (scoreEvents ?? _recentScoreEvents)
            .GroupBy(x => x.TeamSymbol ?? string.Empty, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(g => g.Key, g => g.OrderByDescending(x => x.MatchScoreEventId).First(), StringComparer.OrdinalIgnoreCase);

        EnqueuePendingReplays(current, current.LeftSymbol, previousLeftScore, current.LeftScore, latestBySide);
        EnqueuePendingReplays(current, current.RightSymbol, previousRightScore, current.RightScore, latestBySide);

        _autoReplaySignature = BuildGoalTriggerSignature(current);
        _autoReplayRemainingPlays = _pendingAutoReplayQueue.Count;
        _nextAutoReplayAtUtc = _pendingAutoReplayQueue.Count > 0
            ? _pendingAutoReplayQueue.Peek().ReadyAtUtc
            : DateTime.MaxValue;
    }

    private string ResolveAutoReplaySide(BroadcastSnapshot current)
    {
        if (current.LeftScore <= 0 && current.RightScore > 0)
            return current.RightSymbol;

        if (current.RightScore <= 0 && current.LeftScore > 0)
            return current.LeftSymbol;

        if (string.Equals(_lastAutoReplaySide, current.LeftSymbol, StringComparison.OrdinalIgnoreCase))
            return current.RightSymbol;

        return current.LeftSymbol;
    }

    private void EnqueuePendingReplays(
        BroadcastSnapshot current,
        string side,
        int previousScore,
        int currentScore,
        IReadOnlyDictionary<string, MatchScoreEventDto> latestBySide)
    {
        if (string.IsNullOrWhiteSpace(side) || currentScore <= previousScore)
            return;

        for (var scoreValue = Math.Max(1, previousScore + 1); scoreValue <= currentScore; scoreValue++)
        {
            latestBySide.TryGetValue(side, out var scoreEvent);
            EnqueueAutoReplayPair(current, side, scoreValue, scoreEvent);
        }
    }

    private void ArmAutoReplayForEvents(BroadcastSnapshot current, IEnumerable<MatchScoreEventDto> scoreEvents)
    {
        var events = scoreEvents?.ToList() ?? [];
        if (events.Count == 0)
            return;

        foreach (var scoreEvent in events)
        {
            var side = scoreEvent.TeamSymbol ?? string.Empty;
            if (string.IsNullOrWhiteSpace(side))
                continue;

            var scoreValue = string.Equals(side, current.LeftSymbol, StringComparison.OrdinalIgnoreCase)
                ? current.LeftScore
                : string.Equals(side, current.RightSymbol, StringComparison.OrdinalIgnoreCase)
                    ? current.RightScore
                    : 0;

            if (scoreValue <= 0)
                continue;

            EnqueueAutoReplayPair(current, side, scoreValue, scoreEvent);
        }

        _autoReplaySignature = BuildGoalTriggerSignature(current);
        _autoReplayRemainingPlays = _pendingAutoReplayQueue.Count;
        _nextAutoReplayAtUtc = _pendingAutoReplayQueue.Count > 0
            ? _pendingAutoReplayQueue.Peek().ReadyAtUtc
            : DateTime.MaxValue;
    }

    private void EnqueueAutoReplayPair(BroadcastSnapshot current, string side, int scoreValue, MatchScoreEventDto? scoreEvent)
    {
        var baseSignature = $"{current.MatchId}|{side}|{scoreValue}";
        var firstSignature = $"{baseSignature}|1";
        var secondSignature = $"{baseSignature}|2";

        var firstAdded = _armedAutoReplaySignatures.Add(firstSignature);
        var secondAdded = _armedAutoReplaySignatures.Add(secondSignature);
        if (!firstAdded && !secondAdded)
            return;

        if (firstAdded)
        {
            var firstReadyAtUtc = DateTime.UtcNow.Add(AutoReplayInitialDelay);
            _pendingAutoReplayQueue.Enqueue(new PendingReplayRequest(firstSignature, side, scoreValue, firstReadyAtUtc, scoreEvent));
        }

        if (secondAdded)
        {
            var secondReadyAtUtc = DateTime.UtcNow.Add(AutoReplayInitialDelay + AutoReplaySpacing);
            _pendingAutoReplayQueue.Enqueue(new PendingReplayRequest(secondSignature, side, scoreValue, secondReadyAtUtc, scoreEvent));
        }
    }

