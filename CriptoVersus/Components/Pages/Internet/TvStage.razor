    private async Task DetectRecentScoreEventsAsync()
    {
        var matchId = Match?.MatchId ?? HotMatch?.MatchId ?? 0;
        if (matchId <= 0)
            return;

        _isScoreEventProbeRunning = true;

        try
        {
            var events = await Api.GetMatchScoreEventsAsync(matchId, Culture) ?? [];
            _allScoreEvents = events
                .OrderBy(x => x.EventTimeUtc)
                .ThenBy(x => x.MatchScoreEventId)
                .ToList();
            _recentScoreEvents = events
                .OrderByDescending(x => x.MatchScoreEventId)
                .Take(5)
                .ToList();
            var latestEventId = events.Count == 0 ? 0 : events.Max(x => x.MatchScoreEventId);
            var current = CaptureSnapshot();
            var latestKnownEvent = _recentScoreEvents.FirstOrDefault();
            await SyncProceduralAudioDebugSnapshotAsync(current, latestKnownEvent);

            if (_lastScoreEventMatchId != matchId || !_lastSeenScoreEventId.HasValue)
            {
                _lastScoreEventMatchId = matchId;
                _lastSeenScoreEventId = latestEventId;
                return;
            }

            var newEvents = events
                .Where(x => x.MatchScoreEventId > _lastSeenScoreEventId.Value)
                .OrderBy(x => x.MatchScoreEventId)
                .ToList();

            if (newEvents.Count == 0)
                return;

            _lastSeenScoreEventId = latestEventId;

            current = CaptureSnapshot();
            if (current is null)
                return;

            await ObserveProceduralScoreEventsAsync(current, newEvents);

            var latestGoalEvent = newEvents
                .Where(IsGoalLikeScoreEvent)
                .OrderByDescending(x => x.MatchScoreEventId)
                .FirstOrDefault();

            if (latestGoalEvent is not null
                && (!_lastTriggeredGoalEventId.HasValue || latestGoalEvent.MatchScoreEventId > _lastTriggeredGoalEventId.Value))
            {
                var currentGoalSignature = BuildGoalTriggerSignature(current);
                var latestProceduralAudioUrl = NormalizeProceduralGoalAudioUrl(latestGoalEvent.AudioUrl);
                var canUpgradeToProcedural = !string.IsNullOrWhiteSpace(latestProceduralAudioUrl)
                    && string.Equals(currentGoalSignature, _lastGoalAudioSignature, StringComparison.Ordinal)
                    && !string.Equals(_lastGoalAudioPlaybackKind, "procedural", StringComparison.Ordinal);

                if (!string.Equals(currentGoalSignature, _lastGoalTriggerSignature, StringComparison.Ordinal) || canUpgradeToProcedural)
                {
                    _lastTriggeredGoalEventId = latestGoalEvent.MatchScoreEventId;
                    await PulseScoreAsync(
                        string.Equals(latestGoalEvent.TeamSymbol, current.LeftSymbol, StringComparison.OrdinalIgnoreCase),
                        string.Equals(latestGoalEvent.TeamSymbol, current.RightSymbol, StringComparison.OrdinalIgnoreCase),
                        false);
                    await TriggerEventAsync(CreateGoalEvent(current, latestGoalEvent.TeamSymbol));
                    await QueueNarrationAsync(CreateGoalNarration(current, latestGoalEvent.TeamSymbol));
                    _ = PlayReplayAsync(CreateScoreReplayEvent(current, latestGoalEvent));
                    MarkGoalTrigger(current);
                    ArmAutoReplayForEvents(current, newEvents);
                    await TryPlayGoalAudioAsync(current, latestGoalEvent);
                }
            }

            await TryPlayProceduralArenaEventAsync(current, newEvents);
            if (latestGoalEvent is not null)
                _ = MaybeRefreshAiNarrationAsync("goal");
        }
        catch (Exception ex)
        {
            await LogAsync("TV_SCORE_EVENT_PROBE", "error", ex.Message);
        }
        finally
        {
            _isScoreEventProbeRunning = false;
        }
    }

