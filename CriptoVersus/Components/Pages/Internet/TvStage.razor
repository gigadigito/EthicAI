    private async Task TryPlayGoalAudioAsync(BroadcastSnapshot current, MatchScoreEventDto? scoreEvent = null)
    {
        if (!ShouldRenderGoalAudio)
            return;

        var signature = BuildGoalTriggerSignature(current);
        var proceduralAudioUrl = NormalizeProceduralGoalAudioUrl(scoreEvent?.AudioUrl);
        var canUpgradeToProcedural = !string.IsNullOrWhiteSpace(proceduralAudioUrl)
            && string.Equals(signature, _lastGoalAudioSignature, StringComparison.Ordinal)
            && !string.Equals(_lastGoalAudioPlaybackKind, "procedural", StringComparison.Ordinal);

        // Hard de-dupe: the score event probe and the hot snapshot pipeline can see the same goal.
        if (string.Equals(signature, _lastGoalAudioSignature, StringComparison.Ordinal) && !canUpgradeToProcedural)
            return;

        // Anti-loop guard: if some upstream signal oscillates, never spam the sting.
        if (!canUpgradeToProcedural
            && _lastGoalAudioAtUtc != DateTime.MinValue
            && DateTime.UtcNow - _lastGoalAudioAtUtc < TimeSpan.FromSeconds(6))
            return;

        _lastGoalAudioSignature = signature;
        _lastGoalAudioAtUtc = DateTime.UtcNow;

        if (!string.IsNullOrWhiteSpace(proceduralAudioUrl)
            && await TryPlayProceduralGoalAudioAsync(current, proceduralAudioUrl, scoreEvent))
        {
            _lastGoalAudioPlaybackKind = "procedural";
            return;
        }

        if (scoreEvent is not null)
        {
            await NotifyProceduralAudioDebugAsync("queued", BuildProceduralAudioDebugPayload(
                current,
                scoreEvent,
                proceduralAudioUrl,
                message: "Procedural audio missing in broadcast payload; continuing without blocking arena."));
            await NotifyProceduralAudioDebugAsync("missing", BuildProceduralAudioDebugPayload(
                current,
                scoreEvent,
                proceduralAudioUrl,
                message: "No procedural audio URL available for this event."));
            await LogAsync("TV_AUDIO", "procedural-audio-missing-no-impact", new
            {
                current.MatchId,
                scoreEventId = scoreEvent.MatchScoreEventId,
                scoreEvent.AudioUrl,
                scoreEvent.AudioFallbackUsed,
                scoreEvent.AudioResolvedLanguage
            });
        }

        if (_tvModule is not null)
        {
            try
            {
                if (scoreEvent is not null)
                {
                    await NotifyProceduralAudioDebugAsync("fallback", BuildProceduralAudioDebugPayload(
                        current,
                        scoreEvent,
                        proceduralAudioUrl,
                        message: "Falling back to legacy goal sting."));
                }

                await _tvModule.InvokeVoidAsync("playTvAudioCue", "goal", new
                {
                    priority = 100,
                    cooldownMs = 6500,
                    volume = (double)ResolveCrowdAudioVolume(),
                    muted = _isCrowdAudioMuted
                });
                _lastGoalAudioPlaybackKind = "legacy";
                return;
            }
            catch (JSException)
            {
            }
            catch (ObjectDisposedException)
            {
            }
        }

        try
        {
            if (scoreEvent is not null)
            {
                await NotifyProceduralAudioDebugAsync("fallback", BuildProceduralAudioDebugPayload(
                    current,
                    scoreEvent,
                    proceduralAudioUrl,
                    message: "Falling back to legacy goal sting."));
            }

            await JS.InvokeVoidAsync("playTvAudioCue", "goal", new
            {
                priority = 100,
                cooldownMs = 6500,
                volume = (double)ResolveCrowdAudioVolume(),
                muted = _isCrowdAudioMuted
            });
            _lastGoalAudioPlaybackKind = "legacy";
        }
        catch
        {
        }
    }

    private async Task<bool> TryPlayProceduralGoalAudioAsync(
        BroadcastSnapshot current,
        string audioUrl,
        MatchScoreEventDto? scoreEvent)
    {
        try
        {
            if (_tvModule is not null)
            {
                await _tvModule.InvokeVoidAsync("playProceduralAudioUrl", audioUrl, BuildProceduralAudioDebugPayload(
                    current,
                    scoreEvent,
                    audioUrl,
                    message: "Procedural goal audio resolved for playback."));
            }
            else
            {
                await JS.InvokeVoidAsync("playProceduralAudioUrl", audioUrl, BuildProceduralAudioDebugPayload(
                    current,
                    scoreEvent,
                    audioUrl,
                    message: "Procedural goal audio resolved for playback."));
            }

            await LogAsync("TV_AUDIO", "procedural-goal-used", new
            {
                current.MatchId,
                current.LeftScore,
                current.RightScore,
                scoreEventId = scoreEvent?.MatchScoreEventId,
                audioUrl,
                fallbackUsed = scoreEvent?.AudioFallbackUsed,
                resolvedLanguage = scoreEvent?.AudioResolvedLanguage
            });
            return true;
        }
        catch (Exception ex) when (ex is JSException or ObjectDisposedException)
        {
            await NotifyProceduralAudioDebugAsync("failed", BuildProceduralAudioDebugPayload(
                current,
                scoreEvent,
                audioUrl,
                message: "Procedural goal audio failed and legacy fallback will be used.",
                error: ex.Message));
            await LogAsync("TV_AUDIO", "procedural-goal-failed-fallback", new
            {
                current.MatchId,
                scoreEventId = scoreEvent?.MatchScoreEventId,
                audioUrl,
                message = ex.Message
            });
            return false;
        }
    }

