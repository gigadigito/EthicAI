    private string GetLogoUrl(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        if (Uri.TryCreate(value, UriKind.Absolute, out var absoluteUri))
        {
            if (absoluteUri.Scheme.Equals(Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase)
                || absoluteUri.Scheme.Equals(Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase))
            {
                return absoluteUri.ToString();
            }

            if (absoluteUri.IsFile)
            {
                var filePath = absoluteUri.AbsolutePath.Replace('\\', '/');
                var symbol = ExtractIconSymbol(filePath);
                return string.IsNullOrWhiteSpace(symbol)
                    ? string.Empty
                    : BuildIconUrlFromSymbol(symbol);
            }
        }

        var sanitized = NormalizeIconRoute(value);
        var normalizedSymbol = ExtractIconSymbol(sanitized);
        return string.IsNullOrWhiteSpace(normalizedSymbol)
            ? EnvironmentIsolationGuard.BuildApiUrl(Config, sanitized)
            : BuildIconUrlFromSymbol(normalizedSymbol);
    }

    private string BuildSafeIconUrl(string? rawValue, string fallbackSymbol)
    {
        if (!string.IsNullOrWhiteSpace(rawValue))
        {
            var normalized = NormalizeIconRoute(rawValue);
            var symbol = ExtractIconSymbol(normalized);
            if (!string.IsNullOrWhiteSpace(symbol))
                return BuildIconUrlFromSymbol(symbol);

            if (Uri.TryCreate(rawValue, UriKind.Absolute, out var absoluteUri))
            {
                var secureUri = NormalizeAbsoluteIconUrl(absoluteUri);
                if (!string.IsNullOrWhiteSpace(secureUri))
                    return secureUri;
            }
        }

        return BuildIconUrlFromSymbol(fallbackSymbol);
    }

    private string BuildIconUrlFromSymbol(string? symbol)
    {
        var baseSymbol = GetBaseSymbol(symbol ?? string.Empty);
        if (string.IsNullOrWhiteSpace(baseSymbol))
            return string.Empty;

        return EnvironmentIsolationGuard.BuildBinanceIconUrl(baseSymbol);
    }

    private static string? NormalizeAbsoluteIconUrl(Uri value)
    {
        if (value.IsFile)
            return null;

        if (value.Scheme.Equals(Uri.UriSchemeHttp, StringComparison.OrdinalIgnoreCase)
            || value.Scheme.Equals(Uri.UriSchemeHttps, StringComparison.OrdinalIgnoreCase))
        {
            return value.ToString();
        }

        return null;
    }

    private static string NormalizeIconRoute(string value)
    {
        var normalized = value.Trim().Replace('\\', '/');
        if (normalized.StartsWith("file://", StringComparison.OrdinalIgnoreCase))
            normalized = normalized["file://".Length..].TrimStart('/');

        var symbol = ExtractIconSymbol(normalized);
        return string.IsNullOrWhiteSpace(symbol)
            ? normalized
            : $"/api/icons/binance/{Uri.EscapeDataString(GetBaseSymbol(symbol))}";
    }

    private static string? ExtractIconSymbol(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        var normalized = value.Trim().Replace('\\', '/');
        var queryIndex = normalized.IndexOfAny(['?', '#']);
        if (queryIndex >= 0)
            normalized = normalized[..queryIndex];

        const string prefix = "/api/icons/binance/";

        if (normalized.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
            return Uri.UnescapeDataString(normalized[prefix.Length..]).Trim();

        var marker = normalized.IndexOf("/api/icons/binance/", StringComparison.OrdinalIgnoreCase);
        if (marker >= 0)
            return Uri.UnescapeDataString(normalized[(marker + prefix.Length)..]).Trim();

        if (normalized.Contains('/'))
            return normalized[(normalized.LastIndexOf('/') + 1)..].Trim();

        return normalized.Trim();
    }

