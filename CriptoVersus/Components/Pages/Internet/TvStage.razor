    private bool IsClockLive()
    {
        if (IsMatchFinishedForStage())
            return false;

        if (ResolvePreciseRemainingTime() is TimeSpan remaining)
            return remaining > TimeSpan.Zero;

        return (HotMatch?.RemainingSeconds ?? ParseRemainingSeconds(DisplayRemainingTime())) > 0;
    }

