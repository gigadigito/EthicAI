            {
                return string.Equals(Match.Status, "Ongoing", StringComparison.OrdinalIgnoreCase)
                    && Match.IsFinished != true
                    && Match.EndTime is null;
            }

            if (HotMatch?.HasMatch != true)
                return false;

            if (HotMatch.RemainingSeconds.HasValue)
                return HotMatch.RemainingSeconds.Value > 0;

            return !IsMatchFinishedForStage();
