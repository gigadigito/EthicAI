    private string DisplayClockPrimary()
    {
        var remaining = ResolvePreciseRemainingTime();
        if (remaining is not null)
            return FormatPreciseClock(remaining.Value);

        var parsedSeconds = ParseRemainingSeconds(DisplayRemainingTime());
        if (parsedSeconds > 0)
            return FormatClock(parsedSeconds);

        var fallbackMinutes = Match?.RemainingMinutes;
        return fallbackMinutes.HasValue && fallbackMinutes.Value >= 0
            ? FormatClock(fallbackMinutes.Value * 60)
            : "--:--";
    }

    private string DisplayClockPhaseLabel() => T("labels.remainingWithClock", DisplayClockPrimary());

