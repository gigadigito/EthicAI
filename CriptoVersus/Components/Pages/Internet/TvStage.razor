    private string ResolveArenaNarrativeAudioBlockReason(TvArenaNarrativeCandidate candidate)
    {
        var now = DateTime.UtcNow;
        if (candidate.Silent)
            return "silent-event";

        if (string.IsNullOrWhiteSpace(candidate.AudioUrl) && string.IsNullOrWhiteSpace(candidate.AudioKey))
            return "missing-audio-key";

        if (_isCrowdAudioMuted)
            return "broadcast-muted";

        if (_isEventVisible || now < _broadcastCriticalEventUntilUtc)
            return "critical-overlay-active";

        if (now < _narrationBusyUntilUtc)
            return "main-narration-running";

        if (_lastGoalAudioAtUtc != DateTime.MinValue && now - _lastGoalAudioAtUtc < TimeSpan.FromSeconds(5))
            return "goal-audio-cooldown";

        if (_lastProceduralPlaybackAtUtc != DateTime.MinValue && now - _lastProceduralPlaybackAtUtc < TimeSpan.FromSeconds(4))
            return "procedural-score-audio-cooldown";

        return string.Empty;
    }

    private string ResolveArenaNarrativeVisualCommentBlockReason()
    {
        var now = DateTime.UtcNow;
        if (_showPirateOverlay)
            return "broadcast-overlay-active";

        if (_isEventVisible || now < _broadcastCriticalEventUntilUtc)
            return "critical-overlay-active";

        if (now < _narrationBusyUntilUtc)
            return "main-narration-running";

        if (_lastGoalAudioAtUtc != DateTime.MinValue && now - _lastGoalAudioAtUtc < TimeSpan.FromSeconds(5))
            return "goal-audio-cooldown";

        if (_lastProceduralPlaybackAtUtc != DateTime.MinValue && now - _lastProceduralPlaybackAtUtc < TimeSpan.FromSeconds(4))
            return "procedural-score-audio-cooldown";

        return string.Empty;
    }

    private string ResolveArenaNarrativeTickerBlockReason()
    {
        if (_showPirateOverlay)
            return "broadcast-overlay-active";

        if (_isEventVisible || DateTime.UtcNow < _broadcastCriticalEventUntilUtc)
            return "critical-overlay-active";

        return string.Empty;
    }

    private string BuildArenaNarrativeText(NarrativeEventKind type, string symbol, int matchId, int elapsedMinute, int hotScore)
    {
        var key = type.ToString();
        string[] phrases = IsPortugueseCulture
            ? type switch
            {
                NarrativeEventKind.MatchOpening =>
                new[]
                {
                    "Bem-vindo a mais uma partida do CriptoVersus TV.",
                    "A bola vai rolar na arena CriptoVersus.",
                    "Comeca mais um duelo cripto dentro da arena."
                },
                NarrativeEventKind.OffensivePossession =>
                new[]
                {
                    $"{symbol} toca a bola na area do adversario.",
                    $"{symbol} avanca pelo campo de ataque.",
                    $"{symbol} comeca a pressionar no setor ofensivo."
                },
                NarrativeEventKind.DefensivePossession =>
                new[]
                {
                    $"{symbol} toca a bola na sua area, sem querer arriscar muito.",
                    $"{symbol} recua a jogada e tenta organizar a saida.",
                    $"{symbol} prefere manter a posse com seguranca."
                },
                NarrativeEventKind.Dominance =>
                new[]
                {
                    $"A dominancia da bola esta com {symbol}.",
                    $"{symbol} controla o ritmo da partida neste momento.",
                    $"{symbol} parece mais confortavel com a posse."
                },
                NarrativeEventKind.Transition =>
                new[]
                {
                    "A bola fica viva no meio da arena.",
                    "As duas moedas disputam espaco no campo.",
                    "O jogo fica equilibrado neste momento."
                },
                NarrativeEventKind.PressureGrowth =>
                new[]
                {
                    $"{symbol} aumenta a pressao ofensiva.",
                    $"O time de {symbol} sobe suas linhas.",
                    $"{symbol} empurra o adversario para tras."
                },
                NarrativeEventKind.PossessionRecovery =>
                new[]
                {
                    $"{symbol} recupera a posse no meio-campo.",
                    $"A defesa de {symbol} consegue afastar o perigo.",
                    $"{symbol} retoma o controle da jogada."
                },
                NarrativeEventKind.Tension =>
                new[]
                {
                    "A arena sente o aumento da tensao.",
                    "O confronto fica mais intenso neste momento.",
                    "A torcida virtual acompanha cada movimento."
                },
                _ => Array.Empty<string>()
            }
            : type switch
            {
                NarrativeEventKind.MatchOpening =>
                new[]
                {
                    "Welcome to another CriptoVersus TV match.",
                    "The ball is ready to roll inside the CriptoVersus arena.",
                    "Another crypto duel is underway in the arena."
                },
                NarrativeEventKind.OffensivePossession =>
                new[]
                {
                    $"{symbol} moves the ball into the opponent's box.",
                    $"{symbol} advances through the attacking half.",
                    $"{symbol} starts pressing high in the offensive sector."
                },
                NarrativeEventKind.DefensivePossession =>
                new[]
                {
                    $"{symbol} keeps the ball deep, avoiding too much risk.",
                    $"{symbol} drops the play back and reorganizes the exit.",
                    $"{symbol} prefers to keep possession safely for now."
                },
                NarrativeEventKind.Dominance =>
                new[]
                {
                    $"Ball control leans toward {symbol} right now.",
                    $"{symbol} controls the pace of the match at this moment.",
                    $"{symbol} looks more comfortable in possession."
                },
                NarrativeEventKind.Transition =>
                new[]
                {
                    "The ball stays alive in the middle of the arena.",
                    "Both currencies are fighting for space on the field.",
                    "The match feels balanced right now."
                },
                NarrativeEventKind.PressureGrowth =>
                new[]
                {
                    $"{symbol} raises the attacking pressure.",
                    $"{symbol}'s side pushes its lines higher.",
                    $"{symbol} forces the opponent backward."
                },
                NarrativeEventKind.PossessionRecovery =>
                new[]
                {
                    $"{symbol} wins possession back in midfield.",
                    $"{symbol}'s defense clears the danger.",
                    $"{symbol} regains control of the move."
                },
                NarrativeEventKind.Tension =>
                new[]
                {
                    "The arena can feel the tension rising.",
                    "This battle is getting more intense right now.",
                    "The virtual crowd tracks every movement."
                },
                _ => Array.Empty<string>()
            };

        if (phrases.Length == 0)
            return string.Empty;

        var index = Math.Abs(HashCode.Combine(matchId, elapsedMinute, hotScore, key)) % phrases.Length;
        var text = phrases[index];
        if (_arenaNarrativeLastTextByType.TryGetValue(key, out var previousText)
            && string.Equals(previousText, text, StringComparison.Ordinal)
            && phrases.Length > 1)
        {
            text = phrases[(index + 1) % phrases.Length];
        }

        if (string.Equals(_currentAiNarration, text, StringComparison.Ordinal) && phrases.Length > 1)
            text = phrases[(index + 2) % phrases.Length];

        return text;
    }

    private int ResolveArenaCommentaryMinute(BroadcastSnapshot current)
    {
        var remainingSeconds = Math.Max(0, current.RemainingSeconds);
        var elapsedSeconds = Math.Max(0, (90 * 60) - remainingSeconds);
        return Math.Clamp((int)Math.Floor(elapsedSeconds / 60d) + 1, 1, 90);
    }

    private static string FormatArenaNarrativeMinuteLabel(int minute)
        => $"{Math.Clamp(minute, 1, 90)}'";

