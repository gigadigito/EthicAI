@using System.Globalization
@using System.IO
@using System.Text
@using System.Net
@using BLL.Positions
@using CriptoVersus.Components.Shared
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersusApiClient Api
@inject LocalizationService L
@inject IConfiguration Config
@inject IJSRuntime JS
@inject IWebHostEnvironment Environment
@inject MatchSlugHelper MatchSlugHelper
@inject NavigationManager Nav
@inject RouteLocalizationService RouteLocalization
@inject LocalizedMediaPathResolver MediaResolver
@inject TvArenaCommentaryService ArenaCommentary
@inject TvFieldStateService FieldPositionService
@inject ILogger<TvStage> Logger
@implements IAsyncDisposable

@if (HasLiveMatch)
{
    <section class="tv-stage tv-stage--live @(IsBroadcastMode ? "tv-stage--broadcast" : string.Empty)">
        <div class="tv-stage__backdrop"></div>
        <div class="tv-stage__aurora"></div>
        <div class="tv-stage__fog"></div>
        <div class="tv-stage__gridlines"></div>
        <div class="tv-stage__particles"></div>
        <TvNarrationOverlay @ref="_narrationOverlay" />
        <div id="tv-replay-root" class="tv-replay-root" aria-hidden="true"></div>

        @if (_showPirateOverlay)
        {
            <div class="pirate-signal-backdrop @BroadcastCinematicBackdropClass" aria-live="polite" aria-atomic="true">
                <div class="pirate-vhs-glitch" aria-hidden="true">
                    @for (var i = 0; i < 42; i++)
                    {
                        <span class="pirate-vhs-glitch__line" style="--line-index:@i;"></span>
                    }
                </div>

                <div class="pirate-signal-panel @BroadcastCinematicPanelClass">
                    <div class="pirate-signal-panel__scanlines"></div>
                    <div class="pirate-signal-panel__noise"></div>

                    <div class="pirate-signal-header">
                        <div class="pirate-signal-header__left">
                            <span class="signal-dot"></span>
                            <span>@PirateHeaderTitle</span>
                        </div>
                        <span class="signal-status">@PirateHeaderStatus</span>
                    </div>

                    <div class="pirate-signal-body">
                        <div class="pirate-character-frame">
                            <div class="pirate-character-frame__hud"></div>
                            @if (!string.IsNullOrWhiteSpace(_currentPirateOpeningVideo))
                            {
                                <video @key="_currentPirateOpeningVideo"
                                       class="pirate-character-frame__portrait pirate-character-frame__video"
                                       src="@_currentPirateOpeningVideo"
                                       autoplay
                                       muted
                                       playsinline
                                       preload="auto"
                                       disablepictureinpicture
                                       controlslist="nodownload noplaybackrate nofullscreen"
                                       onloadeddata="this.style.display='block'; this.parentElement.classList.remove('is-placeholder');"
                                       onerror="if(location.hostname==='localhost'||location.hostname==='127.0.0.1'||location.hostname==='::1'||location.hostname.endsWith('.local')){console.warn('[TV_VIDEO] playback error', this.currentSrc || this.src);} this.style.display='none'; this.parentElement.classList.add('is-placeholder');"
                                       @onended="HandleBroadcastCinematicVideoEndedAsync"
                                       aria-label="@PirateSpeakerName"></video>
                            }
                            else
                            {
                                <img class="pirate-character-frame__portrait"
                                     src="/img/tv/zero-host.png"
                                     alt="@PirateSpeakerName"
                                     loading="eager"
                                     onload="this.style.display='block'; this.parentElement.classList.remove('is-placeholder');"
                                     onerror="this.style.display='none'; this.parentElement.classList.add('is-placeholder');" />
                            }
                            <div class="pirate-character-frame__fallback" aria-hidden="true">
                                <span>CV</span>
                            </div>
                            <div class="pirate-character-frame__label">
                                <small>@PirateSpeakerRole</small>
                                <strong>@PirateSpeakerName</strong>
                            </div>
                        </div>

                        <div class="pirate-signal-copy">
                            <div class="pirate-signal-copy__eyebrow">@PirateCopyEyebrow</div>
                            <div class="pirate-message">@_pirateOverlayMessage</div>
                            <div class="pirate-signal-copy__meta">
                                <span>@PirateFooterLeft</span>
                                <span>@PirateFooterRight</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (_isEventVisible && _activeEvent is not null)
        {
            <div class="tv-event-overlay is-visible" aria-live="polite" aria-atomic="true">
                <div class="tv-event-overlay__card" style="@GetEventAccentStyle(_activeEvent.AccentHex)">
                    <span>@_activeEvent.Kicker</span>
                    <strong>@_activeEvent.Title</strong>
                    <small>@_activeEvent.Body</small>
                </div>
            </div>
        }

        @if (IsBroadcastSwitchNoticeVisible)
        {
            <div class="tv-broadcast-notice" aria-live="polite" aria-atomic="true">
                <strong>@T("broadcast.switchingArena")</strong>
                <span>@T("broadcast.nextHotArena")</span>
            </div>
        }

        @if (IsBroadcastMode)
        {
            <div class="tv-broadcast-focus-bar" style="--tv-focus-color:@BroadcastFocusColor; --tv-focus-progress:@BroadcastFocusProgressCss;">
                <span class="tv-broadcast-focus-bar__label">@BroadcastFocusLabel</span>
                <div class="tv-broadcast-focus-bar__track" aria-hidden="true">
                    <i class="tv-broadcast-focus-bar__fill" style="width:@BroadcastFocusWidthCss%;"></i>
                </div>
            </div>

            @if (ShouldShowBroadcastRotationGauge)
            {
                <div class="tv-broadcast-rotation-gauge" aria-live="polite" aria-atomic="true">
                    <div class="tv-broadcast-rotation-gauge__copy">
                        <span>@T("broadcast.rotationGaugeLabel")</span>
                        <strong>@DisplayBroadcastRotationRemaining()</strong>
                        <small>@T("broadcast.rotationGaugeTitle", BroadcastRotationMinutes)</small>
                    </div>
                    <div class="tv-broadcast-rotation-gauge__track" aria-hidden="true">
                        <i class="tv-broadcast-rotation-gauge__fill" style="width:@BroadcastRotationWidthCss%;"></i>
                    </div>
                </div>
            }

            @if (EnableTvDebugOverlay)
            {
                <div class="tv-debug-overlay" aria-hidden="true">
                    <span>EVENT: @_activeEvent?.Key</span>
                    <span>CAMERA: @BroadcastFocusKey</span>
                    <span>REPLAY: @_lastAutoReplaySide</span>
                    <span>AUDIO: @(ShouldRenderCrowdAudio ? ( _isCrowdAudioMuted ? "muted" : "on") : "off")</span>
                    <span>FOCUS: @BroadcastFocusLabel</span>
                    <span>COOLDOWN: @((BroadcastFocusProgress * 100).ToString("0") + "%")</span>
                </div>
            }
        }

        <div class="tv-stage__broadcast-shell @(IsBroadcastFlipActive ? "is-match-switching" : string.Empty)">
        <header class="tv-stage__topbar">
            <div>
                <a class="tv-stage__eyebrow tv-stage__eyebrow-link" href="@RouteLocalization.BuildHomePath(Culture)">
                    @T("hero.eyebrow")
                </a>
                <h1 class="tv-brand-lockup">
                    <a class="tv-brand-link" href="@RouteLocalization.BuildHomePath(Culture)">
                       CriptoVersus TV
                    </a>
                    <span class="tv-brand-subtitle">Procedural TV</span>
                </h1>
                <p class="tv-stage__headline">@DisplayMatchHeadline()</p>
            </div>

            <div class="tv-stage__badges">
                <span class="tv-pill tv-pill--live">
                    <span class="tv-pill__dot"></span>
                    @T("labels.liveArena")
                </span>
                <span class="tv-pill">@T("labels.automaticBroadcast")</span>
                @if (!string.IsNullOrWhiteSpace(CurrentRealMatchUrl))
                {
                    <a target="_blank" class="tv-pill tv-pill--nav" href="@CurrentRealMatchUrl">Match</a>
                }
                <span class="@SignalBadgeClass">@SignalBadgeLabel</span>
                <span class="tv-pill tv-pill--score @(_pulseHotScore ? "is-pulsing" : string.Empty)">@T("labels.hotScore") @DisplayHotScore()</span>
                <button type="button" class="tv-pill tv-pill--audio tv-pill--audio-test" @onclick="PlayKnownArenaAudioAsync" title="@KnownArenaAudioButtonTitle">
                    <span class="tv-pill__audio-icon tv-pill__audio-icon--test" aria-hidden="true"></span>
                    <span>@KnownArenaAudioButtonLabel</span>
                </button>
                @if (ShouldRenderCrowdAudio)
                {
                    <button type="button" class="tv-pill tv-pill--audio" @onclick="ToggleCrowdAudioAsync" title="@DisplayCrowdAudioLabel()">
                        <span class="@CrowdAudioIconClass" aria-hidden="true"></span>
                        <span>@DisplayCrowdAudioLabel()</span>
                    </button>
                    @if (ShouldShowAudioUnlockButton)
                    {
                        <button type="button" class="tv-pill tv-pill--audio tv-pill--audio-unlock" @onclick="EnableBroadcastAudioAsync">@T("audio.startBroadcast")</button>
                    }
                }
            </div>
        </header>

            @if (ShouldShowDataStatusBanner)
            {
                <div class="tv-stage__status-banner" aria-live="polite" aria-atomic="true">
                    <strong>@T("broadcast.dataStatusTitle")</strong>
                    <span>@BroadcastDataStatusMessage</span>
                </div>
            }

            @if (IsBroadcastMode && !string.IsNullOrWhiteSpace(CurrentMatchUrl))
            {
                <section class="tv-broadcast-promo" aria-labelledby="tv-broadcast-promo-heading">
                    <div class="tv-broadcast-promo__copy">
                        <span class="tv-broadcast-promo__eyebrow">@T("broadcast.mainMatchEyebrow")</span>
                        <h2 id="tv-broadcast-promo-heading">@DisplayMatchHeadline()</h2>
                        <p>@T("broadcast.mainMatchDescription")</p>
                    </div>
                    <a class="tv-broadcast-promo__cta"
                       href="@CurrentMatchUrl"
                       aria-label="@T("broadcast.openBroadcastAria", DisplayMatchHeadline())">
                        <span>@T("broadcast.mainMatchCta")</span>
                    </a>
                </section>
            }

            <div class="tv-stage__grid">
                <article class="tv-match-card @(UseFootballFieldLayout ? "tv-match-card--football" : string.Empty)">

                    <div class="tv-match-card__meta">
                        <span>@T("labels.hotMatch")</span>
                        <strong>@DisplayRemainingTime()</strong>
                    </div>

                    @if (UseFootballFieldLayout && CurrentFieldState is not null)
                    {
                        <div class="tv-football-layout">
                            <section class="tv-football-side tv-football-side--left">
                                <div class="tv-football-side__cta-wrap">
                                    @if (CanInvestInArena())
                                    {
                                        <a class="tv-football-side__cta tv-football-side__cta--left"
                                           style="@GetBetButtonStyle(DisplayLeftSymbol())"
                                           href="@BuildArenaInvestmentUrl()">
                                            @MatchGaugeT("invest")
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="tv-football-side__cta tv-football-side__cta--left"
                                                style="@GetBetButtonStyle(DisplayLeftSymbol())"
                                                disabled>
                                            @MatchGaugeT("invest")
                                        </button>
                                    }
                                </div>
                                <div class="tv-football-side__logo">
                                    <img src="@GetLogoUrl(DisplayLeftLogoUrl())" alt="" />
                                </div>
                                <span class="tv-football-side__symbol">@DisplayLeftTickerLabel()</span>
                                <strong>@DisplayLeftHeroLabel()</strong>
                                <small>@DisplayLeftName()</small>
                                <span class="tv-football-side__change @GetChangeClass(DisplayLeftChangePercent())">@FormatChangePercent(DisplayLeftChangePercent())</span>
                            </section>

                            <section class="tv-football-center">
                                <div class="tv-football-scoreboard @(_pulseScoreboard ? "is-pulsing" : string.Empty)">
                                    <span>@T("field.scoreboard")</span>
                                    <div class="tv-football-scoreboard__score">
                                        <strong class="@(_pulseLeftScore ? "tv-score-value tv-score-value--pulse" : "tv-score-value")">@DisplayLeftScore()</strong>
                                        <em>@T("vs")</em>
                                        <strong class="@(_pulseRightScore ? "tv-score-value tv-score-value--pulse" : "tv-score-value")">@DisplayRightScore()</strong>
                                    </div>
                                    <div class="tv-football-scoreboard__clock">
                                        <strong>@DisplayClockPrimary()</strong>
                                        <span>@T("field.remainingTime")</span>
                                    </div>
                                </div>

                                <div class="tv-football-field-viewport">
                                    <TvCryptoFootballField Culture="@Culture"
                                                          FieldState="@CurrentFieldState"
                                                          TeamALogoUrl="@GetLogoUrl(DisplayLeftLogoUrl())"
                                                          TeamBLogoUrl="@GetLogoUrl(DisplayRightLogoUrl())" />
                                </div>
                            </section>

                            <section class="tv-football-side tv-football-side--right">
                                <div class="tv-football-side__cta-wrap">
                                    @if (CanInvestInArena())
                                    {
                                        <a class="tv-football-side__cta tv-football-side__cta--right"
                                           style="@GetBetButtonStyle(DisplayRightSymbol())"
                                           href="@BuildArenaInvestmentUrl()">
                                            @MatchGaugeT("invest")
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="tv-football-side__cta tv-football-side__cta--right"
                                                style="@GetBetButtonStyle(DisplayRightSymbol())"
                                                disabled>
                                            @MatchGaugeT("invest")
                                        </button>
                                    }
                                </div>
                                <div class="tv-football-side__logo">
                                    <img src="@GetLogoUrl(DisplayRightLogoUrl())" alt="" />
                                </div>
                                <span class="tv-football-side__symbol">@DisplayRightTickerLabel()</span>
                                <strong>@DisplayRightHeroLabel()</strong>
                                <small>@DisplayRightName()</small>
                                <span class="tv-football-side__change @GetChangeClass(DisplayRightChangePercent())">@FormatChangePercent(DisplayRightChangePercent())</span>
                            </section>
                        </div>
                    }
                    else
                    {
                        <div class="tv-match-card__arena">
                            <div class="tv-team tv-team--left" style="@GetTeamStyle(DisplayLeftSymbol(), true)">
                                <div class="tv-team__halo"></div>
                                <div class="tv-team__cta-wrap">
                                    @if (CanInvestInArena())
                                    {
                                        <a class="tv-team__cta tv-team__cta--left"
                                           style="@GetBetButtonStyle(DisplayLeftSymbol())"
                                           href="@BuildArenaInvestmentUrl()">
                                            @MatchGaugeT("invest")
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="tv-team__cta tv-team__cta--left"
                                                style="@GetBetButtonStyle(DisplayLeftSymbol())"
                                                disabled>
                                            @MatchGaugeT("invest")
                                        </button>
                                    }
                                </div>
                                <div class="tv-team__logo-shell">
                                    <img src="@GetLogoUrl(DisplayLeftLogoUrl())" alt="" />
                                </div>
                                <span class="tv-team__symbol">@DisplayLeftTickerLabel()</span>
                                <strong>@DisplayLeftName()</strong>
                                <span class="@GetChangeClass(DisplayLeftChangePercent())">@FormatChangePercent(DisplayLeftChangePercent())</span>
                            </div>

                            <div class="tv-center-hud">
                                <div class="tv-broadcast-clock">
                                    <div class="tv-broadcast-clock__header">
                                        <span>@T("labels.matchClock")</span>
                                        @if (IsClockLive())
                                        {
                                            <span class="tv-broadcast-clock__live">@T("labels.live")</span>
                                        }
                                    </div>
                                    <strong>@DisplayClockPrimary()</strong>
                                    <small>@DisplayClockPhaseLabel()</small>
                                </div>

                                <div class="tv-scoreboard @(_pulseScoreboard ? "is-pulsing" : string.Empty)">
                                    <span class="tv-scoreboard__status">@T("labels.matchArena")</span>
                                    <div class="tv-scoreboard__score">
                                        <strong class="@(_pulseLeftScore ? "tv-score-value tv-score-value--pulse" : "tv-score-value")">@DisplayLeftScore()</strong>
                                        <span class="tv-scoreboard__versus">@T("vs")</span>
                                        <strong class="@(_pulseRightScore ? "tv-score-value tv-score-value--pulse" : "tv-score-value")">@DisplayRightScore()</strong>
                                    </div>
                                    <small>@DisplayScoreContext()</small>
                                </div>
                            </div>

                            <div class="tv-team tv-team--right" style="@GetTeamStyle(DisplayRightSymbol(), false)">
                                <div class="tv-team__halo"></div>
                                <div class="tv-team__cta-wrap">
                                    @if (CanInvestInArena())
                                    {
                                        <a class="tv-team__cta tv-team__cta--right"
                                           style="@GetBetButtonStyle(DisplayRightSymbol())"
                                           href="@BuildArenaInvestmentUrl()">
                                            @MatchGaugeT("invest")
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="tv-team__cta tv-team__cta--right"
                                                style="@GetBetButtonStyle(DisplayRightSymbol())"
                                                disabled>
                                            @MatchGaugeT("invest")
                                        </button>
                                    }
                                </div>
                                <div class="tv-team__logo-shell">
                                    <img src="@GetLogoUrl(DisplayRightLogoUrl())" alt="" />
                                </div>
                                <span class="tv-team__symbol">@DisplayRightTickerLabel()</span>
                                <strong>@DisplayRightName()</strong>
                                <span class="@GetChangeClass(DisplayRightChangePercent())">@FormatChangePercent(DisplayRightChangePercent())</span>
                            </div>
                        </div>
                    }

                    <section class="tv-ai-commentary">
                        <div class="tv-ai-commentary__header">
                            <span>@(UseFootballFieldLayout ? T("field.arenaCommentary") : T("commentary.title"))</span>
                            <small>@DisplayCommentaryMeta()</small>
                        </div>

                        @if (HasArenaCommentaryFeed)
                        {
                            <div class="tv-ai-commentary__feed" aria-live="polite" aria-atomic="false">
                                @foreach (var commentary in ArenaCommentaryFeed)
                                {
                                    <article @key="commentary.Id"
                                             class="@(commentary.IsLatest ? "tv-ai-commentary__entry tv-ai-commentary__entry--latest" : "tv-ai-commentary__entry")"
                                             style="@GetArenaCommentaryAccentStyle(commentary.AccentHex)"
                                             @onclick="() => HandleArenaCommentaryClickAsync(commentary)"
                                             title="@GetArenaCommentaryClickTitle(commentary)">
                                        <div class="tv-ai-commentary__entry-meta">
                                            <span class="tv-ai-commentary__minute">@commentary.MinuteLabel</span>
                                            <span class="tv-ai-commentary__type">@commentary.TypeLabel</span>
                                        </div>
                                        <div class="tv-ai-commentary__entry-body">
                                            <strong class="tv-ai-commentary__asset">@commentary.HighlightSymbol</strong>
                                            <p class="tv-ai-commentary__copy">@commentary.Text</p>
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="tv-ai-commentary__text">
                                @DisplayCommentaryText()
                            </div>
                        }
                    </section>

                </article>

                <aside class="tv-telemetry @(UseFootballFieldLayout ? "tv-telemetry--football" : string.Empty)">
                    @if (EnableTelemetryCube)
                    {
                        <div id="tv-telemetry-cube-shell"
                             class="tv-telemetry-cube-shell"
                             data-interval-seconds="@TelemetryCubeIntervalSeconds">
                            <div id="tv-telemetry-cube" class="tv-telemetry-cube is-face-0">
                                <section class="tv-telemetry-cube__face tv-telemetry-cube__face--front">
                                    <div class="tv-telemetry-cube__inner">
                                        <div class="tv-telemetry-cube__telemetry-grid">
                                            @TelemetryPanelContent()
                                        </div>
                                    </div>
                                </section>

                                <section class="tv-telemetry-cube__face tv-telemetry-cube__face--right">
                                    <div class="tv-telemetry-cube__inner">
                                        <header class="tv-telemetry-face-header">
                                            <span class="tv-telemetry-face-header__kicker">@T("labels.leftAssetChange")</span>
                                            <div class="tv-telemetry-face-header__row">
                                                <strong>@DisplayLeftTickerLabel()</strong>
                                                <em class="@GetChangeClass(DisplayLeftChangePercent())">@FormatChangePercent(DisplayLeftChangePercent())</em>
                                            </div>
                                            <small>@DisplayMomentumSupportLine()</small>
                                        </header>
                                        <div id="tv-telemetry-chart-left" class="tv-telemetry-chart-shell" aria-label="chart ativo A"></div>
                                        <div class="tv-telemetry-face-footer">
                                            <span>@T("labels.momentum")</span>
                                            <strong>@DisplayMomentum()</strong>
                                        </div>
                                    </div>
                                </section>

                                <section class="tv-telemetry-cube__face tv-telemetry-cube__face--back">
                                    <div class="tv-telemetry-cube__inner tv-telemetry-cube__inner--compare">
                                        <header class="tv-telemetry-face-header">
                                            <span class="tv-telemetry-face-header__kicker">@T("labels.marketBattleFlow")</span>
                                            <div class="tv-telemetry-face-header__row">
                                                <strong>@DisplayLeftTickerLabel() <span class="tv-telemetry-face-header__vs">@T("vs")</span> @DisplayRightTickerLabel()</strong>
                                                <em>@DisplayPressureSymbol()</em>
                                            </div>
                                            <small>@DisplayPressureHeadline()</small>
                                        </header>
                                        <div id="tv-telemetry-chart-compare" class="tv-telemetry-chart-shell" aria-label="chart comparativo"></div>
                                        <div class="tv-telemetry-face-footer">
                                            <span>@T("labels.pressure")</span>
                                            <strong>@DisplayPoolStatus()</strong>
                                        </div>
                                    </div>

                                    <div class="tv-telemetry-cube__inner tv-telemetry-cube__inner--split">
                                        <header class="tv-telemetry-face-header">
                                            <span class="tv-telemetry-face-header__kicker">@T("labels.assetVariationSplit")</span>
                                            <div class="tv-telemetry-face-header__row">
                                                <strong>@DisplayLeftTickerLabel() <span class="tv-telemetry-face-header__vs">@T("vs")</span> @DisplayRightTickerLabel()</strong>
                                                <em class="tv-telemetry-face-header__muted">@T("labels.momentum")</em>
                                            </div>
                                            <small>@DisplayPressureHeadline()</small>
                                        </header>

                                        <div class="tv-telemetry-split">
                                            <section class="tv-telemetry-split__panel">
                                                <div class="tv-telemetry-split__meta">
                                                    <strong>@DisplayLeftTickerLabel()</strong>
                                                    <em class="@GetChangeClass(DisplayLeftChangePercent())">@FormatChangePercent(DisplayLeftChangePercent())</em>
                                                </div>
                                                <div id="tv-telemetry-chart-split-left" class="tv-telemetry-chart-shell tv-telemetry-chart-shell--split" aria-label="chart split ativo A"></div>
                                            </section>

                                            <section class="tv-telemetry-split__panel">
                                                <div class="tv-telemetry-split__meta">
                                                    <strong>@DisplayRightTickerLabel()</strong>
                                                    <em class="@GetChangeClass(DisplayRightChangePercent())">@FormatChangePercent(DisplayRightChangePercent())</em>
                                                </div>
                                                <div id="tv-telemetry-chart-split-right" class="tv-telemetry-chart-shell tv-telemetry-chart-shell--split" aria-label="chart split ativo B"></div>
                                            </section>
                                        </div>
                                    </div>

                                    <div class="tv-telemetry-cube__inner tv-telemetry-cube__inner--goals">
                                        <header class="tv-telemetry-face-header">
                                            <span class="tv-telemetry-face-header__kicker">@RootT("grid.metrics.goals")</span>
                                            <div class="tv-telemetry-face-header__row">
                                                <strong>@DisplayScoreContext()</strong>
                                                <em>@(_recentScoreEvents.Count > 0 ? _recentScoreEvents[0].TeamSymbol : DisplayPressureSymbol())</em>
                                            </div>
                                            <small>@DisplayGoalLogHeadline()</small>
                                        </header>

                                        <div class="tv-goal-log">
                                            <TvGoalEventFeed FeedId="@GoalEventFeedId"
                                                             Culture="@Culture"
                                                             Items="@_recentScoreEvents.Take(5).ToList()"
                                                             FormatTime="FormatGoalLogTime"
                                                             DescribeFallback="DescribeGoalLog"
                                                             ResolveTeamLogoUrl="ResolveGoalLogTeamLogoUrl"
                                                             EmptyTitle="@RootT("grid.metrics.goals")"
                                                             EmptySubtitle="@DisplayGoalLogEmptyState()" />
                                        </div>
                                    </div>

                                    <div class="tv-telemetry-cube__inner tv-telemetry-cube__inner--sentiment">
                                        <ArenaPressurePanel LeftSymbol="@DisplayLeftHeroLabel()"
                                                            RightSymbol="@DisplayRightHeroLabel()"
                                                            LeftSentiment="@_arenaSentimentA"
                                                            RightSentiment="@_arenaSentimentB"
                                                            LeftClassificationLabel="@GetArenaSentimentLabel(_arenaSentimentA)"
                                                            RightClassificationLabel="@GetArenaSentimentLabel(_arenaSentimentB)"
                                                            IsLoading="@_arenaSentimentLoading"
                                                            GaugeSize="280"
                                                            TitleText="@MatchGaugeT("arenaPressureTitle")"
                                                            SubtitleText="@MatchGaugeT("arenaPressureSubtitle")"
                                                            GaugeLabelText="@MatchGaugeT("arenaPressureLabel")"
                                                            BadgeText="@MatchGaugeT("marketPulse")"
