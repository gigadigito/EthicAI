    private IEnumerable<(string PhysicalPath, string WebPathPrefix, string DefaultCategory)> EnumerateBroadcastVideoRoots()
    {
        foreach (var directory in MediaResolver.ResolveVideoDirectories(
            Culture,
            context: "broadcast",
            legacyRelativeDirectory: "video/broadcast",
            legacyWebPrefix: "/video/broadcast"))
        {
            yield return (directory.PhysicalPath, directory.WebPathPrefix, "special-event");
        }

        foreach (var directory in MediaResolver.ResolveVideoDirectories(
            Culture,
            context: "opening",
            legacyRelativeDirectory: "video/opening",
            legacyWebPrefix: "/video/opening"))
        {
            yield return (directory.PhysicalPath, directory.WebPathPrefix, "intro");
        }
    }

    private BroadcastCinematicVideoAsset? BuildBroadcastCinematicVideoAsset(string filePath, string rootPath, string webPathPrefix, string defaultCategory)
    {
        var supportedExtensions = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            ".mp4",
            ".webm",
            ".mov",
            ".m4v"
        };

        var extension = Path.GetExtension(filePath);
        if (!supportedExtensions.Contains(extension))
            return null;

        var fileName = Path.GetFileNameWithoutExtension(filePath);
        if (string.IsNullOrWhiteSpace(fileName))
            return null;

        var relativePath = Path.GetRelativePath(rootPath, filePath)
            .Replace('\\', '/')
            .TrimStart('/');

        var firstFolder = relativePath.Split('/', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
        var category = InferBroadcastVideoCategory(firstFolder, fileName, defaultCategory);
        var tags = InferBroadcastVideoTags(fileName, category).ToArray();
        var triggers = InferBroadcastVideoTriggers(fileName, category).ToArray();
        var src = $"{webPathPrefix}/{string.Join("/", relativePath.Split('/').Select(Uri.EscapeDataString))}";
        var priority = ResolveBroadcastVideoPriority(category, tags);
        var cooldown = ResolveBroadcastVideoCooldown(category, triggers);
        var transition = ResolveBroadcastVideoTransition(category, tags);
        var weight = ResolveBroadcastVideoWeight(priority, tags, triggers);
        var duration = ResolveBroadcastVideoDuration(category, triggers);

        return new BroadcastCinematicVideoAsset(
            Id: $"{category}:{fileName}".ToLowerInvariant(),
            Src: src,
            Category: category,
            Priority: priority,
            Cooldown: cooldown,
            Tags: tags,
            TriggerKeys: triggers,
            Transition: transition,
            Weight: weight,
            PreferredDuration: duration);
    }

    private BroadcastCinematicVideoAsset? SelectBroadcastCinematicVideo(string triggerKey)
    {
        EnsurePirateOpeningVideosLoaded();

        if (_broadcastCinematicVideos.Count == 0)
            return null;

        var now = DateTime.UtcNow;
        var candidates = _broadcastCinematicVideos
            .Where(asset => IsBroadcastVideoCandidate(asset, triggerKey))
            .ToList();

        if (candidates.Count == 0)
            candidates = [.. _broadcastCinematicVideos];

        var cooledCandidates = candidates
            .Where(asset => !_broadcastVideoCooldownsUtc.TryGetValue(asset.Id, out var untilUtc) || untilUtc <= now)
            .ToList();

        if (cooledCandidates.Count > 0)
            candidates = cooledCandidates;

        if (candidates.Count > 1)
        {
            var nonRepeating = candidates
                .Where(asset => !string.Equals(asset.Id, _lastBroadcastVideoId, StringComparison.Ordinal))
                .ToList();

            if (nonRepeating.Count > 0)
                candidates = nonRepeating;
        }

        var totalWeight = candidates.Sum(asset => Math.Max(0.1d, asset.Weight));
        var roll = Random.Shared.NextDouble() * Math.Max(0.1d, totalWeight);
        var cumulative = 0d;
        foreach (var asset in candidates.OrderByDescending(x => x.Priority))
        {
            cumulative += Math.Max(0.1d, asset.Weight);
            if (roll <= cumulative)
                return asset;
        }

        return candidates.OrderByDescending(x => x.Priority).FirstOrDefault();
    }

    private bool IsBroadcastVideoCandidate(BroadcastCinematicVideoAsset asset, string triggerKey)
    {
        if (asset.TriggerKeys.Contains(triggerKey, StringComparer.OrdinalIgnoreCase))
            return true;

        return triggerKey switch
        {
            "initial" or "match-start" => asset.Category is "intro" or "arena-lore" or "special-event",
            "match-change" => asset.Category is "pirate-transmission" or "villain-message" or "special-event",
            "halftime" => asset.Category is "arena-lore" or "villain-message",
            "final-minutes" => asset.Category is "market-warning" or "villain-message" or "special-event",
            "volatility-spike" => asset.Category is "market-warning" or "special-event",
            "market-crash" => asset.Category is "market-warning" or "villain-message",
            "bitcoin-dominance" => asset.Tags.Contains("bitcoin", StringComparer.OrdinalIgnoreCase) || asset.Tags.Contains("btc", StringComparer.OrdinalIgnoreCase),
            "meme-coin-surge" => asset.Category == "meme-coin-event",
            "random-interruption" => asset.Category is "pirate-transmission" or "villain-message" or "arena-lore",
            "special-event" => asset.Category == "special-event",
            "kickoff" => asset.Category is "intro" or "special-event",
            _ => true
        };
    }

    private static string InferBroadcastVideoCategory(string? folderName, string fileName, string defaultCategory)
    {
        var normalizedFolder = NormalizeBroadcastToken(folderName);
        var normalizedFile = NormalizeBroadcastToken(fileName);

        if (normalizedFolder.Contains("pirate", StringComparison.Ordinal) || normalizedFile.Contains("pirate", StringComparison.Ordinal))
            return "pirate-transmission";

        if (normalizedFolder.Contains("warning", StringComparison.Ordinal)
            || normalizedFolder.Contains("alert", StringComparison.Ordinal)
            || normalizedFile.Contains("warning", StringComparison.Ordinal)
            || normalizedFile.Contains("crash", StringComparison.Ordinal))
            return "market-warning";

        if (normalizedFolder.Contains("villain", StringComparison.Ordinal)
            || normalizedFolder.Contains("mastermind", StringComparison.Ordinal)
            || normalizedFile.Contains("villain", StringComparison.Ordinal)
            || normalizedFile.Contains("mastermind", StringComparison.Ordinal))
            return "villain-message";

        if (normalizedFile.Contains("pepe", StringComparison.Ordinal)
            || normalizedFile.Contains("doge", StringComparison.Ordinal)
            || normalizedFile.Contains("shib", StringComparison.Ordinal)
            || normalizedFile.Contains("floki", StringComparison.Ordinal)
            || normalizedFile.Contains("bonk", StringComparison.Ordinal)
            || normalizedFile.Contains("wif", StringComparison.Ordinal))
            return "meme-coin-event";

        if (normalizedFile.Contains("bitcoin", StringComparison.Ordinal)
            || normalizedFile.Contains("btc", StringComparison.Ordinal)
            || normalizedFolder.Contains("special", StringComparison.Ordinal))
            return "special-event";

        if (normalizedFolder.Contains("lore", StringComparison.Ordinal)
            || normalizedFile.Contains("arena", StringComparison.Ordinal)
            || normalizedFile.Contains("doctor", StringComparison.Ordinal)
            || normalizedFile.Contains("destiny", StringComparison.Ordinal))
            return "arena-lore";

        return defaultCategory;
    }

    private static IEnumerable<string> InferBroadcastVideoTags(string fileName, string category)
    {
        var tags = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            category
        };

        foreach (var token in fileName
            .Split(['_', '-', ' '], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(NormalizeBroadcastToken)
            .Where(token => !string.IsNullOrWhiteSpace(token)))
        {
            tags.Add(token);
        }

        return tags;
    }

    private static IEnumerable<string> InferBroadcastVideoTriggers(string fileName, string category)
    {
        var normalized = NormalizeBroadcastToken(fileName);
        var triggers = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        switch (category)
        {
            case "intro":
                triggers.Add("initial");
                triggers.Add("match-start");
                triggers.Add("kickoff");
                break;
            case "pirate-transmission":
                triggers.Add("match-change");
                triggers.Add("random-interruption");
                break;
            case "market-warning":
                triggers.Add("volatility-spike");
                triggers.Add("final-minutes");
                break;
            case "villain-message":
                triggers.Add("match-change");
                triggers.Add("halftime");
                triggers.Add("random-interruption");
                break;
            case "special-event":
                triggers.Add("special-event");
                triggers.Add("match-start");
                break;
            case "arena-lore":
                triggers.Add("initial");
                triggers.Add("halftime");
                break;
            case "meme-coin-event":
                triggers.Add("meme-coin-surge");
                triggers.Add("random-interruption");
                break;
        }

        if (normalized.Contains("bitcoin", StringComparison.Ordinal) || normalized.Contains("btc", StringComparison.Ordinal))
            triggers.Add("bitcoin-dominance");

        if (normalized.Contains("warning", StringComparison.Ordinal) || normalized.Contains("crash", StringComparison.Ordinal))
            triggers.Add("market-crash");

        return triggers;
    }

    private static int ResolveBroadcastVideoPriority(string category, IReadOnlyList<string> tags)
        => category switch
        {
            "special-event" => 95,
            "market-warning" => 90,
            "villain-message" => 86,
            "pirate-transmission" => 82,
            "meme-coin-event" => 78,
            "arena-lore" => 72,
            _ => tags.Contains("bitcoin", StringComparer.OrdinalIgnoreCase) ? 84 : 68
        };

    private static TimeSpan ResolveBroadcastVideoCooldown(string category, IReadOnlyList<string> triggers)
        => category switch
        {
            "special-event" => TimeSpan.FromMinutes(6),
            "market-warning" => TimeSpan.FromMinutes(5),
            "villain-message" => TimeSpan.FromMinutes(4),
            "pirate-transmission" => TimeSpan.FromMinutes(3),
            "meme-coin-event" => TimeSpan.FromMinutes(4),
            _ => triggers.Contains("initial", StringComparer.OrdinalIgnoreCase) ? TimeSpan.FromMinutes(5) : TimeSpan.FromMinutes(3)
        };

    private static string ResolveBroadcastVideoTransition(string category, IReadOnlyList<string> tags)
    {
        if (category == "market-warning")
            return "emergency-alert";
        if (category == "pirate-transmission")
            return "signal-interference";
        if (category == "villain-message")
            return "arena-takeover";
        if (category == "special-event")
            return tags.Contains("bitcoin", StringComparer.OrdinalIgnoreCase) ? "broadcast-cut" : "glitch";

        return "glitch";
    }

    private static double ResolveBroadcastVideoWeight(int priority, IReadOnlyList<string> tags, IReadOnlyList<string> triggers)
        => Math.Max(1d, (priority / 10d) + (triggers.Count * 0.8d) + (tags.Contains("bitcoin", StringComparer.OrdinalIgnoreCase) ? 1.4d : 0d));

    private static TimeSpan ResolveBroadcastVideoDuration(string category, IReadOnlyList<string> triggers)
        => category switch
        {
            "special-event" => TimeSpan.FromSeconds(10.8),
            "villain-message" => TimeSpan.FromSeconds(9.8),
            "market-warning" => TimeSpan.FromSeconds(8.6),
            "pirate-transmission" => TimeSpan.FromSeconds(8.9),
            _ => triggers.Contains("initial", StringComparer.OrdinalIgnoreCase) ? TimeSpan.FromSeconds(9.4) : TimeSpan.FromSeconds(8.8)
        };

    private static string ResolveFallbackBroadcastTransition(string reason)
        => reason switch
        {
            "match-change" => "broadcast-cut",
            "volatility-spike" or "market-crash" => "emergency-alert",
            "random-interruption" => "signal-interference",
            _ => "glitch"
        };

