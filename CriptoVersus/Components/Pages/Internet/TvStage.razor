    private IReadOnlyList<ActivityChartPoint> BuildActivityChartPoints()
    {
        var activity = Stats?.MatchActivity ?? [];
        if (activity.Count == 0)
            return [];

        var parsed = activity
            .Select(item => new
            {
                Date = ParseActivityDate(item.Date),
                item.Matches
            })
            .Where(item => item.Date.HasValue)
            .Select(item => (Date: item.Date!.Value, item.Matches))
            .OrderBy(item => item.Date)
            .ToList();

        if (parsed.Count == 0)
            return [];

        if (parsed.Count == 1)
        {
            var single = parsed[0];
            return [
                new ActivityChartPoint(0, 180, single.Date.ToString("MM/dd", CultureInfo.InvariantCulture), single.Matches),
                new ActivityChartPoint(1000, 120, single.Date.ToString("MM/dd", CultureInfo.InvariantCulture), single.Matches)
            ];
        }

        var min = parsed.Min(item => item.Matches);
        var max = parsed.Max(item => item.Matches);
        var paddedMin = Math.Max(0, min - 1);
        var paddedMax = Math.Max(paddedMin + 1, max + 1);
        var width = 1000d;
        var height = 180d;
        var step = width / Math.Max(1, parsed.Count - 1);

        return parsed
            .Select((item, index) =>
            {
                var x = index * step;
                var ratio = (item.Matches - paddedMin) / (double)(paddedMax - paddedMin);
                var y = height - (ratio * height);
                return new ActivityChartPoint(x, y, item.Date.ToString("MM/dd", CultureInfo.InvariantCulture), item.Matches);
            })
            .ToList();
    }

    private static string BuildActivityChartAreaPath(IReadOnlyList<ActivityChartPoint> points)
    {
        if (points.Count == 0)
            return string.Empty;

        var first = points[0];
        var last = points[^1];
        var baseY = 200d;
        var builder = new System.Text.StringBuilder();
        builder.Append(FormattableString.Invariant($"M {first.X:0.##} {baseY:0.##} L {first.X:0.##} {first.Y:0.##} "));

        foreach (var point in points.Skip(1))
            builder.Append(FormattableString.Invariant($"L {point.X:0.##} {point.Y:0.##} "));

        builder.Append(FormattableString.Invariant($"L {last.X:0.##} {baseY:0.##} Z"));
        return builder.ToString();
    }

    private static DateTime? ParseActivityDate(string value)
    {
        if (DateTime.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal | DateTimeStyles.AdjustToUniversal, out var parsed))
            return parsed;

        if (DateTime.TryParse(value, CultureInfo.CurrentCulture, DateTimeStyles.AssumeLocal, out parsed))
            return parsed;

        return null;
    }

    private async Task RunClockLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromMilliseconds(ClockRenderIntervalMilliseconds));

        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                var renderSignature = BuildClockRenderSignature();
                if (string.Equals(renderSignature, _lastClockRenderSignature, StringComparison.Ordinal))
                    continue;

                _lastClockRenderSignature = renderSignature;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            Logger.LogInformation("TvStage clock loop stopped. BroadcastMode={BroadcastMode}", IsBroadcastMode);
        }
    }

    private void SyncAudioDebugFlag()
    {
        try
        {
            var uri = new Uri(Nav.Uri, UriKind.Absolute);
            var query = uri.Query;
            if (string.IsNullOrWhiteSpace(query))
            {
                _audioDebugEnabled = false;
                return;
            }

            foreach (var segment in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
            {
                var parts = segment.Split('=', 2, StringSplitOptions.TrimEntries);
                if (!string.Equals(parts[0], "audioDebug", StringComparison.OrdinalIgnoreCase))
                    continue;

                var value = parts.Length > 1 ? WebUtility.UrlDecode(parts[1]) : string.Empty;
                _audioDebugEnabled = string.Equals(value, "1", StringComparison.OrdinalIgnoreCase)
                    || string.Equals(value, "true", StringComparison.OrdinalIgnoreCase);
                return;
            }

            _audioDebugEnabled = false;
        }
        catch
        {
            _audioDebugEnabled = false;
        }
    }

    private async Task EnsureAudioDebugInteropAsync(bool force = false)
    {
        if (_tvModule is null)
            return;

        var cultureChanged = !string.Equals(_lastAppliedAudioDebugCulture, Culture, StringComparison.OrdinalIgnoreCase);
        var enabledChanged = _lastAppliedAudioDebugEnabled != _audioDebugEnabled;
        if (!force && !cultureChanged && !enabledChanged)
            return;

        await _tvModule.InvokeVoidAsync("setTvAudioDebugEnabled", _audioDebugEnabled, new
        {
            culture = Culture,
            backgroundVolume = (double)ResolveCrowdAudioVolume()
        });

        _lastAppliedAudioDebugEnabled = _audioDebugEnabled;
        _lastAppliedAudioDebugCulture = Culture;
    }

    private async Task RunMetricSnapshotLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(2));

        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                var shouldRender = false;
                var matchId = Match?.MatchId ?? HotMatch?.MatchId ?? 0;
                if (matchId <= 0)
                {
                    shouldRender =
                        _metricSnapshotMatchId != 0
                        || _metricSnapshotLastId != 0
                        || _metricSnapshots.Count != 0
                        || _arenaSentimentA is not null
                        || _arenaSentimentB is not null
                        || _arenaSentimentLoading
                        || _lastArenaSentimentFetchUtc != DateTime.MinValue;

                    _metricSnapshotMatchId = 0;
                    _metricSnapshotLastId = 0;
                    _metricSnapshots = [];
                    _arenaSentimentA = null;
                    _arenaSentimentB = null;
                    _arenaSentimentLoading = false;
                    _lastArenaSentimentFetchUtc = DateTime.MinValue;

                    if (shouldRender)
                    {
                        try
                        {
                            await InvokeAsync(StateHasChanged);
                        }
                        catch
                        {
                        }
                    }

                    continue;
                }

                if (_metricSnapshotMatchId != matchId)
                {
                    shouldRender =
                        _metricSnapshotMatchId != 0
                        || _metricSnapshots.Count != 0
                        || _arenaSentimentA is not null
                        || _arenaSentimentB is not null
                        || _lastArenaSentimentFetchUtc != DateTime.MinValue;

                    _metricSnapshotMatchId = matchId;
                    _metricSnapshotLastId = 0;
                    _metricSnapshots = [];
                    _arenaSentimentA = null;
                    _arenaSentimentB = null;
                    _lastArenaSentimentFetchUtc = DateTime.MinValue;
                }

                List<MatchMetricSnapshotDto> snapshots;
                try
                {
                    snapshots = await Api.GetMatchMetricSnapshotsAsync(matchId, 160, ct) ?? [];
                }
                catch (OperationCanceledException)
                {
                    return;
                }
                catch (Exception ex)
                {
                    await LogAsync("TV_SNAPSHOTS", "error", ex.Message);
                    continue;
                }

                var latestId = snapshots.Count == 0 ? 0 : snapshots.Max(x => x.MatchMetricSnapshotId);
                if (latestId != _metricSnapshotLastId || _metricSnapshots.Count == 0)
                {
                    _metricSnapshotLastId = latestId;
                    _metricSnapshots = snapshots
                        .OrderByDescending(x => x.CapturedAtUtc)
                        .Take(160)
                        .ToList();
                    shouldRender = true;
                }

                var shouldRefreshSentiment =
                    _arenaSentimentA is null
                    || _arenaSentimentB is null
                    || DateTime.UtcNow - _lastArenaSentimentFetchUtc >= TimeSpan.FromSeconds(12);

                if (shouldRefreshSentiment)
                {
                    try
                    {
                        var shouldShowArenaSentimentLoading = _arenaSentimentA is null && _arenaSentimentB is null;
                        if (_arenaSentimentLoading != shouldShowArenaSentimentLoading)
                        {
                            _arenaSentimentLoading = shouldShowArenaSentimentLoading;
                            shouldRender = true;
                        }

                        var previousSentimentA = _arenaSentimentA;
                        var previousSentimentB = _arenaSentimentB;
                        var sentiment = await Api.GetMatchArenaSentimentAsync(matchId, ct);
                        _arenaSentimentA = sentiment?.TeamA;
                        _arenaSentimentB = sentiment?.TeamB;
                        _lastArenaSentimentFetchUtc = DateTime.UtcNow;

                        if (!AreArenaSentimentValuesEqual(previousSentimentA, _arenaSentimentA)
                            || !AreArenaSentimentValuesEqual(previousSentimentB, _arenaSentimentB))
                        {
                            shouldRender = true;
                        }
                    }
                    catch (OperationCanceledException)
                    {
                        return;
                    }
                    catch (Exception ex)
                    {
                        await LogAsync("TV_SENTIMENT", "error", ex.Message);
                    }
                    finally
                    {
                        if (_arenaSentimentLoading)
                        {
                            _arenaSentimentLoading = false;
                            shouldRender = true;
                        }
                    }
                }







                var nowTick = System.Environment.TickCount64;



                if (nowTick - _metricSnapshotLastLogTick >= 4000)
                {
                    _metricSnapshotLastLogTick = nowTick;
                    Console.WriteLine($"[TV_SNAPSHOTS] match={matchId} count={_metricSnapshots.Count} latestId={_metricSnapshotLastId}");
                }

                try
                {
                    await InvokeAsync(SyncTelemetryChartsAsync);
                }
                catch
                {
                }

                if (shouldRender)
                {
                    try
                    {
                        await InvokeAsync(StateHasChanged);
                    }
                    catch
                    {
                    }
                }
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void ProcessBroadcastState()
    {
        var current = CaptureSnapshot();
        if (current is null)
        {
            CancelPirateOverlayTimer();
            _showPirateOverlay = false;
            _pirateOverlayReason = string.Empty;
            _currentPirateOpeningVideo = null;
            _currentBroadcastVideoAsset = null;
            _currentBroadcastTransition = "glitch";
            _previousSnapshot = null;
            _lastAiNarrationMatchId = null;
            _currentAiNarration = string.Empty;
            _commentaryHistory = [];
            _arenaCommentaryFeed.Clear();
            _arenaCommentaryArchive.Clear();
            _arenaNarrativeCooldownsUtc.Clear();
            _arenaNarrativeLastTextByType.Clear();
            _lastArenaNarrativeSignature = string.Empty;
            _lastArenaNarrativeOwner = string.Empty;
            _lastArenaNarrativeAtUtc = DateTime.MinValue;
            _narrationBusyUntilUtc = DateTime.MinValue;
            _broadcastCriticalEventUntilUtc = DateTime.MinValue;
            _arenaAttackSequenceCount = 0;
            _didNarrativeOpening = false;
            _recentScoreEvents = [];
            _allScoreEvents = [];
            ResetBroadcastPromoState();
            return;
        }

        if (_lastAiNarrationMatchId != current.MatchId)
        {
            var hadPreviousMatch = _lastAiNarrationMatchId.HasValue;
            if (IsBroadcastMode && hadPreviousMatch)
            {
                _broadcastNoticeUntilUtc = DateTime.UtcNow.AddSeconds(4);
                _ = TriggerBroadcastFlipAsync();
                _ = TryShowPirateOverlayForMatchChangeAsync(current.MatchId);
            }

            _lastAiNarrationMatchId = current.MatchId;
            _lastAiNarrationRequestSignature = string.Empty;
            _currentAiNarration = string.Empty;
            _commentaryHistory = [];
            _arenaCommentaryFeed.Clear();
            _arenaCommentaryArchive.Clear();
            _arenaNarrativeCooldownsUtc.Clear();
            _arenaNarrativeLastTextByType.Clear();
            _lastArenaNarrativeSignature = string.Empty;
            _lastArenaNarrativeOwner = string.Empty;
            _lastArenaNarrativeAtUtc = DateTime.MinValue;
            _narrationBusyUntilUtc = DateTime.MinValue;
            _broadcastCriticalEventUntilUtc = DateTime.MinValue;
            _arenaAttackSequenceCount = 0;
            _didNarrativeOpening = false;
            _recentScoreEvents = [];
            _allScoreEvents = [];
            _lastScoreEventMatchId = current.MatchId;
            _lastSeenScoreEventId = null;
            _lastTriggeredGoalEventId = null;
            _lastGoalTriggerSignature = string.Empty;
            _lastGoalAudioSignature = string.Empty;
            _lastGoalAudioAtUtc = DateTime.MinValue;
            _lastGoalAudioPlaybackKind = string.Empty;
            _proceduralGoalAudioSrc = null;
            _autoReplayRemainingPlays = 0;
            _autoReplaySignature = string.Empty;
            _nextAutoReplayAtUtc = DateTime.MinValue;
            _lastAutoReplaySide = string.Empty;
            _didKickoff = false;
            _didMatchStart = false;
            _didHalftime = false;
            _didMatchEnding = false;
            _didVictoryMoment = false;
            _broadcastCinematicSuppressUntilUtc = DateTime.MinValue;
            _broadcastCinematicWarmupUntilUtc = DateTime.MinValue;
            _nextRandomBroadcastInterruptionAtUtc = DateTime.UtcNow.AddMinutes(Random.Shared.Next(3, 7));
            _pendingAutoReplayQueue.Clear();
            _armedAutoReplaySignatures.Clear();
            if (IsBroadcastMode && hadPreviousMatch)
                ScheduleBroadcastPromo(current.MatchId);
            else
                ResetBroadcastPromoState(current.MatchId);

            // Treat this as a fresh match: don't compare scores against the previous match snapshot,
            // otherwise we'll fire a "goal" (and goal audio) just because the match switched.
            _previousSnapshot = current;
            return;
        }

        if (_previousSnapshot is null)
        {
            _ = TriggerEventAsync(CreateEvent("hotMatchDetected"));
            _ = QueueNarrationAsync(CreateNarrationEvent("hotMatchDetected", current));
            _ = MaybeRefreshAiNarrationAsync("initial");
            _ = MaybeEmitArenaNarrativeAsync(current, CurrentFieldState, NarrativeEventKind.MatchOpening, "match bootstrap");
            _previousSnapshot = current;
            return;
        }

        var hasScoreChange = current.LeftScore != _previousSnapshot.LeftScore || current.RightScore != _previousSnapshot.RightScore;
        var scoreLeaderChanged = current.LeaderSymbol != _previousSnapshot.LeaderSymbol && !string.IsNullOrWhiteSpace(_previousSnapshot.LeaderSymbol);
        var hotScoreSpike = current.HotScore >= _previousSnapshot.HotScore + 8;
        var reversalDetected = current.HasRecentReversal && !_previousSnapshot.HasRecentReversal;
        var fearSpike = current.HasFearSignal && !_previousSnapshot.HasFearSignal;
        var finalMoments = current.RemainingSeconds <= 300 && _previousSnapshot.RemainingSeconds > 300;

        if (hasScoreChange)
        {
            _ = PulseScoreAsync(current.LeftScore > _previousSnapshot.LeftScore, current.RightScore > _previousSnapshot.RightScore, hotScoreSpike);
            _ = TriggerEventAsync(CreateGoalEvent(current));
            _ = QueueNarrationAsync(CreateGoalNarration(current));
            _ = MaybeRefreshAiNarrationAsync("goal");
            MarkGoalTrigger(current);
            ArmAutoReplay(current, _previousSnapshot);
            _ = TryPlayGoalAudioAsync(current);
        }
        else if (scoreLeaderChanged)
        {
            _ = TriggerEventAsync(CreateLeaderEvent(current));
            _ = QueueNarrationAsync(CreateLeaderNarration(current));
            _ = MaybeRefreshAiNarrationAsync("leader-change");
        }
        else if (reversalDetected)
        {
            _ = TriggerEventAsync(CreateEvent("momentumReversal"));
            _ = QueueNarrationAsync(CreateNarrationEvent("momentumReversal", current));
            _ = MaybeRefreshAiNarrationAsync("momentum-shift");
        }
        else if (fearSpike)
        {
            _ = TriggerEventAsync(CreateEvent("fearSurge"));
            _ = QueueNarrationAsync(CreateNarrationEvent("fearSurge", current));
            _ = MaybeRefreshAiNarrationAsync("fear-spike");
            _ = TryShowPirateIntroAsync("market-crash");
        }
        else if (hotScoreSpike)
        {
            _ = PulseScoreAsync(false, false, true);
            _ = TriggerEventAsync(CreateEvent("hotScoreSpike"));
            _ = QueueNarrationAsync(CreateNarrationEvent("hotScoreSpike", current));
            _ = MaybeRefreshAiNarrationAsync("massive-breakout");
            _ = TryShowPirateIntroAsync("volatility-spike");
        }
        else if (finalMoments)
        {
            _ = TriggerEventAsync(CreateEvent("finalMoments"));
            _ = QueueNarrationAsync(CreateNarrationEvent("finalMoments", current));
            _ = MaybeRefreshAiNarrationAsync("final-minutes");
            _ = TryShowPirateIntroAsync("final-minutes");
        }

        _ = MaybeEmitArenaNarrativeAsync(current, CurrentFieldState, null, hasScoreChange
            ? "score-change-suppressed"
            : scoreLeaderChanged
                ? "leader-change-suppressed"
                : reversalDetected
                    ? "reversal-suppressed"
                    : fearSpike
                        ? "fear-surge-suppressed"
                        : hotScoreSpike
                            ? "hot-score-suppressed"
                            : finalMoments
                                ? "final-moments-suppressed"
                                : "state-poll");

        _previousSnapshot = current;
    }

    private async Task InitializeTvAudioManagerAsync()
    {
        if (_tvModule is null)
            return;

        try
        {
            await _tvModule.InvokeVoidAsync("initTvAudioManager", (double)ResolveCrowdAudioVolume(), _isCrowdAudioMuted);
            await LogAsync("TV_AUDIO", "manager-ready", new
            {
                volume = ResolveCrowdAudioVolume(),
                muted = _isCrowdAudioMuted
            });
        }
        catch (JSException)
        {
            try
            {
                await JS.InvokeVoidAsync("initTvAudioManager", (double)ResolveCrowdAudioVolume(), _isCrowdAudioMuted);
                await LogAsync("TV_AUDIO", "manager-ready-fallback", new
                {
                    volume = ResolveCrowdAudioVolume(),
                    muted = _isCrowdAudioMuted
                });
            }
            catch (ObjectDisposedException)
            {
            }
        }
        catch (ObjectDisposedException)
        {
        }
    }

    private async Task RunBroadcastAutomationLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                if (_isDisposed)
                    return;

                var current = CaptureSnapshot();
                if (current is null)
                    continue;

                var fieldState = CurrentFieldState;
                await AdvanceBroadcastFocusAsync(current, fieldState);
                await MaybeTriggerBroadcastPromoAsync(current);
                await EvaluateBroadcastCinematicTriggersAsync(current);

                if (Environment.IsDevelopment())
                {
                    await LogAsync("TV_DIAGNOSTICS", "heartbeat", new
                    {
                        current.MatchId,
                        current.LeftScore,
                        current.RightScore,
                        current.HotScore,
                        focus = BroadcastFocusKey,
                        progress = BroadcastFocusProgress,
                        focusUntil = _broadcastFocusUntilUtc == DateTime.MinValue ? null : _broadcastFocusUntilUtc.ToString("O", CultureInfo.InvariantCulture)
                    });
                }
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task AdvanceBroadcastFocusAsync(BroadcastSnapshot current, TvFieldStateDto? fieldState)
    {
        if (_isDisposed)
            return;

        if (DateTime.UtcNow < _broadcastFocusUntilUtc)
            return;

        var next = ResolveBroadcastFocusState(current, fieldState);
        if (string.Equals(next.Key, "replay", StringComparison.OrdinalIgnoreCase))
        {
            if (await TryPlayAutoReplayAsync(current, next))
            {
                _lastBroadcastFocusChangeUtc = DateTime.UtcNow;
            }

            return;
        }

        if (string.Equals(next.Key, _broadcastFocusKey, StringComparison.OrdinalIgnoreCase)
            && DateTime.UtcNow - _lastBroadcastFocusChangeUtc < TimeSpan.FromSeconds(Math.Max(2, next.DurationMs / 1000)))
        {
            return;
        }

        await SetBroadcastFocusAsync(next.Key, next.Label, next.Color, next.DurationMs);
        _lastBroadcastFocusChangeUtc = DateTime.UtcNow;
    }

    private async Task EvaluateBroadcastCinematicTriggersAsync(BroadcastSnapshot current)
    {
        if (!IsBroadcastMode || _showPirateOverlay)
            return;

        if (DateTime.UtcNow < _broadcastCinematicWarmupUntilUtc)
            return;

        if (DateTime.UtcNow < _broadcastCinematicSuppressUntilUtc)
            return;

        if (!_didMatchStart)
        {
            _didMatchStart = true;
            await TryShowPirateIntroAsync("match-start");
            return;
        }

        if (!_didKickoff && IsKickoffWindow(current))
        {
            _didKickoff = true;
            await TryShowPirateIntroAsync("kickoff");
            return;
        }

        if (!_didHalftime && IsHalftimeWindow(current))
        {
            _didHalftime = true;
            await TryShowPirateIntroAsync("halftime");
            return;
        }

        if (!_didMatchEnding && current.RemainingSeconds <= 300)
        {
            _didMatchEnding = true;
            await TryShowPirateIntroAsync("final-minutes");
            return;
        }

        if (!_didVictoryMoment && IsVictoryWindow(current))
        {
            _didVictoryMoment = true;
            await TryShowPirateIntroAsync("special-event");
            return;
        }

        if (IsBitcoinDominanceArena(current) && throttleBroadcastOverlay("bitcoin-dominance", TimeSpan.FromMinutes(6)))
        {
            await TryShowPirateIntroAsync("bitcoin-dominance");
            return;
        }

        if (IsMemeCoinArena(current) && throttleBroadcastOverlay("meme-coin-surge", TimeSpan.FromMinutes(5)))
        {
            await TryShowPirateIntroAsync("meme-coin-surge");
            return;
        }

        if (_nextRandomBroadcastInterruptionAtUtc != DateTime.MinValue && DateTime.UtcNow >= _nextRandomBroadcastInterruptionAtUtc)
        {
            _nextRandomBroadcastInterruptionAtUtc = DateTime.UtcNow.AddMinutes(Random.Shared.Next(3, 7));
            await TryShowPirateIntroAsync("random-interruption");
        }
    }

    private bool throttleBroadcastOverlay(string key, TimeSpan cooldown)
    {
        var now = DateTime.UtcNow;
        if (_broadcastCooldownUntilUtc.TryGetValue(key, out var untilUtc) && untilUtc > now)
            return false;

        _broadcastCooldownUntilUtc[key] = now.Add(cooldown);
        return true;
    }

    private void ScheduleBroadcastPromo(int matchId)
    {
        _scheduledBroadcastPromoMatchId = matchId;
        _scheduledBroadcastPromoAtUtc = DateTime.UtcNow.Add(BroadcastPromoDelay);
        _lastBroadcastPromoMatchId = null;
        _ = LogAsync("TV_PROMO", "scheduled", new
        {
            matchId,
            triggerAtUtc = _scheduledBroadcastPromoAtUtc.ToString("O", CultureInfo.InvariantCulture)
        });
    }

    private void ResetBroadcastPromoState(int? currentMatchId = null)
    {
        _scheduledBroadcastPromoAtUtc = DateTime.MaxValue;
        _scheduledBroadcastPromoMatchId = null;
        _lastBroadcastPromoMatchId = currentMatchId;
    }

    private static bool AreArenaSentimentValuesEqual(ArenaSentimentDto? left, ArenaSentimentDto? right)
    {
        if (ReferenceEquals(left, right))
            return true;

        if (left is null || right is null)
            return false;

        return left.Symbol == right.Symbol
            && left.Score == right.Score
            && left.Classification == right.Classification
            && left.PriceMomentumScore == right.PriceMomentumScore
            && left.VolumeScore == right.VolumeScore
            && left.OrderBookScore == right.OrderBookScore
            && left.FundingScore == right.FundingScore
            && left.LongShortScore == right.LongShortScore
            && left.VolatilityScore == right.VolatilityScore
            && left.CalculatedAt == right.CalculatedAt
            && left.HasSufficientData == right.HasSufficientData
            && left.DataCoverage == right.DataCoverage
            && left.Note == right.Note;
    }

    private async Task ShowPirateIntroAsync(string reason)
    {
        if (_isDisposed || !IsBroadcastMode || !HasLiveMatch)
            return;

        if (!string.Equals(reason, "match-change", StringComparison.Ordinal))
            return;

        if (string.Equals(reason, "initial", StringComparison.Ordinal))
        {
            if (_hasShownInitialPirateIntro)
                return;

            _hasShownInitialPirateIntro = true;
        }

        CancelPirateOverlayTimer();
        _pirateOverlayCts = new CancellationTokenSource();
        var ct = _pirateOverlayCts.Token;
        var delay = string.Equals(reason, "match-change", StringComparison.Ordinal)
            ? TimeSpan.FromSeconds(3.5)
            : TimeSpan.FromMilliseconds(650);

        try
        {
            if (delay > TimeSpan.Zero)
                await Task.Delay(delay, ct);

            if (ct.IsCancellationRequested || _isDisposed)
                return;

            var selectedVideo = SelectBroadcastCinematicVideo(reason);
            _currentBroadcastVideoAsset = selectedVideo;
            _currentPirateOpeningVideo = selectedVideo?.Src;
            _currentBroadcastTransition = selectedVideo?.Transition ?? ResolveFallbackBroadcastTransition(reason);
            var visibleDuration = ResolvePirateOverlayVisibleDuration(reason, selectedVideo);
            _pirateOverlayReason = reason;
            _pirateOverlayMessage = GetRandomPirateMessage(reason, selectedVideo);
            _showPirateOverlay = true;
            _broadcastCinematicSuppressUntilUtc = DateTime.UtcNow.Add(visibleDuration).Add(TimeSpan.FromSeconds(2));
            if (string.Equals(reason, "initial", StringComparison.Ordinal)
                || string.Equals(reason, "match-start", StringComparison.Ordinal)
                || string.Equals(reason, "kickoff", StringComparison.Ordinal))
            {
                _broadcastCinematicWarmupUntilUtc = DateTime.UtcNow.AddSeconds(45);
                _nextRandomBroadcastInterruptionAtUtc = _broadcastCinematicWarmupUntilUtc.AddMinutes(Random.Shared.Next(3, 7));
                _didMatchStart = true;
                _didKickoff = true;
            }
            if (selectedVideo is not null)
            {
                _lastBroadcastVideoId = selectedVideo.Id;
                _broadcastVideoCooldownsUtc[selectedVideo.Id] = DateTime.UtcNow.Add(selectedVideo.Cooldown);
            }

            Logger.LogInformation(
                "TvStage broadcast cinematic shown. Reason={Reason} MatchId={MatchId} Video={Video} Category={Category} Transition={Transition}",
                reason,
                Match?.MatchId ?? HotMatch?.MatchId ?? 0,
                _currentPirateOpeningVideo ?? "fallback-image",
                selectedVideo?.Category ?? "fallback",
                _currentBroadcastTransition);

            if (Environment.IsDevelopment() && _tvModule is not null)
            {
                await LogAsync("TV_VIDEO", "selected", new
                {
                    trigger = reason,
                    videoId = selectedVideo?.Id,
                    category = selectedVideo?.Category,
                    src = selectedVideo?.Src,
                    transition = _currentBroadcastTransition,
                    tags = selectedVideo?.Tags
                });
            }

            await InvokeAsync(StateHasChanged);
            await Task.Delay(visibleDuration, ct);
        }
        catch (OperationCanceledException)
        {
            return;
        }

        HidePirateIntro();

        if (_pirateOverlayCts is not null && _pirateOverlayCts.Token == ct)
            CancelPirateOverlayTimer();
    }

    private async Task TryShowPirateOverlayForMatchChangeAsync(int currentMatchId)
    {
        if (_isDisposed || !IsBroadcastMode || currentMatchId <= 0)
            return;

        if (_lastPirateOverlayMatchId == currentMatchId)
        {
            Logger.LogInformation("TvStage pirate overlay skipped for repeated match. MatchId={MatchId}", currentMatchId);
            return;
        }

        _lastPirateOverlayMatchId = currentMatchId;
        await ShowPirateIntroAsync("match-change");
    }

    private async Task TryShowPirateIntroAsync(string reason)
    {
        if (_showPirateOverlay || _pirateOverlayCts is not null)
            return;

        await ShowPirateIntroAsync(reason);
    }

    private void HidePirateIntro()
    {
        if (_isDisposed)
            return;

        _showPirateOverlay = false;
        _pirateOverlayReason = string.Empty;
        _currentPirateOpeningVideo = null;
        _currentBroadcastVideoAsset = null;
        _currentBroadcastTransition = "glitch";
        _ = InvokeAsync(StateHasChanged);
    }

    private static TimeSpan ResolvePirateOverlayVisibleDuration(string reason, BroadcastCinematicVideoAsset? asset)
    {
        var hasVideo = !string.IsNullOrWhiteSpace(asset?.Src);
        if (hasVideo)
        {
            var preferred = asset?.PreferredDuration ?? TimeSpan.FromSeconds(9.2);
            return string.Equals(reason, "match-change", StringComparison.Ordinal)
                ? preferred - TimeSpan.FromMilliseconds(250)
                : preferred;
        }

        return string.Equals(reason, "match-change", StringComparison.Ordinal)
            ? TimeSpan.FromSeconds(5.2)
            : TimeSpan.FromSeconds(8.4);
    }

    private void EnsurePirateOpeningVideosLoaded()
    {
        if (_broadcastCinematicVideos.Count > 0)
            return;

        try
        {
            foreach (var root in EnumerateBroadcastVideoRoots())
            {
                if (!Directory.Exists(root.PhysicalPath))
                    continue;

                foreach (var filePath in Directory.EnumerateFiles(root.PhysicalPath, "*.*", SearchOption.AllDirectories))
                {
                    var asset = BuildBroadcastCinematicVideoAsset(filePath, root.PhysicalPath, root.WebPathPrefix, root.DefaultCategory);
                    if (asset is not null)
                        _broadcastCinematicVideos.Add(asset);
                }
            }

            Logger.LogInformation(
                "TvStage broadcast cinematic videos loaded. Count={VideoCount}",
                _broadcastCinematicVideos.Count);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "TvStage failed to load broadcast cinematic videos.");
        }
    }

