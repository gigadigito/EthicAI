    private string ResolveBroadcastDataStatusMessage()
    {
        var snapshotReason = Snapshot?.StaleReason;
        if (string.Equals(snapshotReason, "worker-heartbeat-stale", StringComparison.OrdinalIgnoreCase))
            return T("broadcast.dataStatusWorkerHeartbeat");

        if (string.Equals(snapshotReason, "worker-degraded", StringComparison.OrdinalIgnoreCase))
            return T("broadcast.dataStatusWorkerDegraded");

        if (string.Equals(snapshotReason, "currency-snapshot-missing", StringComparison.OrdinalIgnoreCase))
            return T("broadcast.dataStatusCurrencyMissing");

        if (string.Equals(snapshotReason, "currency-snapshot-stale", StringComparison.OrdinalIgnoreCase))
            return T("broadcast.dataStatusCurrencyStale");

        if (Stats?.IsStale == true)
            return T("broadcast.dataStatusStatsStale");

        return T("broadcast.dataStatusFallback");
    }

