    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isDisposed)
            return;

        if (!firstRender && _tvModule is not null)
        {
            try
            {
                await _tvModule.InvokeVoidAsync("setTvMediaCulture", Culture);
                await EnsureAudioDebugInteropAsync();
            }
            catch (JSException)
            {
            }
        }

        if (firstRender)
        {
            _tvModule = await JS.InvokeAsync<IJSObjectReference>("import", "/js/tvMode.js?v=20260604-audio-debug-1");
            await _tvModule.InvokeVoidAsync("setTvMediaCulture", Culture);
            await EnsureAudioDebugInteropAsync(force: true);
            _tvCameraModule = await JS.InvokeAsync<IJSObjectReference>("import", "/js/tvCinematicCamera.js?v=20260522-2");
            _tvEventFeedModule = await JS.InvokeAsync<IJSObjectReference>("import", "/js/tvEventFeed.mjs?v=20260603-goal-feed-1");
            await LogAsync("TV_MOTION", "motion system ready");
            await EnsureReplayEngineAsync();
            await InitializeTvAudioManagerAsync();
            if (_tickerItems.Count > 0)
                await LogAsync("TV_TICKER", "updated", _tickerItems);

            _clockCts = new CancellationTokenSource();
            _clockLoopTask = RunClockLoopAsync(_clockCts.Token);
            Logger.LogInformation("TvStage clock loop started. IntervalMs={IntervalMs} BroadcastMode={BroadcastMode}", ClockRenderIntervalMilliseconds, IsBroadcastMode);

            _broadcastAutomationCts = new CancellationTokenSource();
            _broadcastAutomationLoopTask = RunBroadcastAutomationLoopAsync(_broadcastAutomationCts.Token);

            _metricSnapshotCts = new CancellationTokenSource();
            _metricSnapshotLoopTask = RunMetricSnapshotLoopAsync(_metricSnapshotCts.Token);

            if (EnableNarrationDebugDemo && !_narrationDebugDemoStarted && _narrationOverlay is not null)
            {
                _narrationDebugDemoStarted = true;
                _ = RunNarrationDebugDemoAsync();
            }

            await LogClockDebugAsync();
        }

        if (_tvEventFeedModule is not null)
        {
            try
            {
                await _tvEventFeedModule.InvokeVoidAsync("initTvEventFeed", GoalEventFeedId);
                await _tvEventFeedModule.InvokeVoidAsync("refreshTvEventFeed", GoalEventFeedId);
            }
            catch
            {
            }
        }

        if (EnableTelemetryCube && _tvModule is not null)
        {
            await EnsureTelemetryCubeAsync();
            await SyncTelemetryChartsAsync();
        }

        var fieldState = CurrentFieldState;

        if (UseFootballFieldLayout && fieldState is not null && _tvModule is not null)
        {
            var fieldInteropSignature = BuildFieldInteropSignature(fieldState);
            try
            {
                if (!string.Equals(fieldInteropSignature, _lastFieldInteropSignature, StringComparison.Ordinal))
                {
                    _lastFieldInteropSignature = fieldInteropSignature;
                    await _tvModule.InvokeVoidAsync("initFieldSway", "tv-crypto-field", BuildFieldMovementOptions());
                }
            }
            catch
            {
            }
        }

        if (UseFootballFieldLayout && fieldState is not null && _tvCameraModule is not null)
        {
            var cameraInteropSignature = BuildCameraInteropSignature();
            try
            {
                if (!string.Equals(cameraInteropSignature, _lastCameraInteropSignature, StringComparison.Ordinal))
                {
                    _lastCameraInteropSignature = cameraInteropSignature;
                    await _tvCameraModule.InvokeVoidAsync("initTvCamera", "tv-crypto-field", new
                    {
                        minZoom = 1d,
                        maxZoom = 1.72d,
                        overviewZoom = 1.04d,
                        ballZoom = 1.22d,
                        attackZoom = 1.34d,
                        goalZoom = 1.48d,
                        autoResetDelayMs = 0,
                        directorIntervalMs = 5600,
                        autoDirectorEnabled = true
                    });
                }
            }
            catch
            {
            }
        }

        if (!ShouldRenderCrowdAudio && _broadcastAudioInitialized)
            await StopBroadcastAudioAsync("no-active-ongoing-match");

        if (ShouldRenderCrowdAudio && !_broadcastAudioInitialized)
            await EnsureBroadcastAudioAsync();

        if (_pendingScoreEventProbe && !_isScoreEventProbeRunning)
        {
            _pendingScoreEventProbe = false;
            await DetectRecentScoreEventsAsync();
        }
    }

    private bool _telemetryCubeInitialized;
    private long _telemetryCubeLastSnapshotId;
    private int _telemetryCubeLastSnapshotCount;
    private long _telemetryCubeLastMissingLogTick;
    private long _telemetryCubeLastRawLogTick;
    private decimal? _telemetryCubeLastLeftLiveValue;
    private decimal? _telemetryCubeLastRightLiveValue;

    private async Task EnsureTelemetryCubeAsync()
    {
