    private static bool IsGoalLikeScoreEvent(MatchScoreEventDto scoreEvent)
        => ResolveMappedEventType(scoreEvent) switch
        {
            "goal" or "equalizer" or "underdog_goal" => true,
            _ => false
        };

    private static string ResolveMappedEventType(MatchScoreEventDto scoreEvent)
        => string.IsNullOrWhiteSpace(scoreEvent.MappedEventType)
            ? scoreEvent.EventType
            : scoreEvent.MappedEventType!;

    private static int ResolveProceduralPlaybackPriority(MatchScoreEventDto scoreEvent)
    {
        if (scoreEvent.ProceduralPlaybackPriority > 0)
            return scoreEvent.ProceduralPlaybackPriority;

        return ResolveMappedEventType(scoreEvent) switch
        {
            "goal" => 100,
            "underdog_goal" => 95,
            "equalizer" => 94,
            "comeback" => 92,
            "dominant_lead" => 90,
            "market_crash" => 88,
            "market_pump" => 76,
            "momentum_shift" => 72,
            "volatility_spike" => 80,
            "near_goal" => 58,
            _ => 60
        };
    }

    private static TimeSpan ResolveProceduralPlaybackCooldown(string mappedEventType)
        => mappedEventType switch
        {
            "goal" => TimeSpan.FromMilliseconds(6500),
            "underdog_goal" or "equalizer" or "comeback" => TimeSpan.FromMilliseconds(5400),
            "dominant_lead" or "market_crash" => TimeSpan.FromMilliseconds(4800),
            "market_pump" or "momentum_shift" or "volatility_spike" => TimeSpan.FromMilliseconds(3600),
            "near_goal" => TimeSpan.FromMilliseconds(2400),
            _ => TimeSpan.FromMilliseconds(3200)
        };

    private bool TryEnterProceduralPlaybackWindow(
        string signature,
        string mappedEventType,
        int playbackPriority,
        TimeSpan cooldown,
        out string reason)
    {
        var now = DateTime.UtcNow;
        var perTypeKey = $"procedural-audio:{mappedEventType}";
        if (_broadcastCooldownUntilUtc.TryGetValue(perTypeKey, out var perTypeUntilUtc) && perTypeUntilUtc > now)
        {
            reason = $"per-type cooldown until {perTypeUntilUtc:O}";
            return false;
        }

        if (_broadcastLastSignatures.TryGetValue(perTypeKey, out var previousSignature)
            && string.Equals(previousSignature, signature, StringComparison.Ordinal))
        {
            reason = "duplicate playback signature";
            return false;
        }

        if (_lastProceduralPlaybackAtUtc != DateTime.MinValue
            && now - _lastProceduralPlaybackAtUtc < TimeSpan.FromMilliseconds(2100)
            && playbackPriority < _lastProceduralPlaybackPriority)
        {
            reason = $"global procedural cooldown after higher-priority audio {_lastProceduralPlaybackPriority}";
            return false;
        }

        _broadcastCooldownUntilUtc[perTypeKey] = now.Add(cooldown);
        _broadcastLastSignatures[perTypeKey] = signature;
        reason = string.Empty;
        return true;
    }

    private void MarkProceduralPlayback(long scoreEventId, int playbackPriority)
    {
        _lastProceduralPlaybackEventId = scoreEventId;
        _lastProceduralPlaybackAtUtc = DateTime.UtcNow;
        _lastProceduralPlaybackPriority = playbackPriority;
    }

    private async Task<bool> TryPlayProceduralArenaAudioAsync(
        BroadcastSnapshot current,
        MatchScoreEventDto scoreEvent,
        string mappedEventType,
        string audioUrl,
        int playbackPriority)
    {
        try
        {
            var payload = BuildProceduralAudioDebugPayload(
                current,
                scoreEvent,
                audioUrl,
                message: "Procedural arena event audio resolved for autoplay.");

            await LogAsync("TV_AUDIO", "procedural-playback-start", new
            {
                scoreEventId = scoreEvent.MatchScoreEventId,
                rawEventType = scoreEvent.RawEventType ?? scoreEvent.EventType,
                mappedEventType,
                normalizedSymbol = scoreEvent.NormalizedTeamSymbol,
                playbackPriority,
                audioUrl
            });

            if (_tvModule is not null)
                await _tvModule.InvokeVoidAsync("playProceduralAudioUrl", audioUrl, payload);
            else
                await JS.InvokeVoidAsync("playProceduralAudioUrl", audioUrl, payload);

            return true;
        }
        catch (Exception ex) when (ex is JSException or ObjectDisposedException)
        {
            await NotifyProceduralAudioDebugAsync("failed", BuildProceduralAudioDebugPayload(
                current,
                scoreEvent,
                audioUrl,
                message: "Procedural arena audio failed during autoplay.",
                error: ex.Message));
            await LogAsync("TV_AUDIO", "procedural-playback-failed", new
            {
                scoreEventId = scoreEvent.MatchScoreEventId,
                rawEventType = scoreEvent.RawEventType ?? scoreEvent.EventType,
                mappedEventType,
                normalizedSymbol = scoreEvent.NormalizedTeamSymbol,
                playbackPriority,
                audioUrl,
                message = ex.Message
            });
            return false;
        }
    }

    private async Task<bool> TryPlayLegacyArenaCueAsync(
        BroadcastSnapshot current,
        MatchScoreEventDto scoreEvent,
        string mappedEventType,
        string? proceduralAudioUrl,
        int playbackPriority)
    {
        var cueKey = ResolveLegacyArenaCueKey(mappedEventType);
        if (string.IsNullOrWhiteSpace(cueKey))
            return false;

        try
        {
            await NotifyProceduralAudioDebugAsync("fallback", BuildProceduralAudioDebugPayload(
                current,
                scoreEvent,
                proceduralAudioUrl,
                message: $"Procedural arena audio unavailable. Falling back to legacy cue '{cueKey}'."));

            if (_tvModule is not null)
            {
                await _tvModule.InvokeVoidAsync("playTvAudioCue", cueKey, new
                {
                    priority = playbackPriority,
                    cooldownMs = (int)ResolveProceduralPlaybackCooldown(mappedEventType).TotalMilliseconds,
                    volume = (double)ResolveCrowdAudioVolume(),
                    muted = _isCrowdAudioMuted
                });
            }
            else
            {
                await JS.InvokeVoidAsync("playTvAudioCue", cueKey, new
                {
                    priority = playbackPriority,
                    cooldownMs = (int)ResolveProceduralPlaybackCooldown(mappedEventType).TotalMilliseconds,
                    volume = (double)ResolveCrowdAudioVolume(),
                    muted = _isCrowdAudioMuted
                });
            }

            return true;
        }
        catch (Exception ex) when (ex is JSException or ObjectDisposedException)
        {
            await LogAsync("TV_AUDIO", "procedural-playback-failed", new
            {
                scoreEventId = scoreEvent.MatchScoreEventId,
                rawEventType = scoreEvent.RawEventType ?? scoreEvent.EventType,
                mappedEventType,
                normalizedSymbol = scoreEvent.NormalizedTeamSymbol,
                playbackPriority,
                legacyCueKey = cueKey,
                message = ex.Message
            });
            return false;
        }
    }

