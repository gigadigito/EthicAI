    private double ResolveRemainingMillisecondsSeed()
    {
        if (HotMatch?.RemainingSeconds is int explicitRemainingSeconds)
            return Math.Max(0, explicitRemainingSeconds) * 1000d;

        var parsed = ParseRemainingSeconds(DisplayRemainingTime());
        if (parsed > 0)
            return parsed * 1000d;

        return Math.Max(0, (Match?.RemainingMinutes ?? 0) * 60) * 1000d;
    }

    private TimeSpan? ResolvePreciseRemainingTime()
    {
        if (_clockAnchorRemainingMilliseconds <= 0d)
            return null;

        var elapsedMs = Math.Max(0d, (DateTime.UtcNow - _clockAnchorUtc).TotalMilliseconds);
        var remainingMs = Math.Max(0d, _clockAnchorRemainingMilliseconds - elapsedMs);
        return TimeSpan.FromMilliseconds(remainingMs);
    }

    private bool IsMatchFinishedForStage()
    {
        if (Match?.IsFinished == true)
            return true;

        if (string.Equals(Match?.Status, "Completed", StringComparison.OrdinalIgnoreCase))
            return true;

        if (Match?.EndTime is not null)
            return true;

        if (ResolvePreciseRemainingTime() is TimeSpan preciseRemaining)
            return preciseRemaining <= TimeSpan.Zero;

        var startUtc = ResolveMatchStartUtc();
        if (startUtc is not null)
            return DateTime.UtcNow >= startUtc.Value.AddMinutes(105);

        var fallbackRemainingSeconds = HotMatch?.RemainingSeconds ?? ParseRemainingSeconds(DisplayRemainingTime());
        var hasExplicitClockSignal =
            HotMatch?.RemainingSeconds.HasValue == true
            || !string.IsNullOrWhiteSpace(HotMatch?.RemainingTimeLabel)
            || (Match?.ElapsedMinutes ?? 0) > 0
            || (Match?.RemainingMinutes ?? 0) > 0;

        return (HotMatch?.HasMatch == true || Match is not null)
            && hasExplicitClockSignal
            && fallbackRemainingSeconds <= 0;
    }

    private TvClockState ResolveClockState()
    {
        if (IsMatchFinishedForStage())
            return new TvClockState(TvClockPhase.Final, 90 * 60);

        var startUtc = ResolveMatchStartUtc();
        if (startUtc is null)
            return BuildFallbackClockState();

        var elapsedSeconds = Math.Max(0, (int)Math.Floor((DateTime.UtcNow - startUtc.Value).TotalSeconds));
        const int firstHalfSeconds = 45 * 60;
        const int halfTimeEndSeconds = 60 * 60;
        const int secondHalfEndSeconds = 105 * 60;

        if (elapsedSeconds < firstHalfSeconds)
            return new TvClockState(TvClockPhase.FirstHalf, elapsedSeconds);

        if (elapsedSeconds < halfTimeEndSeconds)
            return new TvClockState(TvClockPhase.HalfTime, firstHalfSeconds);

        if (elapsedSeconds < secondHalfEndSeconds)
            return new TvClockState(TvClockPhase.SecondHalf, elapsedSeconds - (15 * 60));

        return new TvClockState(TvClockPhase.Final, 90 * 60);
    }

    private DateTime? ResolveMatchStartUtc()
        => HotMatch?.MatchStartTimeUtc ?? Match?.StartTime;

    private TvClockState BuildFallbackClockState()
    {
        var fallbackRemainingSeconds = HotMatch?.RemainingSeconds ?? ParseRemainingSeconds(DisplayRemainingTime());
        if (fallbackRemainingSeconds > 0)
        {
            var elapsed = Math.Max(0, (90 * 60) - fallbackRemainingSeconds);
            return elapsed < 45 * 60
                ? new TvClockState(TvClockPhase.FirstHalf, elapsed)
                : new TvClockState(TvClockPhase.SecondHalf, Math.Min(90 * 60, elapsed));
        }

        return new TvClockState(TvClockPhase.Final, 90 * 60);
    }

