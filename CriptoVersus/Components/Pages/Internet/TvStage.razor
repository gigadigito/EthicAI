    private async Task SyncProceduralAudioDebugSnapshotAsync(BroadcastSnapshot? current, MatchScoreEventDto? scoreEvent)
    {
        if (!_audioDebugEnabled || current is null || scoreEvent is null)
            return;

        if (_lastAudioDebugSnapshotEventId == scoreEvent.MatchScoreEventId)
            return;

        _lastAudioDebugSnapshotEventId = scoreEvent.MatchScoreEventId;
        var audioUrl = NormalizeProceduralGoalAudioUrl(scoreEvent.AudioUrl);
        if (!string.IsNullOrWhiteSpace(audioUrl))
        {
            await NotifyProceduralAudioDebugAsync("found", BuildProceduralAudioDebugPayload(
                current,
                scoreEvent,
                audioUrl,
                message: "Loaded recent score event with procedural audio."));
            return;
        }

        await NotifyProceduralAudioDebugAsync("missing", BuildProceduralAudioDebugPayload(
            current,
            scoreEvent,
            audioUrl,
            message: "Loaded recent score event without procedural audio URL."));
    }

    private async Task ObserveProceduralScoreEventsAsync(BroadcastSnapshot current, IEnumerable<MatchScoreEventDto> scoreEvents)
    {
        foreach (var scoreEvent in scoreEvents.OrderBy(x => x.MatchScoreEventId))
        {
            await LogAsync("TV_AUDIO", "procedural-event-normalized", new
            {
                scoreEventId = scoreEvent.MatchScoreEventId,
                rawEventType = scoreEvent.RawEventType ?? scoreEvent.EventType,
                mappedEventType = scoreEvent.MappedEventType ?? scoreEvent.EventType,
                teamSymbol = scoreEvent.TeamSymbol,
                normalizedSymbol = scoreEvent.NormalizedTeamSymbol,
                playbackPriority = scoreEvent.ProceduralPlaybackPriority
            });

            var proceduralAudioUrl = NormalizeProceduralGoalAudioUrl(scoreEvent.AudioUrl);
            if (!string.IsNullOrWhiteSpace(proceduralAudioUrl))
            {
                await NotifyProceduralAudioDebugAsync("found", BuildProceduralAudioDebugPayload(
                    current,
                    scoreEvent,
                    proceduralAudioUrl,
                    message: "Procedural audio asset already available for this score event."));
                await LogAsync("TV_AUDIO", "procedural-playback-found-existing", new
                {
                    scoreEventId = scoreEvent.MatchScoreEventId,
                    rawEventType = scoreEvent.RawEventType ?? scoreEvent.EventType,
                    mappedEventType = scoreEvent.MappedEventType ?? scoreEvent.EventType,
                    normalizedSymbol = scoreEvent.NormalizedTeamSymbol,
                    audioUrl = proceduralAudioUrl,
                    playbackPriority = scoreEvent.ProceduralPlaybackPriority
                });

                if (scoreEvent.AudioFallbackUsed)
                {
                    await NotifyProceduralAudioDebugAsync("fallback", BuildProceduralAudioDebugPayload(
                        current,
                        scoreEvent,
                        proceduralAudioUrl,
                        message: "Procedural asset resolved through a generic fallback variant."));
                }

                continue;
            }

            await NotifyProceduralAudioDebugAsync("queued", new
            {
                source = "tv-stage",
                eventType = scoreEvent.MappedEventType ?? scoreEvent.EventType,
                rawEventType = scoreEvent.RawEventType ?? scoreEvent.EventType,
                mappedEventType = scoreEvent.MappedEventType ?? scoreEvent.EventType,
                teamSymbol = scoreEvent.TeamSymbol,
                normalizedSymbol = scoreEvent.NormalizedTeamSymbol,
                language = scoreEvent.AudioResolvedLanguage ?? Culture,
                audioAssetId = scoreEvent.AudioAssetId,
                audioFallbackUsed = scoreEvent.AudioFallbackUsed,
                audioContextKey = scoreEvent.AudioContextKey,
                audioIntensity = scoreEvent.AudioIntensity,
                audioVoiceKey = scoreEvent.AudioVoiceKey,
                playbackPriority = scoreEvent.ProceduralPlaybackPriority,
                message = "Procedural audio asset missing; generation queue was requested for this score event."
            });
            await NotifyProceduralAudioDebugAsync("missing", BuildProceduralAudioDebugPayload(
                current,
                scoreEvent,
                null,
                message: "No procedural audio URL arrived for this score event."));
            await LogAsync("TV_AUDIO", "procedural-playback-queue-created", new
            {
                scoreEventId = scoreEvent.MatchScoreEventId,
                rawEventType = scoreEvent.RawEventType ?? scoreEvent.EventType,
                mappedEventType = scoreEvent.MappedEventType ?? scoreEvent.EventType,
                normalizedSymbol = scoreEvent.NormalizedTeamSymbol,
                playbackPriority = scoreEvent.ProceduralPlaybackPriority
            });
        }
    }

    private async Task TryPlayProceduralArenaEventAsync(BroadcastSnapshot current, IEnumerable<MatchScoreEventDto> scoreEvents)
    {
        var candidate = scoreEvents
            .Where(x => !IsGoalLikeScoreEvent(x))
            .OrderByDescending(ResolveProceduralPlaybackPriority)
            .ThenByDescending(x => x.MatchScoreEventId)
            .FirstOrDefault();

        if (candidate is null)
            return;

        var mappedEventType = ResolveMappedEventType(candidate);
        var playbackPriority = ResolveProceduralPlaybackPriority(candidate);
        var audioUrl = NormalizeProceduralGoalAudioUrl(candidate.AudioUrl);
        var cooldown = ResolveProceduralPlaybackCooldown(mappedEventType);
        var signature = $"{candidate.MatchScoreEventId}|{mappedEventType}|{candidate.NormalizedTeamSymbol ?? candidate.TeamSymbol}|{candidate.AudioAssetId}";

        if (_lastProceduralPlaybackEventId == candidate.MatchScoreEventId)
            return;

        if (!TryEnterProceduralPlaybackWindow(signature, mappedEventType, playbackPriority, cooldown, out var skipReason))
        {
            await NotifyProceduralAudioDebugAsync("skipped", BuildProceduralAudioDebugPayload(
                current,
                candidate,
                audioUrl,
                message: $"Cooldown active. {skipReason}"));
            await LogAsync("TV_AUDIO", "procedural-playback-skipped-cooldown", new
            {
                scoreEventId = candidate.MatchScoreEventId,
                rawEventType = candidate.RawEventType ?? candidate.EventType,
                mappedEventType,
                normalizedSymbol = candidate.NormalizedTeamSymbol,
                playbackPriority,
                reason = skipReason
            });
            return;
        }

        if (!string.IsNullOrWhiteSpace(audioUrl))
        {
            var played = await TryPlayProceduralArenaAudioAsync(current, candidate, mappedEventType, audioUrl, playbackPriority);
            if (played)
            {
                MarkProceduralPlayback(candidate.MatchScoreEventId, playbackPriority);
                return;
            }
        }

        if (await TryPlayLegacyArenaCueAsync(current, candidate, mappedEventType, audioUrl, playbackPriority))
        {
            MarkProceduralPlayback(candidate.MatchScoreEventId, playbackPriority);
            return;
        }

        await NotifyProceduralAudioDebugAsync("missing", BuildProceduralAudioDebugPayload(
            current,
            candidate,
            audioUrl,
            message: "Procedural and legacy arena audio were both unavailable, but the broadcast continues normally."));
    }

    private async Task EnsureBroadcastAudioAsync()
    {
        if (_broadcastAudioInitialized || _tvModule is null || !ShouldRenderCrowdAudio)
            return;

        try
        {
            var state = await _tvModule.InvokeAsync<TvAudioInteropState>("initBroadcastAudio", "tv-broadcast-crowd", (double)ResolveCrowdAudioVolume(), _isCrowdAudioMuted);
            ApplyAudioInteropState(state);
            _broadcastAudioInitialized = true;
            Logger.LogInformation(
                "TvStage broadcast crowd audio initialized. MatchId={MatchId} HasActiveOngoingMatch={HasActiveOngoingMatch} BroadcastMode={BroadcastMode}",
                Match?.MatchId ?? HotMatch?.MatchId ?? 0,
                HasActiveOngoingMatch,
                IsBroadcastMode);
        }
        catch (JSException)
        {
            // Fallback for stale browser caches or module resolution mismatches.
            try
            {
                var state = await JS.InvokeAsync<TvAudioInteropState>("initBroadcastAudio", "tv-broadcast-crowd", (double)ResolveCrowdAudioVolume(), _isCrowdAudioMuted);
                ApplyAudioInteropState(state);
                _broadcastAudioInitialized = true;
                Logger.LogInformation(
                    "TvStage broadcast crowd audio initialized via fallback. MatchId={MatchId} HasActiveOngoingMatch={HasActiveOngoingMatch} BroadcastMode={BroadcastMode}",
                    Match?.MatchId ?? HotMatch?.MatchId ?? 0,
                    HasActiveOngoingMatch,
                    IsBroadcastMode);
            }
            catch (ObjectDisposedException)
            {
            }
        }
        catch (ObjectDisposedException)
        {
        }
    }

    private async Task EnableBroadcastAudioAsync()
    {
        if (!ShouldRenderCrowdAudio)
            return;

        try
        {
            if (_tvModule is not null)
            {
                var state = await _tvModule.InvokeAsync<TvAudioInteropState>("unlockBroadcastAudio", "tv-broadcast-crowd", (double)ResolveCrowdAudioVolume(), _isCrowdAudioMuted);
                ApplyAudioInteropState(state);
                return;
            }

            var fallbackState = await JS.InvokeAsync<TvAudioInteropState>("unlockBroadcastAudio", "tv-broadcast-crowd", (double)ResolveCrowdAudioVolume(), _isCrowdAudioMuted);
            ApplyAudioInteropState(fallbackState);
        }
        catch (ObjectDisposedException)
        {
        }
    }

    private async Task StopBroadcastAudioAsync(string reason)
    {
        try
        {
            if (_tvModule is not null)
                await _tvModule.InvokeVoidAsync("destroyBroadcastAudio", "tv-broadcast-crowd");
            else
                await JS.InvokeVoidAsync("destroyBroadcastAudio", "tv-broadcast-crowd");
