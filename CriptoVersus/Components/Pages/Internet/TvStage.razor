    private string GetAccentColor(string? symbol)
    {
        var normalized = symbol?.Trim().ToUpperInvariant() ?? string.Empty;
        return normalized switch
        {
            "BTC" => "#f5b942",
            "ETH" => "#7f8df6",
            "SOL" => "#55f5bf",
            "BNB" => "#f2d56b",
            "XRP" => "#71d1ff",
            "ADA" => "#5dd8ff",
            "DOGE" => "#efc166",
            _ => HashAccent(normalized)
        };
    }

    private static string HashAccent(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return "#53c8ff";

        var seed = value.Sum(ch => ch);
        var hue = seed % 360;
        return $"hsl({hue} 78% 64%)";
    }

    private string ResolveLeaderSymbol()
    {
        if (DisplayLeftScore() == DisplayRightScore())
            return HotMatch?.HasRecentReversal == true
                ? ResolveMomentumLeader()
                : DisplayLeftSymbol();

        return DisplayLeftScore() > DisplayRightScore() ? DisplayLeftSymbol() : DisplayRightSymbol();
    }

    private string ResolveMomentumLeader()
    {
        var momentum = DisplayMomentum();
        if (momentum.Contains(DisplayLeftSymbol(), StringComparison.OrdinalIgnoreCase))
            return DisplayLeftSymbol();

        if (momentum.Contains(DisplayRightSymbol(), StringComparison.OrdinalIgnoreCase))
            return DisplayRightSymbol();

        return DisplayLeftSymbol();
    }

    private static string GetBaseSymbol(string? symbol)

    {

        if (string.IsNullOrWhiteSpace(symbol))

            return string.Empty;



        var upper = symbol.Trim().ToUpperInvariant();



        string[] quoteAssets =

        [

            "USDT",
    "USDC",
    "BUSD",
    "FDUSD",
    "BTC",
    "ETH"

        ];



        foreach (var quote in quoteAssets)

        {

            if (upper.EndsWith(quote, StringComparison.OrdinalIgnoreCase)

                && upper.Length > quote.Length)

            {

                return upper[..^quote.Length];

            }

        }



        return upper;

    }

