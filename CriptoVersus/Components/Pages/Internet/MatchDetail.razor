    private async Task OpenInvestmentAmountModalAsync(int teamId, string teamName)
    {
        _pendingBetTeamId = teamId;
        _pendingBetTeamName = teamName;
        _investmentAmount = 0.1m;
        _investmentAmountError = "";
        await LoadWalletGuardSnapshotAsync();
        _showInvestmentAmountModal = true;
    }

    private void CloseInvestmentAmountModal()
    {
        if (_isSendingBet)
            return;

        _showInvestmentAmountModal = false;
        _pendingBetTeamId = 0;
        _pendingBetTeamName = "";
        _investmentAmountError = "";
    }

    private void SetInvestmentAmount(decimal amount)
    {
        _investmentAmount = amount;
        _investmentAmountError = "";
    }

    private void UseMaxInvestmentAmount()
    {
        SetInvestmentAmount(WalletMaxSpendableAmount);
    }

    private static int GetClosestQuickInvestmentAmountIndex(decimal amount)
    {
        var closestIndex = 0;
        var closestDistance = decimal.MaxValue;

        for (var i = 0; i < QuickInvestmentAmounts.Length; i++)
        {
            var distance = Math.Abs(QuickInvestmentAmounts[i] - amount);
            if (distance >= closestDistance)
                continue;

            closestIndex = i;
            closestDistance = distance;
        }

        return closestIndex;
    }

    private async Task ConfirmInvestmentAmountAsync()
    {
        if (_match is null || _pendingBetTeamId <= 0 || string.IsNullOrWhiteSpace(_pendingBetTeamName))
        {
            _investmentAmountError = T("chooseACoinToInvestIn");
            return;
        }

        _investmentAmount = decimal.Round(_investmentAmount, 8, MidpointRounding.ToZero);

        if (_investmentAmount <= 0)
        {
            _investmentAmountError = T("enterAnAmountGreaterThanZero");
            return;
        }

        if (!_walletMaxSpendableSol.HasValue)
        {
            _investmentAmountError = _walletBalanceLoadError;
            return;
        }

        if (_investmentAmount > WalletMaxSpendableAmount)
        {
            _investmentAmountError = T("walletBalanceGuardInsufficientMessage", WalletMaxSpendableText);
            return;
        }

        var validation = await ValidateWalletBalanceBeforeSendAsync(_investmentAmount);
        if (!validation.ok)
        {
            _investmentAmountError = validation.message ?? T("walletBalanceGuardInsufficientMessage", WalletMaxSpendableText);
            await LoadWalletGuardSnapshotAsync();
            return;
        }

        _showInvestmentAmountModal = false;
        await SendBet(_match.MatchId, _pendingBetTeamId, _pendingBetTeamName, _investmentAmount);
    }

    private async Task LoadWalletGuardSnapshotAsync()
    {
        _walletBalanceLoading = true;
        _walletBalanceLoadError = "";
        await InvokeAsync(StateHasChanged);

        try
        {
            _walletBalanceModule ??= await JS.InvokeAsync<IJSObjectReference>(
                "import",
                "./js/solanaWalletBalance.js?v=20260513-wallet-guard");

            var result = await _walletBalanceModule.InvokeAsync<WalletBalanceGuardResult>(
                "getMaxSpendableSol",
                new
                {
                    rpcUrl = Config["CriptoVersusBlockchain:RpcUrl"],
                    locale = CurrentCulture == "en" ? "en-US" : "pt-BR",
                    flowName = "MATCH_DETAIL_MODAL"
                });

            _walletBalanceSol = result.balanceSol;
            _walletMaxSpendableSol = result.maxSpendableSol;
            _walletBalanceLoadError = result.ok || string.Equals(result.code, "INSUFFICIENT_BALANCE", StringComparison.OrdinalIgnoreCase)
