    private string GetBetPopupExceptionMessage(Exception ex)
    {
        if (ex.Message.Contains("Insufficient wallet balance", StringComparison.OrdinalIgnoreCase)
            || ex.Message.Contains("Saldo insuficiente na carteira", StringComparison.OrdinalIgnoreCase))
            return ex.Message;

        if (ex.ToString().Contains("ONCHAIN_MATCH_NOT_INITIALIZED", StringComparison.OrdinalIgnoreCase))
            return T("theMatchHasNotBeenCreatedOnChainOnDevnetYetPleaseTryAgainShortly");

        if (ex.ToString().Contains("TeamId invalido para posicao on-chain.", StringComparison.OrdinalIgnoreCase))
            return T("itWasNotPossibleToPrepareThisCoinSOnChainPositionRightNowPleaseTryAgainShortly");

        return T("itWasNotPossibleToCompleteTheInvestmentRightNowPleaseTryAgainShortly");
    }

    private PeriodicTimer? _timer;
    private CancellationTokenSource? _tickCts;

    private string _clockText = "00:00";
    private string _remainingText = "(90:00)";

    private static readonly TimeSpan MatchDuration = TimeSpan.FromMinutes(90);
    private static readonly TimeSpan LiveReloadInterval = TimeSpan.FromSeconds(5);

    private bool _hubWired;
    private CancellationTokenSource? _reloadCts;
    private int _reloadSeq;
    private int _clockGeneration;
    private DateTime _lastAutoReloadUtc = DateTime.MinValue;
    private string _lastMetricHistoryLogKey = string.Empty;
    private string _currentRouteKey = string.Empty;
    private string _loadedRouteKey = string.Empty;
    private string _loadingRouteKey = string.Empty;

    protected override void OnInitialized()
    {
        if (!_hubWired)
        {
            _hubWired = true;
            HubClient.DashboardChanged += OnDashboardChanged;
        }
    }

    private void OnDashboardChanged(string? _)
    {
        DebouncedReload();
    }

    private void DebouncedReload()
        => DebouncedReload(TimeSpan.FromMilliseconds(300));

    private void DebouncedReload(TimeSpan delay)
    {
        _reloadCts?.Cancel();
        _reloadCts?.Dispose();
        _reloadCts = new CancellationTokenSource();

        var localSeq = ++_reloadSeq;
        var ct = _reloadCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(delay, ct);

                if (localSeq != _reloadSeq) return;

                await ReloadMatchAsync(ct);
            }
            catch (OperationCanceledException) { }
        });
    }

    private async Task ReloadMatchAsync(CancellationToken ct)
    {
        if (_match is null)
            return;

        var previousMatch = _match;
        var previousStatus = previousMatch.Status;
        var previousStartTime = previousMatch.StartTime;
        var previousEndTime = previousMatch.EndTime;
        var previousBettingCloseTime = previousMatch.BettingCloseTime;
        var nowUtc = DateTime.UtcNow;

        Logger.LogInformation(
            "MATCH_RELOAD_START MatchId={MatchId} PreviousStatus={PreviousStatus} StartTime={StartTime:o} EndTime={EndTime:o} BettingCloseTime={BettingCloseTime:o} UtcNow={UtcNow:o} ThreadId={ThreadId}",
            previousMatch.MatchId,
            previousStatus,
            previousStartTime,
            previousEndTime,
            previousBettingCloseTime,
            nowUtc,
            Environment.CurrentManagedThreadId);

        try
        {
            var updated = await LoadRequestedMatchAsync(ct);

            if (updated is null)
            {
                Logger.LogInformation(
                    "MATCH_RELOAD_RESPONSE MatchId={MatchId} PreviousStatus={PreviousStatus} ReturnedStatus={ReturnedStatus} UtcNow={UtcNow:o} ThreadId={ThreadId}",
                    previousMatch.MatchId,
                    previousStatus,
                    "null",
                    DateTime.UtcNow,
                    Environment.CurrentManagedThreadId);
                return;
            }

            Logger.LogInformation(
                "MATCH_RELOAD_RESPONSE MatchId={MatchId} PreviousStatus={PreviousStatus} ReturnedStatus={ReturnedStatus} StartTime={StartTime:o} EndTime={EndTime:o} BettingCloseTime={BettingCloseTime:o} UtcNow={UtcNow:o} ThreadId={ThreadId}",
                previousMatch.MatchId,
                previousStatus,
                updated.Status,
                updated.StartTime,
                updated.EndTime,
                updated.BettingCloseTime,
                DateTime.UtcNow,
                Environment.CurrentManagedThreadId);

            if (updated.MatchId != previousMatch.MatchId)
            {
                Logger.LogInformation(
                    "MATCH_STATE_REPLACED MatchId={MatchId} PreviousStatus={PreviousStatus} CurrentStatus={CurrentStatus} StoredStatus={StoredStatus} UtcNow={UtcNow:o} ThreadId={ThreadId} Note={Note}",
                    previousMatch.MatchId,
                    previousStatus,
                    previousStatus,
                    updated.Status,
                    DateTime.UtcNow,
                    Environment.CurrentManagedThreadId,
                    "route_mismatch");
                return;
            }

            var statusChanged = !string.Equals(previousStatus, updated.Status, StringComparison.OrdinalIgnoreCase);
            var timingChanged = previousStartTime != updated.StartTime
                || previousEndTime != updated.EndTime
                || previousBettingCloseTime != updated.BettingCloseTime;

            _match = updated;
            _lastAppliedScoreVersion = updated.ScoreVersion;
            _title = $"{GetMatchTitleSymbol(_match.TeamA)} vs {GetMatchTitleSymbol(_match.TeamB)}";

            Logger.LogInformation(
                "MATCH_STATE_REPLACED MatchId={MatchId} PreviousStatus={PreviousStatus} CurrentStatus={CurrentStatus} StoredStatus={StoredStatus} StartTime={StartTime:o} EndTime={EndTime:o} BettingCloseTime={BettingCloseTime:o} UtcNow={UtcNow:o} ThreadId={ThreadId}",
                updated.MatchId,
                previousStatus,
                updated.Status,
                _match.Status,
                _match.StartTime,
                _match.EndTime,
                _match.BettingCloseTime,
                DateTime.UtcNow,
                Environment.CurrentManagedThreadId);

            if (statusChanged)
            {
                Logger.LogInformation(
                    "MATCH_STATUS_TRANSITION MatchId={MatchId} PreviousStatus={PreviousStatus} CurrentStatus={CurrentStatus} StartTime={StartTime:o} EndTime={EndTime:o} UtcNow={UtcNow:o} ThreadId={ThreadId}",
                    updated.MatchId,
                    previousStatus,
                    updated.Status,
                    updated.StartTime,
                    updated.EndTime,
                    DateTime.UtcNow,
                    Environment.CurrentManagedThreadId);
            }

            await LoadMetricChartsAsync(ct);

            if (IsPending(updated.Status) || statusChanged || timingChanged)
            {
                Logger.LogInformation(
                    "MATCH_CLOCK_RESTART MatchId={MatchId} PreviousStatus={PreviousStatus} CurrentStatus={CurrentStatus} TimingChanged={TimingChanged} UtcNow={UtcNow:o} ThreadId={ThreadId}",
                    updated.MatchId,
                    previousStatus,
                    updated.Status,
                    timingChanged,
                    DateTime.UtcNow,
                    Environment.CurrentManagedThreadId);

                await StartOrRestartMatchClockAsync();
            }
            else
            {
                UpdateClockFromUtcNow();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) when (ct.IsCancellationRequested)
        {
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "MATCH_RELOAD_ERROR MatchId={MatchId} PreviousStatus={PreviousStatus} UtcNow={UtcNow:o} ThreadId={ThreadId}", previousMatch.MatchId, previousStatus, DateTime.UtcNow, Environment.CurrentManagedThreadId);
        }
    }

    private async Task<MatchDto?> LoadRequestedMatchAsync(CancellationToken ct)
    {
        if (MatchId is int requestedId && requestedId > 0)
            return await Api.GetMatchByIdAsync(requestedId, ct);

        var a = NormalizeSlugToSymbol(SlugA);
        var b = NormalizeSlugToSymbol(SlugB);
        if (string.IsNullOrWhiteSpace(a) || string.IsNullOrWhiteSpace(b))
            return null;

        return await Api.GetMatchBySymbolsAsync(a, b);
    }

    private void StartClock()
    {
        StopClock();

        var clockGeneration = ++_clockGeneration;
        Logger.LogInformation(
            "CLOCK_LOOP_CREATED MatchId={MatchId} ClockGeneration={ClockGeneration} UtcNow={UtcNow:o} ThreadId={ThreadId}",
            _match?.MatchId ?? 0,
            clockGeneration,
            DateTime.UtcNow,
            Environment.CurrentManagedThreadId);

        _tickCts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromMilliseconds(250));

        _ = Task.Run(async () =>
        {
            var iteration = 0;

            try
            {
                while (_timer is not null && await _timer.WaitForNextTickAsync(_tickCts.Token))
                {
                    iteration++;
                    Logger.LogInformation(
                        "CLOCK_LOOP_ITERATION MatchId={MatchId} ClockGeneration={ClockGeneration} Iteration={Iteration} UtcNow={UtcNow:o} ThreadId={ThreadId}",
                        _match?.MatchId ?? 0,
                        clockGeneration,
                        iteration,
                        DateTime.UtcNow,
                        Environment.CurrentManagedThreadId);

                    // Mantem o relogio fluido e tambem verifica o polling periodico
                    // da partida. O polling chama ReloadMatchAsync(), que recarrega os
                    // snapshots usados pelos graficos mesmo quando nenhum evento do Hub chega.
                    UpdateClockTexts();
                    UpdateLocalClockTexts(DateTime.UtcNow);
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException) when (_tickCts?.IsCancellationRequested == true)
            {
                Logger.LogInformation(
                    "CLOCK_LOOP_CANCELLED MatchId={MatchId} ClockGeneration={ClockGeneration} UtcNow={UtcNow:o} ThreadId={ThreadId}",
                    _match?.MatchId ?? 0,
                    clockGeneration,
                    DateTime.UtcNow,
                    Environment.CurrentManagedThreadId);
            }
        });
    }

    private void StopClock()
    {
        if (_tickCts is not null || _timer is not null)
        {
            Logger.LogInformation(
                "CLOCK_LOOP_CANCELLED MatchId={MatchId} ClockGeneration={ClockGeneration} UtcNow={UtcNow:o} ThreadId={ThreadId}",
                _match?.MatchId ?? 0,
                _clockGeneration,
                DateTime.UtcNow,
                Environment.CurrentManagedThreadId);
        }

        try { _tickCts?.Cancel(); } catch { }
        _tickCts?.Dispose();
        _tickCts = null;

        _timer?.Dispose();
        _timer = null;
    }

    private void UpdateClockTexts()
    {
        if (_match?.StartTime is null)
        {
            _clockText = "00:00";
            _remainingText = "(90:00)";
            return;
        }

        var startUtc = EnsureUtc(_match.StartTime.Value);
        var elapsed = DateTime.UtcNow - startUtc;

        if (elapsed < TimeSpan.Zero) elapsed = TimeSpan.Zero;

        _clockText = $"{(int)elapsed.TotalMinutes:00}:{elapsed.Seconds:00}";

        var remaining = MatchDuration - elapsed;
        if (remaining < TimeSpan.Zero) remaining = TimeSpan.Zero;

        _remainingText = $"({(int)remaining.TotalMinutes:00}:{remaining.Seconds:00})";

        if (ShouldAutoReloadLiveMatch(DateTime.UtcNow, elapsed))
        {
            _lastAutoReloadUtc = DateTime.UtcNow;
            DebouncedReload();
        }
    }

    private bool ShouldAutoReloadLiveMatch(DateTime nowUtc, TimeSpan elapsed)
    {
        if (_match is null || !IsOngoing(_match.Status))
            return false;

        if (elapsed >= MatchDuration)
            return true;

        return nowUtc - _lastAutoReloadUtc >= LiveReloadInterval;
    }

    public void Dispose()
    {
        StopClock();
        StopLocalClock();

        if (_hubWired)
        {
            HubClient.DashboardChanged -= OnDashboardChanged;
            _hubWired = false;
        }

        _reloadCts?.Cancel();
        _reloadCts?.Dispose();
        _reloadCts = null;
    }

    public async ValueTask DisposeAsync()
    {
        Dispose();

        if (_tvModeModule is not null)
        {
            try
            {
                await _tvModeModule.DisposeAsync();
            }
            catch
            {
            }

            _tvModeModule = null;
        }

        if (_tvEventFeedModule is not null)
        {
            try
            {
                await _tvEventFeedModule.DisposeAsync();
            }
            catch
            {
            }

            _tvEventFeedModule = null;
        }
    }

    private void UpdateClockFromUtcNow()
