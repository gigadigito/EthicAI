    }

    private ChartSeriesState BuildChartState(
        IReadOnlyCollection<MatchMetricSnapshotDto> snapshots,
        Func<MatchMetricSnapshotDto, decimal> selector,
        bool ensureZeroLine,
        double minimumPadding)
    {
        if (_match is null || snapshots.Count == 0)
            return ChartSeriesState.Empty;

        var teamASeries = snapshots
            .Where(x => x.TeamId == _match.TeamAId)
            .OrderBy(x => x.CapturedAtUtc)
            .Select(x => (x.CapturedAtUtc, Value: (double)selector(x)))
            .ToList();

        var teamBSeries = snapshots
            .Where(x => x.TeamId == _match.TeamBId)
            .OrderBy(x => x.CapturedAtUtc)
            .Select(x => (x.CapturedAtUtc, Value: (double)selector(x)))
            .ToList();

        if (teamASeries.Count < 2 || teamBSeries.Count < 2)
            return ChartSeriesState.Empty;

        var allValues = teamASeries.Select(x => x.Value).Concat(teamBSeries.Select(x => x.Value)).ToList();
        var min = allValues.Min();
        var max = allValues.Max();
        var pad = Math.Max(minimumPadding, (max - min) * 0.15);

        var yMin = min - pad;
        var yMax = max + pad;

        if (ensureZeroLine)
        {
            yMin = Math.Min(yMin, 0);
            yMax = Math.Max(yMax, 0);
        }

        if (Math.Abs(yMax - yMin) < 0.0001)
        {
            yMin -= 1;
            yMax += 1;
        }

        var globalStart = teamASeries.Concat(teamBSeries).Min(x => x.CapturedAtUtc);
        var globalEnd = teamASeries.Concat(teamBSeries).Max(x => x.CapturedAtUtc);

        return new ChartSeriesState
        {
            PolyA = BuildPolyline(teamASeries, globalStart, globalEnd, yMin, yMax),
            PolyB = BuildPolyline(teamBSeries, globalStart, globalEnd, yMin, yMax),
            YMin = yMin,
            YMax = yMax,
            ZeroY = MapY(0, yMin, yMax),
            StartUtc = globalStart,
            EndUtc = globalEnd
        };
    }

    private static string BuildPolyline(
        List<(DateTime CapturedAtUtc, double Value)> series,
        DateTime globalStart,
        DateTime globalEnd,
        double yMin,
        double yMax)
    {
        if (series.Count < 2)
            return "";

        var totalMs = Math.Max(1d, (globalEnd - globalStart).TotalMilliseconds);
        var sb = new System.Text.StringBuilder();

        for (var i = 0; i < series.Count; i++)
        {
            var point = series[i];
            var x = ((point.CapturedAtUtc - globalStart).TotalMilliseconds / totalMs) * 1000.0;
            var y = MapY(point.Value, yMin, yMax);

            sb.Append(x.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture));
            sb.Append(',');
            sb.Append(y.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture));

            if (i < series.Count - 1)
                sb.Append(' ');
        }

        return sb.ToString();
    }

    private static double MapY(double value, double yMin, double yMax)
    {
        var t = (value - yMin) / (yMax - yMin);
        t = Math.Clamp(t, 0, 1);
        return (1 - t) * 320.0;
    }

