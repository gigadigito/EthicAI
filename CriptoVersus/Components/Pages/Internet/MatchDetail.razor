    private PeriodicTimer? _timer;
    private CancellationTokenSource? _tickCts;

    private string _clockText = "00:00";
    private string _remainingText = "(90:00)";

    private static readonly TimeSpan MatchDuration = TimeSpan.FromMinutes(90);
    private static readonly TimeSpan LiveReloadInterval = TimeSpan.FromSeconds(5);

    private bool _hubWired;
    private CancellationTokenSource? _reloadCts;
    private int _reloadSeq;
    private DateTime _lastAutoReloadUtc = DateTime.MinValue;

    protected override void OnInitialized()
    {
        if (!_hubWired)
        {
            _hubWired = true;
            HubClient.DashboardChanged += OnDashboardChanged;
        }
    }

    private void OnDashboardChanged(string? _)
    {
        DebouncedReload();
    }

    private void DebouncedReload()
    {
        _reloadCts?.Cancel();
        _reloadCts?.Dispose();
        _reloadCts = new CancellationTokenSource();

        var localSeq = ++_reloadSeq;
        var ct = _reloadCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(300, ct);

                if (localSeq != _reloadSeq) return;

                await ReloadMatchAsync(ct);
            }
            catch (OperationCanceledException) { }
        });
    }

    private async Task ReloadMatchAsync(CancellationToken ct)
    {
        if (_match is null) return;

        try
        {
            var updated = await LoadRequestedMatchAsync(ct);

            if (updated is not null)
            {
                _match = updated;
                _title = $"{_match.TeamA} vs {_match.TeamB}";
                await LoadMetricChartsAsync(ct);

                SyncAndStartLocalClock();
                UpdateClockTexts();

                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
        }
    }

    private async Task<MatchDto?> LoadRequestedMatchAsync(CancellationToken ct)
    {
        if (MatchId is int requestedId && requestedId > 0)
            return await Api.GetMatchByIdAsync(requestedId, ct);

        var a = NormalizeSlugToSymbol(SlugA);
        var b = NormalizeSlugToSymbol(SlugB);
        if (string.IsNullOrWhiteSpace(a) || string.IsNullOrWhiteSpace(b))
            return null;

        return await Api.GetMatchBySymbolsAsync(a, b);
    }

    private void StartClock()
    {
        StopClock();

        _tickCts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        _ = Task.Run(async () =>
        {
            try
            {
                while (_timer is not null && await _timer.WaitForNextTickAsync(_tickCts.Token))
                {
                    UpdateClockTexts();
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException) { }
        });
    }

    private void StopClock()
    {
        try { _tickCts?.Cancel(); } catch { }
        _tickCts?.Dispose();
        _tickCts = null;

        _timer?.Dispose();
        _timer = null;
    }

    private void UpdateClockTexts()
    {
        if (_match?.StartTime is null)
        {
            _clockText = "00:00";
            _remainingText = "(90:00)";
            return;
        }

        var startUtc = DateTime.SpecifyKind(_match.StartTime.Value, DateTimeKind.Utc);
        var elapsed = DateTime.UtcNow - startUtc;

        if (elapsed < TimeSpan.Zero) elapsed = TimeSpan.Zero;

        _clockText = $"{(int)elapsed.TotalMinutes:00}:{elapsed.Seconds:00}";

        var remaining = MatchDuration - elapsed;
        if (remaining < TimeSpan.Zero) remaining = TimeSpan.Zero;

        _remainingText = $"({(int)remaining.TotalMinutes:00}:{remaining.Seconds:00})";

        if (ShouldAutoReloadLiveMatch(DateTime.UtcNow, elapsed))
        {
            _lastAutoReloadUtc = DateTime.UtcNow;
            DebouncedReload();
        }
    }

    private bool ShouldAutoReloadLiveMatch(DateTime nowUtc, TimeSpan elapsed)
    {
        if (_match is null || !IsOngoing(_match.Status))
            return false;

        if (elapsed >= MatchDuration)
            return true;

        return nowUtc - _lastAutoReloadUtc >= LiveReloadInterval;
    }

    public void Dispose()
    {
        StopClock();
        StopLocalClock();

        if (_hubWired)
        {
            HubClient.DashboardChanged -= OnDashboardChanged;
            _hubWired = false;
        }

        _reloadCts?.Cancel();
        _reloadCts?.Dispose();
        _reloadCts = null;
    }

    private PeriodicTimer? _uiTimer;
    private CancellationTokenSource? _uiCts;

    private DateTime? _startUtc;

    private string _clockLive = "00:00.000";
    private string _remainingLive = "(90:00.000)";

    private void SyncAndStartLocalClock()
    {
        if (_match?.StartTime is null)
        {
            _startUtc = null;
            _clockLive = "00:00.000";
            _remainingLive = "(90:00.000)";
            StopLocalClock();
            return;
        }

        var match = _match;
        _startUtc = DateTime.SpecifyKind(_match.StartTime.Value, DateTimeKind.Utc);

        UpdateLocalClockTexts(DateTime.UtcNow);

        if (IsOngoing(match.Status))
            StartClock();
        else
            StopClock();

        if (IsOngoing(match.Status))
            StartLocalClock();
        else
            StopLocalClock();
    }

    private void StartLocalClock()
    {
        if (_uiTimer is not null) return;

        _uiCts = new CancellationTokenSource();

        _uiTimer = new PeriodicTimer(TimeSpan.FromMilliseconds(50));

        _ = InvokeAsync(async () =>
        {
            try
            {
                while (_uiTimer is not null && await _uiTimer.WaitForNextTickAsync(_uiCts.Token))
                {
                    UpdateLocalClockTexts(DateTime.UtcNow);
                    StateHasChanged();
                }
            }
            catch (OperationCanceledException) { }
        });
    }

    private void StopLocalClock()
    {
        try { _uiCts?.Cancel(); } catch { }
        _uiCts?.Dispose();
        _uiCts = null;

        _uiTimer?.Dispose();
        _uiTimer = null;
    }

    private void UpdateLocalClockTexts(DateTime nowUtc)
    {
        if (_startUtc is null)
        {
            _clockLive = "00:00.000";
            _remainingLive = "(90:00.000)";
            return;
        }

        var elapsed = nowUtc - _startUtc.Value;
        if (elapsed < TimeSpan.Zero) elapsed = TimeSpan.Zero;

        if (elapsed > MatchDuration) elapsed = MatchDuration;

        var remaining = MatchDuration - elapsed;
        if (remaining < TimeSpan.Zero) remaining = TimeSpan.Zero;

        _clockLive = FormatClock(elapsed);
        _remainingLive = $"({FormatClock(remaining)})";
    }

    private static string FormatClock(TimeSpan t)
    {
        var mm = (int)t.TotalMinutes;
        var ss = t.Seconds;
        var ms = t.Milliseconds;
        return $"{mm:00}:{ss:00}.{ms:000}";
    }

    private readonly List<MatchMetricSnapshotDto> _metricSnapshots = new();
    private readonly List<MatchScoreEventDto> _scoreEvents = new();
    private ChartSeriesState _percentageChart = ChartSeriesState.Empty;
    private ChartSeriesState _volumeChart = ChartSeriesState.Empty;

    private async Task LoadMetricChartsAsync(CancellationToken ct)
    {
        if (_match is null)
        {
            _metricSnapshots.Clear();
            _scoreEvents.Clear();
            _percentageChart = ChartSeriesState.Empty;
            _volumeChart = ChartSeriesState.Empty;
            return;
        }

        var snapshotsTask = Api.GetMatchMetricSnapshotsAsync(_match.MatchId, 500, ct);
        var scoreEventsTask = Api.GetMatchScoreEventsAsync(_match.MatchId, ct);

        await Task.WhenAll(snapshotsTask, scoreEventsTask);

        var snapshots = snapshotsTask.Result ?? [];
        var scoreEvents = scoreEventsTask.Result ?? [];

        _metricSnapshots.Clear();
        _metricSnapshots.AddRange(snapshots
            .OrderBy(x => x.CapturedAtUtc)
            .ThenBy(x => x.TeamId));

        _scoreEvents.Clear();
        _scoreEvents.AddRange(scoreEvents
            .OrderBy(x => x.EventSequence)
            .ThenBy(x => x.EventTimeUtc));

        _percentageChart = BuildChartState(
            _metricSnapshots,
            x => x.PercentageChange,
            ensureZeroLine: true,
            minimumPadding: 0.2);

        _volumeChart = BuildChartState(
            _metricSnapshots,
            x => x.QuoteVolume,
            ensureZeroLine: false,
            minimumPadding: 1d);
    }

    private ChartSeriesState BuildChartState(
        IReadOnlyCollection<MatchMetricSnapshotDto> snapshots,
        Func<MatchMetricSnapshotDto, decimal> selector,
        bool ensureZeroLine,
        double minimumPadding)
    {
        if (_match is null || snapshots.Count == 0)
            return ChartSeriesState.Empty;

        var teamASeries = snapshots
            .Where(x => x.TeamId == _match.TeamAId)
            .OrderBy(x => x.CapturedAtUtc)
            .Select(x => (x.CapturedAtUtc, Value: (double)selector(x)))
            .ToList();

        var teamBSeries = snapshots
            .Where(x => x.TeamId == _match.TeamBId)
            .OrderBy(x => x.CapturedAtUtc)
            .Select(x => (x.CapturedAtUtc, Value: (double)selector(x)))
            .ToList();

        if (teamASeries.Count < 2 || teamBSeries.Count < 2)
            return ChartSeriesState.Empty;

        var allValues = teamASeries.Select(x => x.Value).Concat(teamBSeries.Select(x => x.Value)).ToList();
        var min = allValues.Min();
        var max = allValues.Max();
        var pad = Math.Max(minimumPadding, (max - min) * 0.15);

        var yMin = min - pad;
        var yMax = max + pad;

        if (ensureZeroLine)
        {
            yMin = Math.Min(yMin, 0);
            yMax = Math.Max(yMax, 0);
        }

        if (Math.Abs(yMax - yMin) < 0.0001)
        {
            yMin -= 1;
            yMax += 1;
        }

        var globalStart = teamASeries.Concat(teamBSeries).Min(x => x.CapturedAtUtc);
        var globalEnd = teamASeries.Concat(teamBSeries).Max(x => x.CapturedAtUtc);

        return new ChartSeriesState
        {
            PolyA = BuildPolyline(teamASeries, globalStart, globalEnd, yMin, yMax),
            PolyB = BuildPolyline(teamBSeries, globalStart, globalEnd, yMin, yMax),
            YMin = yMin,
            YMax = yMax,
            ZeroY = MapY(0, yMin, yMax),
            StartUtc = globalStart,
            EndUtc = globalEnd
        };
    }

    private static string BuildPolyline(
        List<(DateTime CapturedAtUtc, double Value)> series,
        DateTime globalStart,
        DateTime globalEnd,
        double yMin,
        double yMax)
    {
        if (series.Count < 2)
            return "";

        var totalMs = Math.Max(1d, (globalEnd - globalStart).TotalMilliseconds);
        var sb = new System.Text.StringBuilder();

        for (var i = 0; i < series.Count; i++)
        {
            var point = series[i];
            var x = ((point.CapturedAtUtc - globalStart).TotalMilliseconds / totalMs) * 1000.0;
            var y = MapY(point.Value, yMin, yMax);

            sb.Append(x.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture));
            sb.Append(',');
            sb.Append(y.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture));

            if (i < series.Count - 1)
                sb.Append(' ');
        }

        return sb.ToString();
    }

    private static double MapY(double value, double yMin, double yMax)
    {
        var t = (value - yMin) / (yMax - yMin);
        t = Math.Clamp(t, 0, 1);
        return (1 - t) * 320.0;
    }

