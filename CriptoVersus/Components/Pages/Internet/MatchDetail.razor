    private async Task LoadMetricChartsAsync(CancellationToken ct)
    {
        if (_match is null)
        {
            _metricSnapshots = new();
            _scoreEvents = new();
            _arenaSentimentA = null;
            _arenaSentimentB = null;
            _leftPriceBattlePoints.Clear();
            _rightPriceBattlePoints.Clear();
            _percentageChart = ChartSeriesState.Empty;
            _volumeChart = ChartSeriesState.Empty;
            return;
        }

        var matchId = _match.MatchId;
        var matchVersion = _match.ScoreVersion;
        var snapshotsTask = Api.GetMatchMetricSnapshotsAsync(matchId, 500, ct);
        var scoreEventsTask = Api.GetMatchScoreEventsAsync(matchId, ct);
        _arenaSentimentLoading = _arenaSentimentA is null && _arenaSentimentB is null;
        var arenaSentimentTask = Api.GetMatchArenaSentimentAsync(matchId, ct);

        await Task.WhenAll(snapshotsTask, scoreEventsTask, arenaSentimentTask);

        if (_match is null || _match.MatchId != matchId || _match.ScoreVersion != matchVersion)
            return;

        var snapshots = snapshotsTask.Result ?? [];
        var scoreEvents = scoreEventsTask.Result ?? [];
        var arenaSentiment = arenaSentimentTask.Result;

        var orderedSnapshots = snapshots
            .OrderBy(x => x.CapturedAtUtc)
            .ThenBy(x => x.TeamId)
            .ToList();

        var orderedScoreEvents = scoreEvents
            .OrderBy(x => x.EventSequence)
            .ThenBy(x => x.EventTimeUtc)
            .ToList();

        _metricSnapshots = orderedSnapshots;
        _scoreEvents = orderedScoreEvents;
        _arenaSentimentA = arenaSentiment?.TeamA;
        _arenaSentimentB = arenaSentiment?.TeamB;
        _arenaSentimentLoading = false;
        _leftPriceBattlePoints.Clear();
        _leftPriceBattlePoints.AddRange(BuildPricePoints(orderedSnapshots.Where(x => x.TeamId == _match.TeamAId)));
        _rightPriceBattlePoints.Clear();
        _rightPriceBattlePoints.AddRange(BuildPricePoints(orderedSnapshots.Where(x => x.TeamId == _match.TeamBId)));

        _percentageChart = BuildChartState(
            _metricSnapshots,
            x => x.PercentageChange,
            ensureZeroLine: true,
            minimumPadding: 0.2);

        _volumeChart = BuildChartState(
            _metricSnapshots,
            x => x.QuoteVolume,
            ensureZeroLine: false,
            minimumPadding: 1d);

        var waitingReason = _leftPriceBattlePoints.Count < 2 && _rightPriceBattlePoints.Count < 2
            ? "waiting for both assets history"
            : _leftPriceBattlePoints.Count < 2
                ? "waiting for asset A history"
                : _rightPriceBattlePoints.Count < 2
                    ? "waiting for asset B history"
                    : "ready";

        var historyLogKey = string.Join(
            "|",
            matchId,
            _match.Status,
            orderedSnapshots.Count,
            _leftPriceBattlePoints.Count,
            _rightPriceBattlePoints.Count,
            orderedScoreEvents.Count,
            waitingReason);

        if (!string.Equals(historyLogKey, _lastMetricHistoryLogKey, StringComparison.Ordinal))
        {
            _lastMetricHistoryLogKey = historyLogKey;

            if (waitingReason == "ready")
            {
                Logger.LogInformation(
                    "[MATCH_HISTORY_READY] MatchId={MatchId} Status={Status} TeamA={TeamA} TeamB={TeamB} TotalSnapshots={TotalSnapshots} LeftPoints={LeftPoints} RightPoints={RightPoints} ScoreEvents={ScoreEvents}",
                    matchId,
                    _match.Status,
                    _match.TeamA,
                    _match.TeamB,
                    orderedSnapshots.Count,
                    _leftPriceBattlePoints.Count,
                    _rightPriceBattlePoints.Count,
                    orderedScoreEvents.Count);
            }
            else
            {
                Logger.LogInformation(
                    "[MATCH_HISTORY_WAIT] MatchId={MatchId} Status={Status} TeamA={TeamA} TeamB={TeamB} TotalSnapshots={TotalSnapshots} LeftPoints={LeftPoints} RightPoints={RightPoints} ScoreEvents={ScoreEvents} Reason={Reason}",
                    matchId,
                    _match.Status,
                    _match.TeamA,
                    _match.TeamB,
                    orderedSnapshots.Count,
                    _leftPriceBattlePoints.Count,
                    _rightPriceBattlePoints.Count,
                    orderedScoreEvents.Count,
                    waitingReason);
            }
        }
    }

