    {
        return !string.IsNullOrWhiteSpace(wallet)
            && !string.IsNullOrWhiteSpace(configuredWallet)
            && string.Equals(wallet, configuredWallet, StringComparison.Ordinal);
    }

    private static string GetBetPopupExceptionMessage(Exception ex)
    {
        if (ex.ToString().Contains("ONCHAIN_MATCH_NOT_INITIALIZED", StringComparison.OrdinalIgnoreCase))
            return "A partida ainda não foi criada on-chain na devnet. Tente novamente em instantes.";

        if (ex.ToString().Contains("TeamId invalido para posicao on-chain.", StringComparison.OrdinalIgnoreCase))
            return "Nao foi possivel preparar a posicao on-chain dessa moeda agora. Tente novamente em instantes.";

        return "Nao foi possivel concluir o investimento agora. Tente novamente em instantes.";
