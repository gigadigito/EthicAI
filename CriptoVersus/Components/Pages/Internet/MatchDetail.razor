    /* ================================================================
                                               EPIC ARENA SKIN
                                               Texturas esperadas em: /wwwroot/img/match-arena/
                                               A tela continua funcional mesmo antes dos arquivos existirem.
                                               ================================================================ */

    .social-share-card--epic {
        --arena-orange: #ff8a00;
        --arena-orange-soft: #ffbd4a;
        --arena-cyan: #00c8ff;
        --arena-cyan-soft: #73e6ff;
        --arena-green: #00ef7b;
        --arena-ink: #02070d;
        isolation: isolate;
        position: relative;
        overflow: hidden;
        background: var(--arena-ink);
        border: 1px solid rgba(93, 198, 255, .2);
        box-shadow: 0 34px 100px rgba(0,0,0,.68), inset 0 1px 0 rgba(255,255,255,.08), inset 0 0 90px rgba(0,126,255,.035);
    }

        .social-share-card--epic::before {
            content: "";
            position: absolute;
            inset: 9px;
            z-index: 30;
            pointer-events: none;
            border-radius: 25px;
            padding: 1px;
            background: linear-gradient(90deg, rgba(255,138,0,.95), rgba(255,138,0,.12) 43%, rgba(0,200,255,.12) 57%, rgba(0,200,255,.95));
            -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            -webkit-mask-composite: xor;
            mask-composite: exclude;
            filter: drop-shadow(-4px 0 8px rgba(255,138,0,.28)) drop-shadow(4px 0 8px rgba(0,191,255,.28));
        }

        .social-share-card--epic::after {
            content: "";
            position: absolute;
            inset: 0;
            z-index: 29;
            pointer-events: none;
            background-image: url('/img/match-arena/corner-orange.svg'), url('/img/match-arena/corner-cyan.svg');
            background-repeat: no-repeat;
            background-position: left 8px top 8px, right 8px top 8px;
            background-size: 150px 150px, 150px 150px;
            opacity: .72;
        }

    .social-share-card__background,
    .social-share-card__stadium,
    .social-share-card__atmosphere {
        position: absolute;
        inset: 0;
        pointer-events: none;
    }

    .social-share-card__background {
        z-index: -4;
        background-image: linear-gradient(180deg, rgba(2,6,11,.62), rgba(2,6,11,.86) 55%, rgba(1,3,7,.98)), url('/img/match-arena/arena-background.webp');
        background-size: cover;
        background-position: center top;
    }

    .social-share-card__stadium {
        z-index: -3;
        background-image: url('/img/match-arena/arena-stadium.webp');
        background-size: cover;
        background-position: center top;
        opacity: .72;
    }

    .social-share-card__atmosphere {
        z-index: -2;
        background: radial-gradient(circle at 24% 25%, rgba(255,115,0,.22), transparent 28%), radial-gradient(circle at 76% 25%, rgba(0,170,255,.22), transparent 28%), radial-gradient(ellipse at center 105%, rgba(0,230,118,.08), transparent 36%);
    }

    .social-share-card--epic .social-share-card__bg {
        z-index: -1;
        background-image: url('/img/match-arena/arena-noise.webp'), url('/img/match-arena/arena-grid.svg');
        background-repeat: repeat, repeat;
        background-size: 512px 512px, 68px 68px;
        opacity: .13;
        mix-blend-mode: screen;
    }

    .social-share-card--epic .social-share-card__shell {
        z-index: 2;
        gap: 1.25rem;
        padding: 1.65rem;
