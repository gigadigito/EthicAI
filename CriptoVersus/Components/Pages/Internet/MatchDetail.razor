    private async Task SendBet(int matchId, int teamId, string teamName, decimal amountSol)
    {
        _isSendingBet = true;
        _betRequestOk = false;
        _betStatusMessage = "";
        _betResponseBody = "";
        _showSimplePopup = false;

        try
        {
            await RefreshAuthenticatedUserAsync();
            var token = await SessionStorage.GetItemAsync<string>("authToken");

            if (string.IsNullOrWhiteSpace(token) || !_loggedUserId.HasValue || _loggedUserId.Value <= 0)
            {
                _betRequestOk = false;
                _betStatusMessage = "Faça login com a carteira Solana antes de investir.";
                ShowInvestmentPopup("Conecte sua carteira", "Faça login com sua carteira Solana para continuar com o investimento.");
                return;
            }

            var investDiagnostics = await PrepareInvestmentDiagnosticsAsync(matchId, teamId, teamName, amountSol);
            _betResponseBody = PrettyJsonOrRaw(JsonSerializer.Serialize(investDiagnostics));

            var payload = new
            {
                userId = _loggedUserId.Value,
                teamId = teamId,
                amount = amountSol,
                onChainSignature = investDiagnostics.Signature,
                onChainAmountLamports = investDiagnostics.AmountLamports
            };

            var url = $"https://criptoversus-api.duckdns.org/api/match/{matchId}/bet";
            using var request = new HttpRequestMessage(HttpMethod.Post, url)
            {
                Content = JsonContent.Create(payload)
            };
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            using var response = await Http.SendAsync(request);
            var body = await response.Content.ReadAsStringAsync();

            _betResponseBody = string.IsNullOrWhiteSpace(_betResponseBody)
                ? PrettyJsonOrRaw(body)
                : $"{_betResponseBody}\n\nAPI:\n{PrettyJsonOrRaw(body)}";

            if (response.IsSuccessStatusCode)
            {
                _betRequestOk = true;
                _betStatusMessage = $"Investimento enviado com sucesso para {teamName}. Usuário={LoggedUserDisplay}. MatchId={matchId}, TeamId={teamId}.";
                ShowInvestmentPopup("Investimento confirmado", $"Seu investimento de {FmtSolAmount(amountSol)} em {teamName} foi registrado com sucesso.");
                await ReloadMatchAsync(CancellationToken.None);
            }
            else
            {
                _betRequestOk = false;
                _betStatusMessage = $"Falha ao investir em {teamName}. Usuário={LoggedUserDisplay}. HTTP {(int)response.StatusCode} - {response.ReasonPhrase}";
                ShowInvestmentPopup("Investimento não concluído", "Não foi possível registrar seu investimento agora. Tente novamente em instantes.");
            }
        }
        catch (Exception ex)
        {
            _betRequestOk = false;
            _betStatusMessage = GetBetExceptionMessage(ex, LoggedUserDisplay);
            _betResponseBody = ex.ToString();
            ShowInvestmentPopup("Investimento não concluído", GetBetPopupExceptionMessage(ex));
        }
        finally
        {
            _isSendingBet = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<InvestmentPreparationResult> PrepareInvestmentDiagnosticsAsync(int matchId, int teamId, string teamName, decimal amountSol)
    {
        if (_match is null)
            throw new InvalidOperationException("Partida nao carregada para investimento on-chain.");

        var blockchainMode = Config["CriptoVersusBlockchain:Mode"] ?? "HybridContractCustody";

        _bettingModule ??= await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "./js/solanaInvestDiagnostics.js?v=20260426-invest-offchain");

        var programId = string.Equals(blockchainMode, "FullOnChain", StringComparison.OrdinalIgnoreCase)
            ? Config["CriptoVersusBlockchain:FutureFullOnChainProgramId"]
            : Config["CriptoVersusBlockchain:CurrentHybridProgramId"] ?? Config["OnChainBetting:ProgramId"];
        if (!string.Equals(blockchainMode, "OffChainCustody", StringComparison.OrdinalIgnoreCase)
            && string.IsNullOrWhiteSpace(programId))
            throw new InvalidOperationException("CriptoVersusBlockchain program id nao configurado para o modo atual.");

        return await _bettingModule.InvokeAsync<InvestmentPreparationResult>(
            "prepareInvestment",
            new
            {
                programId,
                cluster = Config["CriptoVersusBlockchain:Cluster"] ?? Config["OnChainBetting:Cluster"] ?? "devnet",
                matchId,
                teamId,
                teamName,
                teamAId = _match.TeamAId,
                teamBId = _match.TeamBId,
                bettingCloseUnix = GetOnChainBettingCloseUnix(_match),
                amountSol,
                mode = blockchainMode,
                custodyWalletPublicKey = Config["CriptoVersusBlockchain:CustodyWalletPublicKey"],
                supportsLegacyPositionInvestments = Config.GetValue<bool>("OnChainBetting:EnableLegacyPositionInvestments")
            });
    }

    private static long GetOnChainBettingCloseUnix(MatchDto match)
    {
        var fallbackClose = DateTimeOffset.UtcNow.AddHours(24).ToUnixTimeSeconds();
        var configuredClose = match.BettingCloseTime?.ToUnixTimeSeconds();

        if (configuredClose is null)
            return fallbackClose;

        var minimumClose = DateTimeOffset.UtcNow.AddMinutes(5).ToUnixTimeSeconds();
        return configuredClose.Value > minimumClose ? configuredClose.Value : fallbackClose;
    }

    private bool CanBetOnCurrentMatch()
    {
        if (_match is null)
            return false;

        if (string.Equals(_match.Status, "Pending", StringComparison.OrdinalIgnoreCase))
            return true;

        if (string.Equals(_match.Status, "Ongoing", StringComparison.OrdinalIgnoreCase))
            return _match.ElapsedMinutes >= 0 && _match.ElapsedMinutes < _liveBetMaxMinutes;

        return false;
    }

    private static string PrettyJsonOrRaw(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return "";

        try
        {
            using var doc = JsonDocument.Parse(text);
            return JsonSerializer.Serialize(doc, new JsonSerializerOptions
                {
                    WriteIndented = true
                });
        }
        catch
        {
            return text;
        }
    }

    private static string GetBetExceptionMessage(Exception ex, string selectedUserDisplay)
    {
        if (ex.ToString().Contains("ONCHAIN_MATCH_NOT_INITIALIZED", StringComparison.OrdinalIgnoreCase))
            return $"Partida ainda não criada on-chain na devnet. Usuário={selectedUserDisplay}.";

        return $"Erro ao chamar o investimento. Usuário={selectedUserDisplay}.";
    }

