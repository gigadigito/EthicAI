@page "/match/{SlugA}-vs-{SlugB}"
@using System.Net.Http
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Text.Json
@using DTOs
@inject CriptoVersus.Web.Services.CriptoVersusApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject HttpClient Http
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject CriptoVersus.Web.Services.DashboardHubClient HubClient
@inject IConfiguration Config
@rendermode InteractiveServer
@implements IDisposable
<PageTitle>@_title</PageTitle>

<div class="container py-3">

    @if (_loading)
    {
        <div class="d-flex align-items-center gap-2 text-muted">
            <div class="spinner-border spinner-border-sm" role="status"></div>
            <span>Carregando partida...</span>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">
            <strong>Erro:</strong> @_error
        </div>
    }
    else if (_match is null)
    {
        <div class="alert alert-warning">
            Partida não encontrada.
        </div>
    }
    else
    {
        <!-- =========================
             MATCH HERO / ARENA HEADER
             ========================= -->
        <section class="match-hero rounded-4 p-3 p-md-4 mb-3 shadow-sm overflow-hidden">
            <div class="match-hero__bg"></div>

            <div class="position-relative">
                <div class="row align-items-center g-3">

                    <!-- Team A -->
                    <div class="col-12 col-md-4">
                        <div class="d-flex align-items-center gap-3">
                            <div class="team-badge team-badge--a">
                                <div class="coin-wrap" title="@_match.TeamA">
                                    <div class="coin-skeleton"></div>

                                    <img class="coin-img"
                                         src="@GetCoinIconUrl(_match.TeamA)"
                                         alt="@_match.TeamA"
                                         loading="lazy"
                                         onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />

                                    <div class="coin-fallback d-none">@GetInitials(_match.TeamA)</div>
                                </div>
                            </div>

                            <div class="flex-grow-1">
                                <div class="team-name">@_match.TeamA</div>
                                <div class="team-sub">
                                    <span class="@GetPctClass(_match.PctA)">
                                        @FormatPct(_match.PctA)
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Score / Center -->
                    <div class="col-12 col-md-4 text-center">
                        <div class="d-inline-flex flex-column align-items-center gap-2">

                            @if (IsOngoing(_match.Status))
                            {
                                <div class="match-live">
                                    <span class="badge rounded-pill bg-danger match-live__pill">
                                        <span class="match-live__dot"></span>
                                        AO VIVO
                                    </span>
                                </div>
                            }
                            else
                            {
                                <div class="match-live">
                                    <span class="badge rounded-pill text-bg-dark border border-secondary-subtle match-live__pill">
                                        @_match.Status
                                    </span>
                                </div>
                            }

                            <div class="scoreline">
                                <span class="score">@_match.ScoreA</span>
                                <span class="score-sep">x</span>
                                <span class="score">@_match.ScoreB</span>
                            </div>

                            <div class="timebar text-muted">

                                <span class="mx-2">•</span>
                                <span class="text-muted">@_remainingLive</span>
                                @if (IsOngoing(_match.Status))
                                {
                                    <span class="clock-blink ms-2"></span>
                                }
                            </div>

                        </div>
                    </div>

                    <!-- Team B -->
                    <div class="col-12 col-md-4">
                        <div class="d-flex align-items-center gap-3 justify-content-md-end">
                            <div class="text-md-end">
                                <div class="team-name">@_match.TeamB</div>
                                <div class="team-sub">
                                    <span class="@GetPctClass(_match.PctB)">
                                        @FormatPct(_match.PctB)
                                    </span>
                                </div>
                            </div>

                            <div class="team-badge team-badge--b">
                                <div class="coin-wrap" title="@_match.TeamB">
                                    <div class="coin-skeleton"></div>

                                    <img class="coin-img"
                                         src="@GetCoinIconUrl(_match.TeamB)"
                                         alt="@_match.TeamB"
                                         loading="lazy"
                                         onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />

                                    <div class="coin-fallback d-none">@GetInitials(_match.TeamB)</div>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>


                <!-- Meta row -->
                <div class="row mt-3 g-2">
                    <div class="col-12">
                        <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-md-between align-items-center">
                            <div class="small text-muted">
                                Match ID: <span class="text-light-emphasis">@_match.MatchId</span>
                            </div>

                            <div class="d-flex flex-wrap gap-2">
                                @if (_match.StartTime is not null)
                                {
                                    <span class="badge text-bg-dark border border-secondary-subtle">
                                        Início: @_match.StartTime.Value.ToString("dd/MM/yyyy HH:mm")
                                    </span>
                                }
                                @if (_match.EndTime is not null)
                                {
                                    <span class="badge text-bg-dark border border-secondary-subtle">
                                        Fim: @_match.EndTime.Value.ToString("dd/MM/yyyy HH:mm")
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(_betStatusMessage))
        {
            <div class="alert @(_betRequestOk ? "alert-success" : "alert-danger") mb-3">
                @_betStatusMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_betResponseBody))
        {
            <div class="card mb-3">
                <div class="card-header">
                    <strong>Retorno da Aposta</strong>
                </div>
                <div class="card-body">
                    <pre class="bg-dark text-white border rounded p-3 small mb-0" style="white-space: pre-wrap;">@_betResponseBody</pre>
                </div>
            </div>
        }

        <!-- =========================
             TEAM CARDS + CLOCK (GRID)
             ========================= -->
        <div class="row g-3 mb-3">

            <!-- =========================
                 TEAM A CARD
                 ========================= -->
            <div class="col-12 col-lg-4">
                <div class="card match-card p-3 h-100">
                    <div class="d-flex align-items-center justify-content-between gap-2">
                        <div class="d-flex align-items-center gap-3">
                            <div class="coin-wrap coin-wrap--sm" title="@_match.TeamA">
                                <div class="coin-skeleton"></div>
                                <img class="coin-img coin-img--sm"
                                     src="@GetCoinIconUrl(_match.TeamA)"
                                     alt="@_match.TeamA"
                                     loading="lazy"
                                     onload="this.previousElementSibling?.classList.add('d-none')"
                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                <div class="coin-fallback d-none">@GetInitials(_match.TeamA)</div>
                            </div>

                            <div>
                                <div class="fw-bold fs-5 text-light-emphasis">@_match.TeamA</div>
                                <div class="small">
                                    <span class="@GetPctClass(_match.PctA)">@FormatPct(_match.PctA)</span>
                                    <span class="text-muted ms-2">• Score @_match.ScoreA</span>
                                </div>
                            </div>
                        </div>

                        <div class="pill pill--a">@GetTrendIcon(_match.PctA)</div>
                    </div>

                    <div class="mt-3">
                        <div class="d-flex justify-content-between small text-muted mb-1">
                            <span>Força</span>
                            <span class="fw-semibold">@GetStrengthA(_match)%</span>
                        </div>
                        <div class="progress match-progress">
                            <div class="progress-bar match-progress__bar"
                                 style="width:@GetStrengthA(_match)%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- =========================
                 CLOCK CARD (CENTER)
                 ========================= -->
            <div class="col-12 col-lg-4">
                <div class="card clock-card p-3 h-100 text-center d-flex flex-column justify-content-center">
                    <div class="clock-title">CRONÔMETRO</div>

                    <div class="clock-time">@_clockLive</div>

                    <div class="clock-remaining">
                        Restante <span class="fw-semibold">@_remainingLive</span>
                    </div>

                    <div class="mt-2">
                        @if (IsOngoing(_match.Status))
                        {
                            <span class="badge rounded-pill bg-danger match-live__pill">
                                <span class="match-live__dot"></span>
                                AO VIVO
                            </span>
                        }
                        else
                        {
                            <span class="badge rounded-pill text-bg-dark border border-secondary-subtle match-live__pill">
                                @_match.Status
                            </span>
                        }
                    </div>
                </div>
            </div>

            <!-- =========================
                 TEAM B CARD
                 ========================= -->
            <div class="col-12 col-lg-4">
                <div class="card match-card p-3 h-100">
                    <div class="d-flex align-items-center justify-content-between gap-2">
                        <div class="d-flex align-items-center gap-3">
                            <div class="coin-wrap coin-wrap--sm" title="@_match.TeamB">
                                <div class="coin-skeleton"></div>
                                <img class="coin-img coin-img--sm"
                                     src="@GetCoinIconUrl(_match.TeamB)"
                                     alt="@_match.TeamB"
                                     loading="lazy"
                                     onload="this.previousElementSibling?.classList.add('d-none')"
                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                <div class="coin-fallback d-none">@GetInitials(_match.TeamB)</div>
                            </div>

                            <div>
                                <div class="fw-bold fs-5 text-light-emphasis">@_match.TeamB</div>
                                <div class="small">
                                    <span class="@GetPctClass(_match.PctB)">@FormatPct(_match.PctB)</span>
                                    <span class="text-muted ms-2">• Score @_match.ScoreB</span>
                                </div>
                            </div>
                        </div>

                        <div class="pill pill--b">@GetTrendIcon(_match.PctB)</div>
                    </div>

                    <div class="mt-3">
                        <div class="d-flex justify-content-between small text-muted mb-1">
                            <span>Força</span>
                            <span class="fw-semibold">@GetStrengthB(_match)%</span>
                        </div>
                        <div class="progress match-progress">
                            <div class="progress-bar match-progress__bar"
                                 style="width:@GetStrengthB(_match)%"></div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        @if (_seriesA.Count > 1 && _seriesB.Count > 1)
        {
            <div class="row g-3 mb-3">
                <div class="col-12">
                    <div class="card match-panel p-3">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="fw-bold">Variação ao vivo</div>
                            <div class="small text-muted">@_match.TeamA vs @_match.TeamB</div>
                        </div>

                        <div class="chart-wrap mt-3">
                            <svg class="chart" viewBox="0 0 1000 320" preserveAspectRatio="none">
                                @for (var i = 1; i <= 4; i++)
                                {
                                    var y = i * 64;
                                    <line x1="0" y1="@y" x2="1000" y2="@y" class="chart-grid" />
                                }

                                <line x1="0" y1="@_zeroY" x2="1000" y2="@_zeroY" class="chart-zero" />

                                <polyline points="@_polyA" class="chart-line chart-line-a" />
                                <polyline points="@_polyB" class="chart-line chart-line-b" />
                            </svg>
                        </div>

                        <div class="d-flex gap-3 mt-2 small text-muted flex-wrap">
                            <div class="legend"><span class="dot dot-a"></span> @_match.TeamA (@FormatPct(_match.PctA))</div>
                            <div class="legend"><span class="dot dot-b"></span> @_match.TeamB (@FormatPct(_match.PctB))</div>
                            <div class="ms-auto">Range: @_yMin:0.00% → @_yMax:0.00%</div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- =========================
             TECH PANEL + ACTIONS
             ========================= -->
        <div class="row g-3">
            <div class="col-12 col-lg-8">
                <div class="card match-panel p-3">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div class="fw-bold">Painel da Partida</div>

                        <span class="badge @GetStatusBadgeClass(_match.Status)">
                            @_match.Status
                        </span>
                    </div>

                    <div class="row mt-3 g-3 small">
                        <div class="col-6 col-md-3">
                            <div class="text-muted">Decorrido</div>
                            <div class="fw-semibold">@_match.ElapsedMinutes min</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">Restante</div>
                            <div class="fw-semibold">@_match.RemainingMinutes min</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">Placar</div>
                            <div class="fw-semibold">@_match.ScoreA x @_match.ScoreB</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">Partida</div>
                            <div class="fw-semibold">#@_match.MatchId</div>
                        </div>
                    </div>

                    @if (_match.IsFinished)
                    {
                        <div class="mt-3">
                            <span class="badge bg-secondary">Finalizada</span>
                        </div>
                    }
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="card match-panel p-3">
                    <div class="fw-bold mb-2">Ações</div>

                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-light" @onclick="CopyLink">
                            🔗 Copiar link
                        </button>

                        <button class="btn btn-outline-secondary" @onclick="GoBack">
                            ← Voltar
                        </button>
                    </div>

                    <div class="small text-muted mt-3">
                        Dica: compartilhe o link para abrir a partida direto no “modo arena”.
                    </div>
                </div>
            </div>
        </div>

        <!-- =========================
             BET PANEL
             ========================= -->
        <div class="row g-3 mt-1">
            <div class="col-12">
                <div class="card match-panel p-3">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                        <div class="fw-bold">Teste de Aposta</div>
                        <span class="badge @(CanBetOnCurrentMatch() ? "bg-success" : "bg-secondary")">
                            @(CanBetOnCurrentMatch() ? "Apostas abertas" : "Apostas encerradas")
                        </span>
                    </div>

                    <div class="row g-3 align-items-end">
                        <div class="col-md-5 col-lg-4">
                            <label for="betUserSelect" class="form-label">Usuário</label>
                            <select id="betUserSelect" class="form-select" @bind="_selectedUserId">
                                @foreach (var user in _bettingUsers)
                                {
                                    <option value="@user.Id">@user.DisplayName</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-3 col-lg-2">
                            <label class="form-label">Valor</label>
                            <input class="form-control" value="@_testAmount" disabled />
                        </div>

                        <div class="col-md-4 col-lg-6">
                            <div class="small text-muted">Usuário selecionado</div>
                            <div class="fw-semibold">@SelectedUserDisplay</div>
                        </div>
                    </div>

                    <hr class="border-secondary-subtle" />

                    @if (!CanBetOnCurrentMatch())
                    {
                        <div class="alert alert-secondary mb-0">
                            Apostas indisponíveis para esta partida. Status: <strong>@_match.Status</strong>,
                            tempo decorrido: <strong>@_match.ElapsedMinutes min</strong>.
                        </div>
                    }
                    else
                    {
                        <div class="row g-2">
                            <div class="col-md-6">
                                <button class="btn btn-success w-100"
                                        disabled="@_isSendingBet"
                                        @onclick="() => SendBet(_match.MatchId, _match.TeamAId, _match.TeamA)">
                                    Apostar em @_match.TeamA
                                </button>
                            </div>

                            <div class="col-md-6">
                                <button class="btn btn-primary w-100"
                                        disabled="@_isSendingBet"
                                        @onclick="() => SendBet(_match.MatchId, _match.TeamBId, _match.TeamB)">
                                    Apostar em @_match.TeamB
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

<style>
    .match-hero {
        position: relative;
        background: radial-gradient(1200px 500px at 20% 0%, rgba(0, 230, 118, .14), transparent 60%), radial-gradient(1200px 500px at 80% 0%, rgba(255, 82, 82, .14), transparent 60%), linear-gradient(135deg, #0B1020 0%, #0E1117 55%, #0B1020 100%);
        border: 1px solid rgba(255,255,255,.08);
    }

    .match-hero__bg {
        position: absolute;
        inset: 0;
        background-image: linear-gradient(rgba(255,255,255,.06) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.06) 1px, transparent 1px);
        background-size: 26px 26px;
        opacity: .18;
        pointer-events: none;
    }

    .team-name {
        font-weight: 800;
        letter-spacing: .4px;
        font-size: clamp(1.05rem, 1.4vw, 1.35rem);
        color: rgba(255,255,255,.92);
    }

    .team-sub {
        font-size: .95rem;
    }

    .pct {
        font-weight: 800;
        letter-spacing: .2px;
    }

    .pct--up {
        color: #00E676;
    }

    .pct--down {
        color: #FF5252;
    }

    .pct--neutral {
        color: rgba(255,255,255,.70);
    }

    .scoreline {
        display: inline-flex;
        align-items: baseline;
        gap: .6rem;
    }

    .score {
        font-weight: 900;
        font-size: clamp(2.4rem, 4.3vw, 3.4rem);
        line-height: 1;
        color: #fff;
        text-shadow: 0 8px 28px rgba(0,0,0,.35);
    }

    .score-sep {
        font-weight: 800;
        font-size: clamp(1.2rem, 2vw, 1.6rem);
        color: rgba(255,255,255,.55);
    }

    .timebar {
        font-size: .95rem;
    }

    .team-badge {
        width: 54px;
        height: 54px;
        border-radius: 16px;
        display: grid;
        place-items: center;
        font-weight: 900;
        letter-spacing: .5px;
        color: rgba(255,255,255,.95);
        border: 1px solid rgba(255,255,255,.12);
        box-shadow: 0 14px 30px rgba(0,0,0,.25);
        backdrop-filter: blur(6px);
    }

    .team-badge--a {
        background: linear-gradient(135deg, rgba(0,230,118,.25), rgba(0,230,118,.05));
    }

    .team-badge--b {
        background: linear-gradient(135deg, rgba(255,82,82,.25), rgba(255,82,82,.05));
    }

    .match-live__pill {
        font-weight: 800;
        letter-spacing: .25px;
        padding: .45rem .75rem;
    }

    .match-live__dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        margin-right: .45rem;
        border-radius: 50%;
        background: #fff;
        box-shadow: 0 0 0 0 rgba(255,82,82,.8);
        animation: pulseDot 1.2s infinite;
        vertical-align: middle;
    }

    @@keyframes pulseDot {
        0% {
            box-shadow: 0 0 0 0 rgba(255,82,82,.65);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(255,82,82,0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(255,82,82,0);
        }
    }

    .match-card, .match-panel {
        background: #0E1117;
        border: 1px solid rgba(255,255,255,.08);
        color: rgba(255,255,255,.88);
    }

    .pill {
        width: 44px;
        height: 44px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        border: 1px solid rgba(255,255,255,.10);
        color: rgba(255,255,255,.92);
        box-shadow: 0 14px 28px rgba(0,0,0,.25);
    }

    .pill--a {
        background: linear-gradient(135deg, rgba(0,230,118,.22), rgba(0,230,118,.05));
    }

    .pill--b {
        background: linear-gradient(135deg, rgba(255,82,82,.22), rgba(255,82,82,.05));
    }

    .match-progress {
        height: 10px;
        background: rgba(255,255,255,.08);
        border-radius: 999px;
    }

    .match-progress__bar {
        border-radius: 999px;
        background: linear-gradient(90deg, rgba(255,193,7,.85), rgba(0,230,118,.85));
    }

    .coin-wrap {
        width: 54px;
        height: 54px;
        position: relative;
        display: grid;
        place-items: center;
        border-radius: 14px;
        overflow: hidden;
    }

    .coin-skeleton {
        position: absolute;
        inset: 0;
        background: linear-gradient( 90deg, rgba(255,255,255,.06), rgba(255,255,255,.14), rgba(255,255,255,.06) );
        background-size: 200% 100%;
        animation: coinShimmer 1.1s infinite;
        opacity: .9;
    }

    @@keyframes coinShimmer {
        0% {
            background-position: 200% 0;
        }

        100% {
            background-position: -200% 0;
        }
    }

    .coin-img {
        width: 42px;
        height: 42px;
        object-fit: contain;
        image-rendering: auto;
        z-index: 2;
        filter: drop-shadow(0 10px 18px rgba(0,0,0,.25));
    }

    .coin-fallback {
        z-index: 2;
        font-weight: 900;
        letter-spacing: .5px;
        color: rgba(255,255,255,.95);
    }

    .clock-card {
        background: radial-gradient( 600px 200px at 50% 0%, rgba(0,230,118,.15), transparent 60% ), #0E1117;
        border: 1px solid rgba(255,255,255,.12);
        box-shadow: 0 20px 40px rgba(0,0,0,.45);
    }

    .clock-title {
        font-size: .75rem;
        letter-spacing: .3em;
        font-weight: 800;
        color: rgba(255,255,255,.55);
        margin-bottom: .5rem;
    }

    .clock-time {
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
        font-variant-numeric: tabular-nums;
        font-weight: 900;
        font-size: clamp(2.2rem, 4vw, 3rem);
        color: #00E676;
        text-shadow: 0 0 18px rgba(0,230,118,.35);
    }

    .clock-remaining {
        margin-top: .25rem;
        font-size: .9rem;
        color: rgba(255,255,255,.6);
    }

    .chart-wrap {
        width: 100%;
        height: 220px;
        border-radius: 14px;
        background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(0,0,0,.12));
        border: 1px solid rgba(255,255,255,.08);
        overflow: hidden;
    }

    .chart {
        width: 100%;
        height: 100%;
    }

    .chart-grid {
        stroke: rgba(255,255,255,.08);
        stroke-width: 1;
    }

    .chart-zero {
        stroke: rgba(255,255,255,.18);
        stroke-width: 1.2;
        stroke-dasharray: 6 6;
    }

    .chart-line {
        fill: none;
        stroke-width: 2.8;
        stroke-linejoin: round;
        stroke-linecap: round;
    }

