        }

        100% {
            box-shadow: 0 0 0 0 rgba(255,82,82,0);
        }
    }

    @@keyframes winnerSpark {
        0%, 100% {
            transform: scale(1) rotate(0deg);
            opacity: .7;
        }

        50% {
            transform: scale(1.08) rotate(4deg);
            opacity: 1;
        }
    }

    @@keyframes winnerPulse {
        0% {
            transform: scale(.92);
            opacity: .6;
        }

        100% {
            transform: scale(1.2);
            opacity: 0;
        }
    }

    @@keyframes fireworksBurst {
        0%, 100% {
            transform: scale(.92);
            opacity: .42;
        }

        35% {
            transform: scale(1.04);
            opacity: .92;
        }

        60% {
            transform: scale(1.08);
            opacity: .58;
        }
    }

    @@keyframes fireworksRays {
        0%, 100% {
            transform: scale(.78) rotate(0deg);
            opacity: .12;
        }

        30% {
            transform: scale(1) rotate(8deg);
            opacity: .34;
        }

        55% {
            transform: scale(1.12) rotate(-6deg);
            opacity: .18;
        }
    }

    @@keyframes fireworkPop {
        0% {
            opacity: 0;
            transform: scale(.16);
        }

        14% {
            opacity: 1;
            transform: scale(.44);
        }

        32% {
            opacity: .98;
            transform: scale(1);
        }

        58% {
            opacity: .44;
            transform: scale(1.18);
        }

        100% {
            opacity: 0;
            transform: scale(1.34);
        }
    }

