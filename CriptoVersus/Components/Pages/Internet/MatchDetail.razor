    private async Task SendBet(int matchId, int teamId, string teamName)
    {
        _isSendingBet = true;
        _betRequestOk = false;
        _betStatusMessage = "";
        _betResponseBody = "";

        try
        {
            var token = await SessionStorage.GetItemAsync<string>("authToken");

            if (string.IsNullOrWhiteSpace(token))
            {
                _betRequestOk = false;
                _betStatusMessage = "Faça login com a carteira Solana antes de apostar.";
                return;
            }

            string? onChainSignature = null;
            var onChainBettingEnabled = Config.GetValue<bool>("OnChainBetting:Enabled");

            if (onChainBettingEnabled)
            {
                var onChainResult = await PlaceOnChainBetAsync(matchId, teamId, _testAmount);
                onChainSignature = onChainResult.Signature;
                _betResponseBody = PrettyJsonOrRaw(JsonSerializer.Serialize(onChainResult));
            }

            var payload = new
            {
                userId = _selectedUserId,
                teamId = teamId,
                amount = _testAmount,
                onChainSignature
            };

            var url = $"https://criptoversus-api.duckdns.org/api/match/{matchId}/bet";
            using var request = new HttpRequestMessage(HttpMethod.Post, url)
            {
                Content = JsonContent.Create(payload)
            };
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);

            using var response = await Http.SendAsync(request);
            var body = await response.Content.ReadAsStringAsync();

            _betResponseBody = string.IsNullOrWhiteSpace(_betResponseBody)
                ? PrettyJsonOrRaw(body)
                : $"{_betResponseBody}\n\nAPI:\n{PrettyJsonOrRaw(body)}";

            if (response.IsSuccessStatusCode)
            {
                _betRequestOk = true;
                _betStatusMessage = $"Aposta enviada com sucesso para {teamName}. Usuário={SelectedUserDisplay}. MatchId={matchId}, TeamId={teamId}.";
                await ReloadMatchAsync(CancellationToken.None);
            }
            else
            {
                _betRequestOk = false;
                _betStatusMessage = $"Falha ao apostar em {teamName}. Usuário={SelectedUserDisplay}. HTTP {(int)response.StatusCode} - {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            _betRequestOk = false;
            _betStatusMessage = GetBetExceptionMessage(ex, SelectedUserDisplay);
            _betResponseBody = ex.ToString();
        }
        finally
        {
            _isSendingBet = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<OnChainBetResult> PlaceOnChainBetAsync(int matchId, int teamId, decimal amountSol)
    {
        _bettingModule ??= await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "./js/solanaBetting.js");

        var programId = Config["OnChainBetting:ProgramId"];
        if (string.IsNullOrWhiteSpace(programId))
            throw new InvalidOperationException("OnChainBetting:ProgramId não configurado.");

        return await _bettingModule.InvokeAsync<OnChainBetResult>(
            "placeBet",
            new
            {
                programId,
                cluster = Config["OnChainBetting:Cluster"] ?? "devnet",
                matchId,
                teamId,
                amountSol
            });
    }

    private bool CanBetOnCurrentMatch()
    {
        if (_match is null)
            return false;

        if (string.Equals(_match.Status, "Pending", StringComparison.OrdinalIgnoreCase))
            return true;

        if (string.Equals(_match.Status, "Ongoing", StringComparison.OrdinalIgnoreCase))
            return _match.ElapsedMinutes >= 0 && _match.ElapsedMinutes < _liveBetMaxMinutes;

        return false;
    }

    private static string PrettyJsonOrRaw(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return "";

        try
        {
            using var doc = JsonDocument.Parse(text);
            return JsonSerializer.Serialize(doc, new JsonSerializerOptions
                {
                    WriteIndented = true
                });
        }
        catch
        {
            return text;
        }
    }

    private static string GetBetExceptionMessage(Exception ex, string selectedUserDisplay)
    {
        if (ex.ToString().Contains("ONCHAIN_MATCH_NOT_INITIALIZED", StringComparison.OrdinalIgnoreCase))
            return $"Partida ainda não criada on-chain na devnet. Usuário={selectedUserDisplay}.";

        return $"Erro ao chamar a aposta. Usuário={selectedUserDisplay}.";
    }

    private PeriodicTimer? _timer;
    private CancellationTokenSource? _tickCts;

    private string _clockText = "00:00";
    private string _remainingText = "(90:00)";

    private static readonly TimeSpan MatchDuration = TimeSpan.FromMinutes(90);

    private bool _hubWired;
    private CancellationTokenSource? _reloadCts;
    private int _reloadSeq;

    protected override void OnInitialized()
    {
        if (!_hubWired)
        {
            _hubWired = true;
            HubClient.DashboardChanged += OnDashboardChanged;
        }
    }

    private void OnDashboardChanged(string? _)
    {
        DebouncedReload();
    }

    private void DebouncedReload()
    {
        _reloadCts?.Cancel();
        _reloadCts?.Dispose();
        _reloadCts = new CancellationTokenSource();

        var localSeq = ++_reloadSeq;
        var ct = _reloadCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(300, ct);

                if (localSeq != _reloadSeq) return;

                await ReloadMatchAsync(ct);
            }
            catch (OperationCanceledException) { }
        });
    }

    private async Task ReloadMatchAsync(CancellationToken ct)
    {
        if (_match is null) return;

        var a = NormalizeSlugToSymbol(SlugA);
        var b = NormalizeSlugToSymbol(SlugB);
        if (string.IsNullOrWhiteSpace(a) || string.IsNullOrWhiteSpace(b)) return;

        try
        {
            var updated = await Api.GetMatchBySymbolsAsync(a, b);

            if (updated is not null)
            {
                _match = updated;
                _title = $"{_match.TeamA} vs {_match.TeamB}";
                PushChartPointFromMatch();

                SyncAndStartLocalClock();
                UpdateClockTexts();

                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
        }
    }

    private void StartClock()
    {
        StopClock();

        _tickCts = new CancellationTokenSource();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        _ = Task.Run(async () =>
        {
            try
            {
                while (_timer is not null && await _timer.WaitForNextTickAsync(_tickCts.Token))
                {
                    UpdateClockTexts();
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException) { }
        });
    }

    private void StopClock()
    {
        try { _tickCts?.Cancel(); } catch { }
        _tickCts?.Dispose();
        _tickCts = null;

        _timer?.Dispose();
        _timer = null;
    }

    private void UpdateClockTexts()
    {
        if (_match?.StartTime is null)
        {
            _clockText = "00:00";
            _remainingText = "(90:00)";
            return;
        }

        var startUtc = DateTime.SpecifyKind(_match.StartTime.Value, DateTimeKind.Utc);
        var elapsed = DateTime.UtcNow - startUtc;

        if (elapsed < TimeSpan.Zero) elapsed = TimeSpan.Zero;

        _clockText = $"{(int)elapsed.TotalMinutes:00}:{elapsed.Seconds:00}";

        var remaining = MatchDuration - elapsed;
        if (remaining < TimeSpan.Zero) remaining = TimeSpan.Zero;

        _remainingText = $"({(int)remaining.TotalMinutes:00}:{remaining.Seconds:00})";
    }

    public void Dispose()
    {
        StopClock();
        StopLocalClock();

        if (_hubWired)
        {
            HubClient.DashboardChanged -= OnDashboardChanged;
            _hubWired = false;
        }

        _reloadCts?.Cancel();
        _reloadCts?.Dispose();
        _reloadCts = null;
    }

    private PeriodicTimer? _uiTimer;
    private CancellationTokenSource? _uiCts;

    private DateTime? _startUtc;

    private string _clockLive = "00:00.000";
    private string _remainingLive = "(90:00.000)";

    private void SyncAndStartLocalClock()
    {
        if (_match?.StartTime is null)
        {
            _startUtc = null;
            _clockLive = "00:00.000";
            _remainingLive = "(90:00.000)";
            StopLocalClock();
            return;
        }

        _startUtc = DateTime.SpecifyKind(_match.StartTime.Value, DateTimeKind.Utc);

        UpdateLocalClockTexts(DateTime.UtcNow);

        if (IsOngoing(_match?.Status))
            StartClock();
        else
            StopClock();

        if (IsOngoing(_match.Status))
            StartLocalClock();
        else
            StopLocalClock();
    }

    private void StartLocalClock()
    {
        if (_uiTimer is not null) return;

        _uiCts = new CancellationTokenSource();

        _uiTimer = new PeriodicTimer(TimeSpan.FromMilliseconds(50));

        _ = InvokeAsync(async () =>
        {
            try
            {
                while (_uiTimer is not null && await _uiTimer.WaitForNextTickAsync(_uiCts.Token))
                {
                    UpdateLocalClockTexts(DateTime.UtcNow);
                    StateHasChanged();
                }
            }
            catch (OperationCanceledException) { }
        });
    }

    private void StopLocalClock()
    {
        try { _uiCts?.Cancel(); } catch { }
        _uiCts?.Dispose();
        _uiCts = null;

        _uiTimer?.Dispose();
        _uiTimer = null;
    }

    private void UpdateLocalClockTexts(DateTime nowUtc)
    {
        if (_startUtc is null)
        {
            _clockLive = "00:00.000";
            _remainingLive = "(90:00.000)";
            return;
        }

        var elapsed = nowUtc - _startUtc.Value;
        if (elapsed < TimeSpan.Zero) elapsed = TimeSpan.Zero;

        if (elapsed > MatchDuration) elapsed = MatchDuration;

        var remaining = MatchDuration - elapsed;
        if (remaining < TimeSpan.Zero) remaining = TimeSpan.Zero;

        _clockLive = FormatClock(elapsed);
        _remainingLive = $"({FormatClock(remaining)})";
    }

    private static string FormatClock(TimeSpan t)
    {
        var mm = (int)t.TotalMinutes;
        var ss = t.Seconds;
        var ms = t.Milliseconds;
        return $"{mm:00}:{ss:00}.{ms:000}";
    }

    private readonly List<(DateTime t, decimal v)> _seriesA = new();
    private readonly List<(DateTime t, decimal v)> _seriesB = new();

    private const int _maxPoints = 120;

    private string _polyA = "";
    private string _polyB = "";

    private double _yMin = -1;
    private double _yMax = 1;

    private double _zeroY = 160;

    private void PushChartPointFromMatch()
    {
        if (_match is null) return;

        if (_match.PctA is decimal a && _match.PctB is decimal b)
        {
            var now = DateTime.UtcNow;

            _seriesA.Add((now, a));
            _seriesB.Add((now, b));

            TrimSeries(_seriesA);
            TrimSeries(_seriesB);

            RebuildChartPolylines();
        }
    }

    private static void TrimSeries(List<(DateTime t, decimal v)> s)
    {
        while (s.Count > _maxPoints) s.RemoveAt(0);
    }

    private void RebuildChartPolylines()
    {
        if (_seriesA.Count < 2 || _seriesB.Count < 2) return;

        var all = _seriesA.Select(x => (double)x.v).Concat(_seriesB.Select(x => (double)x.v)).ToList();

        var min = all.Min();
        var max = all.Max();

        var pad = Math.Max(0.2, (max - min) * 0.15);
        _yMin = min - pad;
        _yMax = max + pad;

        if (Math.Abs(_yMax - _yMin) < 0.0001)
        {
            _yMin -= 1;
            _yMax += 1;
        }

        _zeroY = MapY(0);

        _polyA = BuildPolyline(_seriesA);
        _polyB = BuildPolyline(_seriesB);
    }

    private string BuildPolyline(List<(DateTime t, decimal v)> s)
    {
        var n = s.Count;
        if (n < 2) return "";

        var sb = new System.Text.StringBuilder();

        for (int i = 0; i < n; i++)
        {
            var x = (i / (double)(n - 1)) * 1000.0;
            var y = MapY((double)s[i].v);

            sb.Append(x.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture));
            sb.Append(',');
            sb.Append(y.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture));

            if (i < n - 1) sb.Append(' ');
        }

        return sb.ToString();
    }

    private double MapY(double value)
    {
        var t = (value - _yMin) / (_yMax - _yMin);
        t = Math.Clamp(t, 0, 1);
        var y = (1 - t) * 320.0;
        return y;
    }

    private PeriodicTimer? _chartTimer;
    private CancellationTokenSource? _chartCts;

    private void StartChartTimer()
    {
        if (_chartTimer is not null) return;

        _chartCts = new CancellationTokenSource();
        _chartTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));

        _ = InvokeAsync(async () =>
        {
            try
            {
                while (_chartTimer is not null && await _chartTimer.WaitForNextTickAsync(_chartCts.Token))
                {
                    PushChartPointFromMatch();
                    StateHasChanged();
                }
            }
            catch (OperationCanceledException) { }
        });
    }

    private void StopChartTimer()
    {
        try { _chartCts?.Cancel(); } catch { }
        _chartCts?.Dispose();
        _chartCts = null;

        _chartTimer?.Dispose();
        _chartTimer = null;
    }

