        public double YMax { get; init; }
        public double ZeroY { get; init; } = 160;
        public DateTime StartUtc { get; init; }
        public DateTime EndUtc { get; init; }
        public bool HasData => !string.IsNullOrWhiteSpace(PolyA) && !string.IsNullOrWhiteSpace(PolyB);
    }

