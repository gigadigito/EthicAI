        => _isSendingBet
            ? T("sending")
            : IsInvestmentAmountInsufficient
                ? T("walletBalanceGuardInsufficient")
                : $"{T("invest")} {FmtSolAmount(_investmentAmount)}";

    private int _investmentAmountRangeIndex
    {
        get => GetClosestQuickInvestmentAmountIndex(_investmentAmount);
        set
        {
            if (value < 0 || value >= QuickInvestmentAmounts.Length)
                return;

            _investmentAmount = QuickInvestmentAmounts[value];
            _investmentAmountError = "";
        }
    }

    private static string GetBaseSymbol(string pair)
    {
        if (string.IsNullOrWhiteSpace(pair)) return "";

        pair = pair.ToUpperInvariant();

        var quotes = new[] { "USDT", "USDC", "BUSD", "BRL", "EUR", "BTC", "ETH" };

        foreach (var q in quotes)
        {
            if (pair.EndsWith(q) && pair.Length > q.Length)
                return pair.Substring(0, pair.Length - q.Length);
        }

        return pair;
    }

    private string GetCoinIconUrl(string pair)
    {
        var baseSymbol = GetBaseSymbol(pair);
        if (string.IsNullOrWhiteSpace(baseSymbol))
            return string.Empty;

        return CriptoVersus.Web.Services.EnvironmentIsolationGuard.BuildBinanceIconUrl(baseSymbol);
    }

    private static IReadOnlyList<TvPriceChartPoint> BuildPricePoints(IEnumerable<MatchMetricSnapshotDto> snapshots)
        => snapshots
            .OrderBy(x => x.CapturedAtUtc)
            .TakeLast(64)
            .Select(x => new TvPriceChartPoint(
                new DateTimeOffset(DateTime.SpecifyKind(x.CapturedAtUtc, DateTimeKind.Utc)).ToUnixTimeSeconds(),
                x.LastPrice ?? x.PercentageChange))
            .ToList();

    private IReadOnlyList<TvPriceChartPoint> LeftPriceBattlePoints => _leftPriceBattlePoints;
    private IReadOnlyList<TvPriceChartPoint> RightPriceBattlePoints => _rightPriceBattlePoints;
    private bool LeftPriceBattleHasHistory => _leftPriceBattlePoints.Count > 1;
    private bool RightPriceBattleHasHistory => _rightPriceBattlePoints.Count > 1;
    private decimal? LeftPriceBattleCurrentPrice => _leftPriceBattlePoints.Count == 0 ? null : _leftPriceBattlePoints[^1].Value;
    private decimal? RightPriceBattleCurrentPrice => _rightPriceBattlePoints.Count == 0 ? null : _rightPriceBattlePoints[^1].Value;
    private decimal? LeftMarketDisplayPrice => _match is null ? null : GetLatestMarketPrice(_match.TeamAId);
    private decimal? RightMarketDisplayPrice => _match is null ? null : GetLatestMarketPrice(_match.TeamBId);

    private decimal? GetLatestMarketPrice(int teamId)
        => _metricSnapshots
            .Where(x => x.TeamId == teamId && x.LastPrice.HasValue)
            .OrderBy(x => x.CapturedAtUtc)
            .Select(x => x.LastPrice)
            .LastOrDefault();

    private int ResolvePriceBattleCompetitiveness()
    {
        var leftScore = _match?.ScoreA ?? 0;
        var rightScore = _match?.ScoreB ?? 0;
        var leftPct = _match?.PctA ?? 0m;
        var rightPct = _match?.PctB ?? 0m;

        return Math.Clamp(
            100 - (Math.Abs(leftScore - rightScore) * 18) - (int)(Math.Abs(leftPct - rightPct) * 10m),
            30,
            98);
    }

    private double GetRemainingProgress()
    {
        if (_match is null || _match.RemainingMinutes <= 0)
            return 0d;

        var progress = Math.Clamp(_match.RemainingMinutes / 90d, 0d, 1d);
        return progress;
    }

    private double GetFocusProgress()
    {
        var left = Math.Abs((_match?.PctA ?? 0m) - (_match?.PctB ?? 0m));
        var normalized = 1d - Math.Clamp((double)(left / 100m), 0d, 1d);
        return Math.Clamp(normalized, 0d, 1d);
    }

    private string GetFocusColor()
        => (_match?.PctA ?? 0m) >= (_match?.PctB ?? 0m)
            ? MarketAccentPalette.Resolve(_match?.TeamA)
            : MarketAccentPalette.Resolve(_match?.TeamB);

    private async Task RefreshAuthenticatedUserAsync()
    {
        _loggedUserId = await SessionStorage.GetItemAsync<int?>("userId");
        _loggedWalletPublicKey = await SessionStorage.GetItemAsync<string>("walletPublicKey");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await EnsureCurrentMatchLoadedAsync(CancellationToken.None);

        if (_match is null)
            return;

        if (!_tvScriptsInitialized)
        {
            try
            {
                await BrowserTimeZone.EnsureInitializedAsync();
                await RefreshAuthenticatedUserAsync();
                await HubClient.EnsureStartedAsync();
            }
            catch (Exception ex) when (CriptoVersus.Web.Services.InteropSafety.IsDeferredInteropException(ex))
            {
                return;
            }
            catch
            {
                // The match detail still works without these extras during prerender.
            }

            _tvScriptsInitialized = true;
        }

        try
        {
            _tvModeModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "/js/tvMode.js?v=20260610-tvmode-2");
            _tvEventFeedModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "/js/tvEventFeed.mjs?v=20260603-goal-feed-1");
        }
        catch
        {
            return;
        }

        await SyncTvTelemetryAsync();
        await SyncTvEventFeedAsync();
    }

    private async Task SyncTvTelemetryAsync()
    {
        if (_tvModeModule is null || _match is null)
            return;

        var signature = BuildTelemetrySignature();
        if (string.Equals(signature, _lastTelemetrySignature, StringComparison.Ordinal))
            return;

        var payload = BuildTelemetryPayload();

        try
        {
            await _tvModeModule.InvokeVoidAsync("updateTelemetryCharts", payload);
            _lastTelemetrySignature = signature;
        }
        catch
        {
        }
    }

    private async Task SyncTvEventFeedAsync()
    {
        if (_tvEventFeedModule is null || _match is null)
            return;

        var signature = BuildEventFeedSignature();
        if (string.Equals(signature, _lastEventFeedSignature, StringComparison.Ordinal))
            return;

        try
        {
            await _tvEventFeedModule.InvokeVoidAsync("initTvEventFeed", GoalEventFeedId);
            await _tvEventFeedModule.InvokeVoidAsync("refreshTvEventFeed", GoalEventFeedId);
            _lastEventFeedSignature = signature;
        }
        catch
        {
        }
    }

    private object BuildTelemetryPayload()
    {
        var leftPoints = _leftPriceBattlePoints.Select(point => new { time = point.Time, value = (double)point.Value }).ToArray();
        var rightPoints = _rightPriceBattlePoints.Select(point => new { time = point.Time, value = (double)point.Value }).ToArray();

        return new
        {
            left = leftPoints,
            right = rightPoints,
            leftMeta = new
            {
                symbol = RemoveTrailingUsdt(_match?.TeamA),
                logoUrl = GetCoinIconUrl(_match?.TeamA ?? string.Empty),
                accentColor = MarketAccentPalette.Resolve(_match?.TeamA)
            },
            rightMeta = new
            {
                symbol = RemoveTrailingUsdt(_match?.TeamB),
                logoUrl = GetCoinIconUrl(_match?.TeamB ?? string.Empty),
                accentColor = MarketAccentPalette.Resolve(_match?.TeamB)
            },
            scoreEvents = _scoreEvents,
            leftTeamId = _match?.TeamAId ?? 0,
            rightTeamId = _match?.TeamBId ?? 0,
            matchStartTimeUtc = _match?.StartTime is DateTime matchStartTime
                ? EnsureUtc(matchStartTime)
                : (DateTime?)null
        };
    }

    private string BuildTelemetrySignature()
    {
        var leftSnapshot = _leftPriceBattlePoints?.ToArray() ?? Array.Empty<TvPriceChartPoint>();
        var rightSnapshot = _rightPriceBattlePoints?.ToArray() ?? Array.Empty<TvPriceChartPoint>();
        var scoreSnapshot = _scoreEvents?.ToArray() ?? Array.Empty<MatchScoreEventDto>();

        var leftTail = string.Join(",",
            leftSnapshot.Select(point => $"{point.Time}:{point.Value:0.##########}"));

        var rightTail = string.Join(",",
            rightSnapshot.Select(point => $"{point.Time}:{point.Value:0.##########}"));

        var scoreTail = string.Join(",",
            scoreSnapshot.Select(item => $"{item.MatchScoreEventId}:{item.EventSequence}:{item.EventTimeUtc:O}"));

        return string.Join("|",
            CurrentCulture,
            _match?.MatchId ?? 0,
            leftTail,
            rightTail,
            scoreTail,
            _arenaSentimentA?.Classification ?? string.Empty,
            _arenaSentimentB?.Classification ?? string.Empty,
            _arenaSentimentA?.Score ?? 0,
            _arenaSentimentB?.Score ?? 0);
    }

    private string BuildEventFeedSignature()
    {
        if (_scoreEvents.Count == 0)
            return $"{_match?.MatchId ?? 0}|0";

        var entries = _scoreEvents.Select(item => string.Join(":",
            item.MatchScoreEventId,
            item.EventSequence,
            item.TeamId,
            item.TeamSymbol,
            item.RuleType,
            item.EventType,
            item.Points,
            item.EventTimeUtc.ToString("O", CultureInfo.InvariantCulture)));

        return string.Join("|",
            CurrentCulture,
            _match?.MatchId ?? 0,
            _scoreEvents.Count,
            string.Join(",", entries));
    }

    protected override Task OnParametersSetAsync()
    {
        var routeKey = BuildCurrentRouteKey();

        if (!string.Equals(routeKey, _currentRouteKey, StringComparison.Ordinal))
        {
            _currentRouteKey = routeKey;
            _loadedRouteKey = string.Empty;
            _loadingRouteKey = string.Empty;
            ResetMatchVisualStateForRouteChange();
        }

        return Task.CompletedTask;
    }

    private async Task EnsureCurrentMatchLoadedAsync(CancellationToken ct)
    {
        var routeKey = BuildCurrentRouteKey();

        if (string.IsNullOrWhiteSpace(routeKey))
            return;

        if (string.Equals(_loadedRouteKey, routeKey, StringComparison.Ordinal)
            || string.Equals(_loadingRouteKey, routeKey, StringComparison.Ordinal))
            return;

        _loadingRouteKey = routeKey;
        _loading = true;
        _error = null;
        await InvokeAsync(StateHasChanged);

        try
        {
            var loadedMatch = await LoadRequestedMatchAsync(ct);

            if (loadedMatch is null)
            {
                _match = null;
                var a = NormalizeSlugToSymbol(SlugA);
                var b = NormalizeSlugToSymbol(SlugB);
                _error = MatchId is int requestedId
                    ? $"Nenhuma partida encontrada para o match #{requestedId}."
                    : $"Nenhuma partida encontrada para {a} vs {b}.";
                _initialLoadCompleted = true;
                return;
            }

            _match = loadedMatch;
            _title = $"{GetMatchTitleSymbol(_match.TeamA)} vs {GetMatchTitleSymbol(_match.TeamB)}";

            await LoadMetricChartsAsync(ct);

            await StartOrRestartMatchClockAsync();

            _loadedRouteKey = routeKey;
            _initialLoadCompleted = true;
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _initialLoadCompleted = true;
        }
        finally
        {
            if (string.Equals(_loadingRouteKey, routeKey, StringComparison.Ordinal))
                _loadingRouteKey = string.Empty;

            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string BuildCurrentRouteKey()
    {
        if (MatchId is int requestedId && requestedId > 0)
            return $"id:{requestedId}";

        return $"symbols:{NormalizeSlugToSymbol(SlugA)}-vs-{NormalizeSlugToSymbol(SlugB)}";
    }

    private void ResetMatchVisualStateForRouteChange()
    {
        _loading = true;
        _initialLoadCompleted = false;
        _error = null;
        _match = null;
        _title = "Match";
        _metricSnapshots = new();
        _scoreEvents = new();
        _arenaSentimentA = null;
        _arenaSentimentB = null;
        _arenaSentimentLoading = false;
        _leftPriceBattlePoints.Clear();
        _rightPriceBattlePoints.Clear();
        _percentageChart = ChartSeriesState.Empty;
        _volumeChart = ChartSeriesState.Empty;
        _lastTelemetrySignature = string.Empty;
        _lastEventFeedSignature = string.Empty;
        _lastMetricHistoryLogKey = string.Empty;
        _lastAutoReloadUtc = DateTime.MinValue;
        _lastAppliedScoreVersion = -1;
        _clockGeneration = 0;

        _reloadCts?.Cancel();
        _reloadCts?.Dispose();
        _reloadCts = null;
        _reloadSeq++;

        StopClock();
        StopLocalClock();
    }

    private static string NormalizeSlugToSymbol(string? slug)
    {
        if (string.IsNullOrWhiteSpace(slug)) return "";
        var s = slug.Trim().Replace("-", "").Replace("_", "").ToUpperInvariant();
        return new string(s.Where(char.IsLetterOrDigit).ToArray());
    }

    private static string FormatPct(decimal? v)
        => v is null ? "—" : $"{(v.Value >= 0 ? "+" : "")}{v.Value:0.00}%";

    private string FormatMarketPrice(decimal? value)
    {
        if (value is null)
            return "—";

        var culture = CultureInfo.GetCultureInfo(CurrentCulture == "en" ? "en-US" : "pt-BR");
        var prefix = CurrentCulture == "en" ? "$" : "US$ ";
        var abs = Math.Abs(value.Value);
        var format = abs switch
        {
            >= 1000m => "N2",
            >= 1m => "N4",
            >= 0.01m => "N6",
            _ => "N8"
        };

        return $"{prefix}{value.Value.ToString(format, culture)}";
    }

    private static string FormatSvgNumber(double value)
        => value.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private static string FormatCompactNumber(decimal? value)
    {
        if (value is null)
            return "—";

        var abs = Math.Abs(value.Value);
        return abs switch
        {
            >= 1_000_000_000m => $"{value.Value / 1_000_000_000m:0.##}B",
            >= 1_000_000m => $"{value.Value / 1_000_000m:0.##}M",
            >= 1_000m => $"{value.Value / 1_000m:0.##}K",
            _ => $"{value.Value:0.##}"
        };
    }

    private static string GetPctClass(decimal? v)
        => v is null ? "pct pct--neutral"
           : v.Value > 0 ? "pct pct--up"
           : v.Value < 0 ? "pct pct--down"
           : "pct pct--neutral";

    private static string GetInitials(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return "??";
        var clean = new string(s.Where(char.IsLetterOrDigit).ToArray());
        if (clean.Length <= 3) return clean.ToUpperInvariant();
        return clean.Substring(0, 3).ToUpperInvariant();
    }

    private static string GetDisplayTeamName(string? symbol)
    {
        var normalized = symbol?.Trim().ToUpperInvariant() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(normalized))
            return "-";

        var quotes = new[] { "USDT", "USDC", "BUSD", "BRL", "EUR", "BTC", "ETH" };
        foreach (var quote in quotes)
        {
            if (normalized.Length > quote.Length && normalized.EndsWith(quote, StringComparison.OrdinalIgnoreCase))
                return normalized[..^quote.Length];
        }

        return normalized;
    }
    private string GetWinnerLogoUrl(MatchDto match)
    {
        var winnerTeamId = GetEffectiveWinnerTeamId(match);

        if (winnerTeamId == match.TeamAId)
            return GetCoinIconUrl(match.TeamA);

        if (winnerTeamId == match.TeamBId)
            return GetCoinIconUrl(match.TeamB);

        return string.Empty;
    }
    private static string GetMatchTitleSymbol(string? symbol)
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return "-";

        var normalized = symbol.Trim().ToUpperInvariant();
        if (normalized.EndsWith("-USDT", StringComparison.OrdinalIgnoreCase))
            return normalized[..^5];

        if (normalized.EndsWith("USDT", StringComparison.OrdinalIgnoreCase))
            return normalized[..^4];

        return normalized;
    }

    private static string RemoveTrailingUsdt(string? symbol)
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return string.Empty;

        return symbol.EndsWith("USDT", StringComparison.OrdinalIgnoreCase)
            ? symbol[..^4]
            : symbol;
    }

    private string GetFinishedAtUtcLabel(MatchDto match)
    {
        if (!match.EndTime.HasValue)
            return T("finishedAtUtc", "-");

        return T("finishedAtUtc", FormatUtcDateTime(match.EndTime.Value));
    }

    private static string FormatUtcDateTime(DateTime value)
        => EnsureUtc(value).ToString("yyyy-MM-dd HH:mm", System.Globalization.CultureInfo.InvariantCulture);

    private static DateTime EnsureUtc(DateTime value)
        => value.Kind switch
        {
            DateTimeKind.Utc => value,
            DateTimeKind.Local => value.ToUniversalTime(),
            _ => DateTime.SpecifyKind(value, DateTimeKind.Utc)
        };

    private static bool IsOngoing(string? status)
        => !string.IsNullOrWhiteSpace(status)
           && status.Trim().Equals("Ongoing", StringComparison.OrdinalIgnoreCase);

    private static bool IsCompleted(string? status)
        => !string.IsNullOrWhiteSpace(status)
           && status.Trim().Equals("Completed", StringComparison.OrdinalIgnoreCase);

    private static bool IsPending(string? status)
        => !string.IsNullOrWhiteSpace(status)
           && status.Trim().Equals("Pending", StringComparison.OrdinalIgnoreCase);

    private bool HasReachedLocalTimeLimit()
        => _startUtc.HasValue && DateTime.UtcNow - _startUtc.Value >= MatchDuration;

    private bool ShouldShowResultStage(MatchDto? match)
        => match is not null
           && (IsCompleted(match.Status) || HasReachedLocalTimeLimit());

    private bool ShouldShowLiveBadge(MatchDto? match)
        => match is not null
           && IsOngoing(match.Status)
           && !HasReachedLocalTimeLimit();

    private string GetPresentationStatusText(MatchDto? match)
    {
        if (match is null)
            return "-";

        if (IsCompleted(match.Status))
            return T("completed");

        if (HasReachedLocalTimeLimit())
            return T("closing");

        return string.Equals(match.Status, "Ongoing", StringComparison.OrdinalIgnoreCase)
            ? T("live2")
            : string.Equals(match.Status, "Pending", StringComparison.OrdinalIgnoreCase)
                ? T("pending")
                : match.Status;
    }

    private int? GetEffectiveWinnerTeamId(MatchDto? match)
    {
        if (match is null)
            return null;

        if (match.WinnerTeamId.HasValue)
            return match.WinnerTeamId;

        var canResolveFromScore =
            IsCompleted(match.Status) ||
            HasReachedLocalTimeLimit();

        if (!canResolveFromScore)
            return null;

        if (match.ScoreA > match.ScoreB)
            return match.TeamAId;

        if (match.ScoreB > match.ScoreA)
            return match.TeamBId;

        return null;
    }

    private static string GetStatusBadgeClass(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return "text-bg-dark border border-secondary-subtle";

        var s = status.Trim().ToLowerInvariant();
        return s switch
        {
            "ongoing" => "bg-success",
            "pending" => "bg-warning text-dark",
            "completed" => "bg-secondary",
            "canceled" or "cancelled" => "bg-danger",
            _ => "text-bg-dark border border-secondary-subtle"
        };
    }

    private static string GetTrendIcon(decimal? v)
        => v is null ? "•"
           : v.Value > 0 ? "▲"
           : v.Value < 0 ? "▼"
           : "•";

    private string GetWinnerDisplayText(MatchDto match)
    {
        var effectiveWinnerTeamId = GetEffectiveWinnerTeamId(match);

        if (!string.IsNullOrWhiteSpace(match.WinnerTeamSymbol))
            return GetDisplayTeamName(match.WinnerTeamSymbol);

        if (effectiveWinnerTeamId == match.TeamAId)
            return GetDisplayTeamName(match.TeamA);

        if (effectiveWinnerTeamId == match.TeamBId)
            return GetDisplayTeamName(match.TeamB);

        return T("noWinner2");
    }

    private string GetWinnerFxClass(int teamId)
        => GetEffectiveWinnerTeamId(_match) == teamId ? "team-badge--winner" : string.Empty;

    private bool HasWinnerTeam(int teamId)
        => GetEffectiveWinnerTeamId(_match) == teamId && HasWinnerCelebration(_match);

    private bool HasWinnerCelebration(MatchDto? match)
        => match is not null
           && GetEffectiveWinnerTeamId(match).HasValue
           && match.ScoreA != match.ScoreB;

    private string CurrentCulture => AppCulture.GetCurrentRouteCulture(Nav);
    private bool IsEnglish => CurrentCulture == "en";
    private string T(string key, params object?[] args)
        => L.T($"matchDetail.{key}", CurrentCulture, args);

    private string BuildAbsolute(string path)
        => SeoDefaults.BuildAbsoluteUrl(Config, Nav, path.StartsWith('/') ? path : "/" + path);

    private static string GetScoreEventIcon(MatchScoreEventDto scoreEvent)
        => scoreEvent.Points > 0 ? "⚽" : "◎";

    private string GetScoreEventIconTitle(MatchScoreEventDto scoreEvent)
        => scoreEvent.Points > 0
            ? (IsEnglish
                ? $"{scoreEvent.TeamSymbol} scored {scoreEvent.Points} point(s)"
                : $"{scoreEvent.TeamSymbol} marcou {scoreEvent.Points} ponto(s)")
            : T("scoringEvent");

    private string GetSettlementHumanText(MatchDto match)
        => match.EndReasonCode switch
        {
            "DRAW_ZERO_ZERO" => T("theMatchEndedWithoutAWinnerNoFeeWasChargedAndAllBetsMustBeFullyRefunded"),
            "NO_BETS_ON_TEAM_A" or "NO_BETS_ON_TEAM_B" => T("thereWasATechnicalWinnerOnTheScoreboardButThereWasNoValidOpposingPoolNoFinancialGainOrHouseFeeWasApplied"),
            "NO_COUNTERPARTY" => T("thereWasNoValidFinancialCounterpartyNoFinancialLossOrHouseFeeWasApplied"),
            "CANCELLED" => T("matchCanceledNoHouseFeeAndFullRefundOfBets"),
            "NO_WINNER" => T("matchFinishedWithoutAValidFinancialWinnerBetsMustBeRefunded"),
            _ => string.IsNullOrWhiteSpace(match.EndReasonDetail)
                ? T("settlementCompletedAccordingToTheMatchRule")
                : match.EndReasonDetail!
        };

    private string GetLocalizedScoreEventDescription(MatchScoreEventDto scoreEvent)
    {
        if (!IsEnglish)
            return scoreEvent.Description;

        return scoreEvent.RuleType switch
        {
            "PercentThreshold" => $"{scoreEvent.TeamSymbol} scored {scoreEvent.Points} point(s) by reaching the percentage threshold.",
            "PercentageCrossover" => $"{scoreEvent.TeamSymbol} scored {scoreEvent.Points} point(s) on an upward percentage crossover.",
            "VolumeWindow" => $"{scoreEvent.TeamSymbol} scored {scoreEvent.Points} point(s) by leading the volume window.",
            "VolumeCrossover" => $"{scoreEvent.TeamSymbol} scored {scoreEvent.Points} point(s) on an upward volume crossover.",
            "ArenaPressure" => $"{scoreEvent.TeamSymbol} scored {scoreEvent.Points} point(s) through Arena Pressure dominance.",
            "CandleBattleDominance" => $"{scoreEvent.TeamSymbol} scored {scoreEvent.Points} point(s) by opening Candle Battle dominance.",
            "CandleBattleLeadChange" => $"{scoreEvent.TeamSymbol} scored {scoreEvent.Points} point(s) by opening Candle Battle dominance.",
            _ => string.IsNullOrWhiteSpace(scoreEvent.Description)
                ? $"{scoreEvent.TeamSymbol} scored {scoreEvent.Points} point(s)."
                : scoreEvent.Description
