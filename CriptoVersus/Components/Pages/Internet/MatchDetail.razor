    private static string PrettyJsonOrRaw(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
            return "";

        try
        {
            using var doc = JsonDocument.Parse(text);
            return JsonSerializer.Serialize(doc, new JsonSerializerOptions
            {
                WriteIndented = true
            });
        }
        catch
        {
            return text;
        }
    }

    private string GetBetExceptionMessage(Exception ex, string selectedUserDisplay)
    {
        if (ex.ToString().Contains("ONCHAIN_MATCH_NOT_INITIALIZED", StringComparison.OrdinalIgnoreCase))
            return $"ONCHAIN_MATCH_NOT_INITIALIZED. User={selectedUserDisplay}.";

        return $"Investment request error. User={selectedUserDisplay}.";
