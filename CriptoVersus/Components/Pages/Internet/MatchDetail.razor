@page "/match/{SlugA}-vs-{SlugB}"
@page "/match/{SlugA}-vs-{SlugB}/{MatchId:int}"
@using System.Net.Http
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Globalization
@using System.Text.Json
@using DTOs
@using CriptoVersus.Web.Services
@using CriptoVersus.Web.Components.Shared
@inject CriptoVersus.Web.Services.CriptoVersusApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject HttpClient Http
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject CriptoVersus.Web.Services.DashboardHubClient HubClient
@inject IConfiguration Config
@inject CriptoVersus.Web.Services.BrowserTimeZoneService BrowserTimeZone
@inject AppCultureService AppCulture
@inject LocalizationService L
@rendermode InteractiveServer
@implements IDisposable
@implements IAsyncDisposable
@if (EmitPageTitle)
{
    <BasicSeoHead Title="@SeoTitle"
                  Description="@SeoDescription"
                  CanonicalUrl="@SeoCanonicalUrl"
                  ImageUrl="@SeoImageUrl"
                  ImageAlt="@SeoTitle"
                  Robots="noindex,nofollow,noarchive" />
}

<div class="match-detail-wide-container py-3">

    @if (_match is null && ShouldShowInitialLoadingShell)
    {
        <section class="match-loading-shell mb-4" aria-busy="true" aria-live="polite">
            <div class="match-loading-shell__bg"></div>
            <div class="match-loading-shell__content">
                <div class="match-loading-shell__header">
                    <div>
                        <div class="match-loading-shell__eyebrow">CRIPTO ARENA</div>
                        <div class="match-loading-shell__title">@T("loadingMatch")</div>
                    </div>
                    <div class="match-loading-shell__pill">
                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                        <span>@T("loadingMatch")</span>
                    </div>
                </div>

                <div class="match-loading-shell__hero">
                    <div class="match-loading-shell__team">
                        <span class="match-loading-shell__coin"></span>
                        <span class="match-loading-shell__line match-loading-shell__line--lg"></span>
                        <span class="match-loading-shell__line match-loading-shell__line--sm"></span>
                    </div>
                    <div class="match-loading-shell__score">
                        <span></span>
                        <strong>vs</strong>
                        <span></span>
                    </div>
                    <div class="match-loading-shell__team match-loading-shell__team--right">
                        <span class="match-loading-shell__coin"></span>
                        <span class="match-loading-shell__line match-loading-shell__line--lg"></span>
                        <span class="match-loading-shell__line match-loading-shell__line--sm"></span>
                    </div>
                </div>

                <div class="match-loading-shell__cards">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            </div>
        </section>
    }
    else if (!string.IsNullOrWhiteSpace(_error) && _match is null)
    {
        <div class="alert alert-danger">
            <strong>@T("error")</strong> @_error
        </div>
    }
    else if (_match is null)
    {
        <div class="alert alert-warning">
            @T("matchNotFound")
        </div>
    }
    else
    {
        @if (_loading)
        {
            <div class="d-flex align-items-center gap-2 text-muted mb-3">
                <div class="spinner-border spinner-border-sm" role="status"></div>
                <span>@T("loadingMatch")</span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-warning mb-3">
                <strong>@T("error")</strong> @_error
            </div>
        }

        <section class="match-semantic-summary">
            <h2>@GetSemanticSummaryTitle()</h2>
            <p>@GetSemanticSummaryIntro()</p>
            <p>@GetSemanticSummaryPools()</p>
            <p>@GetSemanticSummaryRewards()</p>
        </section>

        <p class="small text-muted mb-4">@T("marketDataDisclaimer")</p>

        <section id="social-share-card" class="social-share-card mb-4" aria-label="Social share card">
            <div class="social-share-card__bg"></div>
            <div class="social-share-card__shell">
                <div class="social-share-card__header">
                    <div>
                        <div class="social-share-card__eyebrow">CRIPTO ARENA</div>
                        <div class="social-share-card__title">
                            <span class="social-share-card__title-team social-share-card__title-team--left">
                                @GetMatchTitleSymbol(_match.TeamA)
                            </span>
                            <span class="social-share-card__title-vs">vs</span>
                            <span class="social-share-card__title-team social-share-card__title-team--right">
                                @GetMatchTitleSymbol(_match.TeamB)
                            </span>
                        </div>
                    </div>

                    <div class="social-share-card__header-meta">
                        <span class="social-share-card__status @(ShouldShowLiveBadge(_match) ? "social-share-card__status--live" : "social-share-card__status--final")">
                            @(ShouldShowLiveBadge(_match) ? T("live") : GetPresentationStatusText(_match).ToUpperInvariant())
                        </span>
                        <span class="social-share-card__match-id">Match #@_match.MatchId</span>
                    </div>
                </div>

                <div class="social-share-card__hero">
                    <div class="social-share-hero-team social-share-hero-team--a">
                        <div class="team-badge team-badge--a @(GetWinnerFxClass(_match.TeamAId))">
                            @if (HasWinnerTeam(_match.TeamAId))
                            {
                                <span class="winner-firework winner-firework--badge winner-firework--badge-a"></span>
                                <span class="winner-firework winner-firework--badge winner-firework--badge-b"></span>
                            }
                            <div class="coin-wrap" title="@_match.TeamA">
                                <div class="coin-skeleton"></div>
                                <img class="coin-img"
                                     src="@GetCoinIconUrl(_match.TeamA)"
                                     alt="@_match.TeamA"
                                     loading="lazy"
                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                <div class="coin-fallback d-none">@GetInitials(_match.TeamA)</div>
                            </div>
                        </div>
                        <div>
                            <div class="team-name"><MarketPairText Symbol="@_match.TeamA" /></div>
                            <div class="team-sub">
                                <span class="@GetPctClass(_match.PctA)">@FormatPct(_match.PctA)</span>
                            </div>
                        </div>
                    </div>

                    <div class="social-share-hero-score">
                        @if (ShouldShowLiveBadge(_match))
                        {
                            <div class="match-live">
                                <span class="badge rounded-pill bg-danger match-live__pill">
                                    <span class="match-live__dot"></span>
                                    @T("live")
                                </span>
                            </div>
                        }
                        else
                        {
                            <div class="match-live">
                                <span class="badge rounded-pill text-bg-dark border border-secondary-subtle match-live__pill">
                                    @GetPresentationStatusText(_match)
                                </span>
                            </div>
                        }

                        <div class="scoreline">
                            <span class="score score--left">@_match.ScoreA</span>
                            <span class="score-sep"><img class="tv-versus-image" src="img/vs.png" /></span>
                            <span class="score score--right">@_match.ScoreB</span>
                        </div>

                        @if (_match.IsFinished)
                        {
                            <div class="mt-2">
                                <span class="badge rounded-pill text-bg-info border border-info-subtle match-live__pill">
                                    @GetFinishedAtUtcLabel(_match)
                                </span>
                            </div>
                        }
                    </div>

                    <div class="social-share-hero-team social-share-hero-team--b">
                        <div>
                            <div class="team-name"><MarketPairText Symbol="@_match.TeamB" /></div>
                            <div class="team-sub">
                                <span class="@GetPctClass(_match.PctB)">@FormatPct(_match.PctB)</span>
                            </div>
                        </div>
                        <div class="team-badge team-badge--b @(GetWinnerFxClass(_match.TeamBId))">
                            @if (HasWinnerTeam(_match.TeamBId))
                            {
                                <span class="winner-firework winner-firework--badge winner-firework--badge-a"></span>
                                <span class="winner-firework winner-firework--badge winner-firework--badge-b"></span>
                            }
                            <div class="coin-wrap" title="@_match.TeamB">
                                <div class="coin-skeleton"></div>
                                <img class="coin-img"
                                     src="@GetCoinIconUrl(_match.TeamB)"
                                     alt="@_match.TeamB"
                                     loading="lazy"
                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                <div class="coin-fallback d-none">@GetInitials(_match.TeamB)</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="social-share-card__stats">
                    <div class="card match-card social-share-match-card social-share-team-card--a p-3">
                        <div class="social-share-team-card__top">
                            <div class="coin-wrap coin-wrap--sm social-share-team-card__coin" title="@_match.TeamA">
                                <div class="coin-skeleton"></div>
                                <img class="coin-img coin-img--sm"
                                     src="@GetCoinIconUrl(_match.TeamA)"
                                     alt="@_match.TeamA"
                                     loading="lazy"
                                     onload="this.previousElementSibling?.classList.add('d-none')"
                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                <div class="coin-fallback d-none">@GetInitials(_match.TeamA)</div>
                            </div>
                            <div class="social-share-team-card__identity">
                                <div class="social-share-team-card__symbol"><MarketPairText Symbol="@_match.TeamA" /></div>
                                <div class="social-share-team-card__pct @GetPctClass(_match.PctA)">@FormatPct(_match.PctA)</div>
                            </div>
                            <button class="btn social-share-team-card__cta social-share-team-card__cta--a"
                                    type="button"
                                    disabled="@(!CanBetOnCurrentMatch() || _isSendingBet)"
                                    @onclick="() => OpenInvestmentAmountModalAsync(_match.TeamAId, _match.TeamA)">
                                @T("invest")
                            </button>
                        </div>

                        <div class="social-share-team-card__metrics">
                            <div class="social-share-team-card__metric-row">
                                <span>Pool</span>
                                <strong>@_match.PoolStrengthTeamA%</strong>
                            </div>
                            <div class="social-share-team-card__metric-row">
                                <span>@T("bets")</span>
                                <strong>@_match.BetCountTeamA</strong>
                            </div>
                            <div class="social-share-team-card__metric-row">
                                <span>Volume</span>
                                <strong>@FmtSolAmount(_match.TotalAmountTeamA)</strong>
                            </div>
                        </div>
                    </div>

                    <MatchClockCard ShowWinnerCelebration="@HasWinnerCelebration(_match)"
                                    ShowResultStage="@ShouldShowResultStage(_match)"
                                    ShowLiveBadge="@ShouldShowLiveBadge(_match)"
                                    HasWinner="@HasWinnerCelebration(_match)"
                                    ScoreA="@_match.ScoreA"
                                    ScoreB="@_match.ScoreB"
                                    ClockText="@_clockLive"
                                    RemainingValue="@_remainingLive"
                                    WinnerName="@GetFinalCardHeadline(_match)"
                                    WinnerLogoUrl="@GetWinnerLogoUrl(_match)"
                                    StatusText="@GetPresentationStatusText(_match)"
                                    FinalResultText="@T("finalResult")"
                                    WinnerLabelText="@T("winner")"
                                    NoLeaderLabelText="@T("matchLeader")"
                                    FinalScoreText="@T("finalScore")"
                                    MatchClockText="@T("matchClock")"
                                    RemainingText="@T("remaining")"
                                    LiveText="@T("live")"
                                    WinnerSummaryText="@T("wonTheMatch")"
                                    DrawSummaryText="@T("noLeaderDefined")" />



                    <div class="card match-card social-share-match-card social-share-team-card--b p-3">
                        <div class="social-share-team-card__top">
                            <div class="coin-wrap coin-wrap--sm social-share-team-card__coin" title="@_match.TeamB">
                                <div class="coin-skeleton"></div>
                                <img class="coin-img coin-img--sm"
                                     src="@GetCoinIconUrl(_match.TeamB)"
                                     alt="@_match.TeamB"
                                     loading="lazy"
                                     onload="this.previousElementSibling?.classList.add('d-none')"
                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                <div class="coin-fallback d-none">@GetInitials(_match.TeamB)</div>
                            </div>
                            <div class="social-share-team-card__identity">
                                <div class="social-share-team-card__symbol"><MarketPairText Symbol="@_match.TeamB" /></div>
                                <div class="social-share-team-card__pct @GetPctClass(_match.PctB)">@FormatPct(_match.PctB)</div>
                            </div>
                            <button class="btn social-share-team-card__cta social-share-team-card__cta--b"
                                    type="button"
                                    disabled="@(!CanBetOnCurrentMatch() || _isSendingBet)"
                                    @onclick="() => OpenInvestmentAmountModalAsync(_match.TeamBId, _match.TeamB)">
                                @T("invest")
                            </button>
                        </div>

                        <div class="social-share-team-card__metrics">
                            <div class="social-share-team-card__metric-row">
                                <span>Pool</span>
                                <strong>@_match.PoolStrengthTeamB%</strong>
                            </div>
                            <div class="social-share-team-card__metric-row">
                                <span>@T("bets")</span>
                                <strong>@_match.BetCountTeamB</strong>
                            </div>
                            <div class="social-share-team-card__metric-row">
                                <span>Volume</span>
                                <strong>@FmtSolAmount(_match.TotalAmountTeamB)</strong>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="social-share-card__tv-grid social-share-card__tv-grid--columns">
                    <div class="social-share-card__tv-column social-share-card__tv-column--left">
                        <div class="social-share-card__tv-slot social-share-card__tv-slot--price">
                            <TvMatchPriceBattleChart Culture="@CurrentCulture"
                                                     LeftSymbol="@_match.TeamA"
                                                     LeftDisplayName="@_match.TeamA"
                                                     LeftLogoUrl="@GetCoinIconUrl(_match.TeamA)"
                                                     LeftChartId="tv-telemetry-chart-left"
                                                     LeftCurrentPrice="@LeftPriceBattleCurrentPrice"
                                                     LeftChangePercent="@_match.PctA"
                                                     LeftColor="#ffd76e"
                                                     LeftPoints="@LeftPriceBattlePoints"
                                                     LeftHasPriceHistory="@LeftPriceBattleHasHistory"
                                                     RightSymbol="@_match.TeamB"
                                                     RightDisplayName="@_match.TeamB"
                                                     RightLogoUrl="@GetCoinIconUrl(_match.TeamB)"
                                                     RightChartId="tv-telemetry-chart-right"
                                                     RightCurrentPrice="@RightPriceBattleCurrentPrice"
                                                     RightChangePercent="@_match.PctB"
                                                     RightColor="#53c8ff"
                                                     RightPoints="@RightPriceBattlePoints"
                                                     RightHasPriceHistory="@RightPriceBattleHasHistory"
                                                     Competitiveness="@ResolvePriceBattleCompetitiveness()"
                                                     BroadcastFocusLabel="@GetPresentationStatusText(_match)"
                                                     BroadcastRotationRemaining="@_remainingLive"
                                                     BroadcastRotationProgress="@GetRemainingProgress()"
                                                     BroadcastFocusProgress="@GetFocusProgress()"
                                                     BroadcastFocusColor="#53c8ff"
                                                     IsSignalStable="@(!_loading && string.IsNullOrWhiteSpace(_error))" />
                        </div>

                        <div class="social-share-card__tv-slot social-share-card__tv-slot--pressure">
                            <TvArenaPressureGauge LeftSymbol="@RemoveTrailingUsdt(_match.TeamA)"
                                                  LeftDisplayName="@_match.TeamA"
                                                  LeftLogoUrl="@GetCoinIconUrl(_match.TeamA)"
                                                  LeftPressurePercent="@GetArenaPressureScore(_arenaSentimentA)"
                                                  LeftMomentumLabel="@GetArenaSentimentLabel(_arenaSentimentA)"
                                                  LeftColor="#ffd76e"
                                                  RightSymbol="@RemoveTrailingUsdt(_match.TeamB)"
                                                  RightDisplayName="@_match.TeamB"
                                                  RightLogoUrl="@GetCoinIconUrl(_match.TeamB)"
                                                  RightPressurePercent="@GetArenaPressureScore(_arenaSentimentB)"
                                                  RightMomentumLabel="@GetArenaSentimentLabel(_arenaSentimentB)"
                                                  RightColor="#53c8ff"
                                                  CurrentPressurePercent="@GetArenaCurrentPressureScore()"
                                                  StatusLabel="@string.Empty"
                                                  Description="@string.Empty"
                                                  IsCompact="true"
                                                  Culture="@CurrentCulture" />
                        </div>
                    </div>

                    <div class="social-share-card__tv-column social-share-card__tv-column--right">
                        <div class="social-share-card__tv-slot social-share-card__tv-slot--candle">
                            <TvCandleBattle LeftTickerLabel="@_match.TeamA"
                                            RightTickerLabel="@_match.TeamB"
                                            LeftHeroLabel="@GetBaseSymbol(_match.TeamA)"
                                            RightHeroLabel="@GetBaseSymbol(_match.TeamB)"
                                            LeftLogoUrl="@GetCoinIconUrl(_match.TeamA)"
                                            RightLogoUrl="@GetCoinIconUrl(_match.TeamB)"
                                            LeftChangePercent="@_match.PctA"
                                            RightChangePercent="@_match.PctB"
                                            LeftPoints="@LeftPriceBattlePoints"
                                            RightPoints="@RightPriceBattlePoints"
                                            Culture="@CurrentCulture"
                                            AriaLabel="@($"{_match.TeamA} vs {_match.TeamB} candle battle arena")" />
                        </div>

                        <div class="social-share-card__tv-slot social-share-card__tv-slot--events">
                            <TvGoalEventFeed FeedId="@GoalEventFeedId"
                                             Culture="@CurrentCulture"
                                             Items="@_scoreEvents.OrderByDescending(x => x.EventSequence).Take(8).ToList()"
                                             FormatTime="FormatEventTime"
                                             DescribeFallback="GetLocalizedScoreEventDescription"
                                             ResolveTeamLogoUrl="GetCoinIconUrl"
                                             EmptyTitle="@T("scoringLog")"
                                             EmptySubtitle="@T("noScoringEventsHaveBeenRecordedForThisMatchYet")" />
                        </div>
                    </div>
                </div>

                <div class="social-share-card__footer">
                    <div class="social-share-card__brand">CriptoVersus</div>
                    <div class="social-share-card__footer-meta">
                        <span>@GetPresentationStatusText(_match)</span>
                        <span>•</span>
                        <span><MarketPairText Symbol="@_match.TeamA" /> vs <MarketPairText Symbol="@_match.TeamB" /></span>
                    </div>
                </div>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(_betResponseBody) && CanSeeInvestmentDebug)
        {
            <div class="accordion mb-3" id="investmentReturnAccordion">
                <div class="accordion-item bg-dark border-secondary">
                    <h2 class="accordion-header" id="investmentReturnHeading">
                        <button class="accordion-button @(_isInvestmentReturnOpen ? "" : "collapsed") bg-dark text-light"
                                type="button"
                                @onclick="ToggleInvestmentReturn"
                                aria-expanded="@_isInvestmentReturnOpen"
                                aria-controls="investmentReturnCollapse">
                            @T("investmentResponse")
                        </button>
                    </h2>
                    <div id="investmentReturnCollapse"
                         class="accordion-collapse collapse @(_isInvestmentReturnOpen ? "show" : "")"
                         aria-labelledby="investmentReturnHeading">
                        <div class="accordion-body">
                            <pre class="bg-dark text-white border rounded p-3 small mb-0" style="white-space: pre-wrap;">@_betResponseBody</pre>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- =========================
             TECH PANEL + ACTIONS
             ========================= -->
        <div class="row g-3">
            <div class="col-12 col-lg-8">
                <div id="match-investment" class="card match-panel p-3">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div class="fw-bold">@T("matchPanel")</div>

                        <span class="badge @GetStatusBadgeClass(_match.Status)">
                            @_match.Status
                        </span>
                    </div>

                    <div class="row mt-3 g-3 small">
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("elapsed")</div>
                            <div class="fw-semibold">@_match.ElapsedMinutes min</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("remaining")</div>
                            <div class="fw-semibold">@_match.RemainingMinutes min</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("score")</div>
                            <div class="fw-semibold">@_match.ScoreA x @_match.ScoreB</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("match")</div>
                            <div class="fw-semibold">#@_match.MatchId</div>
                        </div>
                        <div class="col-12">
                            <div class="text-muted">@T("activeRule")</div>
                            <div class="fw-semibold">@GetRuleLabel(_match.ScoringRuleType)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("winner")</div>
                            <div class="fw-semibold">@(_match.WinnerTeamSymbol ?? T("noWinner"))</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("settlementReason")</div>
                            <div class="fw-semibold">@(_match.EndReasonCode ?? "-")</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("validFinancialDispute")</div>
                            <div class="fw-semibold">@(_match.HasValidFinancialDispute? T("yes") : T("no"))</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("betsOnBothSides")</div>
                            <div class="fw-semibold">@(_match.HasBetsOnBothSides? T("yes") : T("no"))</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("walletsOnTeamA")</div>
                            <div class="fw-semibold">@_match.WalletCountTeamA</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("walletsOnTeamB")</div>
                            <div class="fw-semibold">@_match.WalletCountTeamB</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("betsOnTeamA")</div>
                            <div class="fw-semibold">@_match.BetCountTeamA</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("betsOnTeamB")</div>
                            <div class="fw-semibold">@_match.BetCountTeamB</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("totalOnTeamA")</div>
                            <div class="fw-semibold">@FmtSolAmount(_match.TotalAmountTeamA)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("totalOnTeamB")</div>
                            <div class="fw-semibold">@FmtSolAmount(_match.TotalAmountTeamB)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("winningPool")</div>
                            <div class="fw-semibold">@FmtSolAmount(_match.WinningPool)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("losingPool")</div>
                            <div class="fw-semibold">@FmtSolAmount(_match.LosingPool)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("totalPool")</div>
                            <div class="fw-semibold">@FmtSolAmount(_match.TotalPool)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("houseFee")</div>
                            <div class="fw-semibold">@FmtSolAmount(_match.HouseFeeAmount)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("totalDistributed")</div>
                            <div class="fw-semibold">@FmtSolAmount(_match.TotalDistributed)</div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_match.EndReasonDetail))
                        {
                            <div class="col-12">
                                <div class="text-muted">@T("settlementSummary")</div>
                                <div class="fw-semibold">@GetSettlementHumanText(_match)</div>
                            </div>
                        }
                    </div>

                    @if (_match.IsFinished)
                    {
                        <div class="mt-3">
                            <span class="badge bg-secondary">@T("finished")</span>
                        </div>
                    }
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="card match-panel p-3">
                    <div class="fw-bold mb-2">@T("actions")</div>

                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-light" @onclick="CopyLink">
                            🔗 @T("copyLink")
                        </button>

                        <button class="btn btn-outline-secondary" @onclick="GoBack">
                            ← @T("back")
                        </button>
                    </div>

                    <div class="small text-muted mt-3">
                        @T("tipShareTheLinkToOpenTheMatchDirectlyInArenaMode")
                    </div>
                </div>
            </div>
        </div>

        @if (MatchParticipants.Count > 0)
        {
            <div class="row g-3 mt-1">
                <div class="col-12">
                    <div class="card match-panel p-3">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="fw-bold">@T("matchParticipants")</div>
                            <div class="small text-muted">@MatchParticipants.Count @T("participantS")</div>
                        </div>

                        <div class="mt-3 d-flex flex-column gap-2">
                            @foreach (var participant in MatchParticipants)
                            {
                                <div class="border border-secondary-subtle rounded-4 p-3 small">
                                    <strong>@participant.WalletMasked</strong>
                                    <span class="mx-2">•</span>
                                    <span>@participant.TeamSymbol</span>
                                    <span class="mx-2">•</span>
                                    <span>@T("bet") @FmtSolAmount(participant.BetAmount)</span>
                                    <span class="mx-2">•</span>
                                    <span>@T("result") @participant.ResultLabel</span>
                                    <span class="mx-2">•</span>
                                    <span>@T("received") @FmtSolAmount(participant.ReceivedAmount)</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- =========================
             SELECTION PANEL
             ========================= -->
        <div class="row g-3 mt-1">
            <div class="col-12">
                <div class="card match-panel p-3">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                        <div class="fw-bold">@T("securePosition")</div>
                        <span class="badge @(CanBetOnCurrentMatch() ? "bg-success" : "bg-secondary")">
                            @(CanBetOnCurrentMatch() ? T("investmentsOpen") : T("investmentsClosed"))
                        </span>
                    </div>

                    @if (!CanBetOnCurrentMatch())
                    {
                        <div class="alert alert-secondary mb-0">
                            @T("investmentsAreUnavailableForThisMatch") @T("status") <strong>@_match.Status</strong>,
                            @T("elapsedTime") <strong>@_match.ElapsedMinutes min</strong>.
                        </div>
                    }
                    else
                    {
                        <div class="match-invest-grid">
                            <article class="match-invest-option match-invest-option--a">
                                <div class="match-invest-option__top">
                                    <div class="coin-wrap coin-wrap--sm match-invest-option__coin" title="@_match.TeamA">
                                        <div class="coin-skeleton"></div>
                                        <img class="coin-img coin-img--sm"
                                             src="@GetCoinIconUrl(_match.TeamA)"
                                             alt="@_match.TeamA"
                                             loading="lazy"
                                             onload="this.previousElementSibling?.classList.add('d-none')"
                                             onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                        <div class="coin-fallback d-none">@GetInitials(_match.TeamA)</div>
                                    </div>

                                    <div class="match-invest-option__identity">
                                        <div class="match-invest-option__symbol"><MarketPairText Symbol="@_match.TeamA" /></div>
                                        <div class="match-invest-option__pct @GetPctClass(_match.PctA)">@FormatPct(_match.PctA)</div>
                                    </div>

                                    <button class="btn match-invest-option__cta match-invest-option__cta--a"
                                            disabled="@_isSendingBet"
                                            @onclick="() => OpenInvestmentAmountModalAsync(_match.TeamAId, _match.TeamA)">
                                        @T("invest")
                                    </button>
                                </div>

                                <div class="match-invest-option__metrics">
                                    <div class="match-invest-option__metric">
                                        <span>Pool</span>
                                        <strong>@_match.PoolStrengthTeamA%</strong>
                                    </div>
                                    <div class="match-invest-option__metric">
                                        <span>@T("bets")</span>
                                        <strong>@_match.BetCountTeamA</strong>
                                    </div>
                                    <div class="match-invest-option__metric">
                                        <span>Volume</span>
                                        <strong>@FmtSolAmount(_match.TotalAmountTeamA)</strong>
                                    </div>
                                </div>
                            </article>

                            <article class="match-invest-option match-invest-option--b">
                                <div class="match-invest-option__top">
                                    <div class="coin-wrap coin-wrap--sm match-invest-option__coin" title="@_match.TeamB">
                                        <div class="coin-skeleton"></div>
                                        <img class="coin-img coin-img--sm"
                                             src="@GetCoinIconUrl(_match.TeamB)"
                                             alt="@_match.TeamB"
                                             loading="lazy"
                                             onload="this.previousElementSibling?.classList.add('d-none')"
                                             onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                        <div class="coin-fallback d-none">@GetInitials(_match.TeamB)</div>
                                    </div>

                                    <div class="match-invest-option__identity">
                                        <div class="match-invest-option__symbol"><MarketPairText Symbol="@_match.TeamB" /></div>
                                        <div class="match-invest-option__pct @GetPctClass(_match.PctB)">@FormatPct(_match.PctB)</div>
                                    </div>

                                    <button class="btn match-invest-option__cta match-invest-option__cta--b"
                                            disabled="@_isSendingBet"
                                            @onclick="() => OpenInvestmentAmountModalAsync(_match.TeamBId, _match.TeamB)">
                                        @T("invest")
                                    </button>
                                </div>

                                <div class="match-invest-option__metrics">
                                    <div class="match-invest-option__metric">
                                        <span>Pool</span>
                                        <strong>@_match.PoolStrengthTeamB%</strong>
                                    </div>
                                    <div class="match-invest-option__metric">
                                        <span>@T("bets")</span>
                                        <strong>@_match.BetCountTeamB</strong>
                                    </div>
                                    <div class="match-invest-option__metric">
                                        <span>Volume</span>
                                        <strong>@FmtSolAmount(_match.TotalAmountTeamB)</strong>
                                    </div>
                                </div>
                            </article>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (_showInvestmentAmountModal)
        {
            <div class="modal-backdrop fade show"></div>
            <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content bg-dark text-light border border-secondary">
                        <div class="modal-header border-secondary">
                            <h5 class="modal-title">@T("chooseTheAmountInSol")</h5>
                            <button type="button" class="btn-close btn-close-white" aria-label="@T("close")" @onclick="CloseInvestmentAmountModal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="amount-modal-team">
                                <span>@T("investmentIn")</span>
                                <strong><MarketPairText Symbol="@_pendingBetTeamName" /></strong>
                            </div>

                            <div class="wallet-guard-summary">
                                <div>
                                    <span>@T("walletBalanceGuardWalletBalance")</span>
                                    <strong>@WalletBalanceText</strong>
                                </div>
                                <div>
                                    <span>@T("walletBalanceGuardMaximumAvailable")</span>
                                    <strong>@WalletMaxSpendableText</strong>
                                </div>
                            </div>

                            <div class="amount-quick-grid" aria-label="@T("quickValuesInSol")">
                                @foreach (var amount in QuickInvestmentAmounts)
                                {
                                    <button type="button"
                                            class="amount-chip @(_investmentAmount == amount ? "amount-chip-active" : "")"
                                            @onclick="() => SetInvestmentAmount(amount)">
                                        @FmtSolAmount(amount)
                                    </button>
                                }
                            </div>

                            <label class="form-label mt-3" for="matchInvestmentAmountRange">
                                @T("quickAdjustment") <strong>@FmtSolAmount(_investmentAmount)</strong>
                            </label>
                            <input id="matchInvestmentAmountRange"
                                   class="form-range"
                                   type="range"
                                   min="0"
                                   max="@(QuickInvestmentAmounts.Length - 1)"
                                   step="1"
                                   @bind="_investmentAmountRangeIndex"
                                   @bind:event="oninput" />

                            <label class="form-label mt-3" for="matchInvestmentAmountInput">
                                @T("orEnterAnyAmountInSol")
                            </label>
                            <input id="matchInvestmentAmountInput"
                                   class="form-control"
                                   type="number"
                                   min="0.00000001"
                                   step="0.00000001"
                                   @bind="_investmentAmount"
                                   @bind:event="oninput" />
                            <div class="wallet-guard-actions">
                                <span>@T("walletBalanceGuardFeeReserve")</span>
                                <button type="button"
                                        class="btn btn-sm btn-outline-light"
                                        disabled="@(_walletBalanceLoading || !_walletMaxSpendableSol.HasValue || WalletMaxSpendableAmount <= 0m)"
                                        @onclick="UseMaxInvestmentAmount">
                                    @T("walletBalanceGuardUseMax")
                                </button>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(CurrentInvestmentAmountError))
                            {
                                <div class="text-danger small mt-2">@CurrentInvestmentAmountError</div>
                            }
                        </div>
                        <div class="modal-footer border-secondary">
                            <button type="button" class="btn btn-outline-light" @onclick="CloseInvestmentAmountModal">@T("cancel")</button>
                            <button type="button" class="btn btn-primary" disabled="@(_isSendingBet || _walletBalanceLoading || !IsInvestmentAmountValid)" @onclick="ConfirmInvestmentAmountAsync">
                                @InvestmentPrimaryButtonText
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (_showSimplePopup)
        {
            <div class="modal-backdrop fade show"></div>
            <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content bg-dark text-light border border-secondary">
                        <div class="modal-header border-secondary">
                            <h5 class="modal-title">@_simplePopupTitle</h5>
                            <button type="button" class="btn-close btn-close-white" aria-label="@T("close")" @onclick="CloseSimplePopup"></button>
                        </div>
                        <div class="modal-body text-light-emphasis">
                            <p class="mb-0">@_simplePopupMessage</p>
                        </div>
                        <div class="modal-footer border-secondary">
                            <button type="button" class="btn btn-primary" @onclick="CloseSimplePopup">@T("gotIt")</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

