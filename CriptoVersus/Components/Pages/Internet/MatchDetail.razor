@code {
    [Parameter] public string? SlugA { get; set; }
    [Parameter] public string? SlugB { get; set; }
    [Parameter] public int? MatchId { get; set; }
    [Parameter] public bool EmitPageTitle { get; set; } = true;

    private bool _loading = true;
    private string? _error;
    private string _title = "Match";
    private MatchDto? _match;

    private bool _isSendingBet;
    private bool _betRequestOk;
    private string _betStatusMessage = "";
    private string _betResponseBody = "";
    private IJSObjectReference? _bettingModule;
    private bool _showSimplePopup;
    private string _simplePopupTitle = "";
    private string _simplePopupMessage = "";
    private bool _isInvestmentReturnOpen;
    private bool _showInvestmentAmountModal;
    private int _pendingBetTeamId;
    private string _pendingBetTeamName = "";
    private decimal _investmentAmount = 0.1m;
    private string _investmentAmountError = "";
    private IJSObjectReference? _walletBalanceModule;
    private double? _walletBalanceSol;
    private double? _walletMaxSpendableSol;
    private bool _walletBalanceLoading;
    private string _walletBalanceLoadError = "";
    private const int _liveBetMaxMinutes = 45;
    private static readonly decimal[] QuickInvestmentAmounts = [0.01m, 0.05m, 0.1m, 0.25m, 0.5m, 1m];
    private int? _loggedUserId;
    private string? _loggedWalletPublicKey;

    private string LoggedUserDisplay
        => _loggedUserId is int userId && userId > 0
            ? $"Usuario #{userId}"
            : "Faça login para investir";

    private string LoggedWalletDisplay
        => string.IsNullOrWhiteSpace(_loggedWalletPublicKey)
            ? "Carteira nao conectada"
            : _loggedWalletPublicKey;

    private bool CanSeeInvestmentDebug
        => IsConfiguredWallet(_loggedWalletPublicKey, Config["CriptoVersus:AdminWallet"])
            || IsConfiguredWallet(_loggedWalletPublicKey, Config["OnChainBetting:AuthorityWallet"]);

    private decimal WalletMaxSpendableAmount
        => _walletMaxSpendableSol.HasValue
            ? decimal.Round((decimal)Math.Max(0d, _walletMaxSpendableSol.Value), 8, MidpointRounding.ToZero)
            : 0m;

    private string WalletBalanceText
        => _walletBalanceLoading
            ? (IsEnglish ? "Loading..." : "Carregando...")
            : _walletBalanceSol.HasValue
                ? FmtSolAmount((decimal)_walletBalanceSol.Value)
                : "-";

    private string WalletMaxSpendableText
        => _walletBalanceLoading
            ? (IsEnglish ? "Loading..." : "Carregando...")
            : _walletMaxSpendableSol.HasValue
                ? FmtSolAmount((decimal)_walletMaxSpendableSol.Value)
                : "-";

    private bool IsInvestmentAmountInsufficient
        => _walletMaxSpendableSol.HasValue
           && _investmentAmount > 0m
           && _investmentAmount > WalletMaxSpendableAmount;

    private bool IsInvestmentAmountValid
        => _walletMaxSpendableSol.HasValue
           && _investmentAmount > 0m
           && _investmentAmount <= WalletMaxSpendableAmount;

    private string? CurrentInvestmentAmountError
        => !string.IsNullOrWhiteSpace(_investmentAmountError)
            ? _investmentAmountError
            : !string.IsNullOrWhiteSpace(_walletBalanceLoadError)
                ? _walletBalanceLoadError
                : IsInvestmentAmountInsufficient
                    ? T("walletBalanceGuardInsufficientMessage", WalletMaxSpendableText)
                    : null;

    private string InvestmentPrimaryButtonText
        => _isSendingBet
            ? T("sending")
            : IsInvestmentAmountInsufficient
                ? T("walletBalanceGuardInsufficient")
                : $"{T("invest")} {FmtSolAmount(_investmentAmount)}";

    private int _investmentAmountRangeIndex
    {
        get => GetClosestQuickInvestmentAmountIndex(_investmentAmount);
        set
        {
            if (value < 0 || value >= QuickInvestmentAmounts.Length)
                return;

            _investmentAmount = QuickInvestmentAmounts[value];
            _investmentAmountError = "";
        }
    }

    private static string GetBaseSymbol(string pair)
    {
        if (string.IsNullOrWhiteSpace(pair)) return "";

        pair = pair.ToUpperInvariant();

        var quotes = new[] { "USDT", "USDC", "BUSD", "BRL", "EUR", "BTC", "ETH" };

        foreach (var q in quotes)
        {
            if (pair.EndsWith(q) && pair.Length > q.Length)
                return pair.Substring(0, pair.Length - q.Length);
        }

        return pair;
    }

    private string GetCoinIconUrl(string pair)
    {
        var baseSymbol = GetBaseSymbol(pair);
        if (string.IsNullOrWhiteSpace(baseSymbol))
            return string.Empty;

        return CriptoVersus.Web.Services.EnvironmentIsolationGuard.BuildApiUrl(Config, $"/api/icons/binance/{Uri.EscapeDataString(baseSymbol)}");
    }

    private async Task RefreshAuthenticatedUserAsync()
    {
        _loggedUserId = await SessionStorage.GetItemAsync<int?>("userId");
        _loggedWalletPublicKey = await SessionStorage.GetItemAsync<string>("walletPublicKey");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            await BrowserTimeZone.EnsureInitializedAsync();
            await RefreshAuthenticatedUserAsync();
        }
        catch (Exception ex) when (CriptoVersus.Web.Services.InteropSafety.IsDeferredInteropException(ex))
        {
            return;
        }

        try
        {
            await HubClient.EnsureStartedAsync();
        }
        catch
        {
            // O detalhe da partida ainda funciona sem o hub; mantemos o fallback de recarga leve.
        }

        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;
        _match = null;

        try
        {
            _match = await LoadRequestedMatchAsync(CancellationToken.None);

            if (_match is null)
            {
                var a = NormalizeSlugToSymbol(SlugA);
                var b = NormalizeSlugToSymbol(SlugB);
                _error = MatchId is int requestedId
                    ? $"Nenhuma partida encontrada para o match #{requestedId}."
                    : $"Nenhuma partida encontrada para {a} vs {b}.";
                return;
            }

            await LoadMetricChartsAsync(CancellationToken.None);

            _title = $"{_match.TeamA} vs {_match.TeamB}";

            SyncAndStartLocalClock();
            UpdateClockTexts();

            _title = $"{_match.TeamA} vs {_match.TeamB}";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static string NormalizeSlugToSymbol(string? slug)
    {
        if (string.IsNullOrWhiteSpace(slug)) return "";
        var s = slug.Trim().Replace("-", "").Replace("_", "").ToUpperInvariant();
        return new string(s.Where(char.IsLetterOrDigit).ToArray());
    }

    private static string FormatPct(decimal? v)
        => v is null ? "—" : $"{(v.Value >= 0 ? "+" : "")}{v.Value:0.00}%";

    private static string FormatCompactNumber(decimal? value)
    {
        if (value is null)
            return "—";

        var abs = Math.Abs(value.Value);
        return abs switch
        {
            >= 1_000_000_000m => $"{value.Value / 1_000_000_000m:0.##}B",
            >= 1_000_000m => $"{value.Value / 1_000_000m:0.##}M",
            >= 1_000m => $"{value.Value / 1_000m:0.##}K",
            _ => $"{value.Value:0.##}"
        };
    }

    private static string GetPctClass(decimal? v)
        => v is null ? "pct pct--neutral"
           : v.Value > 0 ? "pct pct--up"
           : v.Value < 0 ? "pct pct--down"
           : "pct pct--neutral";

    private static string GetInitials(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return "??";
        var clean = new string(s.Where(char.IsLetterOrDigit).ToArray());
        if (clean.Length <= 3) return clean.ToUpperInvariant();
        return clean.Substring(0, 3).ToUpperInvariant();
    }

    private static string GetDisplayTeamName(string? symbol)
    {
        var normalized = symbol?.Trim().ToUpperInvariant() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(normalized))
            return "-";

        var quotes = new[] { "USDT", "USDC", "BUSD", "BRL", "EUR", "BTC", "ETH" };
        foreach (var quote in quotes)
        {
            if (normalized.Length > quote.Length && normalized.EndsWith(quote, StringComparison.OrdinalIgnoreCase))
                return normalized[..^quote.Length];
        }

        return normalized;
    }

    private static string RemoveTrailingUsdt(string? symbol)
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return string.Empty;

        return symbol.EndsWith("USDT", StringComparison.OrdinalIgnoreCase)
            ? symbol[..^4]
            : symbol;
    }

    private static bool IsOngoing(string? status)
        => !string.IsNullOrWhiteSpace(status)
           && status.Trim().Equals("Ongoing", StringComparison.OrdinalIgnoreCase);

    private static bool IsCompleted(string? status)
        => !string.IsNullOrWhiteSpace(status)
           && status.Trim().Equals("Completed", StringComparison.OrdinalIgnoreCase);

    private bool HasReachedLocalTimeLimit()
        => _startUtc.HasValue && DateTime.UtcNow - _startUtc.Value >= MatchDuration;

    private bool ShouldShowResultStage(MatchDto? match)
        => match is not null
           && (IsCompleted(match.Status) || HasReachedLocalTimeLimit());

    private bool ShouldShowLiveBadge(MatchDto? match)
        => match is not null
           && IsOngoing(match.Status)
           && !HasReachedLocalTimeLimit();

    private string GetPresentationStatusText(MatchDto? match)
    {
        if (match is null)
            return "-";

        if (IsCompleted(match.Status))
            return T("completed");

        if (HasReachedLocalTimeLimit())
            return T("closing");

        return string.Equals(match.Status, "Ongoing", StringComparison.OrdinalIgnoreCase)
            ? T("live2")
            : string.Equals(match.Status, "Pending", StringComparison.OrdinalIgnoreCase)
                ? T("pending")
                : match.Status;
    }

    private static int? GetEffectiveWinnerTeamId(MatchDto? match)
    {
        if (match is null)
            return null;

        if (match.WinnerTeamId.HasValue)
            return match.WinnerTeamId;

        if (!IsCompleted(match.Status))
            return null;

        if (match.ScoreA > match.ScoreB)
            return match.TeamAId;

        if (match.ScoreB > match.ScoreA)
            return match.TeamBId;

        return null;
    }

    private static string GetStatusBadgeClass(string? status)
    {
        if (string.IsNullOrWhiteSpace(status)) return "text-bg-dark border border-secondary-subtle";

        var s = status.Trim().ToLowerInvariant();
        return s switch
        {
            "ongoing" => "bg-success",
            "pending" => "bg-warning text-dark",
            "completed" => "bg-secondary",
            "canceled" or "cancelled" => "bg-danger",
            _ => "text-bg-dark border border-secondary-subtle"
        };
    }

    private static string GetTrendIcon(decimal? v)
        => v is null ? "•"
           : v.Value > 0 ? "▲"
           : v.Value < 0 ? "▼"
           : "•";

    private string GetWinnerDisplayText(MatchDto match)
    {
        var effectiveWinnerTeamId = GetEffectiveWinnerTeamId(match);

        if (!string.IsNullOrWhiteSpace(match.WinnerTeamSymbol))
            return GetDisplayTeamName(match.WinnerTeamSymbol);

        if (effectiveWinnerTeamId == match.TeamAId)
            return GetDisplayTeamName(match.TeamA);

        if (effectiveWinnerTeamId == match.TeamBId)
            return GetDisplayTeamName(match.TeamB);

        return T("noWinner2");
    }

    private string GetWinnerFxClass(int teamId)
        => GetEffectiveWinnerTeamId(_match) == teamId ? "team-badge--winner" : string.Empty;

    private bool HasWinnerTeam(int teamId)
        => GetEffectiveWinnerTeamId(_match) == teamId && HasWinnerCelebration(_match);

    private static bool HasWinnerCelebration(MatchDto? match)
        => match is not null
           && GetEffectiveWinnerTeamId(match).HasValue
           && match.ScoreA != match.ScoreB;

    private string CurrentCulture => AppCulture.GetCurrentRouteCulture(Nav);
