@page "/match/{SlugA}-vs-{SlugB}"
@page "/match/{SlugA}-vs-{SlugB}/{MatchId:int}"
@using System.Net.Http
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using System.Text.Json
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersus.Web.Services.CriptoVersusApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject HttpClient Http
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@inject CriptoVersus.Web.Services.DashboardHubClient HubClient
@inject IConfiguration Config
@inject CriptoVersus.Web.Services.BrowserTimeZoneService BrowserTimeZone
@inject AppCultureService AppCulture
@inject LocalizationService L
@rendermode InteractiveServer
@implements IDisposable
@if (EmitPageTitle)
{
    <PageTitle>@_title</PageTitle>
}

<div class="container py-3">

    @if (_loading)
    {
        <div class="d-flex align-items-center gap-2 text-muted">
            <div class="spinner-border spinner-border-sm" role="status"></div>
            <span>@T("loadingMatch")</span>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="alert alert-danger">
            <strong>@T("error")</strong> @_error
        </div>
    }
    else if (_match is null)
    {
        <div class="alert alert-warning">
            @T("matchNotFound")
        </div>
    }
    else
    {
        <section class="match-semantic-summary">
            <h2>@GetSemanticSummaryTitle()</h2>
            <p>@GetSemanticSummaryIntro()</p>
            <p>@GetSemanticSummaryPools()</p>
            <p>@GetSemanticSummaryRewards()</p>
        </section>

        <section id="social-share-card" class="social-share-card mb-4" aria-label="Social share card">
            <div class="social-share-card__bg"></div>
            <div class="social-share-card__shell">
                <div class="social-share-card__header">
                    <div>
                        <div class="social-share-card__eyebrow">CRIPTO ARENA</div>
                        <div class="social-share-card__title">
                            <MarketPairText Symbol="@_match.TeamA" /> vs <MarketPairText Symbol="@_match.TeamB" />
                        </div>
                    </div>

                    <div class="social-share-card__header-meta">
                        <span class="social-share-card__status @(ShouldShowLiveBadge(_match) ? "social-share-card__status--live" : "social-share-card__status--final")">
                            @(ShouldShowLiveBadge(_match) ? T("live") : GetPresentationStatusText(_match).ToUpperInvariant())
                        </span>
                        <span class="social-share-card__match-id">Match #@_match.MatchId</span>
                    </div>
                </div>

                <div class="social-share-card__hero">
                    <div class="social-share-hero-team social-share-hero-team--a">
                        <div class="team-badge team-badge--a @(GetWinnerFxClass(_match.TeamAId))">
                            @if (HasWinnerTeam(_match.TeamAId))
                            {
                                <span class="winner-firework winner-firework--badge winner-firework--badge-a"></span>
                                <span class="winner-firework winner-firework--badge winner-firework--badge-b"></span>
                            }
                            <div class="coin-wrap" title="@_match.TeamA">
                                <div class="coin-skeleton"></div>
                                <img class="coin-img"
                                     src="@GetCoinIconUrl(_match.TeamA)"
                                     alt="@_match.TeamA"
                                     loading="lazy"
                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                <div class="coin-fallback d-none">@GetInitials(_match.TeamA)</div>
                            </div>
                        </div>
                        <div>
                            <div class="team-name"><MarketPairText Symbol="@_match.TeamA" /></div>
                            <div class="team-sub">
                                <span class="@GetPctClass(_match.PctA)">@FormatPct(_match.PctA)</span>
                            </div>
                        </div>
                    </div>

                    <div class="social-share-hero-score">
                        @if (ShouldShowLiveBadge(_match))
                        {
                            <div class="match-live">
                                <span class="badge rounded-pill bg-danger match-live__pill">
                                    <span class="match-live__dot"></span>
                                    @T("live")
                                </span>
                            </div>
                        }
                        else
                        {
                            <div class="match-live">
                                <span class="badge rounded-pill text-bg-dark border border-secondary-subtle match-live__pill">
                                    @GetPresentationStatusText(_match)
                                </span>
                            </div>
                        }

                        <div class="scoreline">
                            <span class="score">@_match.ScoreA</span>
                            <span class="score-sep">x</span>
                            <span class="score">@_match.ScoreB</span>
                        </div>
                    </div>

                    <div class="social-share-hero-team social-share-hero-team--b">
                        <div>
                            <div class="team-name"><MarketPairText Symbol="@_match.TeamB" /></div>
                            <div class="team-sub">
                                <span class="@GetPctClass(_match.PctB)">@FormatPct(_match.PctB)</span>
                            </div>
                        </div>
                        <div class="team-badge team-badge--b @(GetWinnerFxClass(_match.TeamBId))">
                            @if (HasWinnerTeam(_match.TeamBId))
                            {
                                <span class="winner-firework winner-firework--badge winner-firework--badge-a"></span>
                                <span class="winner-firework winner-firework--badge winner-firework--badge-b"></span>
                            }
                            <div class="coin-wrap" title="@_match.TeamB">
                                <div class="coin-skeleton"></div>
                                <img class="coin-img"
                                     src="@GetCoinIconUrl(_match.TeamB)"
                                     alt="@_match.TeamB"
                                     loading="lazy"
                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                <div class="coin-fallback d-none">@GetInitials(_match.TeamB)</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="social-share-card__stats">
                    <div class="card match-card social-share-match-card p-3">
                        <div class="social-share-team-card__top">
                            <div class="coin-wrap coin-wrap--sm social-share-team-card__coin" title="@_match.TeamA">
                                <div class="coin-skeleton"></div>
                                <img class="coin-img coin-img--sm"
                                     src="@GetCoinIconUrl(_match.TeamA)"
                                     alt="@_match.TeamA"
                                     loading="lazy"
                                     onload="this.previousElementSibling?.classList.add('d-none')"
                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                <div class="coin-fallback d-none">@GetInitials(_match.TeamA)</div>
                            </div>
                            <div class="social-share-team-card__identity">
                                <div class="social-share-team-card__symbol"><MarketPairText Symbol="@_match.TeamA" /></div>
                                <div class="social-share-team-card__pct @GetPctClass(_match.PctA)">@FormatPct(_match.PctA)</div>
                            </div>
                            <button class="btn social-share-team-card__cta social-share-team-card__cta--a"
                                    type="button"
                                    disabled="@(!CanBetOnCurrentMatch() || _isSendingBet)"
                                    @onclick="() => OpenInvestmentAmountModalAsync(_match.TeamAId, _match.TeamA)">
                                @T("invest")
                            </button>
                        </div>

                        <div class="social-share-team-card__metrics">
                            <div class="social-share-team-card__metric-row">
                                <span>Pool</span>
                                <strong>@_match.PoolStrengthTeamA%</strong>
                            </div>
                            <div class="social-share-team-card__metric-row">
                                <span>@T("bets")</span>
                                <strong>@_match.BetCountTeamA</strong>
                            </div>
                            <div class="social-share-team-card__metric-row">
                                <span>Volume</span>
                                <strong>@FmtSolAmount(_match.TotalAmountTeamA)</strong>
                            </div>
                        </div>
                    </div>

                    <div class="card clock-card social-share-clock-card p-3 text-center d-flex flex-column justify-content-center @(HasWinnerCelebration(_match) ? "clock-card--winner" : string.Empty)">
                        @if (HasWinnerCelebration(_match))
                        {
                            <span class="winner-firework winner-firework--card winner-firework--card-a"></span>
                            <span class="winner-firework winner-firework--card winner-firework--card-b"></span>
                            <span class="winner-firework winner-firework--card winner-firework--card-c"></span>
                            <span class="winner-firework winner-firework--card winner-firework--card-d"></span>
                        }
                        @if (ShouldShowResultStage(_match))
                        {
                            <div class="clock-title">@T("finalResult")</div>
                            <div class="winner-label">WINNER IS</div>
                            <div class="winner-name">@GetWinnerDisplayText(_match)</div>
                            <div class="clock-remaining">
                                @T("finalScore") <span class="fw-semibold">@_match.ScoreA x @_match.ScoreB</span>
                            </div>
                            <div class="mt-2">
                                <span class="badge rounded-pill text-bg-dark border border-secondary-subtle match-live__pill">
                                    @GetPresentationStatusText(_match)
                                </span>
                            </div>
                        }
                        else
                        {
                            <div class="clock-title">@T("matchClock")</div>
                            <div class="clock-time">@_clockLive</div>
                            <div class="clock-remaining">
                                @T("remaining") <span class="fw-semibold">@_remainingLive</span>
                            </div>
                            <div class="mt-2">
                                @if (ShouldShowLiveBadge(_match))
                                {
                                    <span class="badge rounded-pill bg-danger match-live__pill">
                                        <span class="match-live__dot"></span>
                                        @T("live")
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill text-bg-dark border border-secondary-subtle match-live__pill">
                                        @GetPresentationStatusText(_match)
                                    </span>
                                }
                            </div>
                        }
                    </div>

                    <div class="card match-card social-share-match-card p-3">
                        <div class="social-share-team-card__top">
                            <div class="coin-wrap coin-wrap--sm social-share-team-card__coin" title="@_match.TeamB">
                                <div class="coin-skeleton"></div>
                                <img class="coin-img coin-img--sm"
                                     src="@GetCoinIconUrl(_match.TeamB)"
                                     alt="@_match.TeamB"
                                     loading="lazy"
                                     onload="this.previousElementSibling?.classList.add('d-none')"
                                     onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                <div class="coin-fallback d-none">@GetInitials(_match.TeamB)</div>
                            </div>
                            <div class="social-share-team-card__identity">
                                <div class="social-share-team-card__symbol"><MarketPairText Symbol="@_match.TeamB" /></div>
                                <div class="social-share-team-card__pct @GetPctClass(_match.PctB)">@FormatPct(_match.PctB)</div>
                            </div>
                            <button class="btn social-share-team-card__cta social-share-team-card__cta--b"
                                    type="button"
                                    disabled="@(!CanBetOnCurrentMatch() || _isSendingBet)"
                                    @onclick="() => OpenInvestmentAmountModalAsync(_match.TeamBId, _match.TeamB)">
                                @T("invest")
                            </button>
                        </div>

                        <div class="social-share-team-card__metrics">
                            <div class="social-share-team-card__metric-row">
                                <span>Pool</span>
                                <strong>@_match.PoolStrengthTeamB%</strong>
                            </div>
                            <div class="social-share-team-card__metric-row">
                                <span>@T("bets")</span>
                                <strong>@_match.BetCountTeamB</strong>
                            </div>
                            <div class="social-share-team-card__metric-row">
                                <span>Volume</span>
                                <strong>@FmtSolAmount(_match.TotalAmountTeamB)</strong>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="social-share-card__charts">
                    <div class="card match-panel social-share-panel p-3">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="fw-bold">@GetPercentageCardTitle()</div>
                            <div class="small text-muted"><MarketPairText Symbol="@_match.TeamA" /> vs <MarketPairText Symbol="@_match.TeamB" /></div>
                        </div>

                        <div class="d-flex gap-2 mt-2 flex-wrap">
                            <span class="badge rounded-pill text-bg-success-subtle border border-success-subtle">
                                <MarketPairText Symbol="@_match.TeamA" />: @GetPercentageWins(_match.TeamAId) @GetPercentageWinLabel()
                            </span>
                            <span class="badge rounded-pill text-bg-danger-subtle border border-danger-subtle">
                                <MarketPairText Symbol="@_match.TeamB" />: @GetPercentageWins(_match.TeamBId) @GetPercentageWinLabel()
                            </span>
                        </div>

                        @if (_percentageChart.HasData)
                        {
                            <div class="chart-wrap social-share-chart-wrap mt-3">
                                @foreach (var tick in GetPercentageAxisTicks())
                                {
                                    <div class="chart-axis-tick" style="top:@($"{tick.Y:0.##}px")">
                                        @tick.Label
                                    </div>
                                }
                                <svg class="chart" viewBox="0 0 1000 320" preserveAspectRatio="none">
                                    @for (var i = 1; i <= 4; i++)
                                    {
                                        var y = i * 64;
                                        <line x1="0" y1="@y" x2="1000" y2="@y" class="chart-grid" />
                                    }
                                    <line x1="0" y1="@_percentageChart.ZeroY" x2="1000" y2="@_percentageChart.ZeroY" class="chart-zero" />
                                    <polyline points="@_percentageChart.PolyA" class="chart-line chart-line-a" />
                                    <polyline points="@_percentageChart.PolyB" class="chart-line chart-line-b" />
                                </svg>
                            </div>

                            <div class="chart-x-axis">
                                @foreach (var tick in GetPercentageTimeTicks())
                                {
                                    <span style="left:@($"{tick.XPercent:0.##}%")">@tick.Label</span>
                                }
                            </div>

                            <div class="d-flex gap-3 mt-2 small text-muted flex-wrap">
                                <div class="legend"><span class="dot dot-a"></span> <MarketPairText Symbol="@_match.TeamA" /> (@FormatPct(_match.PctA))</div>
                                <div class="legend"><span class="dot dot-b"></span> <MarketPairText Symbol="@_match.TeamB" /> (@FormatPct(_match.PctB))</div>
                                <div class="ms-auto">Range: @_percentageChart.YMin:0.00% → @_percentageChart.YMax:0.00%</div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-secondary mt-3 mb-0">Sem snapshots suficientes para o grafico percentual.</div>
                        }
                    </div>

                    <div class="card match-panel social-share-panel p-3">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <div class="fw-bold">@GetVolumeCardTitle()</div>
                                @if (ShouldExplainNoVolumeCross())
                                {
                                    <span class="badge text-bg-dark border border-secondary-subtle">?</span>
                                }
                            </div>
                            <div class="small text-muted"><MarketPairText Symbol="@_match.TeamA" /> vs <MarketPairText Symbol="@_match.TeamB" /></div>
                        </div>

                        <div class="d-flex gap-2 mt-2 flex-wrap">
                            <span class="badge rounded-pill text-bg-success-subtle border border-success-subtle">
                                <MarketPairText Symbol="@_match.TeamA" />: @GetVolumeWins(_match.TeamAId) @GetVolumeWinLabel()
                            </span>
                            <span class="badge rounded-pill text-bg-danger-subtle border border-danger-subtle">
                                <MarketPairText Symbol="@_match.TeamB" />: @GetVolumeWins(_match.TeamBId) @GetVolumeWinLabel()
                            </span>
                        </div>

                        @if (_volumeChart.HasData)
                        {
                            <div class="chart-wrap social-share-chart-wrap mt-3">
                                @foreach (var tick in GetVolumeAxisTicks())
                                {
                                    <div class="chart-axis-tick" style="top:@($"{tick.Y:0.##}px")">
                                        @tick.Label
                                    </div>
                                }
                                <svg class="chart" viewBox="0 0 1000 320" preserveAspectRatio="none">
                                    @for (var i = 1; i <= 4; i++)
                                    {
                                        var y = i * 64;
                                        <line x1="0" y1="@y" x2="1000" y2="@y" class="chart-grid" />
                                    }
                                    <line x1="0" y1="@_volumeChart.ZeroY" x2="1000" y2="@_volumeChart.ZeroY" class="chart-zero" />
                                    <polyline points="@_volumeChart.PolyA" class="chart-line chart-line-a" />
                                    <polyline points="@_volumeChart.PolyB" class="chart-line chart-line-b" />
                                </svg>
                            </div>

                            <div class="chart-x-axis">
                                @foreach (var tick in GetVolumeTimeTicks())
                                {
                                    <span style="left:@($"{tick.XPercent:0.##}%")">@tick.Label</span>
                                }
                            </div>

                            <div class="d-flex gap-3 mt-2 small text-muted flex-wrap">
                                <div class="legend"><span class="dot dot-a"></span> <MarketPairText Symbol="@_match.TeamA" /> (@FormatCompactNumber(_match.QuoteVolumeA))</div>
                                <div class="legend"><span class="dot dot-b"></span> <MarketPairText Symbol="@_match.TeamB" /> (@FormatCompactNumber(_match.QuoteVolumeB))</div>
                                <div class="ms-auto">Range: @FormatCompactNumber((decimal?)_volumeChart.YMin) → @FormatCompactNumber((decimal?)_volumeChart.YMax)</div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-secondary mt-3 mb-0">Sem snapshots suficientes para o grafico de volume.</div>
                        }
                    </div>
                </div>

                <div class="social-share-card__insights">
                    <div class="social-share-card__sentiment">
                        <div class="card match-panel social-share-sentiment-panel p-3">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                                <div>
                                    <div class="fw-bold">@T("arenaPressureTitle")</div>
                                    <div class="small text-muted">@T("arenaPressureSubtitle")</div>
                                </div>
                                <span class="badge rounded-pill text-bg-dark border border-secondary-subtle">@T("marketPulse")</span>
                            </div>

                            <div class="social-share-sentiment-grid">
                                <ArenaSentimentGauge Symbol="@RemoveTrailingUsdt(_match.TeamA)"
                                                     Score="@_arenaSentimentA?.Score"
                                                     Classification="@_arenaSentimentA?.Classification"
                                                     ClassificationLabel="@GetArenaSentimentLabel(_arenaSentimentA)"
                                                     IsLoading="@(_arenaSentimentLoading && _arenaSentimentA is null)"
                                                     Size="250"
                                                     ShowLabel="true"
                                                     LabelText="@T("arenaPressureLabel")" />

                                <ArenaSentimentGauge Symbol="@RemoveTrailingUsdt(_match.TeamB)"
                                                     Score="@_arenaSentimentB?.Score"
                                                     Classification="@_arenaSentimentB?.Classification"
                                                     ClassificationLabel="@GetArenaSentimentLabel(_arenaSentimentB)"
                                                     IsLoading="@(_arenaSentimentLoading && _arenaSentimentB is null)"
                                                     Size="250"
                                                     ShowLabel="true"
                                                     LabelText="@T("arenaPressureLabel")" />
                            </div>
                        </div>
                    </div>

                    <div class="social-share-card__events">
                        <div class="card match-panel social-share-events-panel p-3">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div>
                                    <div class="social-share-events-panel__title">@T("scoringLog")</div>
                                    <div class="social-share-events-panel__subtitle">@T("mostRelevantMomentByMomentEventsFromTheMatch")</div>
                                </div>
                                <div class="small text-muted">@_scoreEvents.Count @T("eventS")</div>
                            </div>

                            @if (_scoreEvents.Count == 0)
                            {
                                <div class="social-share-events-empty mt-3">
                                    @T("noScoringEventsHaveBeenRecordedForThisMatchYet")
                                </div>
                            }
                            else
                            {
                                <div class="social-share-events-list mt-3">
                                    @foreach (var scoreEvent in _scoreEvents.OrderByDescending(x => x.EventSequence).Take(4))
                                    {
                                        <article class="social-share-event-item">
                                            <div class="social-share-event-item__meta">
                                                <div class="social-share-event-item__badges">
                                                    <span class="match-score-event__icon" title="@GetScoreEventIconTitle(scoreEvent)">
                                                        @GetScoreEventIcon(scoreEvent)
                                                    </span>
                                                    <span class="badge text-bg-dark border border-secondary-subtle">#@scoreEvent.EventSequence</span>
                                                    <span class="badge @GetTeamEventBadgeClass(scoreEvent.TeamId)">@scoreEvent.TeamSymbol</span>
                                                    <span class="badge text-bg-dark border border-secondary-subtle">@GetRuleLabel(scoreEvent.RuleType)</span>
                                                    <span class="badge match-score-event__points">+@scoreEvent.Points</span>
                                                </div>
                                                <div class="social-share-event-item__time">@FormatEventTime(scoreEvent.EventTimeUtc)</div>
                                            </div>
                                            <div class="social-share-event-item__description">@GetLocalizedScoreEventDescription(scoreEvent)</div>
                                        </article>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="social-share-card__footer">
                    <div class="social-share-card__brand">CriptoVersus</div>
                    <div class="social-share-card__footer-meta">
                        <span>@GetPresentationStatusText(_match)</span>
                        <span>•</span>
                        <span><MarketPairText Symbol="@_match.TeamA" /> vs <MarketPairText Symbol="@_match.TeamB" /></span>
                    </div>
                </div>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(_betResponseBody) && CanSeeInvestmentDebug)
        {
            <div class="accordion mb-3" id="investmentReturnAccordion">
                <div class="accordion-item bg-dark border-secondary">
                    <h2 class="accordion-header" id="investmentReturnHeading">
                        <button class="accordion-button @(_isInvestmentReturnOpen ? "" : "collapsed") bg-dark text-light"
                                type="button"
                                @onclick="ToggleInvestmentReturn"
                                aria-expanded="@_isInvestmentReturnOpen"
                                aria-controls="investmentReturnCollapse">
                            @T("investmentResponse")
                        </button>
                    </h2>
                    <div id="investmentReturnCollapse"
                         class="accordion-collapse collapse @(_isInvestmentReturnOpen ? "show" : "")"
                         aria-labelledby="investmentReturnHeading">
                        <div class="accordion-body">
                            <pre class="bg-dark text-white border rounded p-3 small mb-0" style="white-space: pre-wrap;">@_betResponseBody</pre>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- =========================
             TECH PANEL + ACTIONS
             ========================= -->
        <div class="row g-3">
            <div class="col-12 col-lg-8">
                <div class="card match-panel p-3">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div class="fw-bold">@T("matchPanel")</div>

                        <span class="badge @GetStatusBadgeClass(_match.Status)">
                            @_match.Status
                        </span>
                    </div>

                    <div class="row mt-3 g-3 small">
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("elapsed")</div>
                            <div class="fw-semibold">@_match.ElapsedMinutes min</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("remaining")</div>
                            <div class="fw-semibold">@_match.RemainingMinutes min</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("score")</div>
                            <div class="fw-semibold">@_match.ScoreA x @_match.ScoreB</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("match")</div>
                            <div class="fw-semibold">#@_match.MatchId</div>
                        </div>
                        <div class="col-12">
                            <div class="text-muted">@T("activeRule")</div>
                            <div class="fw-semibold">@GetRuleLabel(_match.ScoringRuleType)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("winner")</div>
                            <div class="fw-semibold">@(_match.WinnerTeamSymbol ?? T("noWinner"))</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("settlementReason")</div>
                            <div class="fw-semibold">@(_match.EndReasonCode ?? "-")</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("validFinancialDispute")</div>
                            <div class="fw-semibold">@(_match.HasValidFinancialDispute ? T("yes") : T("no"))</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("betsOnBothSides")</div>
                            <div class="fw-semibold">@(_match.HasBetsOnBothSides ? T("yes") : T("no"))</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("walletsOnTeamA")</div>
                            <div class="fw-semibold">@_match.WalletCountTeamA</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("walletsOnTeamB")</div>
                            <div class="fw-semibold">@_match.WalletCountTeamB</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("betsOnTeamA")</div>
                            <div class="fw-semibold">@_match.BetCountTeamA</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("betsOnTeamB")</div>
                            <div class="fw-semibold">@_match.BetCountTeamB</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("totalOnTeamA")</div>
                            <div class="fw-semibold">@FmtSolAmount(_match.TotalAmountTeamA)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("totalOnTeamB")</div>
                            <div class="fw-semibold">@FmtSolAmount(_match.TotalAmountTeamB)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("winningPool")</div>
                            <div class="fw-semibold">@FmtSolAmount(_match.WinningPool)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("losingPool")</div>
                            <div class="fw-semibold">@FmtSolAmount(_match.LosingPool)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("totalPool")</div>
                            <div class="fw-semibold">@FmtSolAmount(_match.TotalPool)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("houseFee")</div>
                            <div class="fw-semibold">@FmtSolAmount(_match.HouseFeeAmount)</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="text-muted">@T("totalDistributed")</div>
                            <div class="fw-semibold">@FmtSolAmount(_match.TotalDistributed)</div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_match.EndReasonDetail))
                        {
                            <div class="col-12">
                                <div class="text-muted">@T("settlementSummary")</div>
                                <div class="fw-semibold">@GetSettlementHumanText(_match)</div>
                            </div>
                        }
                    </div>

                    @if (_match.IsFinished)
                    {
                        <div class="mt-3">
                            <span class="badge bg-secondary">@T("finished")</span>
                        </div>
                    }
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="card match-panel p-3">
                    <div class="fw-bold mb-2">@T("actions")</div>

                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-light" @onclick="CopyLink">
                            🔗 @T("copyLink")
                        </button>

                        <button class="btn btn-outline-secondary" @onclick="GoBack">
                            ← @T("back")
                        </button>
                    </div>

                    <div class="small text-muted mt-3">
                        @T("tipShareTheLinkToOpenTheMatchDirectlyInArenaMode")
                    </div>
                </div>
            </div>
        </div>

        @if (_match.Participants.Count > 0)
        {
            <div class="row g-3 mt-1">
                <div class="col-12">
                    <div class="card match-panel p-3">
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div class="fw-bold">@T("matchParticipants")</div>
                            <div class="small text-muted">@_match.Participants.Count @T("participantS")</div>
                        </div>

                        <div class="mt-3 d-flex flex-column gap-2">
                            @foreach (var participant in _match.Participants)
                            {
                                <div class="border border-secondary-subtle rounded-4 p-3 small">
                                    <strong>@participant.WalletMasked</strong>
                                    <span class="mx-2">•</span>
                                    <span>@participant.TeamSymbol</span>
                                    <span class="mx-2">•</span>
                                    <span>@T("bet") @FmtSolAmount(participant.BetAmount)</span>
                                    <span class="mx-2">•</span>
                                    <span>@T("result") @participant.ResultLabel</span>
                                    <span class="mx-2">•</span>
                                    <span>@T("received") @FmtSolAmount(participant.ReceivedAmount)</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- =========================
             BET PANEL
             ========================= -->
        <div class="row g-3 mt-1">
            <div class="col-12">
                <div class="card match-panel p-3">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                        <div class="fw-bold">@T("securePosition")</div>
                        <span class="badge @(CanBetOnCurrentMatch() ? "bg-success" : "bg-secondary")">
                            @(CanBetOnCurrentMatch() ? T("investmentsOpen") : T("investmentsClosed"))
                        </span>
                    </div>

                    @if (!CanBetOnCurrentMatch())
                    {
                        <div class="alert alert-secondary mb-0">
                            @T("investmentsAreUnavailableForThisMatch") @T("status") <strong>@_match.Status</strong>,
                            @T("elapsedTime") <strong>@_match.ElapsedMinutes min</strong>.
                        </div>
                    }
                    else
                    {
                        <div class="match-invest-grid">
                            <article class="match-invest-option match-invest-option--a">
                                <div class="match-invest-option__top">
                                    <div class="coin-wrap coin-wrap--sm match-invest-option__coin" title="@_match.TeamA">
                                        <div class="coin-skeleton"></div>
                                        <img class="coin-img coin-img--sm"
                                             src="@GetCoinIconUrl(_match.TeamA)"
                                             alt="@_match.TeamA"
                                             loading="lazy"
                                             onload="this.previousElementSibling?.classList.add('d-none')"
                                             onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                        <div class="coin-fallback d-none">@GetInitials(_match.TeamA)</div>
                                    </div>

                                    <div class="match-invest-option__identity">
                                        <div class="match-invest-option__symbol"><MarketPairText Symbol="@_match.TeamA" /></div>
                                        <div class="match-invest-option__pct @GetPctClass(_match.PctA)">@FormatPct(_match.PctA)</div>
                                    </div>

                                    <button class="btn match-invest-option__cta match-invest-option__cta--a"
                                            disabled="@_isSendingBet"
                                            @onclick="() => OpenInvestmentAmountModalAsync(_match.TeamAId, _match.TeamA)">
                                        @T("invest")
                                    </button>
                                </div>

                                <div class="match-invest-option__metrics">
                                    <div class="match-invest-option__metric">
                                        <span>Pool</span>
                                        <strong>@_match.PoolStrengthTeamA%</strong>
                                    </div>
                                    <div class="match-invest-option__metric">
                                        <span>@T("bets")</span>
                                        <strong>@_match.BetCountTeamA</strong>
                                    </div>
                                    <div class="match-invest-option__metric">
                                        <span>Volume</span>
                                        <strong>@FmtSolAmount(_match.TotalAmountTeamA)</strong>
                                    </div>
                                </div>
                            </article>

                            <article class="match-invest-option match-invest-option--b">
                                <div class="match-invest-option__top">
                                    <div class="coin-wrap coin-wrap--sm match-invest-option__coin" title="@_match.TeamB">
                                        <div class="coin-skeleton"></div>
                                        <img class="coin-img coin-img--sm"
                                             src="@GetCoinIconUrl(_match.TeamB)"
                                             alt="@_match.TeamB"
                                             loading="lazy"
                                             onload="this.previousElementSibling?.classList.add('d-none')"
                                             onerror="this.remove(); this.nextElementSibling?.classList.remove('d-none');" />
                                        <div class="coin-fallback d-none">@GetInitials(_match.TeamB)</div>
                                    </div>

                                    <div class="match-invest-option__identity">
                                        <div class="match-invest-option__symbol"><MarketPairText Symbol="@_match.TeamB" /></div>
                                        <div class="match-invest-option__pct @GetPctClass(_match.PctB)">@FormatPct(_match.PctB)</div>
                                    </div>

                                    <button class="btn match-invest-option__cta match-invest-option__cta--b"
                                            disabled="@_isSendingBet"
                                            @onclick="() => OpenInvestmentAmountModalAsync(_match.TeamBId, _match.TeamB)">
                                        @T("invest")
                                    </button>
                                </div>

                                <div class="match-invest-option__metrics">
                                    <div class="match-invest-option__metric">
                                        <span>Pool</span>
                                        <strong>@_match.PoolStrengthTeamB%</strong>
                                    </div>
                                    <div class="match-invest-option__metric">
                                        <span>@T("bets")</span>
                                        <strong>@_match.BetCountTeamB</strong>
                                    </div>
                                    <div class="match-invest-option__metric">
                                        <span>Volume</span>
                                        <strong>@FmtSolAmount(_match.TotalAmountTeamB)</strong>
                                    </div>
                                </div>
                            </article>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (_showInvestmentAmountModal)
        {
            <div class="modal-backdrop fade show"></div>
            <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content bg-dark text-light border border-secondary">
                        <div class="modal-header border-secondary">
                            <h5 class="modal-title">@T("chooseTheAmountInSol")</h5>
                            <button type="button" class="btn-close btn-close-white" aria-label="@T("close")" @onclick="CloseInvestmentAmountModal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="amount-modal-team">
                                <span>@T("investmentIn")</span>
                                <strong><MarketPairText Symbol="@_pendingBetTeamName" /></strong>
                            </div>

                            <div class="wallet-guard-summary">
                                <div>
                                    <span>@T("walletBalanceGuardWalletBalance")</span>
                                    <strong>@WalletBalanceText</strong>
                                </div>
                                <div>
                                    <span>@T("walletBalanceGuardMaximumAvailable")</span>
                                    <strong>@WalletMaxSpendableText</strong>
                                </div>
                            </div>

                            <div class="amount-quick-grid" aria-label="@T("quickValuesInSol")">
                                @foreach (var amount in QuickInvestmentAmounts)
                                {
                                    <button type="button"
                                            class="amount-chip @(_investmentAmount == amount ? "amount-chip-active" : "")"
                                            @onclick="() => SetInvestmentAmount(amount)">
                                        @FmtSolAmount(amount)
                                    </button>
                                }
                            </div>

                            <label class="form-label mt-3" for="matchInvestmentAmountRange">
                                @T("quickAdjustment") <strong>@FmtSolAmount(_investmentAmount)</strong>
                            </label>
                            <input id="matchInvestmentAmountRange"
                                   class="form-range"
                                   type="range"
                                   min="0"
                                   max="@(QuickInvestmentAmounts.Length - 1)"
                                   step="1"
                                   @bind="_investmentAmountRangeIndex"
                                   @bind:event="oninput" />

                            <label class="form-label mt-3" for="matchInvestmentAmountInput">
                                @T("orEnterAnyAmountInSol")
                            </label>
                            <input id="matchInvestmentAmountInput"
                                   class="form-control"
                                   type="number"
                                   min="0.00000001"
                                   step="0.00000001"
                                   @bind="_investmentAmount"
                                   @bind:event="oninput" />
                            <div class="wallet-guard-actions">
                                <span>@T("walletBalanceGuardFeeReserve")</span>
                                <button type="button"
                                        class="btn btn-sm btn-outline-light"
                                        disabled="@(_walletBalanceLoading || !_walletMaxSpendableSol.HasValue || WalletMaxSpendableAmount <= 0m)"
                                        @onclick="UseMaxInvestmentAmount">
                                    @T("walletBalanceGuardUseMax")
                                </button>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(CurrentInvestmentAmountError))
                            {
                                <div class="text-danger small mt-2">@CurrentInvestmentAmountError</div>
                            }
                        </div>
                        <div class="modal-footer border-secondary">
                            <button type="button" class="btn btn-outline-light" @onclick="CloseInvestmentAmountModal">@T("cancel")</button>
                            <button type="button" class="btn btn-primary" disabled="@(_isSendingBet || _walletBalanceLoading || !IsInvestmentAmountValid)" @onclick="ConfirmInvestmentAmountAsync">
                                @InvestmentPrimaryButtonText
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (_showSimplePopup)
        {
            <div class="modal-backdrop fade show"></div>
            <div class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content bg-dark text-light border border-secondary">
                        <div class="modal-header border-secondary">
                            <h5 class="modal-title">@_simplePopupTitle</h5>
                            <button type="button" class="btn-close btn-close-white" aria-label="@T("close")" @onclick="CloseSimplePopup"></button>
                        </div>
                        <div class="modal-body text-light-emphasis">
                            <p class="mb-0">@_simplePopupMessage</p>
                        </div>
                        <div class="modal-footer border-secondary">
                            <button type="button" class="btn btn-primary" @onclick="CloseSimplePopup">@T("gotIt")</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<style>
    .match-hero {
        position: relative;
        background: radial-gradient(1200px 500px at 20% 0%, rgba(0, 230, 118, .14), transparent 60%), radial-gradient(1200px 500px at 80% 0%, rgba(255, 82, 82, .14), transparent 60%), linear-gradient(135deg, #0B1020 0%, #0E1117 55%, #0B1020 100%);
        border: 1px solid rgba(255,255,255,.08);
    }

    .match-hero__bg {
        position: absolute;
        inset: 0;
        background-image: linear-gradient(rgba(255,255,255,.06) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.06) 1px, transparent 1px);
        background-size: 26px 26px;
        opacity: .18;
        pointer-events: none;
    }

    .team-name {
        font-weight: 800;
        letter-spacing: .4px;
        font-size: clamp(1.05rem, 1.4vw, 1.35rem);
        color: rgba(255,255,255,.92);
    }

    .team-sub {
        font-size: .95rem;
    }

    .pct {
        font-weight: 800;
        letter-spacing: .2px;
    }

    .pct--up {
        color: #00E676;
    }

    .pct--down {
        color: #FF5252;
    }

    .pct--neutral {
        color: rgba(255,255,255,.70);
    }

    .scoreline {
        display: inline-flex;
        align-items: baseline;
        gap: .6rem;
    }

    .score {
        font-weight: 900;
        font-size: clamp(2.4rem, 4.3vw, 3.4rem);
        line-height: 1;
        color: #fff;
        text-shadow: 0 8px 28px rgba(0,0,0,.35);
    }

    .score-sep {
        font-weight: 800;
        font-size: clamp(1.2rem, 2vw, 1.6rem);
        color: rgba(255,255,255,.55);
    }

    .timebar {
        font-size: .95rem;
    }

    .team-badge {
        width: 54px;
        height: 54px;
        border-radius: 16px;
        display: grid;
        place-items: center;
        font-weight: 900;
        letter-spacing: .5px;
        color: rgba(255,255,255,.95);
        border: 1px solid rgba(255,255,255,.12);
        box-shadow: 0 14px 30px rgba(0,0,0,.25);
        backdrop-filter: blur(6px);
    }

    .team-badge--a {
        background: linear-gradient(135deg, rgba(0,230,118,.25), rgba(0,230,118,.05));
    }

    .team-badge--b {
        background: linear-gradient(135deg, rgba(255,82,82,.25), rgba(255,82,82,.05));
    }

    .team-badge--winner {
        box-shadow: 0 0 0 1px rgba(255, 215, 64, .32), 0 14px 30px rgba(0,0,0,.25), 0 0 28px rgba(255, 215, 64, .16);
        position: relative;
        overflow: visible;
    }

    .team-badge--winner::before,
    .team-badge--winner::after {
        content: "";
        position: absolute;
        inset: -10px;
        border-radius: 20px;
        pointer-events: none;
    }

    .team-badge--winner::before {
        background:
            radial-gradient(circle at 15% 20%, rgba(255, 214, 10, .95) 0 2px, transparent 3px),
            radial-gradient(circle at 78% 14%, rgba(255, 82, 82, .92) 0 2px, transparent 3px),
            radial-gradient(circle at 84% 72%, rgba(0, 230, 118, .95) 0 2px, transparent 3px),
            radial-gradient(circle at 22% 82%, rgba(96, 165, 250, .92) 0 2px, transparent 3px);
        animation: winnerSpark 1.8s ease-in-out infinite;
        opacity: .85;
    }

    .team-badge--winner::after {
        border: 1px solid rgba(255, 214, 10, .3);
        animation: winnerPulse 2.2s ease-out infinite;
    }

    .winner-firework {
        pointer-events: none;
        position: absolute;
        z-index: 0;
    }

    .winner-firework::before,
    .winner-firework::after {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: 999px;
    }

    .winner-firework::before {
        background:
            radial-gradient(circle, currentColor 0 3px, transparent 4px),
            repeating-conic-gradient(from 0deg, currentColor 0deg 8deg, transparent 8deg 18deg);
        -webkit-mask: radial-gradient(circle, transparent 0 11px, #000 13px 44px, transparent 46px);
        mask: radial-gradient(circle, transparent 0 11px, #000 13px 44px, transparent 46px);
        filter: drop-shadow(0 0 8px currentColor);
        opacity: .92;
    }

    .winner-firework::after {
        background:
            radial-gradient(circle at 50% 8%, rgba(255,255,255,.98) 0 2px, transparent 3px),
            radial-gradient(circle at 92% 50%, rgba(255,255,255,.95) 0 2px, transparent 3px),
            radial-gradient(circle at 50% 92%, rgba(255,255,255,.98) 0 2px, transparent 3px),
            radial-gradient(circle at 8% 50%, rgba(255,255,255,.95) 0 2px, transparent 3px),
            radial-gradient(circle at 20% 20%, currentColor 0 2px, transparent 3px),
            radial-gradient(circle at 80% 20%, currentColor 0 2px, transparent 3px),
            radial-gradient(circle at 80% 80%, currentColor 0 2px, transparent 3px),
            radial-gradient(circle at 20% 80%, currentColor 0 2px, transparent 3px);
        filter: drop-shadow(0 0 6px currentColor);
        opacity: .82;
    }

    .winner-firework--badge {
        width: 58px;
        height: 58px;
        top: 50%;
        left: 50%;
    }

    .winner-firework--badge-a {
        color: rgba(255, 214, 10, .95);
        transform: translate(-62%, -64%) scale(.66);
        animation: fireworkPop 1.55s ease-out infinite;
    }

    .winner-firework--badge-b {
        color: rgba(96, 165, 250, .92);
        transform: translate(-34%, -28%) scale(.52);
        animation: fireworkPop 1.55s ease-out infinite .55s;
    }

    .clock-card--winner {
        overflow: hidden;
        position: relative;
        box-shadow: 0 22px 48px rgba(0,0,0,.28), inset 0 0 0 1px rgba(255, 214, 10, .14);
    }

    .clock-card--winner::before,
    .clock-card--winner::after {
        content: "";
        pointer-events: none;
        position: absolute;
        inset: -12%;
        z-index: 0;
        opacity: .9;
    }

    .clock-card--winner::before {
        background:
            radial-gradient(circle at 18% 24%, rgba(255, 214, 10, .95) 0 3px, rgba(255, 214, 10, .32) 4px, transparent 9px),
            radial-gradient(circle at 18% 24%, rgba(255,255,255,.95) 0 1px, transparent 2px),
            radial-gradient(circle at 82% 20%, rgba(96, 165, 250, .95) 0 3px, rgba(96, 165, 250, .28) 4px, transparent 9px),
            radial-gradient(circle at 82% 20%, rgba(255,255,255,.95) 0 1px, transparent 2px),
            radial-gradient(circle at 26% 84%, rgba(255, 82, 82, .95) 0 3px, rgba(255, 82, 82, .28) 4px, transparent 9px),
            radial-gradient(circle at 26% 84%, rgba(255,255,255,.95) 0 1px, transparent 2px),
            radial-gradient(circle at 78% 80%, rgba(0, 230, 118, .95) 0 3px, rgba(0, 230, 118, .26) 4px, transparent 9px),
            radial-gradient(circle at 78% 80%, rgba(255,255,255,.95) 0 1px, transparent 2px);
        animation: fireworksBurst 2.6s ease-in-out infinite;
    }

    .clock-card--winner::after {
        background:
            conic-gradient(from 0deg at 18% 24%, rgba(255, 214, 10, .8), transparent 18%, rgba(255, 214, 10, .65) 28%, transparent 42%, rgba(255, 214, 10, .55) 55%, transparent 70%, rgba(255, 214, 10, .72) 82%, transparent),
            conic-gradient(from 0deg at 82% 20%, rgba(96, 165, 250, .8), transparent 18%, rgba(96, 165, 250, .65) 28%, transparent 42%, rgba(96, 165, 250, .55) 55%, transparent 70%, rgba(96, 165, 250, .72) 82%, transparent),
            conic-gradient(from 0deg at 26% 84%, rgba(255, 82, 82, .82), transparent 18%, rgba(255, 82, 82, .65) 28%, transparent 42%, rgba(255, 82, 82, .55) 55%, transparent 70%, rgba(255, 82, 82, .72) 82%, transparent),
            conic-gradient(from 0deg at 78% 80%, rgba(0, 230, 118, .82), transparent 18%, rgba(0, 230, 118, .65) 28%, transparent 42%, rgba(0, 230, 118, .55) 55%, transparent 70%, rgba(0, 230, 118, .72) 82%, transparent);
        filter: blur(.4px);
        animation: fireworksRays 2.6s ease-in-out infinite;
    }

    .clock-card--winner > * {
        position: relative;
        z-index: 1;
    }

    .winner-firework--card {
        width: 96px;
        height: 96px;
        opacity: .92;
    }

    .winner-firework--card-a {
        color: rgba(255, 214, 10, .95);
        left: 3%;
        top: 6%;
        animation: fireworkPop 2.2s ease-out infinite;
    }

    .winner-firework--card-b {
        color: rgba(96, 165, 250, .92);
        right: 5%;
        top: 4%;
        animation: fireworkPop 2.2s ease-out infinite .45s;
    }

    .winner-firework--card-c {
        color: rgba(0, 230, 118, .92);
        right: 8%;
        bottom: 8%;
        animation: fireworkPop 2.2s ease-out infinite .95s;
    }

    .winner-firework--card-d {
        color: rgba(255, 82, 82, .9);
        left: 11%;
        bottom: 11%;
        animation: fireworkPop 2.2s ease-out infinite 1.35s;
    }

    .match-live__pill {
        font-weight: 800;
        letter-spacing: .25px;
        padding: .45rem .75rem;
    }

    .match-live__dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        margin-right: .45rem;
        border-radius: 50%;
