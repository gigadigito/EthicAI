    private static IReadOnlyList<ChartAxisTick> BuildAxisTicks(
        ChartSeriesState chart,
        Func<double, string> formatter)
    {
        if (!chart.HasData)
            return [];

        var ticks = new List<ChartAxisTick>(5);

        for (var i = 0; i <= 4; i++)
        {
            var ratio = i / 4d;
            var y = ratio * 320d;
            var value = chart.YMax - ((chart.YMax - chart.YMin) * ratio);
            ticks.Add(new ChartAxisTick
            {
                Y = y,
                Label = formatter(value)
            });
        }

        return ticks;
    }

    private IReadOnlyList<ChartTimeTick> BuildTimeTicks(ChartSeriesState chart)
    {
        if (!chart.HasData || chart.EndUtc <= chart.StartUtc)
            return [];

        var ticks = new List<ChartTimeTick>(5);
        var startUtc = ResolveMatchStartUtc(chart);
        var totalSeconds = Math.Max(1d, (chart.EndUtc - chart.StartUtc).TotalSeconds);

        for (var i = 0; i <= 4; i++)
        {
            var ratio = i / 4d;
            var tickUtc = chart.StartUtc.AddSeconds(totalSeconds * ratio);

            ticks.Add(new ChartTimeTick
            {
                XPercent = ratio * 100d,
                Label = FormatMatchTimeTick(startUtc, tickUtc)
            });
        }

        return ticks;
    }

    private DateTime? ResolveMatchStartUtc(ChartSeriesState chart)
    {
        if (_match?.StartTime is DateTime startTime)
            return DateTime.SpecifyKind(startTime, DateTimeKind.Utc);

        return chart.StartUtc;
    }

    private string FormatMatchTimeTick(DateTime? startUtc, DateTime tickUtc)
    {
        if (startUtc is DateTime matchStartUtc)
        {
            var elapsedMinutes = Math.Max(0, (int)Math.Round((tickUtc - matchStartUtc).TotalMinutes));
            return $"{elapsedMinutes:0}m";
        }

        return BrowserTimeZone.ConvertUtcToLocal(tickUtc).ToString("HH:mm");
    }

    private string FmtDateTime(DateTime? value)
        => BrowserTimeZone.FormatDateTime(value, "pt-BR");

    private static bool IsPercentageCrossoverRule(string ruleType)
        => ruleType.Equals("PercentageCrossover", StringComparison.OrdinalIgnoreCase);

    private static bool IsPercentThresholdRule(string ruleType)
        => ruleType.Equals("PercentThreshold", StringComparison.OrdinalIgnoreCase);

    private static bool IsPercentThresholdOrCrossoverRule(string ruleType)
        => IsPercentThresholdRule(ruleType) || IsPercentageCrossoverRule(ruleType);

    private static bool IsVolumeCrossoverRule(string ruleType)
        => ruleType.Equals("VolumeCrossover", StringComparison.OrdinalIgnoreCase);

    private static bool IsVolumeWindowRule(string ruleType)
        => ruleType.Equals("VolumeWindow", StringComparison.OrdinalIgnoreCase);

    private string GetChartEmptyMessage()
    {
        if (_match is null)
            return T("chartsWillBeDisplayedWhenTheMatchIsLoaded");

        var teamACount = GetTeamSnapshotCount(_match.TeamAId);
        var teamBCount = GetTeamSnapshotCount(_match.TeamBId);

        if (teamACount == 0 && teamBCount == 0)
            return T("thereAreNoPersistedSnapshotsForThisMatchYetAfterTheWorkerRunsAndRecordsTheCapturesTheChartsWillAppearHere");

        return T("notEnoughPointsToDrawLines", _match.TeamA, teamACount, _match.TeamB, teamBCount);
    }

    private sealed class ChartSeriesState
    {
        public static ChartSeriesState Empty { get; } = new();

        public string PolyA { get; init; } = "";
        public string PolyB { get; init; } = "";
        public double YMin { get; init; }
        public double YMax { get; init; }
        public double ZeroY { get; init; } = 160;
        public DateTime StartUtc { get; init; }
        public DateTime EndUtc { get; init; }
        public bool HasData => !string.IsNullOrWhiteSpace(PolyA) && !string.IsNullOrWhiteSpace(PolyB);
    }

