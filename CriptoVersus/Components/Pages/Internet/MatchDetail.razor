                                    @T("walletBalanceGuardUseMax")
                                </button>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(CurrentInvestmentAmountError))
                            {
                                <div class="text-danger small mt-2">@CurrentInvestmentAmountError</div>
                            }
                        </div>
                        <div class="modal-footer border-secondary">
                            <button type="button" class="btn btn-outline-light" @onclick="CloseInvestmentAmountModal">@T("cancel")</button>
                            <button type="button" class="btn btn-primary" disabled="@(_isSendingBet || _walletBalanceLoading || !IsInvestmentAmountValid)" @onclick="ConfirmInvestmentAmountAsync">
                                @InvestmentPrimaryButtonText
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

        <p class="small text-muted disclammer mb-4">@T("marketDataDisclaimer")</p>


    }
