    private bool TryParseManualAmount(string? raw, out decimal value)
    {
        value = 0m;
        if (string.IsNullOrWhiteSpace(raw))
            return false;

        var normalized = raw.Trim().Replace(" ", string.Empty);
        var lastComma = normalized.LastIndexOf(',');
        var lastDot = normalized.LastIndexOf('.');

        if (lastComma >= 0 && lastDot >= 0)
        {
            if (lastComma > lastDot)
                normalized = normalized.Replace(".", string.Empty).Replace(',', '.');
            else
                normalized = normalized.Replace(",", string.Empty);
        }
        else if (lastComma >= 0)
        {
            normalized = normalized.Replace(',', '.');
        }

        return decimal.TryParse(
            normalized,
            NumberStyles.AllowLeadingSign | NumberStyles.AllowDecimalPoint,
            CultureInfo.InvariantCulture,
            out value);
    }

    private string FormatManualInputAmount(decimal value)
        => value == 0m ? "0" : value.ToString("0.##########", CurrentCultureInfo);

    private async Task LoadBattleContextAsync()
    {
        try
        {
            _match = await Api.GetMatchBySymbolsAsync(_fromSymbol, _toSymbol);
        }
        catch (HttpRequestException ex) when (ex.StatusCode == HttpStatusCode.NotFound)
        {
            _match = null;
            Logger.LogInformation("CryptoConverterStats did not find an arena match for {From}/{To}. Conversion remains independent from battle data.", _fromSymbol, _toSymbol);
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            _match = null;
            Logger.LogWarning(ex, "CryptoConverterStats failed to load optional battle context for {From}/{To}", _fromSymbol, _toSymbol);
        }

        if (_match is null)
            return;

        try
        {
            var snapshots = await Api.GetMatchMetricSnapshotsAsync(_match.MatchId, take: 200) ?? [];
            _snapshots = snapshots.OrderBy(x => x.CapturedAtUtc).ThenBy(x => x.MatchMetricSnapshotId).ToList();
            _snapshotCount = _snapshots.Count;
            _priceUpdatedAtUtc = _priceUpdatedAtUtc ?? _snapshots.LastOrDefault()?.CapturedAtUtc ?? _match.EndTime ?? _match.StartTime;

            var fromSeries = _snapshots.Where(x => NormalizeComparisonSymbol(x.TeamSymbol) == _fromSymbol).ToList();
            var toSeries = _snapshots.Where(x => NormalizeComparisonSymbol(x.TeamSymbol) == _toSymbol).ToList();

            if (!_fromPriceUsdt.HasValue)
                _fromPriceUsdt = LatestPrice(fromSeries);
            if (!_toPriceUsdt.HasValue)
                _toPriceUsdt = LatestPrice(toSeries);
            if (!_fromChangePercent.HasValue)
                _fromChangePercent = ComputeSeriesChangePercent(fromSeries);
            if (!_toChangePercent.HasValue)
                _toChangePercent = ComputeSeriesChangePercent(toSeries);
            _priceUpdatedAtUtc ??= _snapshots.LastOrDefault()?.CapturedAtUtc;
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            Logger.LogWarning(ex, "CryptoConverterStats failed to load optional battle snapshots for match {MatchId} and pair {From}/{To}", _match.MatchId, _fromSymbol, _toSymbol);
            _snapshots = Array.Empty<MatchMetricSnapshotDto>();
            _snapshotCount = 0;
        }
    }

    private static ConverterPriceLookupResult BuildLocalLookupFailure(string symbol, string reason)
        => new() { Symbol = symbol, FailureReason = reason };

    private string DisplayRateSummary()
        => IsConversionAvailable ? $"1 {DisplayFromSymbol} \u2248 {DisplayAmount(DirectConvertedAmount)} {DisplayToSymbol}" : T("hero.unavailableTitle");

    private string DisplayPriceUpdatedSummary()
        => IsConversionAvailable && _priceUpdatedAtUtc.HasValue ? $"{T("labels.priceUpdated")} {DisplayPriceUpdatedTime()}" : T("labels.notAvailableYet");

    private string DisplayPriceUpdatedTime()
        => _priceUpdatedAtUtc.HasValue ? _priceUpdatedAtUtc.Value.ToUniversalTime().ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture) : T("labels.notAvailableYet");

    private string DisplayResolvedSourceSummary()
    {
        var sources = new[] { FormatLookupSource(_fromPriceLookup), FormatLookupSource(_toPriceLookup) }
            .Where(source => !string.IsNullOrWhiteSpace(source) && !string.Equals(source, "n/a", StringComparison.OrdinalIgnoreCase))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        return sources.Count == 0 ? "source: n/a" : $"source: {string.Join(" + ", sources)}";
    }

    private string DisplayMomentumSummary()
    {
        if (!IsConversionAvailable)
            return T("labels.notAvailableYet");

        if (_fromChangePercent.HasValue || _toChangePercent.HasValue)
        {
            var symbols = new List<(string Symbol, decimal Value)>();
            if (_fromChangePercent.HasValue)
                symbols.Add((DisplayFromSymbol, _fromChangePercent.Value));
            if (_toChangePercent.HasValue)
                symbols.Add((DisplayToSymbol, _toChangePercent.Value));

            return symbols.OrderByDescending(item => item.Value).First().Symbol;
        }

        return T("labels.notAvailableYet");
    }

    private string DisplayPriceVariation()
    {
        if (!HasBattleData)
            return T("labels.notAvailableYet");

        var parts = new List<string>(2);
        if (_fromChangePercent.HasValue)
            parts.Add($"{DisplayFromSymbol} {FormatPercent(_fromChangePercent.Value, CurrentCultureInfo)}");
        if (_toChangePercent.HasValue)
            parts.Add($"{DisplayToSymbol} {FormatPercent(_toChangePercent.Value, CurrentCultureInfo)}");

        return parts.Count == 0 ? T("labels.notAvailableYet") : string.Join(" · ", parts);
    }

    private string DisplayCandleBattle() => _snapshotCount > 0 ? T("battle.snapshotCount", _snapshotCount) : T("labels.notAvailableYet");
    private string DisplayArenaPressure() => _match is null ? T("labels.notAvailableYet") : $"{TranslateMatchStatus(_match.Status)} · {_match.ScoreA}-{_match.ScoreB}";
    private string DisplayArenaPressureDetail() => _match is null ? T("labels.notAvailableYet") : T("battle.matchId", _match.MatchId);
    private string DisplayBattleMomentum() => HasBattleData && (_fromChangePercent.HasValue || _toChangePercent.HasValue) ? (Math.Abs(_fromChangePercent ?? 0m) >= Math.Abs(_toChangePercent ?? 0m) ? DisplayFromSymbol : DisplayToSymbol) : T("labels.notAvailableYet");
    private string DisplayRecentWinner() => !string.IsNullOrWhiteSpace(_match?.WinnerTeamSymbol) ? NormalizeComparisonSymbol(_match.WinnerTeamSymbol) : T("labels.notAvailableYet");

    private static decimal? LatestPrice(IReadOnlyList<MatchMetricSnapshotDto> series)
        => series.Where(x => x.LastPrice.HasValue && x.LastPrice.Value > 0m).Select(x => x.LastPrice!.Value).LastOrDefault();

    private static decimal? ComputeSeriesChangePercent(IReadOnlyList<MatchMetricSnapshotDto> series)
    {
        var prices = series.Where(x => x.LastPrice.HasValue && x.LastPrice.Value > 0m).Select(x => x.LastPrice!.Value).ToList();
        if (prices.Count < 2)
            return null;

        var first = prices[0];
        var last = prices[^1];
        if (first <= 0m)
            return null;

        return ((last - first) / first) * 100m;
    }

    private static decimal ConvertAmount(decimal amount, decimal? fromPriceUsdt, decimal? toPriceUsdt)
        => amount * (fromPriceUsdt ?? 0m) / (toPriceUsdt ?? 1m);

    private static decimal ConvertInverseAmount(decimal amount, decimal? fromPriceUsdt, decimal? toPriceUsdt)
        => amount * (toPriceUsdt ?? 0m) / (fromPriceUsdt ?? 1m);

    private async Task<ConverterPriceLookupResult> ResolveAssetPriceAsync(string symbol)
    {
        var normalizedSymbol = symbol?.Trim().ToUpperInvariant() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(normalizedSymbol))
            return BuildLocalLookupFailure(string.Empty, "empty-symbol");

        if (StableUsdSymbols.Contains(normalizedSymbol))
        {
            return new ConverterPriceLookupResult
            {
                Symbol = normalizedSymbol,
                StatusCode = HttpStatusCode.OK,
                Source = "stablecoin_override",
                Snapshot = new AssetPriceSnapshotDto
                {
                    QuerySymbol = normalizedSymbol,
                    AssetSymbol = normalizedSymbol,
                    MarketSymbol = normalizedSymbol,
                    LastPriceUsdt = 1m,
                    PercentageChange = 0m,
                    CapturedAtUtc = DateTime.UtcNow,
                    Source = "stablecoin_override"
                }
            };
        }

        try
        {
            var snapshot = await Api.GetAssetPriceSnapshotAsync(normalizedSymbol);
            if (snapshot?.LastPriceUsdt is decimal lastPrice && lastPrice > 0m)
            {
                return new ConverterPriceLookupResult
                {
                    Symbol = normalizedSymbol,
                    StatusCode = HttpStatusCode.OK,
                    Source = string.IsNullOrWhiteSpace(snapshot.Source) ? "api-price-snapshot" : snapshot.Source,
                    Snapshot = snapshot
                };
            }

            return new ConverterPriceLookupResult
            {
                Symbol = normalizedSymbol,
                StatusCode = snapshot is null ? HttpStatusCode.NotFound : HttpStatusCode.OK,
                Source = snapshot is null ? string.Empty : string.IsNullOrWhiteSpace(snapshot.Source) ? "api-price-snapshot" : snapshot.Source,
                Snapshot = snapshot,
                FailureReason = snapshot is null ? "no-positive-market-price" : "endpoint-ok-without-positive-lastprice"
            };
        }
        catch (HttpRequestException ex)
        {
            return new ConverterPriceLookupResult
            {
                Symbol = normalizedSymbol,
                StatusCode = ex.StatusCode,
                FailureReason = ex.StatusCode == HttpStatusCode.NotFound
                    ? "no-positive-market-price"
                    : ex.StatusCode.HasValue ? $"endpoint-http-{(int)ex.StatusCode.Value}" : "endpoint-http-error"
            };
        }
        catch (TimeoutException)
        {
            return BuildLocalLookupFailure(normalizedSymbol, "endpoint-timeout");
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            return BuildLocalLookupFailure(normalizedSymbol, "endpoint-call-failed");
        }
    }

    private string GetIconUrl(string? symbol)
    {
        var baseSymbol = CleanAssetSymbol(symbol);
        return EnvironmentIsolationGuard.BuildBinanceIconUrl(baseSymbol);
    }

    private static string NormalizeSymbol(string? symbol)
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return string.Empty;

        var trimmed = symbol.Trim();
        return SymbolRegex.IsMatch(trimmed) ? trimmed.ToUpperInvariant() : string.Empty;
    }

    private static string NormalizeComparisonSymbol(string? symbol)
        => string.IsNullOrWhiteSpace(symbol)
            ? string.Empty
            : CleanAssetSymbol(new string(symbol.Trim().ToUpperInvariant().Where(char.IsLetterOrDigit).ToArray()));

    private static string CleanAssetSymbol(string? symbol)
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return string.Empty;

        var normalized = new string(symbol.Trim().ToUpperInvariant().Where(char.IsLetterOrDigit).ToArray());
        foreach (var suffix in AssetSuffixes)
        {
            if (normalized.Length > suffix.Length + 1 && normalized.EndsWith(suffix, StringComparison.Ordinal))
                return normalized[..^suffix.Length];
        }

        return normalized;
    }

    private static string GetAssetMonogram(string? symbol)
    {
        if (string.IsNullOrWhiteSpace(symbol))
            return "?";

        var text = symbol.Trim().ToUpperInvariant();
        return text.Length >= 2 ? text[..2] : text;
    }

    private string DisplayAmount(decimal? value) => value.HasValue ? FormatAmount(value.Value, CurrentCultureInfo) : "—";
    private string DisplayAmount(decimal value) => FormatAmount(value, CurrentCultureInfo);

    private static string FormatAmount(decimal value, CultureInfo culture)
    {
        var abs = Math.Abs(value);
        return abs >= 100000m
            ? value.ToString("N2", culture)
            : abs >= 1m ? value.ToString("N4", culture) : value.ToString("0.##########", culture);
    }

    private static string FormatPercent(decimal value, CultureInfo culture)
        => $"{value.ToString("+0.##;-0.##;0", culture)}%";

    private string FormatBoolean(bool value) => value ? "true" : "false";

    private static string FormatEndpointStatus(ConverterPriceLookupResult? lookup)
        => lookup?.StatusCode is HttpStatusCode statusCode ? $"{(int)statusCode} {statusCode}" : "n/a";

    private static string FormatLookupReason(ConverterPriceLookupResult? lookup)
    {
        if (lookup is null)
            return "lookup-not-executed";

        if (lookup.PriceFound)
            return string.IsNullOrWhiteSpace(lookup.FailureReason) ? "resolved" : lookup.FailureReason;

        return string.IsNullOrWhiteSpace(lookup.FailureReason) ? "missing-price-lookup-result" : lookup.FailureReason;
    }

    private static string FormatLookupSource(ConverterPriceLookupResult? lookup)
    {
        if (string.IsNullOrWhiteSpace(lookup?.Source))
            return "n/a";

        return lookup!.Source switch
        {
            "coin_price_current" => "coin_price_current (worker-cache)",
            "match_metric_snapshot_fallback" => "match_metric_snapshot (fallback)",
            "match_metric_snapshot" => "match_metric_snapshot (legacy)",
            "stablecoin_override" => "stablecoin_override",
            _ => lookup.Source
        };
    }

    private string DisplayUnavailableReason()
    {
        if (!_isValidSymbolPair)
            return "invalid-symbol-pair";

        var reasons = new List<string>();
        if (!(_fromPriceLookup?.PriceFound ?? false))
            reasons.Add($"{DisplayFromSymbol}:{FormatLookupReason(_fromPriceLookup)}");
        if (!(_toPriceLookup?.PriceFound ?? false))
            reasons.Add($"{DisplayToSymbol}:{FormatLookupReason(_toPriceLookup)}");

        return reasons.Count > 0 ? string.Join(" | ", reasons) : "conversion-unavailable-without-specific-lookup-failure";
    }

    private static DateTime? MaxDate(DateTime? left, DateTime? right)
        => left.HasValue && right.HasValue ? (left.Value >= right.Value ? left : right) : left ?? right;

    private string BuildBattleSlug() => $"{DisplayFromSymbol.ToLowerInvariant()}-vs-{DisplayToSymbol.ToLowerInvariant()}";

    private string TranslateMatchStatus(string? status)
        => status?.Trim().ToLowerInvariant() switch
        {
            "ongoing" => L.T("match.status.ongoing", _culture),
            "completed" => L.T("match.status.completed", _culture),
            "pending" => L.T("match.status.pending", _culture),
            "cancelled" => L.T("match.status.cancelled", _culture),
            _ => status ?? T("labels.notAvailableYet")
        };

    private string T(string key, params object?[] args)
        => L.T($"cryptoConverterStats.{key}", _culture, args);

    private string BuildAbsolute(string relativePath)
        => SeoDefaults.BuildPublicAbsoluteUrl(Config, relativePath);

    private string BuildRoutePath(string culture, string from, string to)
        => culture == AppCultureService.SecondaryRouteCulture
            ? $"/pt/stats/{from.ToLowerInvariant()}-para-{to.ToLowerInvariant()}"
            : $"/en/stats/{from.ToLowerInvariant()}-to-{to.ToLowerInvariant()}";

    private string GetCultureFromPath()
    {
        var currentPath = "/" + Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].Trim('/');
        return currentPath.StartsWith("/pt/", StringComparison.OrdinalIgnoreCase)
            ? AppCultureService.SecondaryRouteCulture
            : AppCultureService.DefaultRouteCulture;
    }

    private static readonly string[] AssetSuffixes = ["USDT", "USDC", "BUSD", "FDUSD", "BTC", "ETH"];
}
