@page "/en/stats/{fromSymbol}-to-{toSymbol}"
@page "/pt/stats/{fromSymbol}-para-{toSymbol}"
@using System.Net
@using System.Globalization
@using System.Text.Json
@using System.Text.RegularExpressions
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersus.Web.Services.CriptoVersusApiClient Api
@inject NavigationManager Nav
@inject LocalizationService L
@inject RouteLocalizationService RouteLocalization
@inject IConfiguration Config
@inject ILogger<CryptoConverterStats> Logger

@rendermode InteractiveServer

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <meta name="description" content="@MetaDescription" />
    <meta name="robots" content="@RobotsContent" />
    <meta name="keywords" content="@MetaKeywords" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="en-US" href="@EnglishUrl" />
    <link rel="alternate" hreflang="pt-BR" href="@PortugueseUrl" />
    <link rel="alternate" hreflang="x-default" href="@EnglishUrl" />
    <meta property="og:title" content="@PageTitleText" />
    <meta property="og:description" content="@MetaDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="@SocialImageUrl" />
    <meta property="og:image:alt" content="@PageTitleText" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@PageTitleText" />
    <meta name="twitter:description" content="@MetaDescription" />
    <meta name="twitter:image" content="@SocialImageUrl" />
    <meta name="twitter:image:alt" content="@PageTitleText" />
    <script type="application/ld+json">@((MarkupString)StructuredDataMarkup)</script>
</HeadContent>

<section class="crypto-converter-stats">
    <header class="crypto-converter-stats__hero">
        <div class="crypto-converter-stats__copy">
            <div class="crypto-converter-stats__breadcrumb-line">
                <a href="@RouteLocalization.BuildStatsPath(_culture)">@T("breadcrumbs.stats")</a>
                <span>/</span>
                <strong>@DisplayFromSymbol @T("labels.vs") @DisplayToSymbol</strong>
            </div>

            <span class="crypto-converter-stats__eyebrow">@T("hero.eyebrow")</span>
            <h1>@HeroTitleText</h1>
            <p class="crypto-converter-stats__lead">@T("hero.subtitle")</p>

            <div class="crypto-converter-stats__actions">
                <a class="crypto-converter-stats__cta" href="@PrimaryCtaUrl">@PrimaryCtaText</a>
                <a class="crypto-converter-stats__cta crypto-converter-stats__cta--secondary" href="@RouteLocalization.BuildStatsPath(_culture)">
                    @T("hero.backToStats")
                </a>
            </div>
        </div>

        <aside class="crypto-converter-stats__scoreboard" aria-label="@HeroTitleText">
            <div class="crypto-converter-stats__team-card crypto-converter-stats__team-card--from">
                <div class="crypto-converter-stats__team-identity">
                    <span class="crypto-converter-stats__logo-shell crypto-converter-stats__logo-shell--large" aria-hidden="true">
                        @if (!string.IsNullOrWhiteSpace(FromIconUrl))
                        {
                            <img src="@FromIconUrl" alt="" loading="lazy" width="56" height="56" onerror="this.style.display='none';" />
                        }
                        <span class="crypto-converter-stats__fallback">@GetAssetMonogram(DisplayFromSymbol)</span>
                    </span>
                    <div>
                        <small>@T("table.amount")</small>
                        <strong>@DisplayFromSymbol</strong>
                    </div>
                </div>

                @if (IsConversionAvailable)
                {
                    <div class="crypto-converter-stats__hero-manual crypto-converter-stats__hero-manual--from">
                        <label for="hero-manual-from-amount">@T("table.amount")</label>
                        <div class="crypto-converter-stats__hero-manual-control">
                            <input id="hero-manual-from-amount"
                                   inputmode="decimal"
                                   autocomplete="off"
                                   value="@_manualFromAmountText"
                                   @oninput="OnManualFromAmountChanged"
                                   aria-label="@ManualFromAmountAriaLabel" />
                            <span>@DisplayFromSymbol</span>
                        </div>
                        <small>@DisplayHeroFromManualHint()</small>
                    </div>
                }
            </div>

            <div class="crypto-converter-stats__versus-core"><span>@T("labels.vs")</span></div>

            <div class="crypto-converter-stats__team-card crypto-converter-stats__team-card--to">
                <div class="crypto-converter-stats__team-identity">
                    <span class="crypto-converter-stats__logo-shell crypto-converter-stats__logo-shell--large" aria-hidden="true">
                        @if (!string.IsNullOrWhiteSpace(ToIconUrl))
                        {
                            <img src="@ToIconUrl" alt="" loading="lazy" width="56" height="56" onerror="this.style.display='none';" />
                        }
                        <span class="crypto-converter-stats__fallback">@GetAssetMonogram(DisplayToSymbol)</span>
                    </span>
                    <div>
                        <small>@T("table.estimate")</small>
                        <strong>@DisplayToSymbol</strong>
                    </div>
                </div>

                @if (IsConversionAvailable)
                {
                    <div class="crypto-converter-stats__hero-manual crypto-converter-stats__hero-manual--to">
                        <label for="hero-manual-to-amount">@T("table.estimate")</label>
                        <div class="crypto-converter-stats__hero-manual-control">
                            <input id="hero-manual-to-amount"
                                   inputmode="decimal"
                                   autocomplete="off"
                                   value="@_manualToAmountText"
                                   @oninput="OnManualToAmountChanged"
                                   aria-label="@ManualToAmountAriaLabel" />
                            <span>@DisplayToSymbol</span>
                        </div>
                        <small>@DisplayHeroToManualHint()</small>
                    </div>
                }
            </div>

            <div class="crypto-converter-stats__hero-metric crypto-converter-stats__hero-metric--wide">
                <span>@T("labels.directRate")</span>
                <strong>@DisplayRateSummary()</strong>
                <small>@DisplayPriceUpdatedSummary()</small>
            </div>
        </aside>
    </header>

    <section class="crypto-converter-stats__conversion-card">
        <div class="crypto-converter-stats__converter-top">
            <div class="crypto-converter-stats__converter-pair">
                <span class="crypto-converter-stats__symbol-chip crypto-converter-stats__symbol-chip--from">
                    <span class="crypto-converter-stats__logo-shell" aria-hidden="true">
                        @if (!string.IsNullOrWhiteSpace(FromIconUrl))
                        {
                            <img src="@FromIconUrl" alt="" loading="lazy" width="32" height="32" onerror="this.style.display='none';" />
                        }
                        <span class="crypto-converter-stats__fallback">@GetAssetMonogram(DisplayFromSymbol)</span>
                    </span>
                    <strong>@DisplayFromSymbol</strong>
                </span>
                <span class="crypto-converter-stats__swap-arrow" aria-hidden="true">→</span>
                <span class="crypto-converter-stats__symbol-chip crypto-converter-stats__symbol-chip--to">
                    <span class="crypto-converter-stats__logo-shell" aria-hidden="true">
                        @if (!string.IsNullOrWhiteSpace(ToIconUrl))
                        {
                            <img src="@ToIconUrl" alt="" loading="lazy" width="32" height="32" onerror="this.style.display='none';" />
                        }
                        <span class="crypto-converter-stats__fallback">@GetAssetMonogram(DisplayToSymbol)</span>
                    </span>
                    <strong>@DisplayToSymbol</strong>
                </span>
            </div>

            <div class="crypto-converter-stats__status-pill @(IsConversionAvailable ? "is-live" : "is-unavailable")">
                @(IsConversionAvailable? T("labels.priceUpdated") : T("labels.notAvailableYet"))
            </div>
        </div>

        @if (IsConversionAvailable)
        {
            <div class="crypto-converter-stats__result">
                <span>@T("hero.resultLabel")</span>
                <strong>1 @DisplayFromSymbol <em>@T("labels.approx")</em> @DisplayAmount(DirectConvertedAmount) @DisplayToSymbol</strong>
                <small>@T("labels.priceUpdated"): @DisplayPriceUpdatedTime() UTC · @DisplayResolvedSourceSummary()</small>
            </div>

            <div class="crypto-converter-stats__manual-converter" aria-label="@ManualConverterAriaLabel">
                <div class="crypto-converter-stats__manual-row crypto-converter-stats__manual-row--from">
                    <label for="manual-from-amount">
                        <span>@T("table.amount")</span>
                        <strong>@DisplayFromSymbol</strong>
                    </label>
                    <div class="crypto-converter-stats__manual-input-shell">
                        <input id="manual-from-amount"
                               class="crypto-converter-stats__manual-input"
                               inputmode="decimal"
                               autocomplete="off"
                               value="@_manualFromAmountText"
                               @oninput="OnManualFromAmountChanged"
                               aria-label="@ManualFromAmountAriaLabel" />
                        <span>@DisplayFromSymbol</span>
                    </div>
                </div>

                <button type="button"
                        class="crypto-converter-stats__manual-swap"
                        @onclick="SwapManualConverterValues"
                        aria-label="@ManualSwapAriaLabel">
                    ⇅
                </button>

                <div class="crypto-converter-stats__manual-row crypto-converter-stats__manual-row--to">
                    <label for="manual-to-amount">
                        <span>@T("table.estimate")</span>
                        <strong>@DisplayToSymbol</strong>
                    </label>
                    <div class="crypto-converter-stats__manual-input-shell">
                        <input id="manual-to-amount"
                               class="crypto-converter-stats__manual-input"
                               inputmode="decimal"
                               autocomplete="off"
                               value="@_manualToAmountText"
                               @oninput="OnManualToAmountChanged"
                               aria-label="@ManualToAmountAriaLabel" />
                        <span>@DisplayToSymbol</span>
                    </div>
                </div>

                <small class="crypto-converter-stats__manual-hint">
                    @DisplayManualConverterHint()
                </small>
            </div>

            <div class="crypto-converter-stats__quick-metrics">
                <article>
                    <span>@T("labels.directRate")</span>
                    <strong>@DisplayAmount(DirectConvertedAmount) @DisplayToSymbol</strong>
                </article>
                <article>
                    <span>@T("table.inverse.title")</span>
                    <strong>@DisplayAmount(ConvertInverseAmount(1m, _fromPriceUsdt, _toPriceUsdt)) @DisplayFromSymbol</strong>
                </article>
                <article>
                    <span>@T("labels.momentum")</span>
                    <strong>@DisplayMomentumSummary()</strong>
                </article>
            </div>
        }
        else
        {
            <div class="crypto-converter-stats__unavailable" role="status" aria-live="polite">
                <div>
                    <strong>@T("hero.unavailableTitle")</strong>
                    <span>@T("hero.unavailableBody")</span>
                </div>

                <details class="crypto-converter-stats__diagnostics">
                    <summary>@T("hero.diagnostics.title")</summary>
                    <dl class="crypto-converter-stats__diagnostics-grid">
                        <div><dt>@T("hero.diagnostics.fromSymbol")</dt><dd>@DisplayFromSymbol</dd></div>
                        <div><dt>@T("hero.diagnostics.toSymbol")</dt><dd>@DisplayToSymbol</dd></div>
                        <div><dt>@T("hero.diagnostics.fromPriceFound")</dt><dd>@FormatBoolean(_fromPriceLookup?.PriceFound ?? false)</dd></div>
                        <div><dt>@T("hero.diagnostics.toPriceFound")</dt><dd>@FormatBoolean(_toPriceLookup?.PriceFound ?? false)</dd></div>
                        <div><dt>@T("hero.diagnostics.fromStatus")</dt><dd>@FormatEndpointStatus(_fromPriceLookup)</dd></div>
                        <div><dt>@T("hero.diagnostics.toStatus")</dt><dd>@FormatEndpointStatus(_toPriceLookup)</dd></div>
                        <div><dt>@T("hero.diagnostics.fromReason")</dt><dd>@FormatLookupReason(_fromPriceLookup)</dd></div>
                        <div><dt>@T("hero.diagnostics.toReason")</dt><dd>@FormatLookupReason(_toPriceLookup)</dd></div>
                        <div><dt>@T("hero.diagnostics.fromSource")</dt><dd>@FormatLookupSource(_fromPriceLookup)</dd></div>
                        <div><dt>@T("hero.diagnostics.toSource")</dt><dd>@FormatLookupSource(_toPriceLookup)</dd></div>
                        <div class="crypto-converter-stats__diagnostics-full"><dt>@T("hero.diagnostics.reason")</dt><dd>@DisplayUnavailableReason()</dd></div>
                    </dl>
                </details>
            </div>
        }
    </section>

    @if (IsConversionAvailable)
    {
        <section class="crypto-converter-stats__grid" aria-labelledby="direct-conversion-heading">
            <article class="crypto-converter-stats__table-card">
                <div class="crypto-converter-stats__section-head">
                    <div>
                        <span>@T("table.direct.eyebrow")</span>
                        <h2 id="direct-conversion-heading">@T("table.direct.title")</h2>
                    </div>
                    <p>@T("table.direct.description", DisplayFromSymbol, DisplayToSymbol)</p>
                </div>

                <div class="crypto-converter-stats__table-wrap">
                    <table class="crypto-converter-stats__table">
                        <thead><tr><th>@T("table.amount")</th><th>@T("table.estimate")</th></tr></thead>
                        <tbody>
                            @foreach (var amount in DirectAmounts)
                            {
                                <tr>
                                    <td>@DisplayAmount(amount) @DisplayFromSymbol</td>
                                    <td>@DisplayAmount(ConvertAmount(amount, _fromPriceUsdt, _toPriceUsdt)) @DisplayToSymbol</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </article>

            <article class="crypto-converter-stats__table-card">
                <div class="crypto-converter-stats__section-head">
                    <div>
                        <span>@T("table.inverse.eyebrow")</span>
                        <h2>@T("table.inverse.title")</h2>
                    </div>
                    <p>@T("table.inverse.description", DisplayToSymbol, DisplayFromSymbol)</p>
                </div>

                <div class="crypto-converter-stats__table-wrap">
                    <table class="crypto-converter-stats__table">
                        <thead><tr><th>@T("table.amount")</th><th>@T("table.estimate")</th></tr></thead>
                        <tbody>
                            @foreach (var amount in InverseAmounts)
                            {
                                <tr>
                                    <td>@DisplayAmount(amount) @DisplayToSymbol</td>
                                    <td>@DisplayAmount(ConvertInverseAmount(amount, _fromPriceUsdt, _toPriceUsdt)) @DisplayFromSymbol</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </article>
        </section>
    }
    <CryptoConverterBattleLinksSection FromSymbol="@DisplayFromSymbol"
                                       ToSymbol="@DisplayToSymbol"
                                       Culture="@_culture"
                                       HasBattleData="@HasBattleData"
                                       MatchId="@(_match?.MatchId)"
                                       MatchStatus="@(_match?.Status)"
                                       ScoreA="@(_match?.ScoreA)"
                                       ScoreB="@(_match?.ScoreB)" />

    <section class="crypto-converter-stats__disclaimer">
        <div class="crypto-converter-stats__section-head crypto-converter-stats__section-head--stacked">
            <div>
                <span>@T("hero.disclaimerEyebrow")</span>
                <h2>@T("hero.disclaimerTitle")</h2>
            </div>
            <p>@T("hero.disclaimerBody")</p>
        </div>
    </section>
</section>

<style>
    .crypto-converter-stats {
        --cv-bg: #05070d;
        --cv-surface: rgba(11, 16, 27, 0.92);
        --cv-border: rgba(255, 255, 255, 0.09);
        --cv-text: #eef5ff;
        --cv-muted: #a9b7ca;
        --cv-orange: #ff9100;
        --cv-orange-soft: rgba(255, 145, 0, 0.18);
        --cv-cyan: #18d8d2;
        --cv-cyan-soft: rgba(24, 216, 210, 0.16);
        --cv-green: #4cf38d;
        width: 100%;
        max-width: min(1880px, calc(100vw - 24px));
        margin-inline: auto;
        padding: clamp(0.75rem, 2vw, 1.5rem);
        color: var(--cv-text);
    }

        .crypto-converter-stats *,
        .crypto-converter-stats *::before,
        .crypto-converter-stats *::after {
            box-sizing: border-box;
        }

    .crypto-converter-stats__hero,
    .crypto-converter-stats__conversion-card,
    .crypto-converter-stats__table-card,
    .crypto-converter-stats__battle,
    .crypto-converter-stats__disclaimer {
        position: relative;
        overflow: hidden;
        border: 1px solid var(--cv-border);
        background: linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px), radial-gradient(circle at 10% 5%, var(--cv-orange-soft), transparent 30%), radial-gradient(circle at 92% 0%, var(--cv-cyan-soft), transparent 30%), linear-gradient(180deg, rgba(10, 14, 24, 0.98), rgba(5, 8, 15, 0.99));
        background-size: 34px 34px, 34px 34px, auto, auto, auto;
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.38);
    }

    .crypto-converter-stats__hero {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(360px, 0.9fr);
        gap: clamp(1rem, 2vw, 1.5rem);
        min-height: 430px;
        padding: clamp(1.15rem, 2.5vw, 2rem);
        border-radius: 30px;
    }

    .crypto-converter-stats__copy {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .crypto-converter-stats__breadcrumb-line {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        width: fit-content;
        margin-bottom: 1rem;
        padding: .45rem .7rem;
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 999px;
        background: rgba(255,255,255,.035);
        color: var(--cv-muted);
        font-size: .82rem;
    }

        .crypto-converter-stats__breadcrumb-line a {
            color: var(--cv-cyan);
            text-decoration: none;
            font-weight: 800;
        }

        .crypto-converter-stats__breadcrumb-line strong {
            color: var(--cv-text);
        }

    .crypto-converter-stats__eyebrow, .crypto-converter-stats__section-head span {
        display: inline-block;
        margin-bottom: .55rem;
        color: var(--cv-cyan);
        font-size: .76rem;
        font-weight: 950;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .crypto-converter-stats__copy h1 {
        max-width: 900px;
        margin: 0;
        font-size: clamp(2.25rem, 5vw, 4.85rem);
        line-height: .94;
        letter-spacing: -.055em;
    }

    .crypto-converter-stats__lead, .crypto-converter-stats__section-head p, .crypto-converter-stats__unavailable span, .crypto-converter-stats__battle-empty span, .crypto-converter-stats__disclaimer p {
        color: var(--cv-muted);
        line-height: 1.65;
    }

    .crypto-converter-stats__actions {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        margin-top: 1.35rem;
    }

    .crypto-converter-stats__cta, .crypto-converter-stats__battle-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 3rem;
        padding: .78rem 1.05rem;
        border-radius: 16px;
        border: 1px solid rgba(255,145,0,.45);
        background: linear-gradient(135deg, #ff9100, var(--cv-orange));
        color: #160a00;
        font-weight: 950;
        text-decoration: none;
    }

    .crypto-converter-stats__cta--secondary {
        border-color: rgba(24,216,210,.32);
        background: rgba(255,255,255,.035);
        color: var(--cv-text);
    }

    .crypto-converter-stats__scoreboard {
        display: grid;
        align-content: center;
        gap: .85rem;
    }

    .crypto-converter-stats__team-card {
        display: grid;
        grid-template-columns: minmax(160px, auto) minmax(220px, 1fr);
        align-items: center;
        gap: 1rem;
        min-height: 106px;
        padding: 1rem;
        border-radius: 24px;
        border: 1px solid var(--cv-border);
        background: rgba(255,255,255,.045);
    }

    .crypto-converter-stats__team-card--from {
        border-color: rgba(255,145,0,.28);
        box-shadow: inset 4px 0 0 rgba(255,145,0,.8);
    }

    .crypto-converter-stats__team-card--to {
        border-color: rgba(24,216,210,.28);
        box-shadow: inset 4px 0 0 rgba(24,216,210,.8);
    }

    .crypto-converter-stats__team-identity {
        display: flex;
        align-items: center;
        gap: .85rem;
        min-width: 0;
    }

    .crypto-converter-stats__team-card small, .crypto-converter-stats__hero-metric span, .crypto-converter-stats__hero-metric small {
        display: block;
        color: var(--cv-muted);
        font-size: .82rem;
        font-weight: 700;
    }

    .crypto-converter-stats__team-card strong {
        display: block;
        margin-top: .12rem;
        font-size: clamp(1.45rem, 3vw, 2rem);
        line-height: 1;
    }

    .crypto-converter-stats__hero-manual {
        display: grid;
        gap: .4rem;
        min-width: 0;
        justify-self: stretch;
    }

        .crypto-converter-stats__hero-manual label {
            color: var(--cv-muted);
            font-size: .72rem;
            font-weight: 950;
            letter-spacing: .08em;
            text-transform: uppercase;
        }

    .crypto-converter-stats__hero-manual-control {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: center;
        min-height: 3.25rem;
        padding: .3rem .75rem;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,.12);
        background: rgba(0,0,0,.2);
    }

    .crypto-converter-stats__hero-manual--from .crypto-converter-stats__hero-manual-control {
        border-color: rgba(255,145,0,.34);
        box-shadow: inset 3px 0 0 rgba(255,145,0,.78);
    }

    .crypto-converter-stats__hero-manual--to .crypto-converter-stats__hero-manual-control {
        border-color: rgba(24,216,210,.34);
        box-shadow: inset 3px 0 0 rgba(24,216,210,.78);
    }

    .crypto-converter-stats__hero-manual-control input {
        width: 100%;
        min-width: 0;
        border: 0;
        outline: 0;
        background: transparent;
        color: var(--cv-text);
        font: inherit;
        font-size: clamp(1.2rem, 2.4vw, 1.85rem);
        font-weight: 950;
        letter-spacing: -.04em;
    }

    .crypto-converter-stats__hero-manual-control span {
        color: var(--cv-muted);
        font-size: .82rem;
        font-weight: 950;
    }

    .crypto-converter-stats__hero-manual small {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: var(--cv-muted);
        font-size: .76rem;
        font-weight: 800;
    }

    .crypto-converter-stats__versus-core {
        display: grid;
        place-items: center;
        margin-block: -.35rem;
    }

        .crypto-converter-stats__versus-core span {
            display: grid;
            place-items: center;
            width: 4rem;
            height: 4rem;
            border-radius: 999px;
            border: 1px solid rgba(255,255,255,.16);
            background: linear-gradient(135deg, rgba(255,145,0,.78), rgba(24,216,210,.78));
            color: #fff;
            font-weight: 950;
        }

    .crypto-converter-stats__hero-metric {
        display: grid;
        gap: .35rem;
        padding: 1rem;
        border-radius: 20px;
        border: 1px solid var(--cv-border);
        background: rgba(0,0,0,.24);
    }

    .crypto-converter-stats__conversion-card, .crypto-converter-stats__battle, .crypto-converter-stats__disclaimer {
        margin-top: 1.15rem;
        padding: clamp(1rem, 2vw, 1.45rem);
        border-radius: 30px;
    }

    .crypto-converter-stats__converter-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .crypto-converter-stats__converter-pair, .crypto-converter-stats__symbol-chip {
        display: inline-flex;
        align-items: center;
        gap: .55rem;
        flex-wrap: wrap;
    }

    .crypto-converter-stats__symbol-chip {
        padding: .5rem .7rem;
        border-radius: 999px;
        border: 1px solid var(--cv-border);
        background: rgba(255,255,255,.045);
        font-weight: 950;
    }

    .crypto-converter-stats__swap-arrow {
        color: var(--cv-cyan);
        font-size: 1.35rem;
        font-weight: 950;
    }

    .crypto-converter-stats__status-pill {
        display: inline-flex;
        align-items: center;
