@page "/en/stats/{fromSymbol}-to-{toSymbol}"
@page "/pt/stats/{fromSymbol}-para-{toSymbol}"
@using System.Net
@using System.Net.Http
@using System.Globalization
@using System.Text.Json
@using System.Text.RegularExpressions
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersus.Web.Services.CriptoVersusApiClient Api
@inject NavigationManager Nav
@inject LocalizationService L
@inject RouteLocalizationService RouteLocalization
@inject IConfiguration Config
@inject ILogger<CryptoConverterStats> Logger
@rendermode InteractiveServer

<PageTitle>@PageTitleText</PageTitle>
<HeadContent>
    <meta name="description" content="@MetaDescription" />
    <meta name="robots" content="@RobotsContent" />
    <meta name="keywords" content="@MetaKeywords" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="en-US" href="@EnglishUrl" />
    <link rel="alternate" hreflang="pt-BR" href="@PortugueseUrl" />
    <link rel="alternate" hreflang="x-default" href="@EnglishUrl" />
    <meta property="og:title" content="@PageTitleText" />
    <meta property="og:description" content="@MetaDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="@SocialImageUrl" />
    <meta property="og:image:alt" content="@PageTitleText" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@PageTitleText" />
    <meta name="twitter:description" content="@MetaDescription" />
    <meta name="twitter:image" content="@SocialImageUrl" />
    <meta name="twitter:image:alt" content="@PageTitleText" />
    <script type="application/ld+json">@StructuredDataMarkup</script>
</HeadContent>

<section class="crypto-converter-stats">
    <header class="crypto-converter-stats__hero">
        <div class="crypto-converter-stats__hero-bg" aria-hidden="true"></div>

        <div class="crypto-converter-stats__copy">
            <div class="crypto-converter-stats__breadcrumb-line">
                <a href="@RouteLocalization.BuildStatsPath(_culture)">@T("breadcrumbs.stats")</a>
                <span>/</span>
                <strong>@DisplayFromSymbol @T("labels.vs") @DisplayToSymbol</strong>
            </div>

            <span class="crypto-converter-stats__eyebrow">@T("hero.eyebrow")</span>
            <h1>@HeroTitleText</h1>
            <p class="crypto-converter-stats__lead">@T("hero.subtitle")</p>

            <div class="crypto-converter-stats__actions">
                <a class="crypto-converter-stats__cta" href="@PrimaryCtaUrl">
                    <span>@PrimaryCtaText</span>
                </a>
                <a class="crypto-converter-stats__cta crypto-converter-stats__cta--secondary"
                   href="@RouteLocalization.BuildStatsPath(_culture)">
                    @T("hero.backToStats")
                </a>
            </div>
        </div>

        <aside class="crypto-converter-stats__scoreboard" aria-label="@HeroTitleText">
            <div class="crypto-converter-stats__team-card crypto-converter-stats__team-card--from">
                <span class="crypto-converter-stats__logo-shell crypto-converter-stats__logo-shell--large" aria-hidden="true">
                    @if (!string.IsNullOrWhiteSpace(FromIconUrl))
                    {
                        <img src="@FromIconUrl" alt="" loading="lazy" width="56" height="56" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                    }
                    <span class="crypto-converter-stats__fallback" aria-hidden="true">@GetAssetMonogram(DisplayFromSymbol)</span>
                </span>
                <div>
                    <small>@T("table.amount")</small>
                    <strong>@DisplayFromSymbol</strong>
                </div>
            </div>

            <div class="crypto-converter-stats__versus-core">
                <span>@T("labels.vs")</span>
            </div>

            <div class="crypto-converter-stats__team-card crypto-converter-stats__team-card--to">
                <span class="crypto-converter-stats__logo-shell crypto-converter-stats__logo-shell--large" aria-hidden="true">
                    @if (!string.IsNullOrWhiteSpace(ToIconUrl))
                    {
                        <img src="@ToIconUrl" alt="" loading="lazy" width="56" height="56" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                    }
                    <span class="crypto-converter-stats__fallback" aria-hidden="true">@GetAssetMonogram(DisplayToSymbol)</span>
                </span>
                <div>
                    <small>@T("table.estimate")</small>
                    <strong>@DisplayToSymbol</strong>
                </div>
            </div>

            <div class="crypto-converter-stats__hero-metric crypto-converter-stats__hero-metric--wide">
                <span>@T("labels.directRate")</span>
                <strong>@DisplayRateSummary()</strong>
                <small>@DisplayPriceUpdatedSummary()</small>
            </div>
        </aside>
    </header>

    <section class="crypto-converter-stats__conversion-card">
        <div class="crypto-converter-stats__converter-top">
            <div class="crypto-converter-stats__converter-pair">
                <span class="crypto-converter-stats__symbol-chip crypto-converter-stats__symbol-chip--from">
                    <span class="crypto-converter-stats__logo-shell" aria-hidden="true">
                        @if (!string.IsNullOrWhiteSpace(FromIconUrl))
                        {
                            <img src="@FromIconUrl" alt="" loading="lazy" width="32" height="32" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                        }
                        <span class="crypto-converter-stats__fallback" aria-hidden="true">@GetAssetMonogram(DisplayFromSymbol)</span>
                    </span>
                    <strong>@DisplayFromSymbol</strong>
                </span>

                <span class="crypto-converter-stats__swap-arrow" aria-hidden="true">→</span>

                <span class="crypto-converter-stats__symbol-chip crypto-converter-stats__symbol-chip--to">
                    <span class="crypto-converter-stats__logo-shell" aria-hidden="true">
                        @if (!string.IsNullOrWhiteSpace(ToIconUrl))
                        {
                            <img src="@ToIconUrl" alt="" loading="lazy" width="32" height="32" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                        }
                        <span class="crypto-converter-stats__fallback" aria-hidden="true">@GetAssetMonogram(DisplayToSymbol)</span>
                    </span>
                    <strong>@DisplayToSymbol</strong>
                </span>
            </div>

            <div class="crypto-converter-stats__status-pill @(IsConversionAvailable ? "is-live" : "is-unavailable")">
                @(IsConversionAvailable? T("labels.priceUpdated") : T("labels.notAvailableYet"))
            </div>
        </div>

        @if (IsConversionAvailable)
        {
            <div class="crypto-converter-stats__result">
                <span>@T("hero.resultLabel")</span>
                <strong>
                    1 @DisplayFromSymbol
                    <em>@T("labels.approx")</em>
                    @DisplayAmount(DirectConvertedAmount) @DisplayToSymbol
                </strong>
                <small>@T("labels.priceUpdated"): @DisplayPriceUpdatedTime() UTC</small>
            </div>

            <div class="crypto-converter-stats__quick-metrics">
                <article>
                    <span>@T("labels.directRate")</span>
                    <strong>@DisplayAmount(DirectConvertedAmount) @DisplayToSymbol</strong>
                </article>
                <article>
                    <span>@T("table.inverse.title")</span>
                    <strong>@DisplayAmount(ConvertInverseAmount(1m, _fromPriceUsdt, _toPriceUsdt)) @DisplayFromSymbol</strong>
                </article>
                <article>
                    <span>@T("labels.momentum")</span>
                    <strong>@DisplayMomentumSummary()</strong>
                </article>
            </div>
        }
        else
        {
            <div class="crypto-converter-stats__unavailable" role="status" aria-live="polite">
                <div>
                    <strong>@T("hero.unavailableTitle")</strong>
                    <span>@T("hero.unavailableBody")</span>
                </div>

                <details class="crypto-converter-stats__diagnostics">
                    <summary>@T("hero.diagnostics.title")</summary>
                    <dl class="crypto-converter-stats__diagnostics-grid">
                        <div>
                            <dt>@T("hero.diagnostics.fromSymbol")</dt>
                            <dd>@DisplayFromSymbol</dd>
                        </div>
                        <div>
                            <dt>@T("hero.diagnostics.toSymbol")</dt>
                            <dd>@DisplayToSymbol</dd>
                        </div>
                        <div>
                            <dt>@T("hero.diagnostics.fromPriceFound")</dt>
                            <dd>@FormatBoolean(_fromPriceLookup?.PriceFound ?? false)</dd>
                        </div>
                        <div>
                            <dt>@T("hero.diagnostics.toPriceFound")</dt>
                            <dd>@FormatBoolean(_toPriceLookup?.PriceFound ?? false)</dd>
                        </div>
                        <div>
                            <dt>@T("hero.diagnostics.fromStatus")</dt>
                            <dd>@FormatEndpointStatus(_fromPriceLookup)</dd>
                        </div>
                        <div>
                            <dt>@T("hero.diagnostics.toStatus")</dt>
                            <dd>@FormatEndpointStatus(_toPriceLookup)</dd>
                        </div>
                        <div>
                            <dt>@T("hero.diagnostics.fromReason")</dt>
                            <dd>@FormatLookupReason(_fromPriceLookup)</dd>
                        </div>
                        <div>
                            <dt>@T("hero.diagnostics.toReason")</dt>
                            <dd>@FormatLookupReason(_toPriceLookup)</dd>
                        </div>
                        <div>
                            <dt>@T("hero.diagnostics.fromSource")</dt>
                            <dd>@FormatLookupSource(_fromPriceLookup)</dd>
                        </div>
                        <div>
                            <dt>@T("hero.diagnostics.toSource")</dt>
                            <dd>@FormatLookupSource(_toPriceLookup)</dd>
                        </div>
                        <div class="crypto-converter-stats__diagnostics-full">
                            <dt>@T("hero.diagnostics.reason")</dt>
                            <dd>@DisplayUnavailableReason()</dd>
                        </div>
                    </dl>
                </details>
            </div>
        }
    </section>

    @if (IsConversionAvailable)
    {
        <section class="crypto-converter-stats__grid" aria-labelledby="direct-conversion-heading">
            <article class="crypto-converter-stats__table-card">
                <div class="crypto-converter-stats__section-head">
                    <div>
                        <span>@T("table.direct.eyebrow")</span>
                        <h2 id="direct-conversion-heading">@T("table.direct.title")</h2>
                    </div>
                    <p>@T("table.direct.description", DisplayFromSymbol, DisplayToSymbol)</p>
                </div>

                <div class="crypto-converter-stats__table-wrap">
                    <table class="crypto-converter-stats__table">
                        <thead>
                            <tr>
                                <th>@T("table.amount")</th>
                                <th>@T("table.estimate")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var amount in DirectAmounts)
                            {
                                <tr>
                                    <td>
                                        <span class="crypto-converter-stats__table-symbol">
                                            <span class="crypto-converter-stats__logo-shell crypto-converter-stats__logo-shell--small" aria-hidden="true">
                                                @if (!string.IsNullOrWhiteSpace(FromIconUrl))
                                                {
                                                    <img src="@FromIconUrl" alt="" loading="lazy" width="18" height="18" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                                }
                                                <span class="crypto-converter-stats__fallback" aria-hidden="true">@GetAssetMonogram(DisplayFromSymbol)</span>
                                            </span>
                                            <strong>@DisplayAmount(amount)</strong>
                                            <span>@DisplayFromSymbol</span>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="crypto-converter-stats__table-symbol">
                                            <span class="crypto-converter-stats__logo-shell crypto-converter-stats__logo-shell--small" aria-hidden="true">
                                                @if (!string.IsNullOrWhiteSpace(ToIconUrl))
                                                {
                                                    <img src="@ToIconUrl" alt="" loading="lazy" width="18" height="18" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                                }
                                                <span class="crypto-converter-stats__fallback" aria-hidden="true">@GetAssetMonogram(DisplayToSymbol)</span>
                                            </span>
                                            <strong>@DisplayAmount(ConvertAmount(amount, _fromPriceUsdt, _toPriceUsdt))</strong>
                                            <span>@DisplayToSymbol</span>
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </article>

            <article class="crypto-converter-stats__table-card">
                <div class="crypto-converter-stats__section-head">
                    <div>
                        <span>@T("table.inverse.eyebrow")</span>
                        <h2>@T("table.inverse.title")</h2>
                    </div>
                    <p>@T("table.inverse.description", DisplayToSymbol, DisplayFromSymbol)</p>
                </div>

                <div class="crypto-converter-stats__table-wrap">
                    <table class="crypto-converter-stats__table">
                        <thead>
                            <tr>
                                <th>@T("table.amount")</th>
                                <th>@T("table.estimate")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var amount in InverseAmounts)
                            {
                                <tr>
                                    <td>
                                        <span class="crypto-converter-stats__table-symbol">
                                            <span class="crypto-converter-stats__logo-shell crypto-converter-stats__logo-shell--small" aria-hidden="true">
                                                @if (!string.IsNullOrWhiteSpace(ToIconUrl))
                                                {
                                                    <img src="@ToIconUrl" alt="" loading="lazy" width="18" height="18" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                                }
                                                <span class="crypto-converter-stats__fallback" aria-hidden="true">@GetAssetMonogram(DisplayToSymbol)</span>
                                            </span>
                                            <strong>@DisplayAmount(amount)</strong>
                                            <span>@DisplayToSymbol</span>
                                        </span>
                                    </td>
                                    <td>
                                        <span class="crypto-converter-stats__table-symbol">
                                            <span class="crypto-converter-stats__logo-shell crypto-converter-stats__logo-shell--small" aria-hidden="true">
                                                @if (!string.IsNullOrWhiteSpace(FromIconUrl))
                                                {
                                                    <img src="@FromIconUrl" alt="" loading="lazy" width="18" height="18" onerror="this.style.display='none'; this.nextElementSibling?.classList.add('is-visible');" />
                                                }
                                                <span class="crypto-converter-stats__fallback" aria-hidden="true">@GetAssetMonogram(DisplayFromSymbol)</span>
                                            </span>
                                            <strong>@DisplayAmount(ConvertInverseAmount(amount, _fromPriceUsdt, _toPriceUsdt))</strong>
                                            <span>@DisplayFromSymbol</span>
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </article>
        </section>
    }

    <section class="crypto-converter-stats__battle" aria-labelledby="battle-performance-heading">
        <div class="crypto-converter-stats__section-head">
            <div>
                <span>@T("battle.eyebrow")</span>
                <h2 id="battle-performance-heading">
                    @DisplayFromSymbol @T("labels.vs") @DisplayToSymbol @T("battle.title")
                </h2>
            </div>
            <p>@T("battle.description")</p>
        </div>

        <div class="crypto-converter-stats__battle-grid">
            <article class="crypto-converter-stats__battle-card crypto-converter-stats__battle-card--from">
                <span>@T("battle.priceVariation")</span>
                <strong>@DisplayPriceVariation()</strong>
                <small>@T("battle.priceVariationHint")</small>
            </article>

            <article class="crypto-converter-stats__battle-card">
                <span>@T("battle.candleBattle")</span>
                <strong>@DisplayCandleBattle()</strong>
                <small>@T("battle.candleBattleHint")</small>
            </article>

            <article class="crypto-converter-stats__battle-card crypto-converter-stats__battle-card--center">
                <span>@T("battle.arenaPressure")</span>
                <strong>@DisplayArenaPressure()</strong>
                <small>@DisplayArenaPressureDetail()</small>
            </article>

            <article class="crypto-converter-stats__battle-card">
                <span>@T("battle.momentum")</span>
                <strong>@DisplayBattleMomentum()</strong>
                <small>@T("battle.momentumHint")</small>
            </article>

            <article class="crypto-converter-stats__battle-card crypto-converter-stats__battle-card--to">
                <span>@T("battle.recentWinner")</span>
                <strong>@DisplayRecentWinner()</strong>
                <small>@T("battle.recentWinnerHint")</small>
            </article>
        </div>

        @if (!HasBattleData)
        {
            <div class="crypto-converter-stats__battle-empty" role="status" aria-live="polite">
                <strong>@T("battle.unavailableTitle")</strong>
                <span>@T("battle.unavailableBody")</span>
            </div>
        }

        <div class="crypto-converter-stats__battle-cta-shell">
            <a class="crypto-converter-stats__battle-cta" href="@BattleCtaUrl">
                @BattleCtaText
            </a>
        </div>
    </section>

    <section class="crypto-converter-stats__disclaimer">
        <div class="crypto-converter-stats__section-head crypto-converter-stats__section-head--stacked">
            <div>
                <span>@T("hero.disclaimerEyebrow")</span>
                <h2>@T("hero.disclaimerTitle")</h2>
            </div>
            <p>@T("hero.disclaimerBody")</p>
        </div>
    </section>
</section>

<style>
    .crypto-converter-stats {
        --cv-bg: #05070d;
        --cv-surface: rgba(11, 16, 27, 0.92);
        --cv-surface-strong: rgba(17, 24, 39, 0.96);
        --cv-border: rgba(255, 255, 255, 0.09);
        --cv-border-strong: rgba(255, 255, 255, 0.14);
        --cv-text: #eef5ff;
        --cv-muted: #a9b7ca;
        --cv-orange: #ff9100;
        --cv-orange-soft: rgba(255, 145, 0, 0.18);
        --cv-cyan: #18d8d2;
        --cv-cyan-soft: rgba(24, 216, 210, 0.16);
        --cv-green: #4cf38d;
        --cv-radius-xl: 30px;
        --cv-radius-lg: 24px;
        width: 100%;
        max-width: min(1880px, calc(100vw - 24px));
        margin-inline: auto;
        padding-inline: 12px;
        padding-block: clamp(1rem, 2vw, 1.5rem);
        color: #eef5ff;
    }

        .crypto-converter-stats *,
        .crypto-converter-stats *::before,
        .crypto-converter-stats *::after {
            box-sizing: border-box;
        }

    .crypto-converter-stats__hero,
    .crypto-converter-stats__conversion-card,
    .crypto-converter-stats__table-card,
    .crypto-converter-stats__battle,
    .crypto-converter-stats__disclaimer {
        position: relative;
        overflow: hidden;
        border: 1px solid var(--cv-border);
        background: linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px), radial-gradient(circle at 10% 5%, var(--cv-orange-soft), transparent 30%), radial-gradient(circle at 92% 0%, var(--cv-cyan-soft), transparent 30%), linear-gradient(180deg, rgba(10, 14, 24, 0.98), rgba(5, 8, 15, 0.99));
        background-size: 34px 34px, 34px 34px, auto, auto, auto;
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.38);
    }

    .crypto-converter-stats__hero {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(380px, 0.9fr);
        gap: clamp(1rem, 2vw, 1.5rem);
        min-height: 430px;
        padding: clamp(1.15rem, 2.5vw, 2rem);
        border-radius: var(--cv-radius-xl);
    }

    .crypto-converter-stats__hero-bg {
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0.65;
        background: radial-gradient(circle at 50% 105%, rgba(255, 145, 0, 0.16), transparent 34%), linear-gradient(115deg, transparent 0 43%, rgba(255,255,255,.06) 43% 43.4%, transparent 43.4% 100%);
    }

    .crypto-converter-stats__copy,
    .crypto-converter-stats__scoreboard {
        position: relative;
        z-index: 1;
    }

    .crypto-converter-stats__copy {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .crypto-converter-stats__breadcrumb-line {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        width: fit-content;
        max-width: 100%;
        margin-bottom: 1rem;
        padding: 0.45rem 0.7rem;
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 999px;
        background: rgba(255,255,255,.035);
        color: var(--cv-muted);
        font-size: 0.82rem;
    }

        .crypto-converter-stats__breadcrumb-line a {
            color: var(--cv-cyan);
            text-decoration: none;
            font-weight: 800;
        }

        .crypto-converter-stats__breadcrumb-line strong {
            color: var(--cv-text);
            font-weight: 800;
        }

    .crypto-converter-stats__eyebrow,
    .crypto-converter-stats__section-head span {
        display: inline-block;
        margin-bottom: 0.55rem;
        color: var(--cv-cyan);
        font-size: 0.76rem;
        font-weight: 950;
        letter-spacing: 0.16em;
        text-transform: uppercase;
    }

    .crypto-converter-stats__copy h1 {
        max-width: 900px;
        margin: 0;
        font-size: clamp(2.25rem, 5vw, 4.85rem);
        line-height: 0.94;
        letter-spacing: -0.055em;
        text-wrap: balance;
    }

    .crypto-converter-stats__lead,
    .crypto-converter-stats__section-head p,
    .crypto-converter-stats__unavailable span,
    .crypto-converter-stats__battle-empty span,
    .crypto-converter-stats__disclaimer p {
        color: var(--cv-muted);
        line-height: 1.65;
    }

    .crypto-converter-stats__lead {
        max-width: 720px;
        margin: 1rem 0 0;
        font-size: clamp(1rem, 1.35vw, 1.15rem);
    }

    .crypto-converter-stats__actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.35rem;
    }

    .crypto-converter-stats__cta,
    .crypto-converter-stats__battle-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 3rem;
        padding: 0.78rem 1.05rem;
        border-radius: 16px;
        border: 1px solid rgba(255, 145, 0, 0.45);
        background: linear-gradient(135deg, #ffd76e, var(--cv-orange));
        color: #160a00;
        font-weight: 950;
        text-decoration: none;
        box-shadow: 0 16px 35px rgba(255, 145, 0, 0.18);
        transition: transform .18s ease, border-color .18s ease, filter .18s ease;
    }

        .crypto-converter-stats__cta:hover,
        .crypto-converter-stats__battle-cta:hover {
            transform: translateY(-1px);
            filter: brightness(1.03);
        }

    .crypto-converter-stats__cta--secondary {
        border-color: rgba(24, 216, 210, 0.32);
        background: rgba(255, 255, 255, 0.035);
        color: var(--cv-text);
        box-shadow: none;
    }

    .crypto-converter-stats__scoreboard {
        display: grid;
        align-content: center;
        gap: 0.85rem;
    }

    .crypto-converter-stats__team-card {
        display: flex;
        align-items: center;
        gap: 0.85rem;
        min-height: 106px;
        padding: 1rem;
        border-radius: 24px;
        border: 1px solid var(--cv-border);
        background: rgba(255, 255, 255, 0.045);
        backdrop-filter: blur(12px);
    }

    .crypto-converter-stats__team-card--from {
        border-color: rgba(255, 145, 0, 0.28);
        box-shadow: inset 4px 0 0 rgba(255, 145, 0, 0.8);
    }

    .crypto-converter-stats__team-card--to {
        border-color: rgba(24, 216, 210, 0.28);
        box-shadow: inset 4px 0 0 rgba(24, 216, 210, 0.8);
    }

    .crypto-converter-stats__team-card small,
    .crypto-converter-stats__hero-metric span,
    .crypto-converter-stats__hero-metric small {
        display: block;
        color: var(--cv-muted);
        font-size: 0.82rem;
        font-weight: 700;
    }

    .crypto-converter-stats__team-card strong {
        display: block;
        margin-top: 0.12rem;
        font-size: clamp(1.45rem, 3vw, 2rem);
        line-height: 1;
    }

    .crypto-converter-stats__versus-core {
