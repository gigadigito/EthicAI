        : $"{SeoDefaults.GlobalKeywords}, crypto converter, battle stats";
    private string CurrentPath => "/" + Nav.ToBaseRelativePath(Nav.Uri).Split('?', '#')[0].Trim('/');
    private string CanonicalUrl => BuildAbsolute(_canonicalPath ?? CurrentPath);
