    protected override async Task OnParametersSetAsync()
    {
        _culture = GetCultureFromPath();

        _fromSymbol = NormalizeSymbol(FromSymbol);
        _toSymbol = NormalizeSymbol(ToSymbol);
        _isValidSymbolPair = !string.IsNullOrWhiteSpace(_fromSymbol) && !string.IsNullOrWhiteSpace(_toSymbol);
        _canonicalPath = _isValidSymbolPair
            ? BuildRoutePath(_culture, _fromSymbol, _toSymbol)
            : null;

        if (_isValidSymbolPair && !CurrentPath.Equals(_canonicalPath, StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo(_canonicalPath!, replace: true);
            return;
        }

        var signature = $"{_culture}|{_fromSymbol}|{_toSymbol}";
        if (string.Equals(signature, _loadSignature, StringComparison.Ordinal))
            return;

        _loadSignature = signature;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _match = null;
        _snapshots = Array.Empty<MatchMetricSnapshotDto>();
        _fromPriceLookup = null;
        _toPriceLookup = null;
        _fromPriceSnapshot = null;
        _toPriceSnapshot = null;
        _fromPriceUsdt = null;
        _toPriceUsdt = null;
        _fromChangePercent = null;
        _toChangePercent = null;
        _priceUpdatedAtUtc = null;
        _snapshotCount = 0;

        if (!_isValidSymbolPair)
        {
            _pageTitleText = T("seo.title", DisplayFromSymbol, DisplayToSymbol);
            _metaDescription = T("seo.unavailableDescription");
            return;
        }

        try
        {
            var fromPriceTask = ResolveAssetPriceAsync(_fromSymbol);
            var toPriceTask = ResolveAssetPriceAsync(_toSymbol);

            await Task.WhenAll(fromPriceTask, toPriceTask);

            _fromPriceLookup = await fromPriceTask;
            _toPriceLookup = await toPriceTask;
            ApplyPriceLookupResults();
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            Logger.LogWarning(ex, "CryptoConverterStats failed to load conversion prices for {From}/{To}", _fromSymbol, _toSymbol);
            _fromPriceLookup ??= BuildLocalLookupFailure(_fromSymbol, "price-lookup-exception");
            _toPriceLookup ??= BuildLocalLookupFailure(_toSymbol, "price-lookup-exception");
            ApplyPriceLookupResults();
        }

        await LoadBattleContextAsync();

        _pageTitleText = T("seo.title", DisplayFromSymbol, DisplayToSymbol);
        _metaDescription = IsConversionAvailable
            ? T("seo.description", DisplayFromSymbol, DisplayToSymbol)
            : T("seo.unavailableDescription");
    }

    private void ApplyPriceLookupResults()
    {
        _fromPriceSnapshot = _fromPriceLookup?.Snapshot;
