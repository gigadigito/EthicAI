        _toPriceUsdt = _toPriceSnapshot?.LastPriceUsdt;
        _fromChangePercent = _fromPriceSnapshot?.PercentageChange;
        _toChangePercent = _toPriceSnapshot?.PercentageChange;
        _priceUpdatedAtUtc = MaxDate(
