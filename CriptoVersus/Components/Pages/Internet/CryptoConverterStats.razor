    private string ManualFromAmountAriaLabel => $"{DisplayFromSymbol} amount";
    private string ManualToAmountAriaLabel => $"{DisplayToSymbol} amount";
    private string ManualSwapAriaLabel => $"Swap {DisplayFromSymbol} and {DisplayToSymbol} amounts";
    private string PrimaryCtaUrl => HasBattleData ? BattleCtaUrl : RouteLocalization.BuildStatsMatchesPath(_culture);
    private string PrimaryCtaText => HasBattleData ? T("hero.watchCta", DisplayFromSymbol, DisplayToSymbol) : T("hero.exploreCta");
