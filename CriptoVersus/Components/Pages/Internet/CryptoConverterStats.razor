    private string StructuredDataMarkup
        => JsonSerializer.Serialize(new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@graph"] = new object[]
            {
                new Dictionary<string, object?>
                {
                    ["@type"] = "WebApplication",
                    ["name"] = PageTitleText,
                    ["description"] = MetaDescription,
                    ["url"] = CanonicalUrl,
                    ["inLanguage"] = _culture,
                    ["isAccessibleForFree"] = true
                },
                new Dictionary<string, object?>
                {
                    ["@type"] = "BreadcrumbList",
                    ["itemListElement"] = new object[]
                    {
                        new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 1, ["name"] = T("breadcrumbs.home"), ["item"] = BuildAbsolute("/") },
                        new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 2, ["name"] = T("breadcrumbs.stats"), ["item"] = BuildAbsolute(RouteLocalization.BuildStatsPath(_culture)) },
                        new Dictionary<string, object?> { ["@type"] = "ListItem", ["position"] = 3, ["name"] = PageTitleText, ["item"] = CanonicalUrl }
                    }
                },
                new Dictionary<string, object?>
                {
                    ["@type"] = "FAQPage",
                    ["mainEntity"] = new object[]
                    {
                        new Dictionary<string, object?> { ["@type"] = "Question", ["name"] = T("faq.questions.conversion"), ["acceptedAnswer"] = new Dictionary<string, object?> { ["@type"] = "Answer", ["text"] = T("faq.answers.conversion") } },
                        new Dictionary<string, object?> { ["@type"] = "Question", ["name"] = T("faq.questions.prices"), ["acceptedAnswer"] = new Dictionary<string, object?> { ["@type"] = "Answer", ["text"] = T("faq.answers.prices") } },
                        new Dictionary<string, object?> { ["@type"] = "Question", ["name"] = T("faq.questions.watch"), ["acceptedAnswer"] = new Dictionary<string, object?> { ["@type"] = "Answer", ["text"] = T("faq.answers.watch") } }
                    }
                }
            }
        });

    protected override async Task OnParametersSetAsync()
    {
        _culture = GetCultureFromPath();
        _fromSymbol = NormalizeSymbol(FromSymbol);
        _toSymbol = NormalizeSymbol(ToSymbol);
        _isValidSymbolPair = !string.IsNullOrWhiteSpace(_fromSymbol) && !string.IsNullOrWhiteSpace(_toSymbol);
        _canonicalPath = _isValidSymbolPair ? BuildRoutePath(_culture, _fromSymbol, _toSymbol) : null;

        if (_isValidSymbolPair && !CurrentPath.Equals(_canonicalPath, StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo(_canonicalPath!, replace: true);
            return;
        }

        var signature = $"{_culture}|{_fromSymbol}|{_toSymbol}";
        if (string.Equals(signature, _loadSignature, StringComparison.Ordinal))
            return;

        _loadSignature = signature;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _match = null;
        _snapshots = Array.Empty<MatchMetricSnapshotDto>();
        _fromPriceLookup = null;
        _toPriceLookup = null;
        _fromPriceSnapshot = null;
        _toPriceSnapshot = null;
        _fromPriceUsdt = null;
        _toPriceUsdt = null;
        _fromChangePercent = null;
        _toChangePercent = null;
        _priceUpdatedAtUtc = null;
        _snapshotCount = 0;
        _manualFromAmountText = "1";
        _manualToAmountText = string.Empty;

        if (!_isValidSymbolPair)
        {
            _pageTitleText = T("seo.title", DisplayFromSymbol, DisplayToSymbol);
            _metaDescription = T("seo.unavailableDescription");
            return;
        }

        try
        {
            var fromPriceTask = ResolveAssetPriceAsync(_fromSymbol);
            var toPriceTask = ResolveAssetPriceAsync(_toSymbol);
            await Task.WhenAll(fromPriceTask, toPriceTask);

            _fromPriceLookup = await fromPriceTask;
            _toPriceLookup = await toPriceTask;
            ApplyPriceLookupResults();
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            Logger.LogWarning(ex, "CryptoConverterStats failed to load conversion prices for {From}/{To}", _fromSymbol, _toSymbol);
            _fromPriceLookup ??= BuildLocalLookupFailure(_fromSymbol, "price-lookup-exception");
            _toPriceLookup ??= BuildLocalLookupFailure(_toSymbol, "price-lookup-exception");
            ApplyPriceLookupResults();
        }

        await LoadBattleContextAsync();

        _pageTitleText = T("seo.title", DisplayFromSymbol, DisplayToSymbol);
        _metaDescription = IsConversionAvailable ? T("seo.description", DisplayFromSymbol, DisplayToSymbol) : T("seo.unavailableDescription");
    }

    private void ApplyPriceLookupResults()
    {
        _fromPriceSnapshot = _fromPriceLookup?.Snapshot;
        _toPriceSnapshot = _toPriceLookup?.Snapshot;
        _fromPriceUsdt = _fromPriceSnapshot?.LastPriceUsdt;
        _toPriceUsdt = _toPriceSnapshot?.LastPriceUsdt;
        _fromChangePercent = _fromPriceSnapshot?.PercentageChange;
        _toChangePercent = _toPriceSnapshot?.PercentageChange;
        _priceUpdatedAtUtc = MaxDate(_fromPriceSnapshot?.CapturedAtUtc, _toPriceSnapshot?.CapturedAtUtc);
        InitializeManualConverterInputs();
    }

    private void InitializeManualConverterInputs()
    {
        if (!IsConversionAvailable)
        {
            _manualToAmountText = string.Empty;
            return;
        }

        if (!TryParseManualAmount(_manualFromAmountText, out var amount) || amount < 0m)
            amount = 1m;

        _manualFromAmountText = FormatManualInputAmount(amount);
        _manualToAmountText = FormatManualInputAmount(ConvertAmount(amount, _fromPriceUsdt, _toPriceUsdt));
    }

    private void OnManualFromAmountChanged(ChangeEventArgs args)
    {
        _manualFromAmountText = args.Value?.ToString() ?? string.Empty;

        if (!IsConversionAvailable || !TryParseManualAmount(_manualFromAmountText, out var amount) || amount < 0m)
        {
            _manualToAmountText = string.Empty;
            return;
        }

        _manualToAmountText = FormatManualInputAmount(ConvertAmount(amount, _fromPriceUsdt, _toPriceUsdt));
    }

    private void OnManualToAmountChanged(ChangeEventArgs args)
    {
        _manualToAmountText = args.Value?.ToString() ?? string.Empty;

        if (!IsConversionAvailable || !TryParseManualAmount(_manualToAmountText, out var amount) || amount < 0m)
        {
            _manualFromAmountText = string.Empty;
            return;
        }

        _manualFromAmountText = FormatManualInputAmount(ConvertInverseAmount(amount, _fromPriceUsdt, _toPriceUsdt));
    }

    private void SwapManualConverterValues()
    {
        if (!IsConversionAvailable)
            return;

        (_manualFromAmountText, _manualToAmountText) = (_manualToAmountText, _manualFromAmountText);
        OnManualFromAmountChanged(new ChangeEventArgs { Value = _manualFromAmountText });
    }

    private string DisplayManualConverterHint()
        => $"1 {DisplayFromSymbol} ≈ {DisplayAmount(DirectConvertedAmount)} {DisplayToSymbol} · 1 {DisplayToSymbol} ≈ {DisplayAmount(ConvertInverseAmount(1m, _fromPriceUsdt, _toPriceUsdt))} {DisplayFromSymbol}";
