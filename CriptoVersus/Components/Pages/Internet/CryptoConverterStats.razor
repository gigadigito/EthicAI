                .ThenBy(x => x.MatchMetricSnapshotId)
                .ToList();
            _snapshotCount = _snapshots.Count;
            _priceUpdatedAtUtc = _priceUpdatedAtUtc
                ?? _snapshots.LastOrDefault()?.CapturedAtUtc
                ?? _match.EndTime
                ?? _match.StartTime;

            var fromSeries = _snapshots
                .Where(x => NormalizeComparisonSymbol(x.TeamSymbol) == _fromSymbol)
                .ToList();
            var toSeries = _snapshots
                .Where(x => NormalizeComparisonSymbol(x.TeamSymbol) == _toSymbol)
                .ToList();

