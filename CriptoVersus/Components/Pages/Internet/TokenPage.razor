@code {
    private const string HeroImagePath = "/images/token/criptoversus-token-arena.jpg";

    private static readonly string[] StatKeyOrder =
    [
        "token.stats.price",
        "token.stats.marketCap",
        "token.stats.holders",
        "token.stats.volume24h",
        "token.stats.liquidity"
    ];

    private TokenMarketSnapshotResult? _marketResult;
    private bool _marketLoading = true;
    private bool _copied;
    private bool _isInteractive;

    private string CurrentCulture => AppCulture.GetCurrentRouteCulture(Nav);
    private string PumpFunUrl => TokenMarketService.OfficialPumpFunUrl;
    private string HeroImageAbsoluteUrl => BuildAbsolute(HeroImagePath);
    private string CanonicalUrl => BuildAbsolute(RouteLocalization.BuildTokenPath(CurrentCulture));
    private string EnglishUrl => BuildAbsolute(RouteLocalization.BuildTokenPath("en"));
    private string PortugueseUrl => BuildAbsolute(RouteLocalization.BuildTokenPath("pt"));
    private string ZhUrl => BuildAbsolute(RouteLocalization.BuildTokenPath("zh"));
    private string SeoTitle => L.T("token.seo.title", CurrentCulture);
    private string SeoDescription => L.T("token.seo.description", CurrentCulture);
    private string MetaKeywords => $"{SeoDefaults.GlobalKeywords}, CriptoVersus token, #CriptoVersus token, Solana meme token";
    private string CopyButtonText => L.T(_copied ? "token.action.copied" : "token.action.copyContract", CurrentCulture);
    private string QrCodeUrl => $"https://api.qrserver.com/v1/create-qr-code/?size=320x320&data={Uri.EscapeDataString(PumpFunUrl)}";
    private string StructuredDataMarkup => BuildStructuredDataMarkup();
    private TokenMarketSnapshot? MarketSnapshot => _marketResult?.Snapshot;

    private string MarketStatusCssClass
        => _marketLoading
            ? string.Empty
            : IsUnavailableSource
                ? "token-arena-market-status--fallback"
                : _marketResult?.HasError == true
                    ? "token-arena-market-status--fallback"
                    : _marketResult?.IsFallback == true
                        ? "token-arena-market-status--fallback"
                        : string.Empty;

    private bool ShowNotIndexedBadge
        => !_marketLoading && (IsUnavailableSource || string.Equals(MarketSnapshot?.Source, "fallback", StringComparison.OrdinalIgnoreCase));

    private bool IsUnavailableSource
        => string.Equals(MarketSnapshot?.Source, "unavailable", StringComparison.OrdinalIgnoreCase);

    private string MarketStatusTitle
        => _marketLoading
            ? L.T("token.market.loadingTitle", CurrentCulture)
            : IsUnavailableSource
                ? L.T("token.market.unavailableTitle", CurrentCulture)
                : _marketResult?.HasError == true
                    ? L.T("token.market.fallbackTitle", CurrentCulture)
                    : _marketResult?.IsFallback == true
                        ? L.T("token.market.fallbackTitle", CurrentCulture)
                        : L.T("token.market.liveTitle", CurrentCulture);

    private string MarketStatusBody
        => _marketLoading
            ? L.T("token.market.loadingBody", CurrentCulture)
            : IsUnavailableSource
                ? L.T("token.market.unavailableBody", CurrentCulture)
                : _marketResult?.HasError == true
                    ? L.T("token.market.fallbackBody", CurrentCulture)
                    : _marketResult?.IsFallback == true
                        ? L.T("token.market.fallbackBody", CurrentCulture)
                        : L.T("token.market.liveBody", CurrentCulture, FormatUpdatedAt(MarketSnapshot?.UpdatedAtUtc));

    protected override async Task OnInitializedAsync()
    {
        _marketLoading = true;
        _marketResult = null;

        try
        {
            _marketResult = await TokenMarket.GetSnapshotAsync();
        }
        finally
        {
            _marketLoading = false;
        }
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isInteractive = true;
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    private async Task CopyContractAsync()
    {
        if (!_isInteractive)
            return;

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", MarketSnapshot?.ContractAddress ?? TokenMarketService.OfficialContractAddress);
            _copied = true;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(2200);
            _copied = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (InvalidOperationException)
        {
            _copied = false;
        }
        catch (JSDisconnectedException)
        {
            _copied = false;
        }
    }

    private IEnumerable<TokenStatCard> BuildStatCards()
    {
        var snapshot = MarketSnapshot ?? TokenMarketService.CreateFallbackSnapshot();

        return
        [
            new("token.stats.price", FormatUsd(snapshot.CurrentPriceUsd, 7), L.T("token.market.supporting.updated", CurrentCulture, FormatUpdatedAt(snapshot.UpdatedAtUtc))),
            new("token.stats.marketCap", FormatUsd(snapshot.MarketCapUsd), L.T("token.market.supporting.contract", CurrentCulture)),
            new("token.stats.holders", FormatWholeNumber(snapshot.Holders), L.T("token.market.supporting.community", CurrentCulture)),
            new("token.stats.volume24h", FormatUsd(snapshot.Volume24hUsd), L.T("token.market.supporting.window24h", CurrentCulture)),
            new("token.stats.liquidity", FormatUsd(snapshot.LiquidityUsd), L.T("token.market.supporting.depth", CurrentCulture))
        ];
    }

    private string FormatUsd(decimal? value, int decimals = 0)
    {
        if (!value.HasValue)
            return L.T("token.market.unavailableValue", CurrentCulture);

        var culture = ResolveCulture();
        var format = decimals > 0 ? $"C{decimals}" : "C0";
        return value.Value.ToString(format, culture);
    }

    private string FormatPercent(decimal? value)
    {
        if (!value.HasValue)
            return L.T("token.market.unavailableValue", CurrentCulture);

        return $"{value.Value:0.##}%";
    }

    private string FormatWholeNumber(int? value)
    {
        if (!value.HasValue)
            return L.T("token.market.unavailableValue", CurrentCulture);

        return value.Value.ToString("N0", ResolveCulture());
    }

    private string FormatUpdatedAt(DateTimeOffset? value)
    {
        if (!value.HasValue)
            return L.T("token.market.unavailableValue", CurrentCulture);

        return value.Value.ToLocalTime().ToString("g", ResolveCulture());
    }

    private CultureInfo ResolveCulture()
        => CultureInfo.GetCultureInfo(AppCulture.ToCultureCode(CurrentCulture));

    private string BuildAbsolute(string path)
        => SeoDefaults.BuildPublicAbsoluteUrl(Config, path);

    private string BuildStructuredDataMarkup()
    {
        var homeUrl = BuildAbsolute(RouteLocalization.BuildHomePath(CurrentCulture));

        var data = new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@graph"] = new object[]
            {
                new Dictionary<string, object?>
                {
                    ["@type"] = "WebPage",
                    ["name"] = SeoTitle,
                    ["description"] = SeoDescription,
                    ["url"] = CanonicalUrl,
                    ["image"] = HeroImageAbsoluteUrl,
                    ["keywords"] = MetaKeywords,
                    ["inLanguage"] = AppCulture.ToHrefLang(CurrentCulture),
                    ["isPartOf"] = new Dictionary<string, object?>
                    {
                        ["@type"] = "WebSite",
                        ["name"] = "CriptoVersus",
                        ["url"] = homeUrl
                    },
                    ["publisher"] = new Dictionary<string, object?>
                    {
                        ["@type"] = "Organization",
                        ["name"] = "CriptoVersus",
                        ["url"] = homeUrl
                    }
                },
                new Dictionary<string, object?>
                {
                    ["@type"] = "Organization",
                    ["name"] = "CriptoVersus",
                    ["url"] = homeUrl
                }
            }
        };

        return JsonSerializer.Serialize(data);
    }

    private sealed record TokenStatCard(string TitleKey, string Value, string Supporting);
}