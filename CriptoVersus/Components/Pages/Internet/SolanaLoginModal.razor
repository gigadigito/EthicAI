@inject IJSRuntime JS
@inject IHttpClientFactory HttpFactory
@inject Blazored.SessionStorage.ISessionStorageService SessionStorage
@if (isOpen)
{
    <div class="modal-backdrop fade show"></div>

    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.35);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content solana-login-modal">

                <div class="modal-header">
                    <div>
                        <div class="modal-kicker">Carteira Solana</div>
                        <h5 class="modal-title">Login com Solana</h5>
                    </div>
                    <button type="button" class="btn-close" @onclick="Close"></button>
                </div>

                <div class="modal-body">
                    <p class="modal-helper">
                        Conecte sua carteira para investir e acompanhar suas posições na CriptoVersus.
                    </p>

                    @if (string.IsNullOrEmpty(publicKey))
                    {
                        <button class="btn btn-primary w-100 wallet-connect-button" @onclick="ConnectAsync">
                            Conectar Phantom
                        </button>
                    }
                    else
                    {
                        <div class="alert wallet-alert wallet-alert-success">
                            Carteira conectada:
                            <br />
                            <strong>@publicKey</strong>
                        </div>

                        <button class="btn btn-warning w-100 mb-2" @onclick="SignLoginAsync">
                            Assinar Login
                        </button>

                        <button class="btn btn-outline-danger w-100" @onclick="DisconnectAsync">
                            Desconectar
                        </button>
                    }

                    @if (!string.IsNullOrEmpty(status))
                    {
                        <div class="wallet-alert @GetStatusClass() mt-3">
                            <strong>@statusTitle</strong>
                            <div>@status</div>

                            @if (showInstallPhantom)
                            {
                                <a class="btn btn-outline-light btn-sm mt-3"
                                   href="https://phantom.app/download"
                                   target="_blank"
                                   rel="noopener noreferrer">
                                    Instalar Phantom
                                </a>
                            }
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public EventCallback OnLoginSucceeded { get; set; }

    private sealed class LoginResponse
    {
        public string Token { get; set; } = string.Empty;
        public string PublicKey { get; set; } = string.Empty;
        public int UserId { get; set; }
        public int ExpiresInMinutes { get; set; }
    }
    private IJSObjectReference? module;
    private bool isOpen;
    private string? publicKey;
    private string? status;
    private string statusTitle = "";
    private string statusKind = "info";
    private bool showInstallPhantom;

    public async Task OpenAsync()
    {
        isOpen = true;
        await LoadJsAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Close()
    {
        isOpen = false;
        StateHasChanged();
    }

    private async Task LoadJsAsync()
    {
        if (module is null)
        {
            module = await JS.InvokeAsync<IJSObjectReference>(
                "import",
                "./js/solanaWallet.js");
        }
    }

    private async Task ConnectAsync()
    {
        try
        {
            if (module is null)
                await LoadJsAsync();

            var result = await module!.InvokeAsync<WalletResult>("connect");
            publicKey = result.publicKey;
            SetStatus("Carteira conectada", "Agora assine a mensagem para finalizar o login.", "success");
        }
        catch (Exception ex)
        {
            if (IsPhantomMissing(ex))
            {
                SetStatus(
                    "Phantom não encontrada",
                    "Para entrar com Solana, instale a carteira Phantom no navegador e depois clique em Conectar novamente.",
                    "warning",
                    showInstall: true);
            }
            else
            {
                SetStatus(
                    "Não foi possível conectar",
                    "Confira se a carteira está desbloqueada e tente novamente.",
                    "warning");
            }
        }
    }

    private async Task DisconnectAsync()
    {
        try
        {
            if (module is not null)
            {
                await module.InvokeVoidAsync("disconnect");
            }

            publicKey = null;
            SetStatus("Carteira desconectada", "Você pode conectar outra carteira quando quiser.", "info");
        }
        catch (Exception ex)
        {
            SetStatus("Não foi possível desconectar", GetFriendlyError(ex), "warning");
        }
    }

    @inject IHttpClientFactory HttpFactory

    private async Task SignLoginAsync()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(publicKey))
            {
                SetStatus("Conecte sua carteira", "Escolha a Phantom antes de assinar o login.", "warning");
                return;
            }

            if (module is null)
                await LoadJsAsync();

            var http = HttpFactory.CreateClient("CriptoVersusApi");

            var nonceResponse = await http.GetFromJsonAsync<NonceResponse>(
                $"api/Login/solana/nonce?publicKey={Uri.EscapeDataString(publicKey)}");

            if (nonceResponse is null || string.IsNullOrWhiteSpace(nonceResponse.message))
            {
                SetStatus("Login indisponível", "Não conseguimos preparar sua assinatura agora. Tente novamente em instantes.", "warning");
                return;
            }

            var signed = await module!.InvokeAsync<SignedResult>(
                "signMessage",
                nonceResponse.message);

            var payload = new
            {
                publicKey = signed.publicKey,
                message = signed.message,
                signature = signed.signature
            };

            var response = await http.PostAsJsonAsync("api/Login/solana", payload);

            if (response.IsSuccessStatusCode)
            {
                var loginResult = await response.Content.ReadFromJsonAsync<LoginResponse>();

                if (loginResult is not null && !string.IsNullOrWhiteSpace(loginResult.Token))
                {
                    await SessionStorage.SetItemAsync("authToken", loginResult.Token);
                    await SessionStorage.SetItemAsync("userId", loginResult.UserId);
                    await SessionStorage.SetItemAsync("walletPublicKey", loginResult.PublicKey);
                    await OnLoginSucceeded.InvokeAsync();
                    SetStatus("Login realizado", "Sua carteira foi autenticada com sucesso.", "success");
                }
                else
                {
                    SetStatus("Login incompleto", "A API confirmou o login, mas não retornou o token de sessão.", "warning");
                }
            }
            else
            {
                SetStatus("Login recusado", "Não conseguimos validar sua assinatura. Tente assinar novamente.", "warning");
            }
        }
        catch (Exception ex)
        {
            SetStatus("Não foi possível concluir o login", GetFriendlyError(ex), "warning");
        }
    }
    private async Task EnviarLoginBackend(SignedResult result, string message)
    {
        try
        {
            var http = HttpFactory.CreateClient("CriptoVersusApi");

            var payload = new
            {
                publicKey = result.publicKey,
                message = message,
                signature = result.signature
            };

            var response = await http.PostAsJsonAsync(
                "api/Login/solana",
                payload);

            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                SetStatus("Login realizado", "Sua carteira foi autenticada com sucesso.", "success");
            }
            else
            {
                SetStatus("Login recusado", "Não conseguimos validar sua assinatura. Tente assinar novamente.", "warning");
            }
        }
        catch (Exception ex)
        {
            SetStatus("Login indisponível", GetFriendlyError(ex), "warning");
        }
    }

    private void SetStatus(string title, string message, string kind, bool showInstall = false)
    {
        statusTitle = title;
        status = message;
        statusKind = kind;
        showInstallPhantom = showInstall;
    }

    private string GetStatusClass()
        => statusKind switch
        {
            "success" => "wallet-alert-success",
            "warning" => "wallet-alert-warning",
            _ => "wallet-alert-info"
        };

    private static bool IsPhantomMissing(Exception ex)
        => ex.ToString().Contains("Phantom", StringComparison.OrdinalIgnoreCase)
            && ex.ToString().Contains("não encontrado", StringComparison.OrdinalIgnoreCase);

    private static string GetFriendlyError(Exception ex)
    {
        if (IsPhantomMissing(ex))
            return "Instale a carteira Phantom no navegador e tente novamente.";

        return "Algo saiu do esperado. Tente novamente em instantes.";
    }

    private sealed class WalletResult
    {
        public string publicKey { get; set; } = string.Empty;
    }

    private sealed class SignedResult
    {
        public string publicKey { get; set; } = string.Empty;
        public string message { get; set; } = string.Empty;
        public string signature { get; set; } = string.Empty;
    }
    private sealed class NonceResponse
    {
        public string publicKey { get; set; } = string.Empty;
        public string nonce { get; set; } = string.Empty;
        public int expiresInMinutes { get; set; }
        public string message { get; set; } = string.Empty;
    }
}

