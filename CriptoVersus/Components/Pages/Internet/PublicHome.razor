    private static void RemoveNullValues(Dictionary<string, object?> data)
    {
        foreach (var key in data.Where(x => x.Value is null).Select(x => x.Key).ToList())
            data.Remove(key);
    }

    private async Task ReloadSnapshotAsync(CancellationToken ct)
    {
        await _reloadLock.WaitAsync(ct);
        try
        {
            _snapshot = await Api.GetDashboardSnapshotAsync(ct);
        }
        finally
        {
            _reloadLock.Release();
        }
    }

    private void OnDashboardChanged(string? payload)
    {
        if (_disposed)
            return;

        _ = DebouncedReloadAsync(250);
    }

    private Task DebouncedReloadAsync(int delayMs)
    {
        try
        {
            _debounceCts?.Cancel();
            _debounceCts?.Dispose();
        }
        catch
        {
        }

        _debounceCts = new CancellationTokenSource();
        var ct = _debounceCts.Token;

        return Task.Run(async () =>
        {
            try
            {
                await Task.Delay(delayMs, ct);
                if (ct.IsCancellationRequested || _disposed)
                    return;

                await ReloadSnapshotAsync(ct);
                await InvokeAsync(StateHasChanged);
            }
            catch (OperationCanceledException)
            {
            }
            catch
            {
            }
        }, ct);
    }

    public ValueTask DisposeAsync()
    {
        _disposed = true;
        HubClient.DashboardChanged -= OnDashboardChanged;

        try
        {
            _debounceCts?.Cancel();
        }
        catch
        {
        }

        _debounceCts?.Dispose();
        _debounceCts = null;
        _reloadLock.Dispose();

        return ValueTask.CompletedTask;
    }
}

