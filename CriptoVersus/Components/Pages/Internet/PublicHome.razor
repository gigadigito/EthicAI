    private async Task<bool> ReloadHomeDataAsync(
        CancellationToken ct,
        string trigger,
        bool includeSnapshot = true,
        bool includeHotMatches = true)
    {
        if (!await _reloadLock.WaitAsync(TimeSpan.Zero, ct))
        {
            Logger.LogInformation("PublicHome refresh skipped because another refresh is already running. Trigger={Trigger}", trigger);
            return false;
        }

        var startedAtUtc = DateTime.UtcNow;
        var hotMatchesLoadingBefore = _hotMatchesLoading;
        var hotMatchesLoadingChanged = false;

        try
        {
            Logger.LogInformation("PublicHome refresh started. Trigger={Trigger}", trigger);
            if (includeSnapshot)
            {
                var snapshotStopwatch = Stopwatch.StartNew();
                try
                {
                    _snapshot = await Api.GetDashboardSnapshotAsync(ct);
                    Logger.LogInformation(
                        "PublicHome snapshot loaded in {DurationMs} ms. Trigger={Trigger} Ongoing={OngoingCount} Completed24h={CompletedLast24h}",
                        snapshotStopwatch.ElapsedMilliseconds,
                        trigger,
                        _snapshot?.Matches.OngoingList.Count ?? 0,
                        _snapshot?.Matches.CompletedLast24h ?? 0);
                }
                catch (OperationCanceledException) when (ct.IsCancellationRequested)
                {
                    Logger.LogWarning("PublicHome snapshot load canceled. Trigger={Trigger}", trigger);
                }
                catch (TimeoutException ex)
                {
                    Logger.LogWarning(ex, "PublicHome snapshot load timed out. Trigger={Trigger}", trigger);
                }
                catch
                {
                    // Mantemos o ultimo snapshot valido para evitar flicker.
                }
            }

            if (includeHotMatches)
            {
                var hotMatchesStopwatch = Stopwatch.StartNew();
                try
                {
                    using var hotMatchesCts = CancellationTokenSource.CreateLinkedTokenSource(ct);
                    hotMatchesCts.CancelAfter(TimeSpan.FromSeconds(4));
                    _hotMatches = await HotMatches.GetHotMatchesAsync(hotMatchesCts.Token);
                    Logger.LogInformation(
                        "PublicHome deferred details loaded. Trigger={Trigger} HotMatches={HotMatchCount} DurationMs={DurationMs}",
                        trigger,
                        _hotMatches.Count,
                        hotMatchesStopwatch.ElapsedMilliseconds);
                }
                catch (OperationCanceledException) when (ct.IsCancellationRequested)
                {
                    Logger.LogWarning("PublicHome hot matches load canceled. Trigger={Trigger}", trigger);
                }
                catch (OperationCanceledException) when (!ct.IsCancellationRequested)
                {
                    Logger.LogWarning("PublicHome hot matches load canceled by local timeout. Trigger={Trigger}", trigger);
                }
                catch (TimeoutException ex)
                {
                    Logger.LogWarning(ex, "PublicHome hot matches load timed out. Trigger={Trigger}", trigger);
                }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "PublicHome hot matches load failed. Trigger={Trigger}", trigger);
                }
                finally
                {
                    _hotMatchesLoading = false;
                    hotMatchesLoadingChanged = hotMatchesLoadingBefore != _hotMatchesLoading;
                }
            }

            var changed = UpdateRefreshSignature();
            Logger.LogInformation(
                "PublicHome refresh completed. Trigger={Trigger} Changed={Changed} LoadingChanged={LoadingChanged} HotMatches={HotMatchCount} DurationMs={DurationMs}",
                trigger,
                changed,
                hotMatchesLoadingChanged,
                _hotMatches.Count,
                (DateTime.UtcNow - startedAtUtc).TotalMilliseconds);

            if (hotMatchesLoadingChanged)
                await InvokeAsync(StateHasChanged);

            return changed || hotMatchesLoadingChanged;
        }
        finally
        {
            _reloadLock.Release();
        }
    }

    private async Task RunHomeRefreshLoopAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(HomeRefreshSeconds));

        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                if (await ReloadHomeDataAsync(ct, "timer"))
                    await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            Logger.LogInformation("PublicHome automatic refresh loop stopped.");
        }
    }

    private async Task StartInteractiveFeaturesAsync()
    {
        try
        {
            if (!_hubSubscribed)
            {
                HubClient.DashboardChanged += OnDashboardChanged;
                _hubSubscribed = true;
            }

            _ = StartDashboardHubAsync();

            try
            {
                if (await ReloadHomeDataAsync(
                    CancellationToken.None,
                    "after-first-render",
                    includeSnapshot: false,
                    includeHotMatches: true))
                    await InvokeAsync(StateHasChanged);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "PublicHome interactive refresh failed after first render.");
            }

            _homeRefreshCts = new CancellationTokenSource();
            _homeRefreshLoopTask = RunHomeRefreshLoopAsync(_homeRefreshCts.Token);
            Logger.LogInformation("PublicHome automatic refresh loop started. IntervalSeconds={IntervalSeconds}", HomeRefreshSeconds);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "PublicHome interactive feature bootstrap failed.");
        }
    }

    private async Task StartDashboardHubAsync()
    {
        try
        {
            await HubClient.EnsureStartedAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "PublicHome live hub startup failed. Home will continue with snapshot refresh only.");
        }
    }

    private void OnDashboardChanged(string? payload)
    {
        if (_disposed)
            return;

        _ = DebouncedReloadAsync(250);
    }

    private Task DebouncedReloadAsync(int delayMs)
    {
        try
        {
            _debounceCts?.Cancel();
            _debounceCts?.Dispose();
        }
        catch
        {
        }

        _debounceCts = new CancellationTokenSource();
        var ct = _debounceCts.Token;

        return Task.Run(async () =>
        {
            try
            {
                await Task.Delay(delayMs, ct);
                if (ct.IsCancellationRequested || _disposed)
                    return;

                if (await ReloadHomeDataAsync(ct, "dashboard-changed"))
                    await InvokeAsync(StateHasChanged);
            }
            catch (OperationCanceledException)
            {
            }
            catch
            {
            }
        }, ct);
    }

    private bool UpdateRefreshSignature()
    {
        var hotSignature = string.Join(",",
            _hotMatches
                .Take(5)
                .Select(x => $"{x.MatchId}:{x.HomeScore}-{x.AwayScore}:{x.HotScore}:{x.RemainingMinutes}:{x.Status}"));

        var snapshotSignature = string.Join("|",
            _snapshot?.Matches.Ongoing ?? -1,
            _snapshot?.Matches.CompletedLast24h ?? -1,
            _snapshot?.TopGainers.Count ?? -1);

        var signature = $"{snapshotSignature}|{hotSignature}";
        var changed = !string.Equals(signature, _lastRefreshSignature, StringComparison.Ordinal);
        _lastRefreshSignature = signature;
        return changed;
    }

    public ValueTask DisposeAsync()
    {
        _disposed = true;

        if (_hubSubscribed)
            HubClient.DashboardChanged -= OnDashboardChanged;

        Logger.LogInformation("PublicHome disposing refresh resources.");

        try
        {
            _debounceCts?.Cancel();
        }
        catch
        {
        }

        _debounceCts?.Dispose();
        _debounceCts = null;

        _homeRefreshCts?.Cancel();
        _homeRefreshCts?.Dispose();
        _homeRefreshCts = null;

        _reloadLock.Dispose();

        return ValueTask.CompletedTask;
    }
}

