@page "/"
@page "/en"
@page "/pt"
@using Microsoft.AspNetCore.Components
@using System.Text.Json
@using DTOs
@using CriptoVersus.Web.Services
@inject CriptoVersusApiClient Api
@inject DashboardHubClient HubClient
@inject IConfiguration Config
@inject NavigationManager Nav
@inject AppCultureService AppCulture
@inject LocalizationService L
@inject RouteLocalizationService RouteLocalization
@inject MatchSlugHelper MatchSlugHelper
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>@SeoTitle</PageTitle>
<HeadContent>
    <meta name="description" content="@SeoDescription" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="en-US" href="@EnglishUrl" />
    <link rel="alternate" hreflang="pt-BR" href="@PortugueseUrl" />
    <link rel="alternate" hreflang="x-default" href="@EnglishUrl" />
    <meta property="og:title" content="@SeoTitle" />
    <meta property="og:description" content="@SeoDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="@AppCulture.ToOgLocale(CurrentCulture)" />
    <meta property="og:locale:alternate" content="@AppCulture.GetAlternateOgLocale(CurrentCulture)" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@SeoTitle" />
    <meta name="twitter:description" content="@SeoDescription" />
    <script type="application/ld+json">@StructuredDataMarkup</script>
</HeadContent>

<section class="home-landing public-home-arena">
    <header class="home-hero">
        <div class="home-hero__copy">
            <span class="home-hero__eyebrow">
                @T("globalCryptoArena")
            </span>

            <h1>@T("heroTitle")</h1>

            <p>@T("heroDescription")</p>

            <ul class="home-hero__semantic-list" aria-label="@T("heroSemanticLabel")">
                @foreach (var item in HeroSemanticHighlights)
                {
                    <li>@item</li>
                }
            </ul>


            <div class="home-hero__actions">
                <a class="home-cta home-cta--primary" href="#live-matches">
                    @T("exploreLiveMatches")
                </a>

                <a class="home-cta home-cta--secondary"
                   href="@RouteLocalization.BuildHowItWorksPath(CurrentCulture)">
                    @T("howItWorks")
                </a>

                <a class="home-cta home-cta--secondary"
                   href="@RouteLocalization.BuildRoadmapPath(CurrentCulture)">
                    Roadmap
                </a>
            </div>
        </div>
        <div class="home-hero__stats" aria-label="@T("platformHighlights")">
            <article>
                <span>@T("liveMatches")</span>
                <strong>@(_snapshot?.Matches.Ongoing ?? 0)</strong>
            </article>
            <article>
                <span>@T("completedIn24h")</span>
                <strong>@(_snapshot?.Matches.CompletedLast24h ?? 0)</strong>
            </article>
            <article>
                <span>@T("trackedCoins")</span>
                <strong>@Math.Max(_snapshot?.TopGainers.Count ?? 0, 6)</strong>
            </article>
        </div>
    </header>

    <nav class="home-anchor-nav" aria-label="@T("homeSections")">
        <a href="#live-matches">Live Matches</a>
        <a href="#top-battles">Top Crypto Battles</a>
        <a href="#how-it-works">How It Works</a>
        <a href="#trending-coins">Trending Coins</a>
        <a href="#rankings">Crypto Arena Rankings</a>
    </nav>

    <section id="live-matches" class="home-section">
        <div class="home-section__header">
            <h2>Live Matches</h2>
            <p>@T("followOngoingCryptoBattlesWithCrawlablePublicPagesThatShowScoreMomentumAndMatchContext")</p>
        </div>
        <div class="public-home-arena__deck">
            @if (FeaturedBattle is not null)
            {
                var featured = FeaturedBattle!;
                var featuredEnergyA = GetEnergyPercentA(featured);
                var featuredEnergyB = 100 - featuredEnergyA;

                <article class="arena-featured-battle @GetArenaLeaderClass(featured)">
                    <a class="arena-card-hitbox"
                       href="@GetMatchUrl(featured)"
                       aria-label="@ArenaText("openArenaAria", GetBaseSymbol(featured.TeamA), GetBaseSymbol(featured.TeamB), featured.MatchId)"></a>
                    <div class="arena-featured-battle__glow" aria-hidden="true"></div>

                    <div class="arena-featured-battle__hud">
                        <div class="arena-featured-battle__chips">
                            <span class="arena-live-pill">
                                <span class="arena-live-pill__dot" aria-hidden="true"></span>
                                @ArenaText("live")
                            </span>

                            @foreach (var badge in GetBattleBadges(featured, isFeatured: true))
                            {
                                <span class="arena-chip @GetArenaChipClass(badge.Tone)">@badge.Text</span>
                            }
                        </div>

                        <span class="arena-meta">@ArenaText("arenaMatchId", featured.MatchId)</span>
                    </div>

                    <div class="arena-featured-battle__body">
                        <div class="arena-featured-battle__main">
                            <span class="arena-overline">@ArenaText("featuredBattle")</span>

                            <div class="arena-featured-battle__scoreboard">
                                <div class="arena-team-panel @(GetLeaderSide(featured) == BattleLeader.TeamA ? "is-leading" : null)">
                                    <div class="arena-team-panel__identity">
                                        <img class="arena-team-panel__logo"
                                             src="@GetCoinIconUrl(featured.TeamA)"
                                             width="72"
                                             height="72"
                                             alt="@featured.TeamA"
                                             loading="lazy"
                                             onerror="this.remove();" />
                                        <div>
                                            <strong>@GetBaseSymbol(featured.TeamA)</strong>
                                            <span>@featured.TeamA</span>
                                        </div>
                                    </div>

                                    <span class="arena-team-panel__change @(GetSignedChangeClass(featured.PctA))">@FormatPct(featured.PctA)</span>
                                </div>

                                <div class="arena-featured-battle__center">
                                    <span class="arena-status-text">@GetMatchStateLabel(featured)</span>
                                    <div class="arena-scoreboard arena-scoreboard--featured">
                                        <strong>@featured.ScoreA</strong>
                                        <span class="arena-vs-badge">VS</span>
                                        <strong>@featured.ScoreB</strong>
                                    </div>
                                    <span class="arena-status-subtext">@GetMatchClockLabel(featured)</span>
                                </div>

                                <div class="arena-team-panel @(GetLeaderSide(featured) == BattleLeader.TeamB ? "is-leading" : null)">
                                    <div class="arena-team-panel__identity">
                                        <img class="arena-team-panel__logo"
                                             src="@GetCoinIconUrl(featured.TeamB)"
                                             width="72"
                                             height="72"
                                             alt="@featured.TeamB"
                                             loading="lazy"
                                             onerror="this.remove();" />
                                        <div>
                                            <strong>@GetBaseSymbol(featured.TeamB)</strong>
                                            <span>@featured.TeamB</span>
                                        </div>
                                    </div>

                                    <span class="arena-team-panel__change @(GetSignedChangeClass(featured.PctB))">@FormatPct(featured.PctB)</span>
                                </div>
                            </div>

                            <div class="arena-energy-bar arena-energy-bar--featured" aria-label="@ArenaText("momentumBar")">
                                <span class="arena-energy-bar__side arena-energy-bar__side--left" style="@BuildEnergyWidthStyle(featuredEnergyA)"></span>
                                <span class="arena-energy-bar__side arena-energy-bar__side--right" style="@BuildEnergyWidthStyle(featuredEnergyB)"></span>
                            </div>
                        </div>

                        <aside class="arena-featured-battle__insights">
                            <div class="arena-stat-chip">
                                <span>@ArenaText("momentum")</span>
                                <strong>@GetMomentumLabel(featuredEnergyA)</strong>
                            </div>
                            <div class="arena-stat-chip">
                                <span>@ArenaText("scoreLine")</span>
                                <strong>@featured.ScoreA x @featured.ScoreB</strong>
                            </div>
                            <div class="arena-stat-chip">
                                <span>@ArenaText("volatility")</span>
                                <strong>@GetVolatilityLabel(featured)</strong>
                            </div>

                            <a class="arena-cta-button"
                               href="@GetMatchUrl(featured)"
                               aria-label="@ArenaText("openArenaAria", GetBaseSymbol(featured.TeamA), GetBaseSymbol(featured.TeamB), featured.MatchId)">
                                @ArenaText("openArena")
                            </a>
                        </aside>
                    </div>
                </article>
            }

            <div class="arena-match-grid">
                @foreach (var match in ArenaLiveMatches)
                {
                    var energyA = GetEnergyPercentA(match);
                    var energyB = 100 - energyA;

                    <article class="arena-match-card @GetArenaLeaderClass(match)">
                        <a class="arena-card-hitbox"
                           href="@GetMatchUrl(match)"
                           aria-label="@ArenaText("openArenaAria", GetBaseSymbol(match.TeamA), GetBaseSymbol(match.TeamB), match.MatchId)"></a>
                        <div class="arena-match-card__header">
                            <span class="arena-live-pill arena-live-pill--small">
                                <span class="arena-live-pill__dot" aria-hidden="true"></span>
                                @ArenaText("liveNow")
                            </span>

                            <span class="arena-meta">@ArenaText("arenaMatchId", match.MatchId)</span>
                        </div>

                        <div class="arena-match-card__body">
                            <div class="arena-match-card__team @(GetLeaderSide(match) == BattleLeader.TeamA ? "is-leading" : null)">
                                <img class="arena-match-card__logo"
                                     src="@GetCoinIconUrl(match.TeamA)"
                                     width="48"
                                     height="48"
                                     alt="@match.TeamA"
                                     loading="lazy"
                                     onerror="this.remove();" />
                                <div class="arena-match-card__team-copy">
                                    <strong>@GetBaseSymbol(match.TeamA)</strong>
                                    <span class="@GetSignedChangeClass(match.PctA)">@FormatPct(match.PctA)</span>
                                </div>
                            </div>

                            <div class="arena-match-card__center">
                                <span class="arena-vs-badge arena-vs-badge--compact">VS</span>
                                <div class="arena-scoreboard arena-scoreboard--card">
                                    <strong>@match.ScoreA</strong>
                                    <span>:</span>
                                    <strong>@match.ScoreB</strong>
                                </div>
                            </div>

                            <div class="arena-match-card__team arena-match-card__team--right @(GetLeaderSide(match) == BattleLeader.TeamB ? "is-leading" : null)">
                                <img class="arena-match-card__logo"
                                     src="@GetCoinIconUrl(match.TeamB)"
                                     width="48"
                                     height="48"
                                     alt="@match.TeamB"
                                     loading="lazy"
                                     onerror="this.remove();" />
                                <div class="arena-match-card__team-copy">
                                    <strong>@GetBaseSymbol(match.TeamB)</strong>
                                    <span class="@GetSignedChangeClass(match.PctB)">@FormatPct(match.PctB)</span>
                                </div>
                            </div>
                        </div>

                        <div class="arena-energy-bar" aria-hidden="true">
                            <span class="arena-energy-bar__side arena-energy-bar__side--left" style="@BuildEnergyWidthStyle(energyA)"></span>
                            <span class="arena-energy-bar__side arena-energy-bar__side--right" style="@BuildEnergyWidthStyle(energyB)"></span>
                        </div>

                        <div class="arena-match-card__footer">
                            <span class="arena-status-subtext">@GetMatchClockLabel(match)</span>
                            <a class="arena-cta-link"
                               href="@GetMatchUrl(match)"
                               aria-label="@ArenaText("openArenaAria", GetBaseSymbol(match.TeamA), GetBaseSymbol(match.TeamB), match.MatchId)">
                                @ArenaText("openArena")
                            </a>
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>

    <section id="top-battles" class="home-section">
        <div class="home-section__header">
            <h2>Top Crypto Battles</h2>
            <p>@T("featuredPublicMatchPagesConnectMarketPerformanceScoringRulesAndTransparentHistoricalContext")</p>
        </div>

        <div class="arena-top-battle-grid">
            @foreach (var match in TopBattleMatches)
            {
                var energyA = GetEnergyPercentA(match);
                var energyB = 100 - energyA;

                <article class="arena-match-card arena-match-card--compact @GetArenaLeaderClass(match)">
                    <a class="arena-card-hitbox"
                       href="@GetMatchUrl(match)"
                       aria-label="@ArenaText("openArenaAria", GetBaseSymbol(match.TeamA), GetBaseSymbol(match.TeamB), match.MatchId)"></a>
                    <div class="arena-match-card__header">
                        <span class="arena-chip arena-chip--muted">@GetMatchStateLabel(match)</span>
                        <span class="arena-meta">@ArenaText("arenaMatchId", match.MatchId)</span>
                    </div>

                    <div class="arena-match-card__body">
                        <div class="arena-match-card__team @(GetLeaderSide(match) == BattleLeader.TeamA ? "is-leading" : null)">
                            <img class="arena-match-card__logo"
                                 src="@GetCoinIconUrl(match.TeamA)"
                                 width="42"
                                 height="42"
                                 alt="@match.TeamA"
                                 loading="lazy"
                                 onerror="this.remove();" />
                            <div class="arena-match-card__team-copy">
                                <strong>@GetBaseSymbol(match.TeamA)</strong>
                                <span class="@GetSignedChangeClass(match.PctA)">@FormatPct(match.PctA)</span>
                            </div>
                        </div>

                        <div class="arena-match-card__center">
                            <span class="arena-vs-badge arena-vs-badge--compact">VS</span>
                            <div class="arena-scoreboard arena-scoreboard--card">
                                <strong>@match.ScoreA</strong>
                                <span>:</span>
                                <strong>@match.ScoreB</strong>
                            </div>
                        </div>

                        <div class="arena-match-card__team arena-match-card__team--right @(GetLeaderSide(match) == BattleLeader.TeamB ? "is-leading" : null)">
                            <img class="arena-match-card__logo"
                                 src="@GetCoinIconUrl(match.TeamB)"
                                 width="42"
                                 height="42"
                                 alt="@match.TeamB"
                                 loading="lazy"
                                 onerror="this.remove();" />
                            <div class="arena-match-card__team-copy">
                                <strong>@GetBaseSymbol(match.TeamB)</strong>
                                <span class="@GetSignedChangeClass(match.PctB)">@FormatPct(match.PctB)</span>
                            </div>
                        </div>
                    </div>

                    <div class="arena-energy-bar arena-energy-bar--compact" aria-hidden="true">
                        <span class="arena-energy-bar__side arena-energy-bar__side--left" style="@BuildEnergyWidthStyle(energyA)"></span>
                        <span class="arena-energy-bar__side arena-energy-bar__side--right" style="@BuildEnergyWidthStyle(energyB)"></span>
                    </div>

                    <div class="arena-match-card__footer">
                        <span class="arena-status-subtext">@T("featuredMatchScoreSummary", match.MatchId, match.ScoreA, match.ScoreB)</span>
                        <a class="arena-cta-link"
                           href="@GetMatchUrl(match)"
                           aria-label="@ArenaText("openArenaAria", GetBaseSymbol(match.TeamA), GetBaseSymbol(match.TeamB), match.MatchId)">
                            @ArenaText("openBattle")
                        </a>
                    </div>
                </article>
            }
        </div>
    </section>

    <section id="how-it-works" class="home-section home-section--split">
        <div class="home-section__header">
            <h2>How It Works</h2>
            <p>@T("criptoversusTracksMarketVariationBetweenAssetsConvertsConfiguredRulesIntoScoreEventsAndPublishesMatchPagesThatCanBeIndexedSharedAndAudited")</p>
            <a class="home-inline-link" href="@RouteLocalization.BuildHowItWorksPath(CurrentCulture)">@T("readTheFullRules")</a>
        </div>
        <div class="home-feature-grid">
            <article>
                <h3>@T("publicMatchLogic")</h3>
                <p>@T("eachMatchHasScoreStatusVolumePriceVariationAndRuleBasedEventsVisibleOnThePublicPage")</p>
            </article>
            <article>
                <h3>@T("arenaStyleExperience")</h3>
                <p>@T("theProductBlendsCryptoDataLiveConfrontationAndSocialReadyStorytelling")</p>
            </article>
            <article>
                <h3>@T("globalSeoReadyRouting")</h3>
                <p>@T("localizedPublicRoutesCanonicalUrlsAndHreflangSupportKeepInternationalDiscoveryClean")</p>
            </article>
        </div>
    </section>

    <section id="trending-coins" class="home-section">
        <div class="home-section__header">
            <h2>Trending Coins</h2>
            <p>@T("aQuickPulseOfTheAssetsCurrentlyDrawingTheStrongestAttentionInsideTheArena")</p>
        </div>
        <div class="home-coin-grid">
            @foreach (var coin in TrendingCoins)
            {
                <article class="home-coin-card">
                    <span class="home-coin-card__rank">#@coin.Rank</span>
                    <h3>@coin.Symbol</h3>
                    <p>@(!string.IsNullOrWhiteSpace(coin.Name) ? coin.Name : T("trackedMarketAsset"))</p>
                    <strong class="@(coin.PercentageChange >= 0 ? "is-up" : "is-down")">@FormatPct(coin.PercentageChange)</strong>
                </article>
            }
        </div>
    </section>

    <section id="rankings" class="home-section">
        <div class="home-section__header">
            <h2>Crypto Arena Rankings</h2>
            <p>@T("trendingAssetsFeaturedBattlesAndPublicMatchPagesBuildTheCompetitiveRankingLayerOfTheArena")</p>
        </div>
        <ol class="home-ranking-list">
            @foreach (var coin in RankingCoins)
            {
                <li>
                    <strong>@coin.Symbol</strong>
                    <span>@FormatPct(coin.PercentageChange)</span>
                </li>
            }
        </ol>
    </section>

    <section id="arena-faq" class="home-section home-section--faq">
        <div class="home-section__header">
            <h2>@T("faqTitle")</h2>
            <p>@T("faqSubtitle")</p>
        </div>
        <div class="home-faq-grid">
            @foreach (var item in FaqItems)
            {
                <article class="home-faq-card">
                    <h3>@item.Question</h3>
                    <p>@item.Answer</p>
                </article>
            }
        </div>
    </section>

    <section class="home-section home-section--compact">
        <div class="home-section__header">
            <h2>@T("exploreTheProduct")</h2>
        </div>
        <div class="home-link-grid">
            <a href="@RouteLocalization.BuildRoadmapPath(CurrentCulture)">Roadmap</a>
            <a href="@RouteLocalization.BuildHowItWorksPath(CurrentCulture)">@T("howItWorks2")</a>
            @if (FeaturedMatches.Count > 0)
            {
                <a href="@GetMatchUrl(FeaturedMatches[0])">@T("featuredMatch")</a>
            }
            <a href="#rankings">Rankings</a>
        </div>
    </section>

</section>

@code {
    private DashboardSnapshotDto? _snapshot;
    private bool _disposed;
    private readonly SemaphoreSlim _reloadLock = new(1, 1);
    private CancellationTokenSource? _debounceCts;

    private string CurrentCulture => AppCulture.GetCurrentRouteCulture(Nav);
    private string SeoTitle => T("criptoversusLiveCryptoMatchArena");
    private string SeoDescription => T("seoDescription");
    private string CanonicalUrl => BuildAbsolute(RouteLocalization.BuildHomePath(CurrentCulture));
    private string EnglishUrl => BuildAbsolute(RouteLocalization.BuildHomePath("en"));
    private string PortugueseUrl => BuildAbsolute(RouteLocalization.BuildHomePath("pt"));
    private MarkupString StructuredDataMarkup => new(BuildStructuredDataJson());
    private IReadOnlyList<string> HeroSemanticHighlights => new[]
    {
        T("heroSemantic1"),
        T("heroSemantic2"),
        T("heroSemantic3"),
        T("heroSemantic4"),
        T("heroSemantic5")
    };
    private IReadOnlyList<FaqItem> FaqItems => new[]
    {
        new FaqItem(T("faq.onlyScoreboard.question"), T("faq.onlyScoreboard.answer")),
        new FaqItem(T("faq.openPositions.question"), T("faq.openPositions.answer")),
        new FaqItem(T("faq.arenaPools.question"), T("faq.arenaPools.answer")),
        new FaqItem(T("faq.cyclicalPools.question"), T("faq.cyclicalPools.answer")),
        new FaqItem(T("faq.rewardDistribution.question"), T("faq.rewardDistribution.answer")),
        new FaqItem(T("faq.battleCycle.question"), T("faq.battleCycle.answer"))
    };

    private const int HomeMatchLimit = 10;

    private List<MatchDto> LiveMatches => RankHomeMatches(_snapshot?.Matches.OngoingList ?? []).Take(HomeMatchLimit).ToList();
    private List<MatchDto> FeaturedMatches => RankHomeMatches(
            (_snapshot?.Matches.OngoingList ?? [])
                .Concat(_snapshot?.Matches.Upcoming ?? [])
                .Concat(_snapshot?.Matches.CompletedList ?? []))
        .Take(HomeMatchLimit)
        .ToList();
    private MatchDto? FeaturedBattle => SelectFeaturedBattle();
    private List<MatchDto> ArenaLiveMatches => LiveMatches
        .Where(x => x.MatchId != FeaturedBattle?.MatchId)
        .Take(HomeMatchLimit - 1)
        .ToList();
    private List<MatchDto> TopBattleMatches => FeaturedMatches
        .Where(x => x.MatchId != FeaturedBattle?.MatchId)
        .Take(HomeMatchLimit)
        .ToList();
    private List<CurrencyDto> TrendingCoins => (_snapshot?.TopGainers ?? []).OrderBy(x => x.Rank).Take(6).ToList();
    private List<CurrencyDto> RankingCoins => (_snapshot?.TopGainers ?? []).OrderBy(x => x.Rank).Take(10).ToList();
    private Dictionary<string, int> TopGainerRankMap => (_snapshot?.TopGainers ?? [])
        .Where(x => !string.IsNullOrWhiteSpace(x.Symbol))
        .OrderBy(x => x.Rank)
        .GroupBy(x => x.Symbol, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(x => x.Key, x => x.First().Rank, StringComparer.OrdinalIgnoreCase);
    private string GetCoinIconUrl(string pair)
    {
        var baseSymbol = GetBaseSymbol(pair);
        return CriptoVersus.Web.Services.EnvironmentIsolationGuard.BuildApiUrl(Config, $"/api/icons/binance/{baseSymbol}");
    }

    private static string GetBaseSymbol(string pair)
    {
        if (string.IsNullOrWhiteSpace(pair)) return "";

        pair = pair.ToUpperInvariant();

        var quotes = new[] { "USDT", "USDC", "BUSD", "BRL", "EUR", "BTC", "ETH" };

        foreach (var q in quotes)
        {
            if (pair.EndsWith(q) && pair.Length > q.Length)
                return pair.Substring(0, pair.Length - q.Length);
        }

        return pair;
    }
    protected override async Task OnInitializedAsync()
    {
        HubClient.DashboardChanged += OnDashboardChanged;

        try
        {
            await ReloadSnapshotAsync(CancellationToken.None);
        }
        catch
        {
            _snapshot = null;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            await HubClient.EnsureStartedAsync();
        }
        catch
        {
            // A home continua funcional sem o hub; mantemos o snapshot inicial.
        }
    }

    private string T(string key, params object?[] args)
        => L.T($"publicHome.{key}", CurrentCulture, args);

    private string BuildAbsolute(string relativePath)
    {
        var baseUrl = Config["CriptoVersus:PublicBaseUrl"]?.TrimEnd('/') ?? Nav.BaseUri.TrimEnd('/');
        return $"{baseUrl}{relativePath}";
    }

    private string GetMatchUrl(MatchDto match)
    {
        var slug = MatchSlugHelper.BuildSlug(match.TeamA, match.TeamB);
        return string.IsNullOrWhiteSpace(slug)
            ? RouteLocalization.BuildHomePath(CurrentCulture)
            : RouteLocalization.BuildLocalizedPath(CurrentCulture, match.MatchId, slug);
    }

    private List<MatchDto> RankHomeMatches(IEnumerable<MatchDto> source)
    {
        var distinctMatches = source
            .Where(x => x.MatchId > 0)
            .GroupBy(x => x.MatchId)
            .Select(x => x.First())
            .ToList();

        if (distinctMatches.Count <= 1)
            return distinctMatches;

        var preferredPairs = BuildPreferredTopPairs();

        return distinctMatches
            .OrderBy(x => GetPreferredPairIndex(x, preferredPairs))
            .ThenBy(x => GetTopGainerCoverageRank(x))
            .ThenBy(x => GetTopGainerDistanceRank(x))
            .ThenBy(x => GetTopGainerSumRank(x))
            .ThenBy(x => GetHomeStatusRank(x))
            .ThenByDescending(x => GetOptionalHotScore(x) ?? int.MinValue)
            .ThenByDescending(x => x.StartTime ?? DateTime.MinValue)
            .ToList();
    }

    private List<string> BuildPreferredTopPairs()
    {
        var rankedSymbols = (_snapshot?.TopGainers ?? [])
            .Where(x => !string.IsNullOrWhiteSpace(x.Symbol))
            .OrderBy(x => x.Rank)
            .Select(x => x.Symbol)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        var result = new List<string>();
        for (var i = 0; i + 1 < rankedSymbols.Count; i += 2)
            result.Add(BuildPairKey(rankedSymbols[i], rankedSymbols[i + 1]));

        return result;
    }

    private static string BuildPairKey(string? teamA, string? teamB)
    {
        var a = (teamA ?? string.Empty).Trim().ToUpperInvariant();
        var b = (teamB ?? string.Empty).Trim().ToUpperInvariant();
        return string.CompareOrdinal(a, b) <= 0 ? $"{a}|{b}" : $"{b}|{a}";
    }

    private int GetPreferredPairIndex(MatchDto match, List<string> preferredPairs)
    {
        var key = BuildPairKey(match.TeamA, match.TeamB);
        var index = preferredPairs.FindIndex(x => string.Equals(x, key, StringComparison.OrdinalIgnoreCase));
        return index >= 0 ? index : int.MaxValue;
    }

    private int GetTopGainerCoverageRank(MatchDto match)
    {
        var teamARank = GetTopGainerRank(match.TeamA);
        var teamBRank = GetTopGainerRank(match.TeamB);
        var coverage = (teamARank.HasValue ? 1 : 0) + (teamBRank.HasValue ? 1 : 0);

        return coverage switch
        {
            2 => 0,
            1 => 1,
            _ => 2
        };
    }

    private int GetTopGainerDistanceRank(MatchDto match)
    {
        var teamARank = GetTopGainerRank(match.TeamA);
        var teamBRank = GetTopGainerRank(match.TeamB);

        if (teamARank.HasValue && teamBRank.HasValue)
            return Math.Abs(teamARank.Value - teamBRank.Value);

        return int.MaxValue;
    }

    private int GetTopGainerSumRank(MatchDto match)
    {
        var teamARank = GetTopGainerRank(match.TeamA);
        var teamBRank = GetTopGainerRank(match.TeamB);

        if (teamARank.HasValue && teamBRank.HasValue)
            return teamARank.Value + teamBRank.Value;

        if (teamARank.HasValue)
            return 10_000 + teamARank.Value;

        if (teamBRank.HasValue)
            return 10_000 + teamBRank.Value;

        return int.MaxValue;
    }

    private int? GetTopGainerRank(string? symbol)
        => !string.IsNullOrWhiteSpace(symbol) && TopGainerRankMap.TryGetValue(symbol, out var rank)
            ? rank
            : null;

    private static int GetHomeStatusRank(MatchDto match)
    {
        if (match.IsFinished)
            return 2;

        return match.StartTime.HasValue && match.StartTime.Value > DateTime.UtcNow
            ? 1
            : 0;
    }

    private static string FormatPct(decimal? value)
        => $"{(value ?? 0):+0.##;-0.##;0.##}%";

    private MatchDto? SelectFeaturedBattle()
    {
        var source = LiveMatches.Count > 0 ? LiveMatches : FeaturedMatches;
        if (source.Count == 0)
            return null;

        MatchDto? bestByHotScore = null;
        int? bestHotScore = null;

        foreach (var match in source)
        {
            var hotScore = GetOptionalHotScore(match);
            if (!hotScore.HasValue)
                continue;

            if (!bestHotScore.HasValue || hotScore.Value > bestHotScore.Value)
            {
                bestHotScore = hotScore.Value;
                bestByHotScore = match;
            }
        }

        return bestByHotScore ?? source.FirstOrDefault();
    }

    private static int? GetOptionalHotScore(MatchDto match)
    {
        var property = typeof(MatchDto).GetProperty("HotScore");
        if (property?.GetValue(match) is int hotScore)
            return hotScore;

        return null;
    }

    private string ArenaText(string key, params object?[] args)
    {
