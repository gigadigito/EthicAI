    private string GetArenaHeatClass(MatchDto match)
    {
        var hot = FindHotMatch(match.MatchId);
        if (hot is null)
            return string.Empty;

        return GetArenaHeatClass(hot);
    }

    private static string GetArenaHeatClass(HotMatchDto match)
        => match.IsExplosive
            ? "is-explosive"
            : match.IsTrending
                ? "is-trending"
                : string.Empty;

    private decimal GetHeroFieldArenaPressure(MatchDto match, HotMatchDto? hotMatch, double energyA)
    {
        var hotArenaPressure = TryReadDecimalProperty(hotMatch, "ArenaPressure");
        if (hotArenaPressure.HasValue)
            return hotArenaPressure.Value;

        var matchArenaPressure = TryReadDecimalProperty(match, "ArenaPressure");
        if (matchArenaPressure.HasValue)
            return matchArenaPressure.Value;

        return Convert.ToDecimal(Math.Round(energyA));
    }

    private decimal GetHeroFieldHotScore(MatchDto match, HotMatchDto? hotMatch)
    {
        var hotScore = TryReadDecimalProperty(hotMatch, "HotScore");
        if (hotScore.HasValue)
            return hotScore.Value;

        var matchHotScore = TryReadDecimalProperty(match, "HotScore");
        if (matchHotScore.HasValue)
            return matchHotScore.Value;

        return 0m;
    }

    private static decimal? TryReadDecimalProperty(object? source, string propertyName)
    {
        if (source is null)
            return null;

        var property = source.GetType().GetProperty(propertyName);
        if (property is null)
            return null;

        var value = property.GetValue(source);
        if (value is null)
            return null;

        try
        {
            return Convert.ToDecimal(value, CultureInfo.InvariantCulture);
        }
        catch
        {
            return null;
        }
    }

