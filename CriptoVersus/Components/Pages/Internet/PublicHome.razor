    private string BuildStructuredDataJson()
    {
        var graph = new List<Dictionary<string, object?>>();
        var siteUrl = BuildAbsolute("");
        var organizer = new Dictionary<string, object?>
        {
            ["@type"] = "Organization",
            ["name"] = "CriptoVersus",
            ["url"] = siteUrl
        };
        var virtualLocation = new Dictionary<string, object?>
        {
            ["@type"] = "VirtualLocation",
            ["url"] = siteUrl
        };

        graph.Add(new Dictionary<string, object?>
        {
            ["@type"] = "Organization",
            ["name"] = "CriptoVersus",
            ["url"] = BuildAbsolute(RouteLocalization.BuildHomePath("en")),
            ["logo"] = BuildAbsolute("/favicon-round-preview.png")
        });

        graph.Add(new Dictionary<string, object?>
        {
            ["@type"] = "WebSite",
            ["name"] = "CriptoVersus",
            ["url"] = BuildAbsolute(RouteLocalization.BuildHomePath("en")),
            ["inLanguage"] = new[] { "en-US", "pt-BR" }
        });

        graph.Add(new Dictionary<string, object?>
        {
            ["@type"] = "WebPage",
            ["name"] = SeoTitle,
            ["url"] = CanonicalUrl,
            ["description"] = SeoDescription,
            ["abstract"] = T("structuredDataAbstract"),
            ["about"] = GetStructuredAbout(),
            ["keywords"] = GetStructuredKeywords(),
            ["inLanguage"] = AppCulture.ToHrefLang(CurrentCulture)
        });

        graph.Add(new Dictionary<string, object?>
        {
            ["@type"] = "BreadcrumbList",
            ["itemListElement"] = new[]
            {
                new Dictionary<string, object?>
                {
                    ["@type"] = "ListItem",
                    ["position"] = 1,
                    ["name"] = CurrentCulture == "en" ? "Home" : "Inicio",
                    ["item"] = CanonicalUrl
                }
            }
        });

        foreach (var match in FeaturedMatches.Take(3))
        {
            var slug = MatchSlugHelper.BuildSlug(match.TeamA, match.TeamB);
            var eventUrl = BuildAbsolute(GetMatchUrl(match));
            var competitors = new[]
            {
                new Dictionary<string, object?> { ["@type"] = "SportsTeam", ["name"] = match.TeamA },
                new Dictionary<string, object?> { ["@type"] = "SportsTeam", ["name"] = match.TeamB }
            };

            var sportsEvent = new Dictionary<string, object?>
            {
                ["@type"] = "SportsEvent",
                ["name"] = $"{match.TeamA} vs {match.TeamB}",
                ["eventStatus"] = GetSchemaEventStatus(match),
                ["startDate"] = FormatSchemaDate(match.StartTime),
                ["endDate"] = GetSchemaEndDate(match),
                ["url"] = eventUrl,
                ["location"] = virtualLocation,
                ["organizer"] = organizer,
                ["competitor"] = competitors,
                ["performer"] = competitors,
                ["image"] = new[] { GetSchemaImageUrl(match, slug) },
                ["description"] = GetStructuredEventDescription(match),
                ["about"] = GetStructuredAbout(),
                ["keywords"] = GetStructuredKeywords()
            };

            RemoveNullValues(sportsEvent);
            graph.Add(sportsEvent);
        }

        graph.Add(new Dictionary<string, object?>
        {
            ["@type"] = "FAQPage",
            ["mainEntity"] = FaqItems.Select(item => new Dictionary<string, object?>
            {
                ["@type"] = "Question",
                ["name"] = item.Question,
                ["acceptedAnswer"] = new Dictionary<string, object?>
                {
                    ["@type"] = "Answer",
                    ["text"] = item.Answer
                }
            }).ToArray()
        });

        return JsonSerializer.Serialize(new Dictionary<string, object?>
        {
            ["@context"] = "https://schema.org",
            ["@graph"] = graph
        });
    }

    private string GetSchemaEventStatus(MatchDto match)
    {
        if (match.IsFinished || IsMatchCompleted(match.Status))
            return "https://schema.org/EventCompleted";

        if (IsMatchOngoing(match.Status))
            return "https://schema.org/EventInProgress";

        return "https://schema.org/EventScheduled";
    }

    private string? GetSchemaEndDate(MatchDto match)
    {
        if (match.IsFinished || IsMatchCompleted(match.Status))
            return FormatSchemaDate(match.EndTime);

        if (IsMatchOngoing(match.Status) && match.StartTime.HasValue)
            return FormatSchemaDate(match.StartTime.Value.AddHours(2));

        return null;
    }

    private static bool IsMatchOngoing(string? status)
        => string.Equals(status, "ongoing", StringComparison.OrdinalIgnoreCase);

    private static bool IsMatchCompleted(string? status)
        => string.Equals(status, "completed", StringComparison.OrdinalIgnoreCase);

    private static string? FormatSchemaDate(DateTime? value)
    {
        if (!value.HasValue)
            return null;

        var normalized = value.Value.Kind == DateTimeKind.Unspecified
            ? DateTime.SpecifyKind(value.Value, DateTimeKind.Utc)
            : value.Value;

        return normalized.ToUniversalTime().ToString("yyyy-MM-dd'T'HH:mm:ss'Z'");
    }

    private string GetSchemaImageUrl(MatchDto match, string slug)
    {
        if (!string.IsNullOrWhiteSpace(slug))
            return BuildAbsolute($"/social-images/match/{match.MatchId}/{slug}.svg");

        return BuildAbsolute("/favicon-round-preview.png");
    }

