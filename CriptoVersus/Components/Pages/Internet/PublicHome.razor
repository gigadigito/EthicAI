@page "/"
@page "/en"
@page "/pt"
@page "/zh"
@using Microsoft.AspNetCore.Components
@using System.Diagnostics
@using System.Globalization
@using System.Text.Json
@using DTOs
@using CriptoVersus.Web.Services
@using CriptoVersus.Web.Components.Shared
@inject CriptoVersusApiClient Api
@inject HotMatchService HotMatches
@inject DashboardHubClient HubClient
@inject IConfiguration Config
@inject NavigationManager Nav
@inject AppCultureService AppCulture
@inject LocalizationService L
@inject RouteLocalizationService RouteLocalization
@inject MatchSlugHelper MatchSlugHelper
@inject ILogger<PublicHome> Logger
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>@SeoTitle</PageTitle>
<HeadContent>
    <meta name="description" content="@SeoDescription" />
    <meta name="keywords" content="@MetaKeywords" />
    <link rel="canonical" href="@CanonicalUrl" />
    <link rel="alternate" hreflang="en-US" href="@EnglishUrl" />
    <link rel="alternate" hreflang="pt-BR" href="@PortugueseUrl" />
    <link rel="alternate" hreflang="zh-CN" href="@ZhUrl" />
    <link rel="alternate" hreflang="x-default" href="@HomeRootUrl" />
    <meta property="og:title" content="@SeoTitle" />
    <meta property="og:description" content="@SeoDescription" />
    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="@SocialImageUrl" />
    <meta property="og:image:alt" content="@SeoTitle" />
    <meta property="og:locale" content="@AppCulture.ToOgLocale(CurrentCulture)" />
    <meta property="og:locale:alternate" content="@AppCulture.GetAlternateOgLocale(CurrentCulture)" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@SeoTitle" />
    <meta name="twitter:description" content="@SeoDescription" />
    <meta name="twitter:image" content="@SocialImageUrl" />
    <meta name="twitter:image:alt" content="@SeoTitle" />
    <script type="application/ld+json">@((MarkupString)StructuredDataMarkup)</script>
</HeadContent>

<section class="home-landing public-home-arena">
    @if (_showCommunityMatchFloatingCard)
    {
        <aside class="community-match-floating"
               role="complementary"
               aria-label="Community battle">
            <button type="button"
                    class="community-match-floating__close"
                    title="@CommunityMatchCloseLabel"
                    aria-label="@CommunityMatchCloseLabel"
                    @onclick="CloseCommunityMatchFloatingCard">
                ×
            </button>

            <CommunityMatchCreationCard />
        </aside>
    }
    <header class="home-hero">
        <div class="home-hero__copy">
            <span class="home-hero__eyebrow">
                @T("globalCryptoArena")
            </span>

            <h1>@T("heroTitle")</h1>

            <p>@T("heroDescription")</p>

            <ul class="home-hero__semantic-list" aria-label="@T("heroSemanticLabel")">
                @foreach (var item in HeroSemanticHighlights)
                {
                    <li>@item</li>
                }
            </ul>

            <div class="home-hero__actions">
                <a class="home-cta home-cta--primary" href="#live-matches">
                    @T("exploreLiveMatches")
                </a>

                <a class="home-cta home-cta--secondary"
                   href="@RouteLocalization.BuildHowItWorksPath(CurrentCulture)">
                    @T("howItWorks")
                </a>

                <a class="home-cta home-cta--secondary"
                   href="@RouteLocalization.BuildRoadmapPath(CurrentCulture)">
                    @T("roadmap")
                </a>
            </div>

            <p class="small text-muted mt-3 mb-0">@T("marketDataDisclaimer")</p>

            @if (HeroArenaFieldMatch is not null)
            {
                var heroField = HeroArenaFieldMatch!;
                var heroFieldHot = HeroArenaFieldHotMatch;
                var heroFieldEnergyA = GetEnergyPercentA(heroField);

                <div class="home-hero__field-slot" aria-label="@ArenaText("featuredBattle")">
                    <CryptoArenaFieldVisual MatchId="@heroField.MatchId"
                                            LeftSymbol="@heroField.TeamA"
                                            RightSymbol="@heroField.TeamB"
                                            LeftScore="@heroField.ScoreA"
                                            RightScore="@heroField.ScoreB"
                                            LeftChangePercent="@heroField.PctA"
                                            RightChangePercent="@heroField.PctB"
                                            PressurePercentA="@heroFieldEnergyA"
                                            ArenaPressure="@GetHeroFieldArenaPressure(heroField, heroFieldHot, heroFieldEnergyA)"
                                            HotScore="@GetHeroFieldHotScore(heroField, heroFieldHot)"
                                            ClockLabel="@GetMatchClockLabel(heroField)"
                                            IsLive="@(!heroField.IsFinished)" />
                </div>
            }
        </div>

        <div class="home-hero__visual">
            @if (_hotMatchesLoading && HeroHotMatch is null && HeroFallbackMatch is null)
            {
                <div class="home-hot-hero home-hot-hero--skeleton" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            }
            else if (HeroHotMatch is not null)
            {
                var hero = HeroHotMatch!;
                var heroEnergyA = GetEnergyPercentA(hero);
                var heroEnergyB = 100 - heroEnergyA;

                <article class="home-hot-hero @GetArenaLeaderClass(hero) @GetArenaHeatClass(hero)">
                    <div class="home-hot-hero__header">
                        <div class="home-hot-hero__badges">
                            @foreach (var badge in GetBattleBadges(hero, isFeatured: true))
                            {
                                <span class="arena-chip @GetArenaChipClass(badge.Tone)">@badge.Text</span>
                            }
                        </div>
                        <span class="arena-meta">@ArenaText("arenaMatchId", hero.MatchId)</span>
                    </div>

                    <div class="home-hot-hero__scoreboard">
                        <div class="home-hot-hero__team">
                            <img class="home-hot-hero__logo"
                                 src="@GetCoinIconUrl(hero.TeamA)"
                                 width="56"
                                 height="56"
                                 alt="@hero.HomeSymbol"
                                 loading="lazy"
                                 onerror="this.remove();" />
                            <div>
                                <strong>@GetBaseSymbol(hero.TeamA)</strong>
                                <span class="@GetSignedChangeClass(hero.PctA)">@FormatPct(hero.PctA)</span>
                            </div>
                        </div>

                        <div class="home-hot-hero__center">
                            <small>@GetMatchClockLabel(hero)</small>
                            <div class="arena-scoreboard arena-scoreboard--featured">
                                <strong class="arena-score-number arena-score-number--left">@hero.ScoreA</strong>
                                <span class="arena-vs-badge">@T("vs")</span>
                                <strong class="arena-score-number arena-score-number--right">@hero.ScoreB</strong>
                            </div>
                        </div>

                        <div class="home-hot-hero__team home-hot-hero__team--right">
                            <div>
                                <strong>@GetBaseSymbol(hero.TeamB)</strong>
                                <span class="@GetSignedChangeClass(hero.PctB)">@FormatPct(hero.PctB)</span>
                            </div>
                            <img class="home-hot-hero__logo"
                                 src="@GetCoinIconUrl(hero.TeamB)"
                                 width="56"
                                 height="56"
                                 alt="@hero.AwaySymbol"
                                 loading="lazy"
                                 onerror="this.remove();" />
                        </div>
                    </div>

                    <div class="arena-energy-bar arena-energy-bar--featured" aria-hidden="true">
                        <span class="arena-energy-bar__side arena-energy-bar__side--left" style="@BuildEnergyWidthStyle(heroEnergyA)"></span>
                        <span class="arena-energy-bar__side arena-energy-bar__side--right" style="@BuildEnergyWidthStyle(heroEnergyB)"></span>
                    </div>

                    <div class="home-hot-hero__metrics">
                        <article>
                            <span>@ArenaText("momentum")</span>
                            <strong>@GetMomentumLabel(heroEnergyA)</strong>
                        </article>
                        <article>
                            <span>@ArenaText("arenaPressure")</span>
                            <strong>@hero.ArenaPressure</strong>
                        </article>
                        <article>
                            <span>@ArenaText("hotScore")</span>
                            <strong>@hero.HotScore</strong>
                        </article>
                    </div>

                    <div class="home-hot-hero__cta-group">
                        <a class="arena-cta-button home-hot-hero__cta"
                           href="@GetTvWatchUrl(hero)"
                           target="_blank"
                           rel="noopener noreferrer"
                           aria-label="@ArenaText("openArenaAria", GetBaseSymbol(hero.TeamA), GetBaseSymbol(hero.TeamB), hero.MatchId)">
                            @ArenaText("openArena")
                        </a>
                        <a class="arena-cta-link home-hot-hero__cta-link"
                           href="@GetPublicMatchUrl(hero.MatchId, hero.TeamA, hero.TeamB)"
                           target="_blank"
                           rel="noopener noreferrer"
                           aria-label="@ArenaText("openMatchAria", GetBaseSymbol(hero.TeamA), GetBaseSymbol(hero.TeamB), hero.MatchId)">
                            @ArenaText("openMatch")
                        </a>
                    </div>
                </article>
            }
            else if (HeroFallbackMatch is not null)
            {
                var hero = HeroFallbackMatch!;
                var heroEnergyA = GetEnergyPercentA(hero);
                var heroEnergyB = 100 - heroEnergyA;

                <article class="home-hot-hero @GetArenaLeaderClass(hero) @GetArenaHeatClass(hero)">
                    <div class="home-hot-hero__header">
                        <div class="home-hot-hero__badges">
                            @foreach (var badge in GetBattleBadges(hero, isFeatured: true))
                            {
                                <span class="arena-chip @GetArenaChipClass(badge.Tone)">@badge.Text</span>
                            }
                        </div>
                        <span class="arena-meta">@ArenaText("arenaMatchId", hero.MatchId)</span>
                    </div>

                    <div class="home-hot-hero__scoreboard">
                        <div class="home-hot-hero__team">
                            <img class="home-hot-hero__logo"
                                 src="@GetCoinIconUrl(hero.TeamA)"
                                 width="56"
                                 height="56"
                                 alt="@hero.TeamA"
                                 loading="lazy"
                                 onerror="this.remove();" />
                            <div>
                                <strong>@GetBaseSymbol(hero.TeamA)</strong>
                                <span class="@GetSignedChangeClass(hero.PctA)">@FormatPct(hero.PctA)</span>
                            </div>
                        </div>

                        <div class="home-hot-hero__center">
                            <small>@GetMatchClockLabel(hero)</small>
                            <div class="arena-scoreboard arena-scoreboard--featured">
                                <strong class="arena-score-number arena-score-number--left">@hero.ScoreA</strong>
                                <span class="arena-vs-badge">@T("vs")</span>
                                <strong class="arena-score-number arena-score-number--right">@hero.ScoreB</strong>
                            </div>
                        </div>

                        <div class="home-hot-hero__team home-hot-hero__team--right">
                            <div>
                                <strong>@GetBaseSymbol(hero.TeamB)</strong>
                                <span class="@GetSignedChangeClass(hero.PctB)">@FormatPct(hero.PctB)</span>
                            </div>
                            <img class="home-hot-hero__logo"
                                 src="@GetCoinIconUrl(hero.TeamB)"
                                 width="56"
                                 height="56"
                                 alt="@hero.TeamB"
                                 loading="lazy"
                                 onerror="this.remove();" />
                        </div>
                    </div>

                    <div class="arena-energy-bar arena-energy-bar--featured" aria-hidden="true">
                        <span class="arena-energy-bar__side arena-energy-bar__side--left" style="@BuildEnergyWidthStyle(heroEnergyA)"></span>
                        <span class="arena-energy-bar__side arena-energy-bar__side--right" style="@BuildEnergyWidthStyle(heroEnergyB)"></span>
                    </div>

                    <div class="home-hot-hero__metrics">
                        <article>
                            <span>@ArenaText("momentum")</span>
                            <strong>@GetMomentumLabel(heroEnergyA)</strong>
                        </article>
                        <article>
                            <span>@ArenaText("volatility")</span>
                            <strong>@GetVolatilityLabel(hero)</strong>
                        </article>
                        <article>
                            <span>@ArenaText("scoreLine")</span>
                            <strong>@GetMatchStateLabel(hero)</strong>
                        </article>
                    </div>

                    <div class="home-hot-hero__cta-group">
                        <a class="arena-cta-button home-hot-hero__cta"
                           href="@GetTvMatchUrl(hero)"
                           target="_blank"
                           rel="noopener noreferrer"
                           aria-label="@ArenaText("openArenaAria", GetBaseSymbol(hero.TeamA), GetBaseSymbol(hero.TeamB), hero.MatchId)">
                            @ArenaText("openArena")
                        </a>
                        <a class="arena-cta-link home-hot-hero__cta-link"
                           href="@GetPublicMatchUrl(hero.MatchId, hero.TeamA, hero.TeamB)"
                           target="_blank"
                           rel="noopener noreferrer"
                           aria-label="@ArenaText("openMatchAria", GetBaseSymbol(hero.TeamA), GetBaseSymbol(hero.TeamB), hero.MatchId)">
                            @ArenaText("openMatch")
                        </a>
                    </div>
                </article>
            }

            <div class="home-hero__stats" aria-label="@T("platformHighlights")">
                <article>
                    <span>@T("liveMatches")</span>
                    <strong>@(_snapshot?.Matches.Ongoing ?? HotMatchFeed.Count)</strong>
                </article>
                <article>
                    <span>@T("completedIn24h")</span>
                    <strong>@(_snapshot?.Matches.CompletedLast24h ?? 0)</strong>
                </article>
                <article>
                    <span>@T("trackedCoins")</span>
                    <strong>@Math.Max(_snapshot?.TopGainers.Count ?? 0, 6)</strong>
                </article>
            </div>
        </div>
    </header>

    <nav class="home-anchor-nav" aria-label="@T("homeSections")">
        <a href="#live-matches">@T("liveMatches")</a>
        <a href="#top-battles">@T("topCryptoBattles")</a>
        <a href="#how-it-works">@T("howItWorks")</a>
        <a href="#trending-coins">@T("trendingCoins")</a>
        <a href="#rankings">@T("cryptoArenaRankings")</a>
    </nav>

    <section id="live-matches" class="home-section">
        <div class="home-section__header">
            <h2>@T("liveMatches")</h2>
            <p>@T("followOngoingCryptoBattlesWithCrawlablePublicPagesThatShowScoreMomentumAndMatchContext")</p>
        </div>
        <div class="public-home-arena__deck">
            @if (FeaturedBattle is not null)
            {
                var featured = FeaturedBattle!;
                var featuredEnergyA = GetEnergyPercentA(featured);
                var featuredEnergyB = 100 - featuredEnergyA;

                <article class="arena-featured-battle @GetArenaLeaderClass(featured) @GetArenaHeatClass(featured)">
                    <div class="arena-featured-battle__glow" aria-hidden="true"></div>

                    <div class="arena-featured-battle__hud">
                        <div class="arena-featured-battle__chips">
                            <span class="arena-live-pill">
                                <span class="arena-live-pill__dot" aria-hidden="true"></span>
                                @ArenaText("live")
                            </span>

                            @foreach (var badge in GetBattleBadges(featured, isFeatured: true))
                            {
                                <span class="arena-chip @GetArenaChipClass(badge.Tone)">@badge.Text</span>
                            }
                        </div>

                        <span class="arena-meta">@ArenaText("arenaMatchId", featured.MatchId)</span>
                    </div>

                    <div class="arena-featured-battle__body">
                        <div class="arena-featured-battle__main">
                            <span class="arena-overline">@ArenaText("featuredBattle")</span>

                            <div class="arena-featured-battle__scoreboard">
                                <div class="arena-team-panel @(GetLeaderSide(featured) == BattleLeader.TeamA ? "is-leading" : null)">
                                    <div class="arena-team-panel__identity">
                                        <img class="arena-team-panel__logo"
                                             src="@GetCoinIconUrl(featured.TeamA)"
                                             width="72"
                                             height="72"
                                             alt="@featured.TeamA"
                                             loading="lazy"
                                             onerror="this.remove();" />
                                        <div>
                                            <strong>@GetBaseSymbol(featured.TeamA)</strong>
                                            <span>@featured.TeamA</span>
                                        </div>
                                    </div>

                                    <span class="arena-team-panel__change @(GetSignedChangeClass(featured.PctA))">@FormatPct(featured.PctA)</span>
                                </div>

                                <div class="arena-featured-battle__center">
                                    <span class="arena-status-text">@GetMatchStateLabel(featured)</span>
                                    <div class="arena-scoreboard arena-scoreboard--featured">
                                        <strong class="arena-score-number arena-score-number--left">@featured.ScoreA</strong>
                                        <span class="arena-vs-badge">@T("vs")</span>
                                        <strong class="arena-score-number arena-score-number--right">@featured.ScoreB</strong>
                                    </div>
                                    <span class="arena-status-subtext">@GetMatchClockLabel(featured)</span>
                                </div>

                                <div class="arena-team-panel @(GetLeaderSide(featured) == BattleLeader.TeamB ? "is-leading" : null)">
                                    <div class="arena-team-panel__identity">
                                        <img class="arena-team-panel__logo"
                                             src="@GetCoinIconUrl(featured.TeamB)"
                                             width="72"
                                             height="72"
                                             alt="@featured.TeamB"
                                             loading="lazy"
                                             onerror="this.remove();" />
                                        <div>
                                            <strong>@GetBaseSymbol(featured.TeamB)</strong>
                                            <span>@featured.TeamB</span>
                                        </div>
                                    </div>

                                    <span class="arena-team-panel__change @(GetSignedChangeClass(featured.PctB))">@FormatPct(featured.PctB)</span>
                                </div>
                            </div>

                            <div class="arena-energy-bar arena-energy-bar--featured" aria-label="@ArenaText("momentumBar")">
                                <span class="arena-energy-bar__side arena-energy-bar__side--left" style="@BuildEnergyWidthStyle(featuredEnergyA)"></span>
                                <span class="arena-energy-bar__side arena-energy-bar__side--right" style="@BuildEnergyWidthStyle(featuredEnergyB)"></span>
                            </div>
                        </div>

                        <aside class="arena-featured-battle__insights">
                            <div class="arena-stat-chip">
                                <span>@ArenaText("momentum")</span>
                                <strong>@GetMomentumLabel(featuredEnergyA)</strong>
                            </div>
                            <div class="arena-stat-chip">
                                <span>@ArenaText("scoreLine")</span>
                                <strong>@featured.ScoreA x @featured.ScoreB</strong>
                            </div>
                            <div class="arena-stat-chip">
                                <span>@ArenaText("volatility")</span>
                                <strong>@GetVolatilityLabel(featured)</strong>
                            </div>

                            <div class="arena-featured-battle__actions">
                                <a class="arena-cta-button"
                                   href="@GetTvMatchUrl(featured)"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   aria-label="@ArenaText("openArenaAria", GetBaseSymbol(featured.TeamA), GetBaseSymbol(featured.TeamB), featured.MatchId)">
                                    @ArenaText("openArena")
                                </a>
                                <a class="arena-cta-link"
                                   href="@GetPublicMatchUrl(featured)"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   aria-label="@ArenaText("openMatchAria", GetBaseSymbol(featured.TeamA), GetBaseSymbol(featured.TeamB), featured.MatchId)">
                                    @ArenaText("openMatch")
                                </a>
                            </div>
                        </aside>
                    </div>
                </article>
            }

            <div class="arena-match-grid">
                @if (_hotMatchesLoading && ArenaLiveMatches.Count == 0)
                {
                    @for (var i = 0; i < 4; i++)
                    {
                        <article class="arena-match-card arena-match-card--skeleton" aria-hidden="true">
                            <span></span>
                            <span></span>
                            <span></span>
                        </article>
                    }
                }
                @foreach (var match in ArenaLiveMatches)
                {
                    var energyA = GetEnergyPercentA(match);
                    var energyB = 100 - energyA;

                    <article class="arena-match-card @GetArenaLeaderClass(match) @GetArenaHeatClass(match)">
                        <div class="arena-match-card__header">
                            <span class="arena-live-pill arena-live-pill--small">
                                <span class="arena-live-pill__dot" aria-hidden="true"></span>
                                @ArenaText("liveNow")
                            </span>

                            <span class="arena-meta">@ArenaText("arenaMatchId", match.MatchId)</span>
                        </div>

                        <div class="arena-match-card__body">
                            <div class="arena-match-card__team @(GetLeaderSide(match) == BattleLeader.TeamA ? "is-leading" : null)">
                                <img class="arena-match-card__logo"
                                     src="@GetCoinIconUrl(match.TeamA)"
                                     width="48"
                                     height="48"
                                     alt="@match.TeamA"
                                     loading="lazy"
                                     onerror="this.remove();" />
                                <div class="arena-match-card__team-copy">
                                    <strong>@GetBaseSymbol(match.TeamA)</strong>
                                    <span class="@GetSignedChangeClass(match.PctA)">@FormatPct(match.PctA)</span>
                                </div>
                            </div>

                            <div class="arena-match-card__center">
                                <span class="arena-vs-badge arena-vs-badge--compact">@T("vs")</span>
                                <div class="arena-scoreboard arena-scoreboard--card">
                                    <strong class="arena-score-number arena-score-number--left">@match.ScoreA</strong>
                                    <span>:</span>
                                    <strong class="arena-score-number arena-score-number--right">@match.ScoreB</strong>
                                </div>
                            </div>

                            <div class="arena-match-card__team arena-match-card__team--right @(GetLeaderSide(match) == BattleLeader.TeamB ? "is-leading" : null)">
                                <img class="arena-match-card__logo"
                                     src="@GetCoinIconUrl(match.TeamB)"
                                     width="48"
                                     height="48"
                                     alt="@match.TeamB"
                                     loading="lazy"
                                     onerror="this.remove();" />
                                <div class="arena-match-card__team-copy">
                                    <strong>@GetBaseSymbol(match.TeamB)</strong>
                                    <span class="@GetSignedChangeClass(match.PctB)">@FormatPct(match.PctB)</span>
                                </div>
                            </div>
                        </div>

                        <div class="arena-energy-bar" aria-hidden="true">
                            <span class="arena-energy-bar__side arena-energy-bar__side--left" style="@BuildEnergyWidthStyle(energyA)"></span>
                            <span class="arena-energy-bar__side arena-energy-bar__side--right" style="@BuildEnergyWidthStyle(energyB)"></span>
                        </div>

                        <div class="arena-match-card__footer">
                            <span class="arena-status-subtext">@GetMatchClockLabel(match)</span>
                            <div class="arena-match-card__actions">
                                <a class="arena-cta-button"
                                   href="@GetTvMatchUrl(match)"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   aria-label="@ArenaText("openArenaAria", GetBaseSymbol(match.TeamA), GetBaseSymbol(match.TeamB), match.MatchId)">
                                    @ArenaText("openArena")
                                </a>
                                <a class="arena-cta-link"
                                   href="@GetPublicMatchUrl(match)"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   aria-label="@ArenaText("openMatchAria", GetBaseSymbol(match.TeamA), GetBaseSymbol(match.TeamB), match.MatchId)">
                                    @ArenaText("openMatch")
                                </a>
                            </div>
                        </div>
                    </article>
                }
            </div>
        </div>
    </section>

    <section id="top-battles" class="home-section">
        <div class="home-section__header">
            <h2>@T("topCryptoBattles")</h2>
            <p>@T("featuredPublicMatchPagesConnectMarketPerformanceScoringRulesAndTransparentHistoricalContext")</p>
        </div>

        <div class="arena-top-battle-grid">
            @foreach (var match in TopBattleMatches)
            {
                var energyA = GetEnergyPercentA(match);
                var energyB = 100 - energyA;

                <article class="arena-match-card arena-match-card--compact @GetArenaLeaderClass(match) @GetArenaHeatClass(match)">
                    <div class="arena-match-card__header">
                        <span class="arena-chip arena-chip--muted">@GetMatchStateLabel(match)</span>
                        <span class="arena-meta">@ArenaText("arenaMatchId", match.MatchId)</span>
                    </div>

                    <div class="arena-match-card__body">
                        <div class="arena-match-card__team @(GetLeaderSide(match) == BattleLeader.TeamA ? "is-leading" : null)">
                            <img class="arena-match-card__logo"
                                 src="@GetCoinIconUrl(match.TeamA)"
                                 width="42"
                                 height="42"
                                 alt="@match.TeamA"
                                 loading="lazy"
                                 onerror="this.remove();" />
                            <div class="arena-match-card__team-copy">
                                <strong>@GetBaseSymbol(match.TeamA)</strong>
