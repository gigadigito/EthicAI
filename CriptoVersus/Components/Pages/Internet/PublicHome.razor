            "openBattle" => CurrentCulture == "en" ? "Open battle" : "Abrir batalha",
            "hotMatch" => CurrentCulture == "en" ? "HOT MATCH" : "BATALHA QUENTE",
            "momentum" => CurrentCulture == "en" ? "MOMENTUM" : "MOMENTUM",
            "highVolatility" => CurrentCulture == "en" ? "HIGH VOLATILITY" : "ALTA VOLATILIDADE",
            "volatility" => CurrentCulture == "en" ? "Volatility" : "Volatilidade",
            "scoreLine" => CurrentCulture == "en" ? "Scoreline" : "Placar",
            "arenaMatchId" => CurrentCulture == "en" ? "Arena match #{0}" : "Partida da arena #{0}",
            "openArenaAria" => CurrentCulture == "en" ? "Open arena match {0} versus {1}, match {2}" : "Abrir arena da partida {0} contra {1}, partida {2}",
            "momentumBar" => CurrentCulture == "en" ? "Momentum balance" : "Equilibrio de momentum",
            "finalResultShort" => CurrentCulture == "en" ? "Final result" : "Resultado final",
            "elapsedMinutes" => CurrentCulture == "en" ? "{0}' elapsed" : "{0}' jogados",
            "startingSoon" => CurrentCulture == "en" ? "Starting soon" : "Comeca em breve",
            "marketLive" => CurrentCulture == "en" ? "Market pulse live" : "Mercado ao vivo",
            "momentumEdgeA" => CurrentCulture == "en" ? "{0}% left-side pressure" : "{0}% de pressao do lado esquerdo",
            "momentumEdgeB" => CurrentCulture == "en" ? "{0}% right-side pressure" : "{0}% de pressao do lado direito",
            "momentumEdgeNeutral" => CurrentCulture == "en" ? "Balanced arena pressure" : "Pressao equilibrada na arena",
            "volatilityHigh" => CurrentCulture == "en" ? "High" : "Alta",
