    private string GetMatchStateLabel(MatchDto match)
        => match.IsFinished ? ArenaText("finalResultShort") : ArenaText("liveNow");

    private string GetMatchClockLabel(MatchDto match)
    {
        if (match.IsFinished)
            return ArenaText("finalResultShort");

        if (match.ElapsedMinutes > 0)
            return ArenaText("elapsedMinutes", match.ElapsedMinutes);

        return match.StartTime.HasValue ? ArenaText("startingSoon") : ArenaText("marketLive");
    }

    private BattleLeader GetLeaderSide(MatchDto match)
    {
        if (match.ScoreA > match.ScoreB)
            return BattleLeader.TeamA;

        if (match.ScoreB > match.ScoreA)
            return BattleLeader.TeamB;

        if ((match.PctA ?? 0) > (match.PctB ?? 0))
            return BattleLeader.TeamA;

        if ((match.PctB ?? 0) > (match.PctA ?? 0))
            return BattleLeader.TeamB;

        return BattleLeader.Neutral;
    }

    private string GetArenaLeaderClass(MatchDto match)
        => GetLeaderSide(match) switch
        {
            BattleLeader.TeamA => "is-team-a-leading",
            BattleLeader.TeamB => "is-team-b-leading",
            _ => "is-even"
        };

    private string GetSignedChangeClass(decimal? pct)
        => (pct ?? 0) switch
        {
            > 0 => "is-up",
            < 0 => "is-down",
            _ => "is-flat"
        };

    private double GetEnergyPercentA(MatchDto match)
    {
        if (match.ScoreA != match.ScoreB && match.ScoreA + match.ScoreB > 0)
            return Clamp(100d * match.ScoreA / Math.Max(1, match.ScoreA + match.ScoreB), 18d, 82d);

        var pctEnergy = GetPctEnergy(match);
        if (pctEnergy.HasValue)
            return pctEnergy.Value;

        var poolTotal = match.PoolStrengthTeamA + match.PoolStrengthTeamB;
        if (poolTotal > 0)
            return Clamp(100d * match.PoolStrengthTeamA / poolTotal, 22d, 78d);

        return 50d;
    }

    private double? GetPctEnergy(MatchDto match)
    {
        if (!match.PctA.HasValue && !match.PctB.HasValue)
            return null;

        var delta = (double)((match.PctA ?? 0) - (match.PctB ?? 0));
        if (Math.Abs(delta) < .01d)
            return 50d;

        return Clamp(50d + (delta * 9d), 18d, 82d);
    }

    private static double Clamp(double value, double min, double max)
        => Math.Min(max, Math.Max(min, value));

    private static string BuildEnergyWidthStyle(double width)
        => $"width:{Clamp(width, 0d, 100d):0.##}%;";

    private string GetMomentumLabel(double energyA)
    {
        if (Math.Abs(energyA - 50d) < 4d)
            return ArenaText("momentumEdgeNeutral");

        return energyA > 50d
            ? ArenaText("momentumEdgeA", Math.Round(energyA))
            : ArenaText("momentumEdgeB", Math.Round(100d - energyA));
    }

    private string GetVolatilityLabel(MatchDto match)
    {
        var combined = Math.Abs((double)(match.PctA ?? 0)) + Math.Abs((double)(match.PctB ?? 0));
        return combined >= 6d ? ArenaText("volatilityHigh") : ArenaText("volatilityMedium");
    }

    private IEnumerable<ArenaBadge> GetBattleBadges(MatchDto match, bool isFeatured)
    {
        if (isFeatured)
            yield return new ArenaBadge(ArenaText("hotMatch"), "hot");

        if (HasMomentumSignal(match))
            yield return new ArenaBadge(ArenaText("momentum"), "momentum");

        if (HasHighVolatility(match))
            yield return new ArenaBadge(ArenaText("highVolatility"), "volatility");
    }

    private static bool HasMomentumSignal(MatchDto match)
        => Math.Abs((match.PctA ?? 0) - (match.PctB ?? 0)) >= 1m || Math.Abs(match.ScoreA - match.ScoreB) >= 1;

    private static bool HasHighVolatility(MatchDto match)
        => Math.Abs(match.PctA ?? 0) + Math.Abs(match.PctB ?? 0) >= 6m;

