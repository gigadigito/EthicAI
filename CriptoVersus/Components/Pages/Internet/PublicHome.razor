@code {
    private DashboardSnapshotDto? _snapshot;
    private bool _disposed;
    private readonly SemaphoreSlim _reloadLock = new(1, 1);
    private CancellationTokenSource? _debounceCts;
    private CancellationTokenSource? _homeRefreshCts;
    private Task? _homeRefreshLoopTask;
    private IReadOnlyList<HotMatchDto> _hotMatches = [];
    private bool _hotMatchesLoading = true;
    private string _lastRefreshSignature = string.Empty;
    private bool _interactiveFeaturesStarted;
    private bool _hubSubscribed;
    private bool _showCommunityMatchFloatingCard = true;

    private string CommunityMatchCloseLabel => CurrentCulture switch
    {
        "pt" => "Fechar",
        "zh" => "关闭",
        _ => "Close"
    };

    private void CloseCommunityMatchFloatingCard()
        => _showCommunityMatchFloatingCard = false;

    private string CurrentCulture => AppCulture.GetCurrentRouteCulture(Nav);
