</section>

@code {
    private DashboardSnapshotDto? _snapshot;
    private bool _disposed;
    private readonly SemaphoreSlim _reloadLock = new(1, 1);
    private CancellationTokenSource? _debounceCts;
    private CancellationTokenSource? _homeRefreshCts;
    private Task? _homeRefreshLoopTask;
    private IReadOnlyList<HotMatchDto> _hotMatches = [];
    private bool _hotMatchesLoading = true;
    private string _lastRefreshSignature = string.Empty;
    private bool _interactiveFeaturesStarted;
    private bool _hubSubscribed;

    private string CurrentCulture => AppCulture.GetCurrentRouteCulture(Nav);
    private string SeoTitle => T("criptoversusLiveCryptoMatchArena");
    private string SeoDescription => T("seoDescription");
    private string MetaKeywords => SeoDefaults.GlobalKeywords;
    private string HomeRootUrl => SeoDefaults.BuildPublicBaseUrl(Config, Nav);
    private string SocialImageUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, SeoDefaults.DefaultSocialImagePath);
    private string CanonicalUrl => CurrentCulture == "pt" ? PortugueseUrl : HomeRootUrl;
    private string EnglishUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildHomePath("en"));
    private string PortugueseUrl => SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildHomePath("pt"));
    private MarkupString StructuredDataMarkup => new(BuildStructuredDataJson());
    private IReadOnlyList<string> HeroSemanticHighlights => new[]
    {
        T("heroSemantic1"),
        T("heroSemantic2"),
        T("heroSemantic3"),
        T("heroSemantic4"),
        T("heroSemantic5")
    };
    private IReadOnlyList<FaqItem> FaqItems => new[]
    {
        new FaqItem(T("faq.onlyScoreboard.question"), T("faq.onlyScoreboard.answer")),
        new FaqItem(T("faq.openPositions.question"), T("faq.openPositions.answer")),
        new FaqItem(T("faq.arenaPools.question"), T("faq.arenaPools.answer")),
        new FaqItem(T("faq.cyclicalPools.question"), T("faq.cyclicalPools.answer")),
        new FaqItem(T("faq.rewardDistribution.question"), T("faq.rewardDistribution.answer")),
        new FaqItem(T("faq.battleCycle.question"), T("faq.battleCycle.answer"))
    };

    private const int HomeMatchLimit = 10;
    private const int HomeRefreshSeconds = 15;

    private List<HotMatchDto> HotMatchFeed => _hotMatches.Take(HomeMatchLimit).ToList();
    private HotMatchDto? HeroHotMatch => HotMatchFeed.FirstOrDefault();
    private MatchDto? HeroFallbackMatch => HeroHotMatch is null ? FeaturedBattle : null;
    private MatchDto? HeroArenaFieldMatch => HeroHotMatch is not null
        ? ToMatchCard(HeroHotMatch)
        : HeroFallbackMatch;

    private HotMatchDto? HeroArenaFieldHotMatch => HeroHotMatch
        ?? (HeroArenaFieldMatch is not null ? FindHotMatch(HeroArenaFieldMatch.MatchId) : null);
    private List<MatchDto> SnapshotLiveMatches => RankHomeMatches(_snapshot?.Matches.OngoingList ?? [])
        .Take(HomeMatchLimit)
        .ToList();
    private List<MatchDto> SnapshotFeaturedMatches => RankHomeMatches(
            (_snapshot?.Matches.OngoingList ?? [])
                .Concat(_snapshot?.Matches.CompletedList ?? []))
        .Take(HomeMatchLimit)
        .ToList();
    private List<MatchDto> LiveMatches => HotMatchFeed.Count > 0
        ? HotMatchFeed
            .Where(x => !x.IsFinished && string.Equals(x.Status, "Ongoing", StringComparison.OrdinalIgnoreCase))
            .Select(ToMatchCard)
            .Take(HomeMatchLimit)
            .ToList()
        : SnapshotLiveMatches;
    private List<MatchDto> FeaturedMatches => HotMatchFeed.Count > 0
        ? HotMatchFeed
            .Select(ToMatchCard)
            .Take(HomeMatchLimit)
            .ToList()
        : SnapshotFeaturedMatches;
    private MatchDto? FeaturedBattle => SelectFeaturedBattle();
    private List<MatchDto> ArenaLiveMatches => LiveMatches
        .Where(x => x.MatchId != FeaturedBattle?.MatchId)
        .Take(HomeMatchLimit - 1)
        .ToList();
    private List<MatchDto> TopBattleMatches => FeaturedMatches
        .Where(x => x.MatchId != FeaturedBattle?.MatchId)
        .Take(HomeMatchLimit)
        .ToList();
    private List<CurrencyDto> TrendingCoins => (_snapshot?.TopGainers ?? []).OrderBy(x => x.Rank).Take(6).ToList();
    private List<CurrencyDto> RankingCoins => (_snapshot?.TopGainers ?? []).OrderBy(x => x.Rank).Take(10).ToList();
    private Dictionary<string, int> TopGainerRankMap => (_snapshot?.TopGainers ?? [])
        .Where(x => !string.IsNullOrWhiteSpace(x.Symbol))
        .OrderBy(x => x.Rank)
        .GroupBy(x => x.Symbol, StringComparer.OrdinalIgnoreCase)
        .ToDictionary(x => x.Key, x => x.First().Rank, StringComparer.OrdinalIgnoreCase);
    private string GetCoinIconUrl(string pair)
    {
        var baseSymbol = GetBaseSymbol(pair);
        return CriptoVersus.Web.Services.EnvironmentIsolationGuard.BuildBinanceIconUrl(baseSymbol);
    }

    private static string GetBaseSymbol(string pair)
    {
        if (string.IsNullOrWhiteSpace(pair)) return "";

        pair = pair.ToUpperInvariant();

        var quotes = new[] { "USDT", "USDC", "BUSD", "BRL", "EUR", "BTC", "ETH" };

        foreach (var q in quotes)
        {
            if (pair.EndsWith(q) && pair.Length > q.Length)
                return pair.Substring(0, pair.Length - q.Length);
        }

        return pair;
    }
    protected override async Task OnInitializedAsync()
    {
        try
        {
            using var initialLoadCts = new CancellationTokenSource(TimeSpan.FromSeconds(5));
            await ReloadHomeDataAsync(
                initialLoadCts.Token,
                "initial-load",
                includeHotMatches: false);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "PublicHome initial snapshot load failed. Rendering partial home state.");
            _snapshot = null;
            _hotMatchesLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _interactiveFeaturesStarted)
            return;

        Logger.LogInformation("PublicHome first render ready.");
        _interactiveFeaturesStarted = true;
        _ = StartInteractiveFeaturesAsync();
        await Task.CompletedTask;
    }

    private string T(string key, params object?[] args)
        => L.T($"publicHome.{key}", CurrentCulture, args);

    private string GetMatchUrl(MatchDto match)
    {
        var slug = MatchSlugHelper.BuildSlug(match.TeamA, match.TeamB);
        return string.IsNullOrWhiteSpace(slug)
            ? RouteLocalization.BuildHomePath(CurrentCulture)
            : RouteLocalization.BuildLocalizedPath(CurrentCulture, match.MatchId, slug);
    }

    private string GetTvWatchUrl(HotMatchDto match)
        => GetTvMatchUrl(match);

    private string GetPublicMatchUrl(MatchDto match)
        => GetPublicMatchUrl(match.MatchId, match.TeamA, match.TeamB);

    private string GetPublicMatchUrl(int matchId, string? teamA, string? teamB)
    {
        var slug = MatchSlugHelper.BuildSlug(teamA ?? string.Empty, teamB ?? string.Empty);
        return string.IsNullOrWhiteSpace(slug)
            ? SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildHomePath(AppCultureService.DefaultRouteCulture))
            : SeoDefaults.BuildPublicAbsoluteUrl(Config, RouteLocalization.BuildLocalizedPath(AppCultureService.DefaultRouteCulture, matchId, slug));
    }

    private string GetTvMatchUrl(HotMatchDto match)
    {
        var slug = !string.IsNullOrWhiteSpace(match.Slug)
            ? match.Slug
            : MatchSlugHelper.BuildSlug(match.TeamA, match.TeamB);
        return string.IsNullOrWhiteSpace(slug)
            ? RouteLocalization.BuildTvPath(CurrentCulture)
            : RouteLocalization.BuildTvMatchPath(CurrentCulture, match.MatchId, slug);
    }

    private string GetTvMatchUrl(MatchDto match)
    {
        var slug = MatchSlugHelper.BuildSlug(match.TeamA, match.TeamB);
        return string.IsNullOrWhiteSpace(slug)
            ? RouteLocalization.BuildTvPath(CurrentCulture)
            : RouteLocalization.BuildTvMatchPath(CurrentCulture, match.MatchId, slug);
    }

    private MatchDto ToMatchCard(HotMatchDto match)
        => match.MatchSnapshot ?? new MatchDto
        {
            MatchId = match.MatchId,
            TeamA = match.TeamA,
            TeamB = match.TeamB,
            ScoreA = match.ScoreA,
            ScoreB = match.ScoreB,
            Status = match.Status,
            ElapsedMinutes = match.ElapsedMinutes,
            RemainingMinutes = match.RemainingMinutes,
            IsFinished = match.IsFinished,
            PctA = match.PctA,
            PctB = match.PctB,
            TotalPool = match.TotalPool,
            TotalPoolAmount = match.TotalPoolAmount,
            HasBetsOnBothSides = match.HasBetsOnBothSides,
            PoolStrengthTeamA = match.PoolStrengthTeamA,
            PoolStrengthTeamB = match.PoolStrengthTeamB
        };

    private HotMatchDto? FindHotMatch(int matchId)
        => HotMatchFeed.FirstOrDefault(x => x.MatchId == matchId);

    private List<MatchDto> RankHomeMatches(IEnumerable<MatchDto> source)
    {
        var distinctMatches = source
            .Where(x => x.MatchId > 0)
            .GroupBy(x => x.MatchId)
            .Select(x => x.First())
            .ToList();

        if (distinctMatches.Count <= 1)
            return distinctMatches;

        var preferredPairs = BuildPreferredTopPairs();

        return distinctMatches
            .OrderBy(x => GetPreferredPairIndex(x, preferredPairs))
            .ThenBy(x => GetTopGainerCoverageRank(x))
            .ThenBy(x => GetTopGainerDistanceRank(x))
            .ThenBy(x => GetTopGainerSumRank(x))
            .ThenBy(x => GetHomeStatusRank(x))
            .ThenByDescending(x => GetOptionalHotScore(x) ?? int.MinValue)
            .ThenByDescending(x => x.StartTime ?? DateTime.MinValue)
            .ToList();
    }

    private List<string> BuildPreferredTopPairs()
    {
        var rankedSymbols = (_snapshot?.TopGainers ?? [])
            .Where(x => !string.IsNullOrWhiteSpace(x.Symbol))
            .OrderBy(x => x.Rank)
            .Select(x => x.Symbol)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        var result = new List<string>();
        for (var i = 0; i + 1 < rankedSymbols.Count; i += 2)
            result.Add(BuildPairKey(rankedSymbols[i], rankedSymbols[i + 1]));

        return result;
    }

    private static string BuildPairKey(string? teamA, string? teamB)
    {
        var a = (teamA ?? string.Empty).Trim().ToUpperInvariant();
        var b = (teamB ?? string.Empty).Trim().ToUpperInvariant();
        return string.CompareOrdinal(a, b) <= 0 ? $"{a}|{b}" : $"{b}|{a}";
    }

    private int GetPreferredPairIndex(MatchDto match, List<string> preferredPairs)
    {
        var key = BuildPairKey(match.TeamA, match.TeamB);
        var index = preferredPairs.FindIndex(x => string.Equals(x, key, StringComparison.OrdinalIgnoreCase));
        return index >= 0 ? index : int.MaxValue;
    }

    private int GetTopGainerCoverageRank(MatchDto match)
    {
        var teamARank = GetTopGainerRank(match.TeamA);
        var teamBRank = GetTopGainerRank(match.TeamB);
        var coverage = (teamARank.HasValue ? 1 : 0) + (teamBRank.HasValue ? 1 : 0);

        return coverage switch
        {
            2 => 0,
            1 => 1,
            _ => 2
        };
    }

    private int GetTopGainerDistanceRank(MatchDto match)
    {
        var teamARank = GetTopGainerRank(match.TeamA);
        var teamBRank = GetTopGainerRank(match.TeamB);

        if (teamARank.HasValue && teamBRank.HasValue)
            return Math.Abs(teamARank.Value - teamBRank.Value);

        return int.MaxValue;
    }

    private int GetTopGainerSumRank(MatchDto match)
    {
        var teamARank = GetTopGainerRank(match.TeamA);
        var teamBRank = GetTopGainerRank(match.TeamB);

        if (teamARank.HasValue && teamBRank.HasValue)
            return teamARank.Value + teamBRank.Value;

        if (teamARank.HasValue)
            return 10_000 + teamARank.Value;

        if (teamBRank.HasValue)
            return 10_000 + teamBRank.Value;

        return int.MaxValue;
    }

    private int? GetTopGainerRank(string? symbol)
        => !string.IsNullOrWhiteSpace(symbol) && TopGainerRankMap.TryGetValue(symbol, out var rank)
            ? rank
            : null;

    private static int GetHomeStatusRank(MatchDto match)
    {
        if (match.IsFinished)
            return 2;

        return match.StartTime.HasValue && match.StartTime.Value > DateTime.UtcNow
            ? 1
            : 0;
    }

    private static string FormatPct(decimal? value)
        => $"{(value ?? 0):+0.##;-0.##;0.##}%";

    private MatchDto? SelectFeaturedBattle()
    {
        var source = LiveMatches.Count > 0 ? LiveMatches : FeaturedMatches;
        if (source.Count == 0)
            return null;

        MatchDto? bestByHotScore = null;
        int? bestHotScore = null;

        foreach (var match in source)
        {
            var hotScore = GetOptionalHotScore(match);
            if (!hotScore.HasValue)
                continue;

            if (!bestHotScore.HasValue || hotScore.Value > bestHotScore.Value)
            {
                bestHotScore = hotScore.Value;
                bestByHotScore = match;
            }
        }

        return bestByHotScore ?? source.FirstOrDefault();
    }

    private static int? GetOptionalHotScore(MatchDto match)
    {
        var property = typeof(MatchDto).GetProperty("HotScore");
        if (property?.GetValue(match) is int hotScore)
            return hotScore;

        return null;
    }

    private string ArenaText(string key, params object?[] args)
    {
        var template = key switch
        {
            "live" => CurrentCulture == "en" ? "LIVE" : "AO VIVO",
            "liveNow" => CurrentCulture == "en" ? "LIVE NOW" : "AO VIVO",
            "featuredBattle" => CurrentCulture == "en" ? "Featured Battle" : "Batalha em destaque",
            "openArena" => CurrentCulture == "en" ? "Open Arena" : "Abrir Arena",
            "openBattle" => CurrentCulture == "en" ? "Open battle" : "Abrir batalha",
            "openMatch" => CurrentCulture == "en" ? "Open Match" : "Abrir Match",
            "openMatchAria" => CurrentCulture == "en" ? "Open match {0} versus {1}, match {2}" : "Abrir a partida {0} contra {1}, partida {2}",
            "hotMatch" => CurrentCulture == "en" ? "HOT MATCH" : "BATALHA QUENTE",
            "trending" => CurrentCulture == "en" ? "TRENDING" : "TRENDING",
            "momentum" => CurrentCulture == "en" ? "MOMENTUM" : "MOMENTUM",
            "fear" => CurrentCulture == "en" ? "FEAR" : "FEAR",
            "hotScore" => CurrentCulture == "en" ? "Hot score" : "Hot score",
            "arenaPressure" => CurrentCulture == "en" ? "Arena pressure" : "Pressao da arena",
            "highVolatility" => CurrentCulture == "en" ? "HIGH VOLATILITY" : "ALTA VOLATILIDADE",
            "volatility" => CurrentCulture == "en" ? "Volatility" : "Volatilidade",
            "scoreLine" => CurrentCulture == "en" ? "Scoreline" : "Placar",
            "arenaMatchId" => CurrentCulture == "en" ? "Arena match #{0}" : "Partida da arena #{0}",
            "openArenaAria" => CurrentCulture == "en" ? "Open arena match {0} versus {1}, match {2}" : "Abrir Arena da partida {0} contra {1}, partida {2}",
            "momentumBar" => CurrentCulture == "en" ? "Momentum balance" : "Equilibrio de momentum",
            "finalResultShort" => CurrentCulture == "en" ? "Final result" : "Resultado final",
            "elapsedMinutes" => CurrentCulture == "en" ? "{0}' elapsed" : "{0}' jogados",
            "startingSoon" => CurrentCulture == "en" ? "Starting soon" : "Comeca em breve",
            "marketLive" => CurrentCulture == "en" ? "Market pulse live" : "Mercado ao vivo",
            "momentumEdgeA" => CurrentCulture == "en" ? "{0}% left-side pressure" : "{0}% de pressao do lado esquerdo",
            "momentumEdgeB" => CurrentCulture == "en" ? "{0}% right-side pressure" : "{0}% de pressao do lado direito",
            "momentumEdgeNeutral" => ArenaText("tiePressure"),
            "volatilityHigh" => CurrentCulture == "en" ? "High" : "Alta",
            "volatilityMedium" => CurrentCulture == "en" ? "Medium" : "Media",
            _ => key
        };

        return args.Length == 0 ? template : string.Format(template, args);
    }

    private string GetMatchStateLabel(MatchDto match)
        => match.IsFinished ? ArenaText("finalResultShort") : ArenaText("liveNow");

    private string GetMatchClockLabel(MatchDto match)
    {
        if (match.IsFinished)
            return ArenaText("finalResultShort");

        if (match.ElapsedMinutes > 0)
            return ArenaText("elapsedMinutes", match.ElapsedMinutes);

        return match.StartTime.HasValue ? ArenaText("startingSoon") : ArenaText("marketLive");
    }

    private string GetMatchClockLabel(HotMatchDto match)
    {
        if (match.IsFinished)
            return ArenaText("finalResultShort");

        if (match.ElapsedMinutes > 0)
            return ArenaText("elapsedMinutes", match.ElapsedMinutes);

        return ArenaText("marketLive");
    }

    private BattleLeader GetLeaderSide(MatchDto match)
    {
        if (match.ScoreA > match.ScoreB)
            return BattleLeader.TeamA;

        if (match.ScoreB > match.ScoreA)
            return BattleLeader.TeamB;

        if ((match.PctA ?? 0) > (match.PctB ?? 0))
            return BattleLeader.TeamA;

        if ((match.PctB ?? 0) > (match.PctA ?? 0))
            return BattleLeader.TeamB;

        return BattleLeader.Neutral;
    }

    private string GetArenaLeaderClass(MatchDto match)
        => GetLeaderSide(match) switch
        {
            BattleLeader.TeamA => "is-team-a-leading",
            BattleLeader.TeamB => "is-team-b-leading",
            _ => "is-even"
        };

    private string GetArenaLeaderClass(HotMatchDto match)
        => GetArenaLeaderClass(ToMatchCard(match));

    private string GetSignedChangeClass(decimal? pct)
        => (pct ?? 0) switch
        {
            > 0 => "is-up",
            < 0 => "is-down",
            _ => "is-flat"
        };

    private double GetEnergyPercentA(MatchDto match)
    {
        if (match.ScoreA != match.ScoreB && match.ScoreA + match.ScoreB > 0)
            return Clamp(100d * match.ScoreA / Math.Max(1, match.ScoreA + match.ScoreB), 18d, 82d);

        var pctEnergy = GetPctEnergy(match);
        if (pctEnergy.HasValue)
            return pctEnergy.Value;

        var poolTotal = match.PoolStrengthTeamA + match.PoolStrengthTeamB;
        if (poolTotal > 0)
            return Clamp(100d * match.PoolStrengthTeamA / poolTotal, 22d, 78d);

        return 50d;
    }

    private double GetEnergyPercentA(HotMatchDto match)
        => GetEnergyPercentA(ToMatchCard(match));

    private double? GetPctEnergy(MatchDto match)
    {
        if (!match.PctA.HasValue && !match.PctB.HasValue)
            return null;

        var delta = (double)((match.PctA ?? 0) - (match.PctB ?? 0));
        if (Math.Abs(delta) < .01d)
            return 50d;

        return Clamp(50d + (delta * 9d), 18d, 82d);
    }

    private static double Clamp(double value, double min, double max)
        => Math.Min(max, Math.Max(min, value));

    private static string BuildEnergyWidthStyle(double width)
        => $"width:{Clamp(width, 0d, 100d):0.##}%;";

    private string GetMomentumLabel(double energyA)
    {
        if (Math.Abs(energyA - 50d) < 4d)
            return ArenaText("momentumEdgeNeutral");

        return energyA > 50d
            ? ArenaText("momentumEdgeA", Math.Round(energyA))
            : ArenaText("momentumEdgeB", Math.Round(100d - energyA));
    }

    private string GetVolatilityLabel(MatchDto match)
    {
        var combined = Math.Abs((double)(match.PctA ?? 0)) + Math.Abs((double)(match.PctB ?? 0));
        return combined >= 6d ? ArenaText("volatilityHigh") : ArenaText("volatilityMedium");
    }

    private IEnumerable<ArenaBadge> GetBattleBadges(MatchDto match, bool isFeatured)
    {
        var hot = FindHotMatch(match.MatchId);
        if (hot is not null)
        {
            foreach (var badge in GetBattleBadges(hot, isFeatured))
                yield return badge;

            yield break;
        }

        if (isFeatured)
            yield return new ArenaBadge(ArenaText("hotMatch"), "hot");

        if (HasMomentumSignal(match))
            yield return new ArenaBadge(ArenaText("momentum"), "momentum");

        if (HasHighVolatility(match))
            yield return new ArenaBadge(ArenaText("highVolatility"), "volatility");
    }

    private IEnumerable<ArenaBadge> GetBattleBadges(HotMatchDto match, bool isFeatured)
    {
        if (isFeatured)
            yield return new ArenaBadge(ArenaText("hotMatch"), "hot");

        if (match.IsTrending)
            yield return new ArenaBadge(ArenaText("trending"), "trending");

        if (match.Fear >= 55m)
            yield return new ArenaBadge(ArenaText("fear"), "fear");

        if (match.Momentum >= 24m)
            yield return new ArenaBadge(ArenaText("momentum"), "momentum");

        if (HasHighVolatility(ToMatchCard(match)))
            yield return new ArenaBadge(ArenaText("highVolatility"), "volatility");
    }

    private static bool HasMomentumSignal(MatchDto match)
        => Math.Abs((match.PctA ?? 0) - (match.PctB ?? 0)) >= 1m || Math.Abs(match.ScoreA - match.ScoreB) >= 1;

    private static bool HasHighVolatility(MatchDto match)
        => Math.Abs(match.PctA ?? 0) + Math.Abs(match.PctB ?? 0) >= 6m;

    private static string GetArenaChipClass(string tone)
        => tone switch
        {
            "hot" => "arena-chip--hot",
            "momentum" => "arena-chip--momentum",
            "volatility" => "arena-chip--volatility",
            "fear" => "arena-chip--fear",
            "trending" => "arena-chip--trending",
            _ => "arena-chip--muted"
        };

    private string GetArenaHeatClass(MatchDto match)
    {
        var hot = FindHotMatch(match.MatchId);
        if (hot is null)
            return string.Empty;

        return GetArenaHeatClass(hot);
    }

    private static string GetArenaHeatClass(HotMatchDto match)
        => match.IsExplosive
            ? "is-explosive"
            : match.IsTrending
                ? "is-trending"
                : string.Empty;

    private decimal GetHeroFieldArenaPressure(MatchDto match, HotMatchDto? hotMatch, double energyA)
    {
        var hotArenaPressure = TryReadDecimalProperty(hotMatch, "ArenaPressure");
        if (hotArenaPressure.HasValue)
            return hotArenaPressure.Value;

        var matchArenaPressure = TryReadDecimalProperty(match, "ArenaPressure");
        if (matchArenaPressure.HasValue)
            return matchArenaPressure.Value;

        return Convert.ToDecimal(Math.Round(energyA));
    }

    private decimal GetHeroFieldHotScore(MatchDto match, HotMatchDto? hotMatch)
    {
        var hotScore = TryReadDecimalProperty(hotMatch, "HotScore");
        if (hotScore.HasValue)
            return hotScore.Value;

        var matchHotScore = TryReadDecimalProperty(match, "HotScore");
        if (matchHotScore.HasValue)
            return matchHotScore.Value;

        return 0m;
    }

    private static decimal? TryReadDecimalProperty(object? source, string propertyName)
    {
        if (source is null)
            return null;

        var property = source.GetType().GetProperty(propertyName);
        if (property is null)
            return null;

        var value = property.GetValue(source);
        if (value is null)
            return null;

        try
        {
            return Convert.ToDecimal(value, CultureInfo.InvariantCulture);
        }
        catch
        {
            return null;
        }
    }

