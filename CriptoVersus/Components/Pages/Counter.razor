@page "/counter"
@rendermode InteractiveServer
@inject IConfiguration Config
@inject NavigationManager Nav

<BasicSeoHead Title="CriptoVersus Counter Demo"
              Description="Interactive counter demo page inside CriptoVersus.Web used for UI validation and component testing."
              CanonicalUrl="@CanonicalUrl"
              ImageUrl="@SocialImageUrl"
              ImageAlt="CriptoVersus emblem"
              Robots="noindex,nofollow,noarchive" />

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

@code {
    private int currentCount = 0;
    private string CanonicalUrl => SeoDefaults.BuildAbsoluteUrl(Config, Nav, "/counter");
    private string SocialImageUrl => SeoDefaults.BuildAbsoluteUrl(Config, Nav, SeoDefaults.DefaultSocialImagePath);

    private void IncrementCount()
    {
        currentCount++;
    }
}
