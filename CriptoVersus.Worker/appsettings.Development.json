{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "CriptoVersus": {
    "Match": {
      "ForbiddenStablecoins": [ "USDC", "USDT", "FDUSD", "EUR", "RLUSD", "USD1", "U" ]
    }
  },
  "CriptoVersusWorker": {
    "IntervalSeconds": 30,
    "TopGainersTake": 6,
    "DesiredActiveMatches": 3,
    "AutoEndOngoingMatches": false,
    "MatchDurationMinutes": 90,
    "Settlement": {
      "HouseFeeRate": 0.01,
      "LoserRefundRate": 0.94,
      "AutoReenterEnabled": true,
      "MinPositionCapital": 0.00000001
    }
  },
  "ConnectionStrings": {
    "Default": ""
  }
}
